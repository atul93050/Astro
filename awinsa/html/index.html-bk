                                    <div class="country-name">
                                        <h4>Netherlands</h4>
                                        <img src="assets/images/world.svg">
                                    </div>
                                </div>
                                <div class="col-lg-8">
                                    <div class="country-detail">
                                        <div class="country-addres">
                                            <p>Wilhelmina Druckerlaan 10,<br>
                                                6532 SR,
                                                Nijmegen,<br>
                                                The Netherlands</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdownMenuLink" role="button"
                            data-bs-toggle="dropdown" aria-expanded="false">
                            Latin America <img src="assets/images/arow.svg">
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="navbarDropdownMenuLink">
                            <div class="row">
                                <div class="col-lg-4">
                                    <div class="country-name">
                                        <h4>Mexico</h4>
                                        <img src="assets/images/world.svg">
                                    </div>
                                </div>
                                <div class="col-lg-8">
                                    <div class="country-detail">
                                        <div class="country-addres">
                                            <p>Cerrada Ahuizotla 53, <br>
                                                Col. Santiago Ahuizotla,<br>
                                                Del. Azcapotzalco
                                                CP.02750<br>
