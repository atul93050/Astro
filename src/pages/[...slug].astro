---
import { getEntry } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

// Import block components
import HeroBlock from "../blocks/HeroBlock.astro";
import AboutBlock from "../blocks/AboutBlock.astro";
import RichTextBlock from "../blocks/RichTextBlock.astro";
import TwoColumnBlock from "../blocks/TwoColumnBlock.astro";
import ImageContentBlock from "../blocks/ImageContentBlock.astro";
import CtaBlock from "../blocks/CtaBlock.astro";
import StatsBlock from "../blocks/StatsBlock.astro";
import TeamBlock from "../blocks/TeamBlock.astro";
import TestimonialsBlock from "../blocks/TestimonialsBlock.astro";
import FaqBlock from "../blocks/FaqBlock.astro";
import LogoSliderBlock from "../blocks/LogoSliderBlock.astro";
import ServicesGridBlock from "../blocks/ServicesGridBlock.astro";
import PricingBlock from "../blocks/PricingBlock.astro";
import CaseStudiesBlock from "../blocks/CaseStudiesBlock.astro";
import TimelineBlock from "../blocks/TimelineBlock.astro";
import AwardsBlock from "../blocks/AwardsBlock.astro";
import ContactFormBlock from "../blocks/ContactFormBlock.astro";
import CustomHtmlBlock from "../blocks/CustomHtmlBlock.astro";
import VideoBlock from "../blocks/VideoBlock.astro";
import GalleryBlock from "../blocks/GalleryBlock.astro";
import BlogListingBlock from "../blocks/BlogListingBlock.astro";
import RelatedPagesBlock from "../blocks/RelatedPagesBlock.astro";

import fs from "node:fs";
import path from "node:path";

export const prerender = false;

// 1. Resolve slug parameter
const { slug } = Astro.params;
const cleanSlug = slug || "index";

// 2. Query page entry
const entry = await getEntry("pages", cleanSlug);

// If page does not exist, return 404
if (!entry) {
  return new Response("Page Not Found", { status: 404 });
}

const page = entry.data;

// 3. Draft/Publish Workflow checks
const isPreview = Astro.url.searchParams.get("preview") === "true";
if (page.status === "draft" && !isPreview) {
  return new Response("This page is a draft. Please use preview mode to view it.", { status: 403 });
}

// 4. Fetch Global Site Settings (Header/Footer menus, custom code injection)
let globalSettings = {
  headerScripts: "",
  footerScripts: "",
  redirects: [] as Array<{ from: string; to: string }>,
};

try {
  const settingsPath = path.resolve("src/data/global-settings.json");
  if (fs.existsSync(settingsPath)) {
    globalSettings = JSON.parse(fs.readFileSync(settingsPath, "utf-8"));
  }
} catch (e) {
  // Graceful fallback
}

// 5. Redirect Manager check
const matchingRedirect = globalSettings.redirects?.find(r => r.from === `/${cleanSlug}` && r.active !== false);
if (matchingRedirect) {
  const status = matchingRedirect.type === "302" ? 302 : 301;
  return Astro.redirect(matchingRedirect.to, status);
}

// 6. JSON-LD Schema Generator
let schemaJson = "";
if (page.seo.schemaMarkup) {
  schemaJson = page.seo.schemaMarkup;
} else if (page.seo.schemaType && page.seo.schemaType !== "none") {
  // Auto-generate based on selected schema type
  const title = page.seo.metaTitle || page.title;
  const desc = page.seo.metaDescription;
  
  if (page.seo.schemaType === "faq") {
    // Extract faq block items
    const faqBlock = page.blocks.find(b => b.type === "faq") as any;
    if (faqBlock && faqBlock.items) {
      schemaJson = JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqBlock.items.map((f: any) => ({
          "@type": "Question",
          "name": f.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": f.answer
          }
        }))
      });
    }
  } else if (page.seo.schemaType === "organization") {
    schemaJson = JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Tangence Performance Marketing",
      "url": "https://www.tangence.in",
      "logo": "https://www.tangence.in/logo.png"
    });
  } else if (page.seo.schemaType === "article") {
    schemaJson = JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": desc,
      "dateModified": page.lastUpdated
    });
  }
}
---

<MainLayout
  title={page.seo.metaTitle || page.title}
  description={page.seo.metaDescription}
  canonicalUrl={page.seo.canonicalUrl}
  robots={page.seo.robots}
  ogTitle={page.seo.ogTitle}
  ogDescription={page.seo.ogDescription}
  ogImage={page.seo.ogImage}
  twitterCard={page.seo.twitterCard}
  schemaMarkup={schemaJson}
  headerScripts={page.headerScripts}
  footerScripts={page.footerScripts}
  customCss={page.customCss}
  customJs={page.customJs}
>
  <Header />

  <!-- Render dynamically generated blocks stack -->
  <main class="page-builder-content">
    {page.status === "draft" && (
      <div class="preview-banner">
        <span>Preview Mode: You are viewing a draft version of this page.</span>
      </div>
    )}

    {page.blocks && page.blocks.map((block: any) => {
      switch (block.type) {
        case "hero":
          return <HeroBlock {...block} />;
        case "about":
          return <AboutBlock {...block} />;
        case "rich_text":
          return <RichTextBlock {...block} />;
        case "two_column":
          return <TwoColumnBlock {...block} />;
        case "image_content":
          return <ImageContentBlock {...block} />;
        case "cta":
          return <CtaBlock {...block} />;
        case "stats":
          return <StatsBlock {...block} />;
        case "team":
          return <TeamBlock {...block} />;
        case "testimonials":
          return <TestimonialsBlock {...block} />;
        case "faq":
          return <FaqBlock {...block} />;
        case "logo_slider":
          return <LogoSliderBlock {...block} />;
        case "services_grid":
          return <ServicesGridBlock {...block} />;
        case "pricing":
          return <PricingBlock {...block} />;
        case "case_studies":
          return <CaseStudiesBlock {...block} />;
        case "timeline":
          return <TimelineBlock {...block} />;
        case "awards":
          return <AwardsBlock {...block} />;
        case "contact_form_block":
          return <ContactFormBlock {...block} />;
        case "custom_html":
          return <CustomHtmlBlock {...block} />;
        case "video_section":
          return <VideoBlock {...block} />;
        case "gallery":
          return <GalleryBlock {...block} />;
        case "blog_listing":
          return <BlogListingBlock {...block} />;
        case "related_pages":
          return <RelatedPagesBlock {...block} />;
        default:
          return null;
      }
    })}
  </main>

  <Footer />
</MainLayout>

<style>
  .preview-banner {
    background-color: #F59E0B;
    color: #0B0F19;
    text-align: center;
    padding: 0.75rem 1.5rem;
    font-weight: 700;
    font-size: 0.9rem;
    position: sticky;
    top: 0;
    z-index: 999;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    font-family: system-ui, -apple-system, sans-serif;
  }
</style>
