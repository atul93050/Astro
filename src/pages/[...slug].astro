---
import { parse } from "yaml";
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

// Import block components
import BlockRenderer from "../components/BlockRenderer.astro";

import fs from "node:fs";
import path from "node:path";

export const prerender = false;

// 1. Resolve slug parameter
const { slug } = Astro.params;
const cleanSlug = slug || "index";

// 2. Fetch Global Site Settings for Redirect check
let globalSettings = {
  headerScripts: "",
  footerScripts: "",
  redirects: [] as Array<{ from: string; to: string; type?: string; active?: boolean }>,
};

try {
  const settingsPath = path.resolve("src/data/global-settings.json");
  if (fs.existsSync(settingsPath)) {
    globalSettings = JSON.parse(fs.readFileSync(settingsPath, "utf-8"));
  }
} catch (e) {
  // Graceful fallback
}

// Normalize current path and check redirects using Astro.url.pathname (fully case-insensitive, handles missing/extra slashes)
const reqPath = Astro.url.pathname.toLowerCase().trim().replace(/\/$/, "");
const matchingRedirect = globalSettings.redirects?.find(r => {
  if (!r.from) return false;
  // Ensure from has leading slash and no trailing slash
  const fromNormalized = ("/" + r.from).replace(/^\/\/+/, "/").replace(/\/$/, "").toLowerCase().trim();
  return fromNormalized === reqPath && r.active !== false;
});

if (matchingRedirect) {
  const status = matchingRedirect.type === "302" ? 302 : 301;
  return Astro.redirect(matchingRedirect.to, status);
}

// Load section definitions dynamically
let allDefinitions: any[] = [];
try {
  const definitionsPath = path.resolve("src/data/section-definitions.json");
  if (fs.existsSync(definitionsPath)) {
    allDefinitions = JSON.parse(fs.readFileSync(definitionsPath, "utf-8"));
  }
} catch (e) {
  console.error("Failed to load section definitions inside slug.astro:", e);
}

// 3. Query page entry directly from disk to bypass content collections cache
const pagePath = path.resolve("src/content/pages", `${cleanSlug}.md`);
if (!fs.existsSync(pagePath)) {
  return new Response("Page Not Found", { status: 404 });
}

let pageRaw: any = {};
try {
  const content = fs.readFileSync(pagePath, "utf-8");
  const parts = content.split(/^---$/m);
  if (parts.length >= 3) {
    pageRaw = parse(parts[1]);
  }
} catch (e) {
  console.error("Error reading page from disk:", e);
  return new Response("Error loading page", { status: 500 });
}

// Asynchronously resolve section blocks content directly from disk
const resolvedBlocks = await Promise.all(
  (pageRaw.blocks || []).map(async (block: any) => {
    const config = allDefinitions.find((d: any) => d.key === block.type);
    const defaultValues = config ? Object.fromEntries(
      (config.fields || []).map((f: any) => [f.name, f.default !== undefined ? f.default : ""])
    ) : {};

    if (block.sectionId) {
      const sectionPath = path.resolve("src/content/sections", `${block.sectionId}.md`);
      let sectionData = {};
      if (fs.existsSync(sectionPath)) {
        try {
          const content = fs.readFileSync(sectionPath, "utf-8");
          const parts = content.split(/^---$/m);
          if (parts.length >= 3) {
            sectionData = parse(parts[1]);
          }
        } catch (e) {
          console.error("Error reading section data from disk:", e);
        }
      }
      return {
        ...defaultValues,
        ...block,
        ...sectionData
      };
    }
    return {
      ...defaultValues,
      ...block
    };
  })
);

const page = {
  ...pageRaw,
  blocks: resolvedBlocks
};

// Centralized per-page CSS auto-loader: loads src/styles/pages/<slug>.css if present.
// The homepage (slug "index") maps to home.css.
const pageStyleSheets = import.meta.glob("/src/styles/pages/*.css", { query: "?url", import: "default", eager: true }) as Record<string, string>;
const cssSlug = cleanSlug === "index" ? "home" : cleanSlug;
const pageStyleUrl = pageStyleSheets[`/src/styles/pages/${cssSlug}.css`] || "";

// 4. Draft/Publish Workflow checks
if (page.status === "trash") {
  return new Response("Page Not Found", { status: 404 });
}

const isPreview = Astro.url.searchParams.get("preview") === "true";
if (page.status === "draft" && !isPreview) {
  return new Response("This page is a draft. Please use preview mode to view it.", { status: 403 });
}

// 6. JSON-LD Schema Generator
let schemaJson = "";
if (page.seo.schemaMarkup) {
  schemaJson = page.seo.schemaMarkup;
} else if (page.seo.schemaType && page.seo.schemaType !== "none") {
  // Auto-generate based on selected schema type
  const title = page.seo.metaTitle || page.title;
  const desc = page.seo.metaDescription;
  
  if (page.seo.schemaType === "faq") {
    // Extract faq block items
    const faqBlock = page.blocks.find(b => b.type === "faq") as any;
    if (faqBlock && faqBlock.items) {
      schemaJson = JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqBlock.items.map((f: any) => ({
          "@type": "Question",
          "name": f.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": f.answer
          }
        }))
      });
    }
  } else if (page.seo.schemaType === "organization") {
    schemaJson = JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Tangence Performance Marketing",
      "url": "https://www.tangence.in",
      "logo": "https://www.tangence.in/logo.png"
    });
  } else if (page.seo.schemaType === "article") {
    schemaJson = JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": desc,
      "dateModified": page.lastUpdated
    });
  }
}

// 7. Auto-load section specific scripts if they exist in public/assets/js/sections/<type>.js
const uniqueBlockTypes = [...new Set((page.blocks || []).map((b: any) => b.type))];
const sectionScripts = uniqueBlockTypes
  .map(type => `/assets/js/sections/${type}.js`)
  .filter(scriptUrl => {
    const filePath = path.resolve(`public/assets/js/sections/${path.basename(scriptUrl)}`);
    return fs.existsSync(filePath);
  });

// 8. Auto-load section specific stylesheets if they exist in public/assets/css/sections/<type>.css
const sectionStyles = uniqueBlockTypes
  .map(type => `/assets/css/sections/${type}.css`)
  .filter(styleUrl => {
    const filePath = path.resolve(`public/assets/css/sections/${path.basename(styleUrl)}`);
    return fs.existsSync(filePath);
  });
---

<MainLayout
  title={page.seo.metaTitle || page.title}
  description={page.seo.metaDescription}
  canonicalUrl={page.seo.canonicalUrl}
  robots={page.seo.robots}
  ogTitle={page.seo.ogTitle}
  ogDescription={page.seo.ogDescription}
  ogImage={page.seo.ogImage}
  twitterCard={page.seo.twitterCard}
  schemaMarkup={schemaJson}
  pageStyleUrl={pageStyleUrl}
  headerScripts={page.headerScripts}
  footerScripts={page.footerScripts}
  customCss={page.customCss}
  customJs={page.customJs}
  sectionScripts={sectionScripts}
  sectionStyles={sectionStyles}
>
  <Header />

  <!-- Render dynamically generated blocks stack -->
  <main class="page-builder-content">
    {page.status === "draft" && (
      <div class="preview-banner">
        <span>Preview Mode: You are viewing a draft version of this page.</span>
      </div>
    )}

    {page.blocks && page.blocks.map((block: any) => (
      <BlockRenderer block={block} />
    ))}
  </main>

  <Footer />
</MainLayout>

<style>
  .preview-banner {
    background-color: #F59E0B;
    color: #0B0F19;
    text-align: center;
    padding: 0.75rem 1.5rem;
    font-weight: 700;
    font-size: 0.9rem;
    position: sticky;
    top: 0;
    z-index: 999;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    font-family: system-ui, -apple-system, sans-serif;
  }
</style>
