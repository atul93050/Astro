---
import MainLayout from '../../layouts/MainLayout.astro';

export const prerender = false;

const orderId = Astro.url.searchParams.get("order_id") || "";
---
<MainLayout title="Order Completed Successfully">

  <div style="max-width:600px; margin:5rem auto; padding:2rem; background:#111827; border:1px solid #1F2937; border-radius:12px; text-align:center; box-shadow:0 10px 30px rgba(0,0,0,0.5);">
    <div style="width:64px; height:64px; border-radius:50%; background:rgba(16,185,129,0.1); color:#10B981; display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem; border:2px solid rgba(16,185,129,0.25);">
      <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
    </div>
    <h2 style="font-size:1.8rem; font-weight:800; color:#fff; margin-bottom:0.75rem;">Payment Successful!</h2>
    <p style="color:#9CA3AF; font-size:1.0rem; line-height:1.5; margin-bottom:1.5rem;">
      Thank you for shopping with us. Your payment has been verified and your order is now being processed.
    </p>

    {orderId && (
      <div style="background:#1F2937; border-radius:8px; padding:0.85rem 1.25rem; display:inline-block; margin-bottom:2rem; border:1px solid #374151;">
        <span style="font-size:0.8rem; color:#9CA3AF; display:block; margin-bottom:2px;">Order Reference ID</span>
        <strong style="color:#fff; font-family:monospace; font-size:1.0rem; letter-spacing:0.02em;">{orderId}</strong>
      </div>
    )}

    <div>
      <a href="/" style="background:#6366F1; color:#fff; padding:0.65rem 1.5rem; border-radius:6px; font-weight:600; text-decoration:none; display:inline-block; transition:all 0.2s;">
        Return to Home
      </a>
    </div>
  </div>

</MainLayout>
