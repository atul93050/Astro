---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<MainLayout
  title="Page Not Found | Tangence"
  description="The page you are looking for does not exist. Return to Tangence homepage."
  robots="noindex, nofollow"
>
  <Header />

  <main class="not-found-page">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
    <div class="container">
      <div class="not-found-content">
        <div class="error-code">404</div>
        <h1>Page Not Found</h1>
        <p>
          Sorry, the page you are looking for doesn't exist or has been moved.
          Check the URL, or head back to our homepage.
        </p>
        <div class="cta-group">
          <a href="/" class="btn-primary-link">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            Back to Homepage
          </a>
          <a href="/contact" class="btn-outline-link">Contact Support</a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</MainLayout>

<style>
  .not-found-page {
    min-height: 70vh;
    background-color: #050811;
    color: white;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 5rem 0;
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }
  .glow-1 {
    top: -10%;
    left: -5%;
    width: 550px;
    height: 550px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.1) 0%, transparent 70%);
  }
  .glow-2 {
    bottom: -10%;
    right: -5%;
    width: 450px;
    height: 450px;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.07) 0%, transparent 70%);
  }
  .container {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }
  .not-found-content {
    text-align: center;
  }
  .error-code {
    font-family: 'Outfit', sans-serif;
    font-size: 8rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.05em;
    background: linear-gradient(135deg, #6366F1 0%, #10B981 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
  }
  h1 {
    font-family: 'Outfit', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  p {
    font-size: 1.05rem;
    line-height: 1.65;
    color: #9CA3AF;
    max-width: 520px;
    margin: 0 auto 2.5rem auto;
  }
  .cta-group {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
    color: white;
    text-decoration: none;
    padding: 0.85rem 1.75rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.25s ease;
    box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
  }
  .btn-primary-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.5);
  }
  .btn-outline-link {
    display: inline-flex;
    align-items: center;
    color: #9CA3AF;
    text-decoration: none;
    padding: 0.85rem 1.75rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    border: 1px solid rgba(255,255,255,0.1);
    transition: all 0.25s ease;
  }
  .btn-outline-link:hover {
    color: white;
    border-color: rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.04);
  }
</style>
