---
import AdminLayout from '../../../layouts/admin/AdminLayout.astro';

export const prerender = false;
---
<AdminLayout title="Orders">

  <div class="page-header-flex" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:2rem;">
    <div>
      <p class="page-sub" style="color:var(--text-muted); margin:0;">Track e-commerce checkouts, verify payment sessions, and override shipping stages.</p>
    </div>
  </div>

  <!-- Status Filter Tabs -->
  <div class="status-tabs-bar" style="display:flex; gap:0.5rem; margin-bottom:1.5rem; border-bottom:1px solid var(--border-color); padding-bottom:1px; overflow-x:auto;">
    <button class="status-tab active" data-status="all">All</button>
    <button class="status-tab" data-status="pending">Pending</button>
    <button class="status-tab" data-status="paid">Paid</button>
    <button class="status-tab" data-status="shipped">Shipped</button>
    <button class="status-tab" data-status="delivered">Delivered</button>
    <button class="status-tab" data-status="refunded">Refunded</button>
    <button class="status-tab" data-status="failed">Failed</button>
  </div>

  <!-- Search Filter Row -->
  <div class="filters-row" style="display:flex; justify-content:flex-end; gap:1rem; margin-bottom:1.5rem; align-items:center;">
    <div style="position:relative; display:flex; align-items:center;">
      <input type="search" id="order-search" placeholder="Search by customer, order ID..." style="background:var(--input-bg); border:1px solid var(--input-border); color:var(--text-main); padding:0.45rem 0.75rem; padding-left:2rem; border-radius:var(--radius-sm); font-size:0.85rem; outline:none; width:250px;" autocomplete="off" />
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" style="position:absolute; left:0.75rem; color:var(--text-dim);"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
    </div>
  </div>

  <!-- Table List -->
  <div class="admin-table-wrapper" style="background:var(--bg-surface); border:1px solid var(--border-color); border-radius:var(--radius-lg); overflow:hidden; margin-bottom:5rem;">
    <div id="table-loading" style="display:flex; flex-direction:column; align-items:center; padding:5rem; gap:1rem; color:var(--text-dim);">
      <div class="loading-spinner" style="width:30px; height:30px; border:3px solid var(--border-color); border-top-color:var(--primary); border-radius:50%; animation:spin 0.8s linear infinite;"></div>
      <span>Loading orders...</span>
    </div>

    <div id="table-empty" style="display:none; flex-direction:column; align-items:center; padding:5rem; color:var(--text-dim); text-align:center;">
      <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:1rem; color:var(--text-dim);"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
      <h3>No orders found</h3>
      <p style="margin-top:0.25rem;">Orders will appear here once checkouts are initiated.</p>
    </div>

    <table class="admin-table" id="orders-table" style="display:none; width:100%; border-collapse:collapse; text-align:left; font-size:0.9rem;">
      <thead>
        <tr style="border-bottom:1px solid var(--border-color); background:rgba(255,255,255,0.01);">
          <th style="padding:1rem 1.5rem; font-weight:600; color:var(--text-muted);">Order ID</th>
          <th style="padding:1rem 1.5rem; font-weight:600; color:var(--text-muted);">Date</th>
          <th style="padding:1rem 1.5rem; font-weight:600; color:var(--text-muted);">Customer</th>
          <th style="padding:1rem 1.5rem; font-weight:600; color:var(--text-muted);">Items</th>
          <th style="padding:1rem 1.5rem; font-weight:600; color:var(--text-muted);">Total</th>
          <th style="padding:1rem 1.5rem; font-weight:600; color:var(--text-muted); width:120px;">Status</th>
          <th style="padding:1rem 1.5rem; font-weight:600; color:var(--text-muted); text-align:right; width:120px;">Actions</th>
        </tr>
      </thead>
      <tbody id="orders-tbody">
        <!-- Rendered via JS -->
      </tbody>
    </table>
  </div>

  <div class="toast-notification" id="toast"><div class="toast-content"><span id="toast-msg"></span></div></div>

</AdminLayout>

<style is:global>
  @keyframes spin { to { transform: rotate(360deg); } }
  .status-tabs-bar::-webkit-scrollbar { display:none; }
  .status-tab { background:transparent; border:none; color:var(--text-dim); padding:0.6rem 1.1rem; font-size:0.88rem; font-weight:600; cursor:pointer; transition:var(--transition); border-bottom:2px solid transparent; white-space:nowrap; }
  .status-tab:hover { color:var(--text-main); }
  .status-tab.active { color:var(--primary); border-bottom-color:var(--primary); }
  
  .order-status-badge { display:inline-flex; align-items:center; padding:0.25rem 0.5rem; border-radius:4px; font-size:0.75rem; font-weight:600; border:1px solid transparent; text-transform:capitalize; }
  .order-status-pending { background: rgba(245,158,11,0.1); color:#f59e0b; border-color: rgba(245,158,11,0.2); }
  .order-status-paid { background: rgba(59,130,246,0.1); color:#3b82f6; border-color: rgba(59,130,246,0.2); }
  .order-status-shipped { background: rgba(139,92,246,0.1); color:#8b5cf6; border-color: rgba(139,92,246,0.2); }
  .order-status-delivered { background: rgba(16,185,129,0.1); color:#10B981; border-color: rgba(16,185,129,0.2); }
  .order-status-refunded { background: rgba(156,163,175,0.1); color:#9ca3af; border-color: rgba(156,163,175,0.2); }
  .order-status-failed { background: rgba(239,68,68,0.1); color:#ef4444; border-color: rgba(239,68,68,0.2); }
</style>

<script>
  let currentStatus = 'all';

  function showToast(msg: string) {
    const t = document.getElementById('toast');
    const m = document.getElementById('toast-msg');
    if (t && m) { m.textContent = msg; t.classList.add('active'); setTimeout(() => t.classList.remove('active'), 3000); }
  }

  async function loadOrders() {
    const table = document.getElementById('orders-table');
    const loading = document.getElementById('table-loading');
    const empty = document.getElementById('table-empty');
    const tbody = document.getElementById('orders-tbody');
    if (!tbody || !loading || !empty || !table) return;

    table.style.display = 'none';
    loading.style.display = 'flex';
    empty.style.display = 'none';

    try {
      const search = (document.getElementById('order-search') as HTMLInputElement)?.value || '';
      const url = `/api/orders-crud?action=list&status=${currentStatus}&search=${search}`;
      
      const res = await fetch(url);
      const data = await res.json();
      loading.style.display = 'none';

      if (data.success && data.orders && data.orders.length > 0) {
        tbody.innerHTML = data.orders.map((o: any) => {
          const formattedDate = o.createdAt ? new Date(o.createdAt).toLocaleDateString('en-GB', {
            day: '2-digit',
            month: 'short',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
          }) : '—';

          const itemsCount = (o.items || []).reduce((sum: number, item: any) => sum + (item.quantity || 0), 0);
          const itemsSummary = (o.items || []).map((item: any) => `${item.label} (x${item.quantity})`).join(', ');

          return `
            <tr style="border-bottom:1px solid var(--border-color);">
              <td style="padding:1rem 1.5rem; vertical-align:middle; font-weight:600; color:var(--text-main); font-family:monospace; font-size:0.82rem;">${o.id}</td>
              <td style="padding:1rem 1.5rem; vertical-align:middle; color:var(--text-muted); font-size:0.83rem;">${formattedDate}</td>
              <td style="padding:1rem 1.5rem; vertical-align:middle;">
                <strong style="color:var(--text-main); font-weight:600; display:block;">${o.customer?.name || '—'}</strong>
                <span style="font-size:0.78rem; color:var(--text-dim); display:block; margin-top:2px;">${o.customer?.email || '—'}</span>
              </td>
              <td style="padding:1rem 1.5rem; vertical-align:middle; color:var(--text-muted); max-width:240px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="${itemsSummary}">
                <strong style="color:var(--text-main);">${itemsCount} Item(s)</strong>
                <span style="font-size:0.78rem; color:var(--text-dim); display:block; margin-top:2px; overflow:hidden; text-overflow:ellipsis;">${itemsSummary}</span>
              </td>
              <td style="padding:1rem 1.5rem; vertical-align:middle; font-weight:600; color:var(--text-main);">₹${o.totalAmount}</td>
              <td style="padding:1rem 1.5rem; vertical-align:middle;">
                <span class="order-status-badge order-status-${o.status}">${o.status}</span>
              </td>
              <td style="padding:1rem 1.5rem; vertical-align:middle; text-align:right;">
                <a href="/admin/orders/${o.id}" class="btn btn-outline btn-sm" style="padding:0.25rem 0.6rem; font-size:0.78rem;">Manage</a>
              </td>
            </tr>
          `;
        }).join('');
        table.style.display = 'table';
      } else {
        empty.style.display = 'flex';
      }
    } catch {
      loading.style.display = 'none';
      empty.style.display = 'flex';
    }
  }

  function init() {
    loadOrders();

    // Tab buttons click
    document.querySelectorAll('.status-tab').forEach(btn => {
      btn.addEventListener('click', function(this: HTMLElement) {
        document.querySelectorAll('.status-tab').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        currentStatus = this.dataset.status!;
        loadOrders();
      });
    });

    // Search input
    document.getElementById('order-search')?.addEventListener('input', (e) => {
      clearTimeout((window as any).searchTimeout);
      (window as any).searchTimeout = setTimeout(loadOrders, 300);
    });
  }

  if (document.readyState !== 'loading') {
    init();
  } else {
    document.addEventListener('DOMContentLoaded', init);
  }
  document.addEventListener('astro:page-load', init);
</script>
