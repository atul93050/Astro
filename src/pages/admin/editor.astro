        `;
      } else if (field.type === "gradient") {
        inputFieldHtml = `
          <div style="display:flex; flex-direction:column; gap:0.35rem;">
            <div style="display:flex; align-items:center; gap:0.5rem;">
              <div id="grad-preview-${pathId}" style="width:50px; height:34px; border-radius:4px; border:1px solid var(--border-color); background:${val || 'transparent'};"></div>
              <input type="text" id="${inputId}" value="${val}" oninput="syncPathValue('${escPathStr}', this.value); document.getElementById('grad-preview-${pathId}').style.background = this.value" style="flex:1;" placeholder="linear-gradient(...)" ${validationAttr} />
            </div>
          </div>
        `;
      } else if (field.type === "link") {
        const linkVal = typeof val === 'object' ? val : {};
        inputFieldHtml = `
          <div class="link-editor-card" ${validationAttr} style="border: 1px solid var(--border-color); padding: 0.85rem; border-radius: 6px; display:flex; flex-direction:column; gap:0.5rem; background: rgba(255,255,255,0.01);">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.5rem;">
              <div class="form-group" style="margin:0;">
                <label style="font-size:0.75rem;">Link Text</label>
                <input type="text" value="${escHtml(linkVal.text || '')}" oninput="syncLinkField('${escPathStr}', 'text', this.value)" placeholder="e.g. Learn More" />
              </div>
              <div class="form-group" style="margin:0;">
                <label style="font-size:0.75rem;">Link URL</label>
                <input type="text" value="${escHtml(linkVal.url || '')}" oninput="syncLinkField('${escPathStr}', 'url', this.value)" placeholder="e.g. /about OR https://google.com" />
              </div>
            </div>
            <div style="display:flex; flex-wrap:wrap; gap:0.75rem; margin-top:0.25rem;">
              <label style="display:flex; align-items:center; gap:0.3; font-size:0.75rem; cursor:pointer;"><input type="checkbox" ${linkVal.newTab ? 'checked' : ''} onchange="syncLinkField('${escPathStr}', 'newTab', this.checked)" style="width:auto;" /> New Tab</label>
              <label style="display:flex; align-items:center; gap:0.3; font-size:0.75rem; cursor:pointer;"><input type="checkbox" ${linkVal.nofollow ? 'checked' : ''} onchange="syncLinkField('${escPathStr}', 'nofollow', this.checked)" style="width:auto;" /> No Follow</label>
              <label style="display:flex; align-items:center; gap:0.3; font-size:0.75rem; cursor:pointer;"><input type="checkbox" ${linkVal.sponsored ? 'checked' : ''} onchange="syncLinkField('${escPathStr}', 'sponsored', this.checked)" style="width:auto;" /> Sponsored</label>
              <label style="display:flex; align-items:center; gap:0.3; font-size:0.75rem; cursor:pointer;"><input type="checkbox" ${linkVal.ugc ? 'checked' : ''} onchange="syncLinkField('${escPathStr}', 'ugc', this.checked)" style="width:auto;" /> UGC</label>
            </div>
          </div>
        `;
      } else if (["group", "object"].includes(field.type)) {
        const subVal = typeof val === 'object' ? val : {};
        inputFieldHtml = `
          <div class="group-editor-card" ${validationAttr} style="border:1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; background: rgba(99, 102, 241, 0.02); display:flex; flex-direction:column; gap:0.5rem;">
            ${renderSubFieldsHTML(field.repeaterFields || [], subVal, currentPath)}
          </div>
        `;
      } else if (field.type === "repeater") {
        const items = Array.isArray(val) ? val : [];
        const schemaJson = JSON.stringify(field.repeaterFields || []);
        
        inputFieldHtml = `
          <div class="repeater-section" ${validationAttr}>
            <div class="repeater-header" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
              <h5 style="margin:0; font-size:0.85rem;">${field.label} Items</h5>
              <button type="button" class="btn btn-outline btn-sm" onclick="addRepeaterItemAtPath('${escPathStr}', '${escHtml(schemaJson)}')">+ Add Item</button>
            </div>
            <div class="repeater-items-wrap" style="display:flex; flex-direction:column; gap:0.5rem;">
              ${items.map((item, itemIdx) => `
                <div class="repeater-item-row" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 6px; padding: 1rem; position: relative;">
                  <div style="position:absolute; top:0.5rem; right:0.5rem; display:flex; gap:0.25rem;">
                    <button type="button" class="btn btn-outline btn-sm" style="padding:2px; height:20px; min-width:24px;" onclick="moveRepeaterItemAtPath('${escPathStr}', ${itemIdx}, -1)" ${itemIdx === 0 ? 'disabled' : ''}>&uarr;</button>
                    <button type="button" class="btn btn-outline btn-sm" style="padding:2px; height:20px; min-width:24px;" onclick="moveRepeaterItemAtPath('${escPathStr}', ${itemIdx}, 1)" ${itemIdx === items.length - 1 ? 'disabled' : ''}>&darr;</button>
                    <button type="button" class="btn-icon-sm btn-delete-block" onclick="removeRepeaterItemAtPath('${escPathStr}', ${itemIdx})" style="padding:2px; height:20px; width:20px; display:flex; align-items:center; justify-content:center;">&times;</button>
                  </div>
                  <div style="display:flex; flex-direction:column; gap:0.5rem; padding-top:0.75rem; width:100%;">
                    ${renderSubFieldsHTML(field.repeaterFields || [], item, [...currentPath, itemIdx])}
                  </div>
                </div>
              `).join('')}
            </div>
          </div>
        `;
      } else if (field.type === "array" || field.type === "list") {
        const items = Array.isArray(val) ? val : [];
        inputFieldHtml = `
          <div class="repeater-section" ${validationAttr}>
            <div class="repeater-header" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
              <h5 style="margin:0; font-size:0.85rem;">${field.label}</h5>
              <button type="button" class="btn btn-outline btn-sm" onclick="addListStringItemAtPath('${escPathStr}')">+ Add Item</button>
            </div>
            <div class="repeater-items-wrap" style="display:flex; flex-direction:column; gap:0.35rem;">
              ${items.map((item, itemIdx) => `
                <div style="display:flex; gap:0.5rem; align-items:center;">
                  <input type="text" value="${escHtml(item)}" oninput="syncListStringFieldAtPath('${escPathStr}', ${itemIdx}, this.value)" style="flex:1;" />
                  <button type="button" class="btn-icon-sm btn-delete-block" onclick="removeListStringItemAtPath('${escPathStr}', ${itemIdx})" style="padding:2px; height:24px; width:24px; display:flex; align-items:center; justify-content:center;">&times;</button>
                </div>
              `).join('')}
            </div>
          </div>
        `;
      }

      const showIfAttr = field.showIf ? `data-show-if-field="${field.showIf.field}" data-show-if-value="${field.showIf.value}"` : '';
      const hideIfAttr = field.hideIf ? `data-hide-if-field="${field.hideIf.field}" data-hide-if-value="${field.hideIf.value}"` : '';

      html += `
        <div class="form-group ${['repeater', 'gallery', 'textarea', 'group', 'object', 'array', 'list', 'link'].includes(field.type) ? 'col-12' : 'col-6'}" 
             id="wrap-${pathId}" 
             data-path='${escPathStr}'
             ${showIfAttr} 
             ${hideIfAttr} 
             style="margin-top:0.4rem;">
          <label style="font-weight:600; display:block; margin-bottom:0.25rem;">${field.label} ${isRequired}</label>
          ${inputFieldHtml}
          ${helpText}
          <span class="field-error" id="err-${pathId}" style="color:var(--color-error); font-size:0.75rem; display:none; margin-top:0.25rem; font-weight:500;"></span>
        </div>
      `;
    });
    return html;
  }

  function escHtml(str) {
    return String(str || '').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function setNestedValue(obj, path, value) {
    let current = obj;
    for (let i = 0; i < path.length - 1; i++) {
      const key = path[i];
      if (current[key] === undefined || current[key] === null) {
        current[key] = typeof path[i+1] === 'number' ? [] : {};
      }
      current = current[key];
    }
    current[path[path.length - 1]] = value;
  }

  function getNestedValue(obj, path) {
    let current = obj;
    for (let i = 0; i < path.length; i++) {
      if (current === undefined || current === null) return undefined;
      current = current[path[i]];
    }
    return current;
  }

  window.syncPathValue = function(pathJsonStr, value) {
    const path = JSON.parse(pathJsonStr);
    setNestedValue(ROOT_OBJECT, path, value);
    evaluateConditionalVisibility();
    validateAllFields();
    updateSeoIndicators();
  };

  window.syncMultiselect = function(pathJsonStr, optVal, checked) {
    const path = JSON.parse(pathJsonStr);
    let items = getNestedValue(ROOT_OBJECT, path);
    if (!Array.isArray(items)) items = [];
    if (checked) {
      if (!items.includes(optVal)) items.push(optVal);
    } else {
      const idx = items.indexOf(optVal);
      if (idx !== -1) items.splice(idx, 1);
    }
    setNestedValue(ROOT_OBJECT, path, items);
    validateAllFields();
  };

  window.syncLinkField = function(pathJsonStr, key, value) {
    const path = JSON.parse(pathJsonStr);
    let linkVal = getNestedValue(ROOT_OBJECT, path);
    if (typeof linkVal !== 'object' || linkVal === null) linkVal = {};
    linkVal[key] = value;
    setNestedValue(ROOT_OBJECT, path, linkVal);
    validateAllFields();
  };

  window.addRepeaterItemAtPath = function(pathJsonStr, schemaJson) {
    const path = JSON.parse(pathJsonStr);
    const schema = JSON.parse(schemaJson);
    let items = getNestedValue(ROOT_OBJECT, path);
    if (!Array.isArray(items)) items = [];
    const newItem = {};
    schema.forEach(f => {
      newItem[f.name] = f.default !== undefined ? f.default : "";
    });
    items.push(newItem);
    setNestedValue(ROOT_OBJECT, path, items);
    updateUI();
  };

  window.removeRepeaterItemAtPath = function(pathJsonStr, idx) {
    const path = JSON.parse(pathJsonStr);
    const items = getNestedValue(ROOT_OBJECT, path);
    if (Array.isArray(items)) {
      items.splice(idx, 1);
      updateUI();
    }
  };

  window.moveRepeaterItemAtPath = function(pathJsonStr, idx, dir) {
    const path = JSON.parse(pathJsonStr);
    const items = getNestedValue(ROOT_OBJECT, path);
    if (Array.isArray(items)) {
      const targetIdx = idx + dir;
      if (targetIdx >= 0 && targetIdx < items.length) {
        const temp = items[idx];
        items[idx] = items[targetIdx];
        items[targetIdx] = temp;
        updateUI();
      }
    }
  };

  window.addListStringItemAtPath = function(pathJsonStr) {
    const path = JSON.parse(pathJsonStr);
    let items = getNestedValue(ROOT_OBJECT, path);
    if (!Array.isArray(items)) items = [];
    items.push("");
    setNestedValue(ROOT_OBJECT, path, items);
    updateUI();
  };

  window.removeListStringItemAtPath = function(pathJsonStr, idx) {
    const path = JSON.parse(pathJsonStr);
    const items = getNestedValue(ROOT_OBJECT, path);
    if (Array.isArray(items)) {
      items.splice(idx, 1);
      updateUI();
    }
  };

  window.syncListStringFieldAtPath = function(pathJsonStr, idx, val) {
    const path = JSON.parse(pathJsonStr);
    const items = getNestedValue(ROOT_OBJECT, path);
    if (Array.isArray(items)) {
      items[idx] = val;
    }
  };

  let activeGalleryPathStr = null;
  window.openGalleryPicker = function(pathStr) {
    activeGalleryPathStr = pathStr;
    activeMediaPickerTarget = "";
    document.getElementById("media-picker-overlay").classList.add("active");
    loadMediaCatalogGrid();
  };

  window.removeFromGallery = function(pathStr, idx) {
    const path = JSON.parse(pathStr);
    const items = getNestedValue(ROOT_OBJECT, path);
    if (Array.isArray(items)) {
      items.splice(idx, 1);
      updateUI();
    }
  };

  window.evaluateConditionalVisibility = function() {
    document.querySelectorAll('[data-show-if-field]').forEach(el => {
      const showField = el.dataset.showIfField;
      const showVal = el.dataset.showIfValue;
      const path = JSON.parse(el.dataset.path);
      const dependencyPath = [...path.slice(0, -1), showField];
      const actualVal = getNestedValue(ROOT_OBJECT, dependencyPath);
      
      let isMatch = false;
      if (showVal === 'true') isMatch = (actualVal === true);
      else if (showVal === 'false') isMatch = (actualVal === false || actualVal === undefined || actualVal === null || actualVal === '');
      else isMatch = (String(actualVal) === String(showVal));

      el.style.display = isMatch ? '' : 'none';
    });

    document.querySelectorAll('[data-hide-if-field]').forEach(el => {
      const hideField = el.dataset.hideIfField;
      const hideVal = el.dataset.hideIfValue;
      const path = JSON.parse(el.dataset.path);
      const dependencyPath = [...path.slice(0, -1), hideField];
      const actualVal = getNestedValue(ROOT_OBJECT, dependencyPath);
      
      let isMatch = false;
      if (hideVal === 'true') isMatch = (actualVal === true);
      else if (hideVal === 'false') isMatch = (actualVal === false || actualVal === undefined || actualVal === null || actualVal === '');
      else isMatch = (String(actualVal) === String(hideVal));

      el.style.display = isMatch ? 'none' : '';
    });
  };

  window.validateAllFields = function() {
    let hasErrors = false;
    document.querySelectorAll('[data-validation]').forEach(el => {
      const validation = JSON.parse(el.dataset.validation || '{}');
      const path = JSON.parse(el.dataset.path || '[]');
      const isRequired = el.dataset.required === 'true';
      const val = getNestedValue(ROOT_OBJECT, path);
      const label = el.dataset.label || 'Field';

      let errorMsg = '';
      if (isRequired && (val === undefined || val === null || val === '')) {
        errorMsg = `${label} is required`;
      } else if (val !== undefined && val !== null && val !== '') {
        if (validation.minLength && String(val).length < validation.minLength) {
          errorMsg = `${label} must be at least ${validation.minLength} characters`;
        }
        if (validation.maxLength && String(val).length > validation.maxLength) {
          errorMsg = `${label} cannot exceed ${validation.maxLength} characters`;
        }
        if (validation.min !== undefined && parseFloat(val) < validation.min) {
          errorMsg = `${label} must be at least ${validation.min}`;
        }
        if (validation.max !== undefined && parseFloat(val) > validation.max) {
          errorMsg = `${label} cannot exceed ${validation.max}`;
        }
        if (validation.regex) {
          const rx = new RegExp(validation.regex);
          if (!rx.test(String(val))) {
            errorMsg = `${label} format is invalid`;
          }
        }
      }

      const pathId = path.join('-');
      const errSpan = document.getElementById(`err-${pathId}`);
      if (errSpan) {
        errSpan.textContent = errorMsg;
        if (errorMsg) {
          errSpan.style.display = 'block';
          hasErrors = true;
        } else {
          errSpan.style.display = 'none';
        }
      }
    });
    return !hasErrors;
  };

  // Dynamic form renderer driven completely by BLOCK_REGISTRY
  function renderBlocks() {
    const container = document.getElementById("blocks-stack");
    const fallback = document.getElementById("blocks-fallback");
    
    if (!container) return;
    container.innerHTML = "";

    if (blocks.length === 0) {
      if (fallback) fallback.style.display = "block";
      return;
    }
    
    if (fallback) fallback.style.display = "none";

    blocks.forEach((block, idx) => {
      const card = document.createElement("div");
      card.className = "builder-block-card";
      card.id = `builder-block-${idx}`;
      
      const config = BLOCK_REGISTRY.find(b => b.type === block.type);
      const blockTitle = config ? config.name : block.type;
      
      let fieldsHtml = "";

      if (config) {
        fieldsHtml = renderSubFieldsHTML(config.fields, block, [idx]);
      }

      const sectionIdHtml = block.sectionId 
        ? `<span class="block-section-id-badge" style="background:#4F46E5; color:white; font-size:0.7rem; padding:0.15rem 0.45rem; border-radius:4px; font-weight:700; margin-left:0.5rem; text-transform:none;">Reusable: ${block.sectionId}</span>`
        : "";

      card.innerHTML = `
        <div class="block-header-wrap">
          <div class="block-badge-title">
            <span class="block-type-badge">${block.type}</span>
            <h4>${blockTitle} Block</h4>
            ${sectionIdHtml}
          </div>
          <div class="block-actions">
            <button type="button" class="btn-icon-sm" onclick="moveBlock(${idx}, -1)" title="Move Up">${ICONS.arrowUp}</button>
            <button type="button" class="btn-icon-sm" onclick="moveBlock(${idx}, 1)" title="Move Down">${ICONS.arrowDown}</button>
            <button type="button" class="btn-icon-sm btn-delete-block" onclick="deleteBlock(${idx})" title="Delete Block">${ICONS.delete}</button>
          </div>
        </div>
        <div class="block-form-grid" style="display:flex; flex-direction:column; gap:0.5rem;">
          ${fieldsHtml}
        </div>
      `;

      container.appendChild(card);
    });

    evaluateConditionalVisibility();
    validateAllFields();
  }

  // Real-time SEO Scoring & Character Counter logic
  function updateSeoIndicators() {
    const titleInput = document.getElementById("seo-title");
    const descInput = document.getElementById("seo-description");
    const keywordInput = document.getElementById("seo-focus-keyword");

    const titleVal = titleInput ? titleInput.value.trim() : "";
    const descVal = descInput ? descInput.value.trim() : "";
    const keywordVal = keywordInput ? keywordInput.value.trim().toLowerCase() : "";

    // Length counters
    const cntTitle = document.getElementById("cnt-seo-title");
    const cntDesc = document.getElementById("cnt-seo-description");
    
    if (cntTitle) cntTitle.innerText = `${titleVal.length} chars`;
    if (cntDesc) cntDesc.innerText = `${descVal.length} chars`;

    // scoring metrics
    let score = 0;
    const checks = [];

    // Title Check (25 pts)
    if (titleVal.length > 0) {
      if (titleVal.length >= 30 && titleVal.length <= 60) {
        score += 25;
        checks.push({ name: "Meta Title length is perfect (30-60 chars)", passed: true });
      } else {
        score += 10;
        checks.push({ name: "Meta Title length should be between 30 and 60 chars (currently " + titleVal.length + " chars)", passed: false });
      }
    } else {
      checks.push({ name: "Meta Title is missing", passed: false });
    }

    // Description Check (25 pts)
    if (descVal.length > 0) {
      if (descVal.length >= 120 && descVal.length <= 160) {
        score += 25;
        checks.push({ name: "Meta Description length is perfect (120-160 chars)", passed: true });
      } else {
        score += 10;
        checks.push({ name: "Meta Description length should be between 120 and 160 chars (currently " + descVal.length + " chars)", passed: false });
      }
    } else {
      checks.push({ name: "Meta Description is missing", passed: false });
    }

    // Keyword Check (20 pts)
    if (keywordVal.length > 0) {
      score += 10;
      checks.push({ name: "Focus Keyword provided", passed: true });
      
      const keywordInTitle = titleVal.toLowerCase().includes(keywordVal);
      const keywordInDesc = descVal.toLowerCase().includes(keywordVal);

      if (keywordInTitle) {
        score += 5;
        checks.push({ name: "Focus keyword found in Meta Title", passed: true });
      } else {
        checks.push({ name: "Focus keyword not found in Meta Title", passed: false });
      }

      if (keywordInDesc) {
        score += 5;
        checks.push({ name: "Focus keyword found in Meta Description", passed: true });
      } else {
        checks.push({ name: "Focus keyword not found in Meta Description", passed: false });
      }
    } else {
      checks.push({ name: "Focus Keyword is missing", passed: false });
    }

    // Canonical URL Check (10 pts)
    const canonicalInput = document.getElementById("seo-canonical");
    const canonicalVal = canonicalInput ? canonicalInput.value.trim() : "";
    if (canonicalVal.length > 0) {
      score += 10;
      checks.push({ name: "Canonical URL provided", passed: true });
    } else {
      checks.push({ name: "Canonical URL is missing (recommended)", passed: false });
    }

    // OG Image URL Check (10 pts)
    const ogImageInput = document.getElementById("seo-og-image");
    const ogImageVal = ogImageInput ? ogImageInput.value.trim() : "";
    if (ogImageVal.length > 0) {
      score += 10;
      checks.push({ name: "Open Graph (OG) Image URL provided", passed: true });
    } else {
      checks.push({ name: "Open Graph (OG) Image is missing", passed: false });
    }

    // JSON-LD Schema Check (10 pts)
    const schemaTypeSelect = document.getElementById("seo-schema-type");
    const schemaTypeVal = schemaTypeSelect ? schemaTypeSelect.value : "none";
    const schemaMarkupInput = document.getElementById("seo-schema-markup");
    const schemaMarkupVal = schemaMarkupInput ? schemaMarkupInput.value.trim() : "";
    if (schemaTypeVal !== "none") {
      if (schemaTypeVal === "custom") {
        if (schemaMarkupVal.length > 0) {
          try {
            JSON.parse(schemaMarkupVal);
            score += 10;
            checks.push({ name: "Custom JSON-LD Schema markup is valid JSON", passed: true });
          } catch(e) {
            checks.push({ name: "Custom JSON-LD Schema markup is NOT valid JSON", passed: false });
          }
        } else {
          checks.push({ name: "Custom JSON-LD Schema markup is empty", passed: false });
        }
      } else {
        score += 10;
        checks.push({ name: "JSON-LD Schema Type set to " + schemaTypeVal, passed: true });
      }
    } else {
      checks.push({ name: "JSON-LD Schema structured data is missing", passed: false });
    }

    // Update Score Circle and Ring
    const scoreRing = document.getElementById("seo-score-ring");
    const scoreText = document.getElementById("seo-score-text");
    const healthText = document.getElementById("seo-health-text");

    if (scoreRing) {
      scoreRing.setAttribute("stroke-dasharray", `${score}, 100`);
      
      let strokeColor = "var(--color-error)";
      let health = "Poor SEO";
      if (score >= 80) {
        strokeColor = "var(--color-success)";
        health = "Excellent SEO";
      } else if (score >= 50) {
        strokeColor = "var(--color-warning)";
        health = "Needs Tweaks";
      }
      
      scoreRing.style.stroke = strokeColor;
      if (healthText) {
        healthText.innerText = health;
        healthText.style.color = strokeColor;
      }
    }

    if (scoreText) scoreText.textContent = `${score}%`;

    // Render Checklist
    const checksList = document.getElementById("seo-checks-list");
    if (checksList) {
      checksList.innerHTML = checks.map(c => `
        <li>
          <span class="seo-check-icon" style="color: ${c.passed ? 'var(--color-success)' : 'var(--color-error)'};">
            ${c.passed ? '✓' : '✗'}
          </span>
          <span>${c.name}</span>
        </li>
      `).join('');
    }
  }

  // Save changes via API
  async function submitPageForm() {
    const title = document.getElementById("page-title").value.trim();
    let slugVal = document.getElementById("page-slug").value.trim().toLowerCase();
    if (slugVal === "/" || slugVal === "") {
      slugVal = "index";
    }
    const status = document.getElementById("page-status").value;
    const body = document.getElementById("page-body").value.trim();
    
    // SEO fields
    const metaTitle = document.getElementById("seo-title").value.trim();
    const metaDescription = document.getElementById("seo-description").value.trim();
    const canonicalUrl = document.getElementById("seo-canonical").value.trim();
    const robots = document.getElementById("seo-robots").value.trim();
    const ogTitle = document.getElementById("seo-og-title").value.trim();
    const ogDescription = document.getElementById("seo-og-description").value.trim();
    const ogImage = document.getElementById("seo-og-image").value.trim();
    const twitterCard = document.getElementById("seo-twitter").value;
    const schemaType = document.getElementById("seo-schema-type").value;
    const schemaMarkup = document.getElementById("seo-schema-markup").value.trim();
    const focusKeyword = document.getElementById("seo-focus-keyword").value.trim();

    // Clear previous errors
    document.querySelectorAll(".field-error").forEach(el => el.innerText = "");

    // Client-side quick check
    let hasClientErrors = false;
    if (!title) {
      document.getElementById("err-title").innerText = "Page Title is required";
      hasClientErrors = true;
    }
    if (!slugVal) {
      document.getElementById("err-slug").innerText = "Slug is required";
      hasClientErrors = true;
    }
    // Meta Title and Meta Description are now optional and not strict validation blockers

    if (hasClientErrors) {
      showToast("Please fix the validation errors.");
      return;
    }

    if (!validateAllFields()) {
      showToast("Please fix the validation errors in the blocks section first.");
      return;
    }

    const headerScripts = document.getElementById("page-header-scripts").value;
    const footerScripts = document.getElementById("page-footer-scripts").value;
    const customCss = document.getElementById("page-custom-css").value;
    const customJs = document.getElementById("page-custom-js").value;

    const payload = {
      originalSlug,
      title,
      slug: slugVal,
      status,
      body,
      headerScripts,
      footerScripts,
      customCss,
      customJs,
      seo: {
        metaTitle: metaTitle.trim() || title.trim(),
        metaDescription,
        canonicalUrl,
        robots,
        ogTitle,
        ogDescription,
        ogImage,
        twitterCard,
        schemaType,
        schemaMarkup,
        focusKeyword
      },
      blocks
    };

    const saveBtn = document.getElementById("save-page-btn");
    const saveLabel = document.getElementById("save-btn-label");
    saveBtn.disabled = true;
    saveLabel.innerText = "Saving...";

    try {
      const res = await fetch("/api/pages-crud", {
        method: isEditMode ? "PUT" : "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      const data = await res.json();

      if (data.success) {
        showToast(isEditMode ? "Page updated successfully!" : "Page created successfully!");
        setTimeout(() => {
          window.location.href = `/admin/editor?slug=${slugVal}`;
        }, 1000);
      } else {
        showToast("Error: Failed to save changes");
        // Print backend validation errors
        if (data.errors) {
          for (const [field, errMsg] of Object.entries(data.errors)) {
            // Match main fields
            if (field === "title") document.getElementById("err-title").innerText = errMsg;
            if (field === "slug") document.getElementById("err-slug").innerText = errMsg;
            if (field === "seo.metaTitle") document.getElementById("err-seo-title").innerText = errMsg;
            if (field === "seo.metaDescription") document.getElementById("err-seo-description").innerText = errMsg;
            
            // Highlight blocks error inside stack
            if (field.startsWith("blocks.")) {
              showToast(`Block Error: ${errMsg}`);
            }
          }
        }
        saveBtn.disabled = false;
        saveLabel.innerText = "Save Changes";
      }
    } catch (e) {
      showToast("Network Error: Could not save page content");
      saveBtn.disabled = false;
      saveLabel.innerText = "Save Changes";
    }
  }

  // Load Revisions from Endpoint
  async function fetchRevisions() {
    const listContainer = document.getElementById("revisions-list");
    if (!listContainer) return;

    try {
      const res = await fetch(`/api/pages-crud?action=revisions&slug=${originalSlug}`);
      const data = await res.json();

      if (data.success && data.revisions.length > 0) {
        listContainer.innerHTML = data.revisions.map(rev => `
          <div class="revision-row">
            <span class="rev-date">${rev.date}</span>
            <button type="button" class="btn btn-outline btn-sm rev-action-btn" onclick="rollbackRevision('${rev.timestamp}')">
              Rollback
            </button>
          </div>
        `).join('');
      } else {
        listContainer.innerHTML = `<div class="revision-placeholder" style="padding:1.5rem; text-align:center; color:var(--text-dim); font-size:0.8rem;">No backups saved yet. Changes save revisions automatically.</div>`;
      }
    } catch (e) {
      listContainer.innerHTML = `<div class="revision-placeholder" style="color:var(--color-error); padding:1rem;">Error fetching revision records</div>`;
    }
  }

  // Rollback to specific timestamp
  window.rollbackRevision = function(timestamp) {
    window.customConfirm("This will overwrite your current draft configuration with the revision data. Are you sure you want to proceed?", async () => {
      showToast("Rolling back page draft...");
      try {
        const res = await fetch(`/api/pages-crud?action=rollback&slug=${originalSlug}&timestamp=${timestamp}`);
        const data = await res.json();
        
        if (data.success) {
          showToast("Draft restored successfully!");
          setTimeout(() => {
            window.location.reload();
          }, 1000);
        } else {
          showToast("Error: " + data.error);
        }
      } catch (e) {
        showToast("Error restoring revision backup.");
      }
    });
  };

  // Toast banner utility
  const toast = document.getElementById("toast-notify");
  const toastMsg = document.getElementById("toast-message");
  
  function showToast(message) {
    if (toast && toastMsg) {
      toastMsg.innerText = message;
      toast.classList.add("active");
      setTimeout(() => {
        toast.classList.remove("active");
      }, 3000);
    }
  }

  // Interactive Media Modal functions
  function openMediaModal(targetId) {
    activeMediaPickerTarget = targetId;
    const modal = document.getElementById("media-picker-overlay");
    if (modal) modal.classList.add("active");
    loadMediaCatalogGrid();
  }

  function hideMediaModal() {
    const modal = document.getElementById("media-picker-overlay");
    if (modal) modal.classList.remove("active");
    activeMediaPickerTarget = "";
  }

  // Load physical catalog and meta JSON in modal
  async function loadMediaCatalogGrid() {
    const grid = document.getElementById("media-picker-grid");
    if (!grid) return;

    try {
      const res = await fetch("/api/media-crud");
      const data = await res.json();

      if (data.success && data.media.length > 0) {
        grid.innerHTML = data.media.map(item => `
          <div class="media-picker-item" onclick="selectMediaAsset('${item.url}')" title="${item.alt || item.title}">
            <img src="${item.url}" alt="${item.alt || ''}" />
          </div>
        `).join('');
      } else {
        grid.innerHTML = `<p class="media-empty">No catalog images. Upload a new asset.</p>`;
      }
    } catch (e) {
      grid.innerHTML = `<p class="media-empty" style="color:var(--color-error);">Error loading media catalog files.</p>`;
    }
  }

  // Pick media item
  window.selectMediaAsset = function(url) {
    if (activeMediaPickerTarget) {
      const targetInput = document.getElementById(activeMediaPickerTarget);
      if (targetInput) {
        targetInput.value = url;
        
        // Trigger manual input update event to sync array block state!
        const changeEvent = new Event('input', { bubbles: true });
        targetInput.dispatchEvent(changeEvent);
      }
      hideMediaModal();
    } else if (activeGalleryPathStr) {
      const path = JSON.parse(activeGalleryPathStr);
      let items = getNestedValue(ROOT_OBJECT, path);
      if (!Array.isArray(items)) items = [];
      if (!items.includes(url)) {
        items.push(url);
      }
      setNestedValue(ROOT_OBJECT, path, items);
      hideMediaModal();
      activeGalleryPathStr = null;
      updateUI();
    }
  };

  // Upload local media file directly in modal
  async function uploadMediaFile() {
    const fileInput = document.getElementById("media-upload-file");
    const uploadBtn = document.getElementById("upload-media-btn");
    const fileSelectBtn = document.getElementById("trigger-file-select");

    if (!fileInput || fileInput.files.length === 0) return;

    const file = fileInput.files[0];
    const formData = new FormData();
    formData.append("file", file);
    formData.append("alt", file.name.split(".")[0]);

    uploadBtn.disabled = true;
    uploadBtn.innerText = "Uploading...";

    try {
      const res = await fetch("/api/media-crud", {
        method: "POST",
        body: formData
      });
      const result = await res.json();

      if (result.success) {
        showToast("Asset uploaded successfully!");
        
        // Clear upload state
        fileInput.value = "";
        fileSelectBtn.innerText = "Choose Upload File";
        uploadBtn.innerText = "Upload";
        
        // Pick uploaded image directly
        selectMediaAsset(result.media.url);
      } else {
        showToast("Error: " + (result.error || "Upload failed"));
        uploadBtn.disabled = false;
        uploadBtn.innerText = "Upload";
      }
    } catch (e) {
      showToast("Network Error: Could not upload file asset");
      uploadBtn.disabled = false;
      uploadBtn.innerText = "Upload";
    }
  }

  // Hook layout on content loads
  document.addEventListener("DOMContentLoaded", initEditor);
  document.addEventListener("astro:page-load", initEditor);
  if (document.readyState === "interactive" || document.readyState === "complete") {
    initEditor();
  }
</script>
