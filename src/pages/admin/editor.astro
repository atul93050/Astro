---
import AdminLayout from "../../layouts/admin/AdminLayout.astro";
import fs from "node:fs";
import path from "node:path";
import { parse } from "yaml";

export const prerender = false;

// Load section definitions registry (dynamic, replaces hardcoded BLOCK_REGISTRY)
const definitionsPath = path.resolve("src/data/section-definitions.json");
let BLOCK_REGISTRY: any[] = [];
try {
  if (fs.existsSync(definitionsPath)) {
    const rawDefs = JSON.parse(fs.readFileSync(definitionsPath, "utf-8"));
    // Map to legacy BLOCK_REGISTRY shape for compatibility
    BLOCK_REGISTRY = rawDefs.map((d: any) => ({
      type: d.key,
      name: d.name,
      category: d.category,
      icon: d.key,
      description: d.description || "",
      componentPath: d.componentPath || "",
      fields: d.fields || [],
      defaultValues: Object.fromEntries(
        (d.fields || []).map((f: any) => [f.name, f.default !== undefined ? f.default : ""])
      )
    }));
  }
} catch (e) {
  console.error("Failed to load section definitions for editor:", e);
}

// 1. Check if we are editing an existing page
const slug = Astro.url.searchParams.get("slug") || "";
let isEditMode = false;
let pageData = {
  title: "",
  slug: "",
  status: "draft",
  headerScripts: "",
  footerScripts: "",
  customCss: "",
  customJs: "",
  seo: {
    metaTitle: "",
    metaDescription: "",
    canonicalUrl: "",
    robots: "index, follow",
    ogTitle: "",
    ogDescription: "",
    ogImage: "",
    twitterCard: "summary_large_image",
    focusKeyword: "",
    schemaMarkup: "",
    schemaType: "none"
  },
  blocks: [] as any[]
};
let rawBody = "";

if (slug) {
  const filePath = path.resolve("src/content/pages", `${slug}.md`);
  if (fs.existsSync(filePath)) {
    isEditMode = true;
    const content = fs.readFileSync(filePath, "utf-8");
    const parts = content.split(/^---$/m);
    if (parts.length >= 3) {
      try {
        pageData = { ...pageData, ...parse(parts[1]) };
        rawBody = parts.slice(2).join("---").trim();
        
        // Resolve section blocks content for the editor client
        if (pageData.blocks && Array.isArray(pageData.blocks)) {
          pageData.blocks = pageData.blocks.map((block: any) => {
            const config = BLOCK_REGISTRY.find((d: any) => d.type === block.type);
            const defaultValues = config ? { ...config.defaultValues } : {};

            if (block.sectionId) {
              const secPath = path.resolve("src/content/sections", `${block.sectionId}.md`);
              let secData = {};
              if (fs.existsSync(secPath)) {
                const secContent = fs.readFileSync(secPath, "utf-8");
                const secParts = secContent.split(/^---$/m);
                if (secParts.length >= 3) {
                  try {
                    secData = parse(secParts[1]) || {};
                  } catch (err) {
                    console.error(`Error parsing YAML in section ${block.sectionId}:`, err);
                  }
                }
              }
              return {
                ...defaultValues,
                ...block,
                ...secData
              };
            }
            return {
              ...defaultValues,
              ...block
            };
          });
        }
      } catch (e) {
        console.error("Error parsing YAML in editor:", e);
      }
    }
  }
}
import "../../styles/admin/css/editor.css";
---

<AdminLayout title={isEditMode ? `Edit Page: ${pageData.title}` : "Create New Page"}>
  
  <div class="editor-header-bar">
    <div class="header-back-wrap">
      <a href="/admin/pages" class="back-link">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        <span>Back to Pages</span>
      </a>
      <h2>{isEditMode ? `Edit: ${pageData.title}` : "New Landing Page"}</h2>
    </div>
    
    <div class="editor-action-buttons">
      {isEditMode && (
        <a id="page-preview-btn" href={pageData.status === 'published' ? `/${pageData.slug}` : `/${pageData.slug}?preview=true`} target="_blank" class="btn btn-outline ">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
          <span>Preview Page</span>
        </a>
      )}
      <button class="btn btn-primary" id="save-page-btn">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
        <span id="save-btn-label">Save Changes</span>
      </button>
    </div>
  </div>

  <div class="editor-layout">
    
    <!-- Main Content Form Area -->
    <div class="editor-main-form">
      <form id="cms-editor-form" onsubmit="return false;">
        
        <!-- Basic Configuration block -->
        <div class="form-card">
          <div class="card-header">
            <h3>Page Settings</h3>
          </div>
          <div class="card-body">
            <div class="form-grid">
              <div class="form-group col-6">
                <label for="page-title">Page Title <span class="required">*</span></label>
                <input type="text" id="page-title" value={pageData.title} placeholder="e.g., Performance SEO Agency" required />
                <span class="field-error" id="err-title"></span>
              </div>
              
              <div class="form-group col-6">
                <label for="page-slug">URL Slug <span class="required">*</span></label>
                <input type="text" id="page-slug" value={pageData.slug === 'index' ? '/' : pageData.slug} placeholder="e.g., performance-seo" required />
                <span class="field-error" id="err-slug"></span>
                <span class="field-help">Only lowercase letters, numbers, dashes, and underscores. Use / or index for home.</span>
              </div>

              <div class="form-group col-6">
                <label for="page-status">Publication Status</label>
                <select id="page-status">
                  <option value="draft" selected={pageData.status === "draft"}>Draft (Visible only under admin previews)</option>
                  <option value="published" selected={pageData.status === "published"}>Published (Live on site & indexing allowed)</option>
                </select>
                <span class="field-error" id="err-status"></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Interactive Dynamic Page Builder Section -->
        <div class="form-card" style="margin-top: 1.5rem;">
          <div class="card-header block-header-flex">
            <h3>Page Builder Blocks</h3>
            <div class="block-controls-wrap">
              <button type="button" class="btn btn-outline btn-sm" id="attach-existing-btn">
                <span>Attach Existing Section</span>
              </button>
              <button type="button" class="btn btn-primary btn-sm" id="open-add-block-modal-btn">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                <span>Add Section</span>
              </button>
            </div>
          </div>
          
          <div class="card-body padding-zero">
            <!-- Dynamic Blocks Stack Container -->
            <div class="blocks-stack-container" id="blocks-stack">
              <!-- JS will inject dynamic fields forms here -->
            </div>
            
            <div class="no-blocks-fallback" id="blocks-fallback">
              <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.4; margin-bottom:1rem;"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="9" x2="15" y2="9"></line><line x1="9" y1="13" x2="15" y2="13"></line><line x1="9" y1="17" x2="11" y2="17"></line></svg>
              <h4>No sections inside the builder stack yet</h4>
              <p>Add components using the select dropdown above to assemble your landing page layout.</p>
            </div>
          </div>
        </div>

        <!-- Custom Scripts & Styles Card -->
        <div class="form-card" style="margin-top: 1.5rem;">
          <div class="card-header">
            <h3>Page Custom Scripts & Styles</h3>
          </div>
          <div class="card-body" style="display:flex; flex-direction:column; gap:1.25rem;">
            <div class="form-group">
              <label for="page-header-scripts">Page Header Scripts (Injects before <code>&lt;/head&gt;</code>)</label>
              <textarea id="page-header-scripts" rows="3" placeholder="<!-- Place page-specific meta tags, verification scripts, head tags here -->">{pageData.headerScripts || ""}</textarea>
            </div>

            <div class="form-group">
              <label for="page-footer-scripts">Page Footer Scripts (Injects before <code>&lt;/body&gt;</code>)</label>
              <textarea id="page-footer-scripts" rows="3" placeholder="<!-- Place page-specific custom body end scripts here -->">{pageData.footerScripts || ""}</textarea>
            </div>

            <div class="form-group">
              <label for="page-custom-css">Page Custom CSS (Will be wrapped inside <code>&lt;style&gt;</code>)</label>
              <textarea id="page-custom-css" rows="3" placeholder="/* CSS syntax only */\nbody { background: #000; }">{pageData.customCss || ""}</textarea>
            </div>

            <div class="form-group">
              <label for="page-custom-js">Page Custom JS (Will be wrapped inside <code>&lt;script&gt;</code>)</label>
              <textarea id="page-custom-js" rows="3" placeholder="// JS code syntax only\nconsole.log('page loaded');">{pageData.customJs || ""}</textarea>
            </div>
          </div>
        </div>

        <!-- Optional Raw Content body -->
        <div class="form-card" style="margin-top: 1.5rem;">
          <div class="card-header">
            <h3>Additional Markdown Body</h3>
          </div>
          <div class="card-body">
            <div class="form-group">
              <label for="page-body">Markdown Content</label>
              <textarea id="page-body" rows="6" placeholder="Write additional text or markdown content that renders at the bottom of the page...">{rawBody}</textarea>
            </div>
          </div>
        </div>

      </form>
    </div>

    <!-- Right Sidebar for SEO Management & Revisions -->
    <div class="editor-sidebar">
      
      <!-- SEO Scoring Panel -->
      <div class="sidebar-card">
        <div class="sidebar-card-header">
          <h4>Real-time SEO Manager</h4>
        </div>
        <div class="sidebar-card-body">
          <div class="seo-score-meter-wrap">
            <div class="seo-gauge">
              <svg viewBox="0 0 36 36" class="circular-chart">
                <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"></path>
                <path class="circle" id="seo-score-ring" stroke-dasharray="0, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"></path>
                <text x="18" y="20.35" class="percentage" id="seo-score-text">0%</text>
              </svg>
            </div>
            <div class="seo-score-label">
              <span id="seo-health-text">Not Rated</span>
            </div>
          </div>

          <div class="form-group">
            <label for="seo-focus-keyword">Focus Keyword</label>
            <input type="text" id="seo-focus-keyword" value={pageData.seo.focusKeyword} placeholder="e.g., performance marketing" />
          </div>

          <div class="form-group">
            <label for="seo-title">Meta Title</label>
            <input type="text" id="seo-title" value={pageData.seo.metaTitle} placeholder="50-60 characters ideal" />
            <span class="length-counter" id="cnt-seo-title">0 chars</span>
            <span class="field-error" id="err-seo-title"></span>
          </div>

          <div class="form-group">
            <label for="seo-description">Meta Description</label>
            <textarea id="seo-description" rows="3" placeholder="120-160 characters ideal">{pageData.seo.metaDescription}</textarea>
            <span class="length-counter" id="cnt-seo-description">0 chars</span>
            <span class="field-error" id="err-seo-description"></span>
          </div>

          <!-- Collapsible Advanced SEO Controls -->
          <details class="advanced-details">
            <summary>Advanced SEO Configurations</summary>
            
            <div class="form-group" style="margin-top:0.75rem;">
              <label for="seo-canonical">Canonical URL</label>
              <input type="url" id="seo-canonical" value={pageData.seo.canonicalUrl} placeholder="https://www.tangence.in/url" />
            </div>

            <div class="form-group">
              <label for="seo-robots">Robots Meta</label>
              <input type="text" id="seo-robots" value={pageData.seo.robots} placeholder="index, follow" />
            </div>

            <div class="form-group">
              <label for="seo-og-title">OG Title</label>
              <input type="text" id="seo-og-title" value={pageData.seo.ogTitle} />
            </div>

            <div class="form-group">
              <label for="seo-og-description">OG Description</label>
              <textarea id="seo-og-description" rows="2">{pageData.seo.ogDescription}</textarea>
            </div>

            <div class="form-group">
              <label for="seo-og-image">OG Image URL</label>
              <div class="input-picker-wrap">
                <input type="text" id="seo-og-image" value={pageData.seo.ogImage} />
                <button type="button" class="btn btn-outline media-picker-trigger" data-target="seo-og-image">Pick</button>
              </div>
            </div>

            <div class="form-group">
              <label for="seo-twitter">Twitter Card</label>
              <select id="seo-twitter">
                <option value="summary" selected={pageData.seo.twitterCard === "summary"}>Summary</option>
                <option value="summary_large_image" selected={pageData.seo.twitterCard === "summary_large_image"}>Summary Large Image</option>
              </select>
            </div>

            <div class="form-group">
              <label for="seo-schema-type">JSON-LD Schema Type</label>
              <select id="seo-schema-type">
                <option value="none" selected={pageData.seo.schemaType === "none"}>None (Auto / Omit)</option>
                <option value="organization" selected={pageData.seo.schemaType === "organization"}>Organization</option>
                <option value="faq" selected={pageData.seo.schemaType === "faq"}>FAQ Page Schema</option>
                <option value="article" selected={pageData.seo.schemaType === "article"}>Article Details</option>
                <option value="custom" selected={pageData.seo.schemaType === "custom"}>Custom Input</option>
              </select>
            </div>

            <div class="form-group" id="custom-schema-group" style="display:none;">
              <label for="seo-schema-markup">Custom JSON-LD Markup</label>
              <textarea id="seo-schema-markup" rows="4" placeholder="JSON format context script content">{pageData.seo.schemaMarkup}</textarea>
            </div>
          </details>

          <!-- SEO Checklist Indicators -->
          <div class="seo-checklist">
            <h5>SEO Checklist</h5>
            <ul id="seo-checks-list">
              <!-- JS loaded dynamically -->
            </ul>
          </div>
        </div>
      </div>

      <!-- Revision Logs Panel -->
      {isEditMode && (
        <div class="sidebar-card" style="margin-top: 1.5rem;">
          <div class="sidebar-card-header">
            <h4>Revision History</h4>
          </div>
          <div class="sidebar-card-body padding-zero">
            <div class="revisions-list" id="revisions-list">
              <!-- Loaded via dynamic fetch -->
              <div class="revision-placeholder">Loading revisions history...</div>
            </div>
          </div>
        </div>
      )}

    </div>
  </div>

  <!-- Reusable Media Library Selector Modal Dialog -->
  <div class="confirm-modal-overlay" id="media-picker-overlay">
    <div class="confirm-modal media-modal">
      <div class="confirm-modal-header">
        <h4>Select Asset from Media Catalog</h4>
        <button class="close-modal-btn" id="close-media-modal">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="media-modal-actions">
        <form id="media-upload-form" onsubmit="return false;" style="display:flex; gap:0.5rem; width:100%;">
          <input type="file" id="media-upload-file" accept="image/*" style="display:none;" />
          <button type="button" class="btn btn-outline btn-sm" id="trigger-file-select" style="flex:1;">
            Choose Upload File
          </button>
          <button type="button" class="btn btn-primary btn-sm" id="upload-media-btn" disabled>
            Upload
          </button>
        </form>
      </div>
      <div class="media-picker-grid" id="media-picker-grid" style="max-height:280px; overflow-y:auto; overflow-x:hidden;">
        <!-- Injected dynamic catalog grid -->
        <p class="media-empty">No catalog images. Upload a new asset.</p>
      </div>
      <div class="confirm-modal-footer">
        <button class="btn btn-outline" id="close-media-picker-btn">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Modal 1: Visual Block Catalog Selector -->
  <div class="confirm-modal-overlay" id="add-section-modal-overlay">
    <div class="confirm-modal create-section-modal" style="max-width: 600px;">
      <div class="confirm-modal-header">
        <h4>Add Layout Block Section</h4>
        <button type="button" class="close-modal-btn" id="close-add-section-modal">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="confirm-modal-body">
        <div class="catalog-filters" style="display:flex; gap:0.35rem; margin-bottom:0.75rem; border-bottom:1px solid var(--border-color); padding-bottom:0.5rem;">
          <button type="button" class="catalog-tab-btn active" data-category="all">All</button>
          <button type="button" class="catalog-tab-btn" data-category="hero">Hero</button>
          <button type="button" class="catalog-tab-btn" data-category="content">Content</button>
          <button type="button" class="catalog-tab-btn" data-category="marketing">Marketing</button>
          <button type="button" class="catalog-tab-btn" data-category="social">Social</button>
          <button type="button" class="catalog-tab-btn" data-category="other">Other</button>
        </div>
        <div class="block-catalog-grid" id="add-section-catalog" style="max-height: 320px; overflow-y: auto;">
          <!-- Dynamically loaded list of blocks in BLOCK_REGISTRY -->
        </div>
      </div>
      <div class="confirm-modal-footer">
        <button type="button" class="btn btn-outline" id="cancel-add-section-btn">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Modal 2: Attach Existing Reusable Section Selector (Enhanced Visual Browser) -->
  <div class="confirm-modal-overlay" id="attach-section-modal-overlay">
    <div class="confirm-modal" style="max-width: 950px; width: 90vw;">
      <div class="confirm-modal-header">
        <h4>Visual Section Browser</h4>
        <button type="button" class="close-modal-btn" id="close-attach-section-modal">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="confirm-modal-body">
        <p style="margin-bottom:0.75rem; font-size:0.85rem; color:var(--text-muted);">Search, filter, preview, and select one or more reusable sections to insert into the page builder blocks stack.</p>
        
        <!-- Search and Filter controls -->
        <div class="attach-toolbar" style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:1rem; align-items:center; background:var(--bg-base); padding:0.75rem; border-radius:6px; border:1px solid var(--border-color);">
          <input type="text" id="attach-search" placeholder="Search by name, type, id..." style="flex:1.5; min-width:180px; padding:0.4rem 0.6rem; font-size:0.82rem;" />
          
          <select id="attach-filter-type" style="padding:0.4rem 0.6rem; font-size:0.82rem; width:auto;">
            <option value="all">All Types</option>
          </select>
          
          <select id="attach-filter-status" style="padding:0.4rem 0.6rem; font-size:0.82rem; width:auto;">
            <option value="all">All Statuses</option>
            <option value="published">Published</option>
            <option value="draft">Draft</option>
            <option value="archived">Archived</option>
          </select>
          
          <select id="attach-sort" style="padding:0.4rem 0.6rem; font-size:0.82rem; width:auto;">
            <option value="updated">Recently Updated</option>
            <option value="created">Recently Created</option>
            <option value="used">Most Used</option>
            <option value="alpha">Alphabetical</option>
          </select>
          
          <div style="display:flex; align-items:center; gap:0.25rem; margin-left:auto; white-space:nowrap;">
            <input type="checkbox" id="attach-select-all" style="width:auto; cursor:pointer;" />
            <label for="attach-select-all" style="font-size:0.78rem; font-weight:600; cursor:pointer; user-select:none; color:var(--text-muted);">Select All</label>
          </div>
        </div>

        <div class="sections-attach-list-grid" id="sections-attach-list" style="max-height: 380px; overflow-y: auto; display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; padding: 0.5rem; border: 1px solid var(--border-color); border-radius: 6px; background: var(--bg-base);">
          <!-- Loaded dynamically via API -->
          <p class="media-empty">No matching reusable sections found.</p>
        </div>
      </div>
      
      <div class="confirm-modal-footer">
        <button type="button" class="btn btn-outline" id="cancel-attach-section-btn">Cancel</button>
        <button type="button" class="btn btn-primary" id="confirm-attach-selected-btn" disabled>Attach Selected (0)</button>
      </div>
    </div>
  </div>

  <!-- Modal 3: Section Live Viewport Preview Overlay -->
  <div class="preview-overlay" id="preview-overlay" style="z-index:4000;">
    <div class="preview-modal-wrap">
      <div class="preview-modal-top">
        <div class="preview-modal-title">
          <h4 id="preview-section-title">Preview: Section</h4>
        </div>
        <div class="preview-device-selectors">
          <button type="button" class="device-btn active" data-device="desktop">Desktop</button>
          <button type="button" class="device-btn" data-device="tablet">Tablet</button>
          <button type="button" class="device-btn" data-device="mobile">Mobile</button>
        </div>
        <button type="button" class="close-modal-btn" id="close-preview-overlay">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="preview-modal-body-frame">
        <div class="device-viewport desktop" id="preview-device-viewport">
          <iframe id="preview-iframe" src="about:blank"></iframe>
        </div>
      </div>
    </div>
  </div>

  <!-- Notification Banner -->
  <div class="toast-notification" id="toast-notify">
    <div class="toast-content">
      <span class="toast-message" id="toast-message">Page saved successfully!</span>
    </div>
  </div>

</AdminLayout>


<script is:inline define:vars={{ pageData, isEditMode, BLOCK_REGISTRY, urlSlug: slug }}>
  // Hold initial state from server
  let blocks = pageData.blocks || [];
  let originalSlug = urlSlug || pageData.slug || "";
  let activeMediaPickerTarget = "";

  let attachSectionsData = [];

  function initEditor() {
    const form = document.getElementById("cms-editor-form");
    if (!form || form.dataset.listenerBound) return;
    form.dataset.listenerBound = "true";

    renderBlocks();
    setupEventListeners();
    updateSeoIndicators();
    
    if (isEditMode) {
      fetchRevisions();
    }
  }

  // Define SVG Icons for Block Controls
  const ICONS = {
    arrowUp: `<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"></polyline></svg>`,
    arrowDown: `<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>`,
    delete: `<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>`
  };

  // Setup Global Event Listeners
  function setupEventListeners() {
    const openAddBtn = document.getElementById("open-add-block-modal-btn");
    if (openAddBtn) {
      openAddBtn.addEventListener("click", () => {
        document.getElementById("add-section-modal-overlay").classList.add("active");
        renderVisualCatalog();
      });
    }
    
    const closeAddX = document.getElementById("close-add-section-modal");
    const cancelAddBtn = document.getElementById("cancel-add-section-btn");
    if (closeAddX) closeAddX.addEventListener("click", () => document.getElementById("add-section-modal-overlay").classList.remove("active"));
    if (cancelAddBtn) cancelAddBtn.addEventListener("click", () => document.getElementById("add-section-modal-overlay").classList.remove("active"));

    const attachBtn = document.getElementById("attach-existing-btn");
    if (attachBtn) {
      attachBtn.addEventListener("click", openAttachModal);
    }

    const closeAttachX = document.getElementById("close-attach-section-modal");
    const cancelAttachBtn = document.getElementById("cancel-attach-section-btn");
    if (closeAttachX) closeAttachX.addEventListener("click", () => document.getElementById("attach-section-modal-overlay").classList.remove("active"));
    if (cancelAttachBtn) cancelAttachBtn.addEventListener("click", () => document.getElementById("attach-section-modal-overlay").classList.remove("active"));

    // Visual Section Browser Search, Filters & Sorting
    const attachSearch = document.getElementById("attach-search");
    if (attachSearch) {
      attachSearch.addEventListener("input", filterAndRenderAttachList);
    }
    const attachFilterType = document.getElementById("attach-filter-type");
    if (attachFilterType) {
      attachFilterType.addEventListener("change", filterAndRenderAttachList);
    }
    const attachFilterStatus = document.getElementById("attach-filter-status");
    if (attachFilterStatus) {
      attachFilterStatus.addEventListener("change", filterAndRenderAttachList);
    }
    const attachSort = document.getElementById("attach-sort");
    if (attachSort) {
      attachSort.addEventListener("change", filterAndRenderAttachList);
    }

    // Select All Checkbox
    const selectAllCheckbox = document.getElementById("attach-select-all");
    if (selectAllCheckbox) {
      selectAllCheckbox.addEventListener("change", (e) => {
        const checkboxes = document.querySelectorAll(".attach-checkbox");
        checkboxes.forEach(cb => {
          cb.checked = e.target.checked;
        });
        updateAttachSelectedButton();
      });
    }

    // Event delegation for checkbox changes to update count and "Select All" checked state
    const attachListContainer = document.getElementById("sections-attach-list");
    if (attachListContainer) {
      attachListContainer.addEventListener("change", (e) => {
        if (e.target && e.target.classList.contains("attach-checkbox")) {
          const selectAll = document.getElementById("attach-select-all");
          if (selectAll) {
            const allCheckboxCount = document.querySelectorAll(".attach-checkbox").length;
            const checkedCount = document.querySelectorAll(".attach-checkbox:checked").length;
            selectAll.checked = allCheckboxCount > 0 && checkedCount === allCheckboxCount;
          }
          updateAttachSelectedButton();
        }
      });
    }

    // Attach Selected Button
    const confirmAttachBtn = document.getElementById("confirm-attach-selected-btn");
    if (confirmAttachBtn) {
      confirmAttachBtn.addEventListener("click", attachMultipleSelected);
    }

    // Close Section Preview Overlay
    const closePreviewBtn = document.getElementById("close-preview-overlay");
    if (closePreviewBtn) {
      closePreviewBtn.addEventListener("click", () => {
        const overlay = document.getElementById("preview-overlay");
        const iframe = document.getElementById("preview-iframe");
        if (overlay) overlay.classList.remove("active");
        if (iframe) iframe.src = "about:blank";
      });
    }

    // Preview Device Viewport Switcher
    const deviceButtons = document.querySelectorAll(".preview-device-selectors .device-btn");
    const viewport = document.getElementById("preview-device-viewport");
    deviceButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        deviceButtons.forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
        const device = btn.getAttribute("data-device");
        if (viewport) {
          viewport.className = `device-viewport ${device}`;
        }
      });
    });

    const saveBtn = document.getElementById("save-page-btn");
    if (saveBtn) {
      saveBtn.addEventListener("click", submitPageForm);
    }

    const slugInput = document.getElementById("page-slug");
    const statusInput = document.getElementById("page-status");
    const previewBtn = document.getElementById("page-preview-btn");

    function updatePreviewUrl() {
      if (!previewBtn || !slugInput || !statusInput) return;
      const slugVal = slugInput.value.trim() || "index";
      const statusVal = statusInput.value;
      previewBtn.href = statusVal === 'published' ? `/${slugVal}` : `/${slugVal}?preview=true`;
    }

    if (slugInput) slugInput.addEventListener("input", updatePreviewUrl);
    if (statusInput) statusInput.addEventListener("change", updatePreviewUrl);

    // SEO inputs event mapping
    const titleInput = document.getElementById("page-title");
    const seoTitleInput = document.getElementById("seo-title");
    const seoDescInput = document.getElementById("seo-description");
    const seoKeywordInput = document.getElementById("seo-focus-keyword");

    if (titleInput && !isEditMode) {
      // Auto-slugify on title input for new pages
      titleInput.addEventListener("input", () => {
        const slugInput = document.getElementById("page-slug");
        if (slugInput) {
          slugInput.value = titleInput.value
            .toLowerCase()
            .trim()
            .replace(/[^a-z0-9\s-_]/g, "")
            .replace(/\s+/g, "-");
        }
      });
    }

    if (seoTitleInput) seoTitleInput.addEventListener("input", updateSeoIndicators);
    if (seoDescInput) seoDescInput.addEventListener("input", updateSeoIndicators);
    if (seoKeywordInput) seoKeywordInput.addEventListener("input", updateSeoIndicators);

    const seoCanonicalInput = document.getElementById("seo-canonical");
    if (seoCanonicalInput) seoCanonicalInput.addEventListener("input", updateSeoIndicators);

    const seoOgImageInput = document.getElementById("seo-og-image");
    if (seoOgImageInput) seoOgImageInput.addEventListener("input", updateSeoIndicators);

    const seoSchemaMarkupInput = document.getElementById("seo-schema-markup");
    if (seoSchemaMarkupInput) seoSchemaMarkupInput.addEventListener("input", updateSeoIndicators);

    // Schema Type change
    const schemaTypeSelect = document.getElementById("seo-schema-type");
    const customSchemaGroup = document.getElementById("custom-schema-group");
    if (schemaTypeSelect && customSchemaGroup) {
      schemaTypeSelect.addEventListener("change", () => {
        customSchemaGroup.style.display = schemaTypeSelect.value !== "none" ? "block" : "none";
        updateSeoIndicators();
      });
      // Initial trigger
      customSchemaGroup.style.display = schemaTypeSelect.value !== "none" ? "block" : "none";
    }

    // Media Modal close bindings
    const closePickerX = document.getElementById("close-media-modal");
    const closePickerBtn = document.getElementById("close-media-picker-btn");
    if (closePickerX) closePickerX.addEventListener("click", hideMediaModal);
    if (closePickerBtn) closePickerBtn.addEventListener("click", hideMediaModal);

    // Dynamic Media triggers hooking on delegates
    document.addEventListener("click", (e) => {
      const trigger = e.target.closest(".media-picker-trigger");
      if (trigger) {
        const targetId = trigger.getAttribute("data-target");
        const galleryTarget = trigger.getAttribute("data-gallery-target");
        if (targetId) {
          openMediaModal(targetId);
        } else if (galleryTarget) {
          openGalleryPicker(galleryTarget);
        }
      }
    });

    // File Upload listeners in modal
    const fileSelectBtn = document.getElementById("trigger-file-select");
    const fileInput = document.getElementById("media-upload-file");
    const uploadBtn = document.getElementById("upload-media-btn");

    if (fileSelectBtn && fileInput) {
      fileSelectBtn.addEventListener("click", () => fileInput.click());
      fileInput.addEventListener("change", () => {
        if (fileInput.files.length > 0) {
          fileSelectBtn.innerText = fileInput.files[0].name;
          if (uploadBtn) uploadBtn.disabled = false;
        } else {
          fileSelectBtn.innerText = "Choose Upload File";
          if (uploadBtn) uploadBtn.disabled = true;
        }
      });
    }

    if (uploadBtn) {
      uploadBtn.addEventListener("click", uploadMediaFile);
    }
  }

  function renderVisualCatalog() {
    const grid = document.getElementById("add-section-catalog");
    if (!grid) return;
    grid.innerHTML = BLOCK_REGISTRY.map(b => `
      <div class="catalog-item" data-category="${b.category}" onclick="addNewBlock('${b.type}'); document.getElementById('add-section-modal-overlay').classList.remove('active');">
        <div class="catalog-item-icon">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line></svg>
        </div>
        <div class="catalog-item-info">
          <strong>${b.name}</strong>
          <span>Category: ${b.category}</span>
        </div>
      </div>
    `).join('');
    
    // Bind catalog category tabs inside modal
    const tabs = document.querySelectorAll("#add-section-modal-overlay .catalog-tab-btn");
    tabs.forEach(tab => {
      tab.addEventListener("click", (e) => {
        e.stopPropagation();
        tabs.forEach(t => t.classList.remove("active"));
        tab.classList.add("active");
        const cat = tab.getAttribute("data-category");
        document.querySelectorAll("#add-section-catalog .catalog-item").forEach(item => {
          const itemCat = item.getAttribute("data-category");
          if (cat === "all" || itemCat === cat) {
            item.style.display = "flex";
          } else {
            item.style.display = "none";
          }
        });
      });
    });
  }

  async function openAttachModal() {
    const searchInput = document.getElementById("attach-search");
    if (searchInput) searchInput.value = "";
    
    const typeFilter = document.getElementById("attach-filter-type");
    if (typeFilter) {
      typeFilter.value = "all";
      // Populate type filter choices dynamically from BLOCK_REGISTRY
      typeFilter.innerHTML = `<option value="all">All Types</option>` + BLOCK_REGISTRY.map(b => `<option value="${b.type}">${b.name}</option>`).join('');
    }
    
    const statusFilter = document.getElementById("attach-filter-status");
    if (statusFilter) statusFilter.value = "all";
    
    const sortVal = document.getElementById("attach-sort");
    if (sortVal) sortVal.value = "updated";
    
    const selectAll = document.getElementById("attach-select-all");
    if (selectAll) selectAll.checked = false;
    
    const confirmBtn = document.getElementById("confirm-attach-selected-btn");
    if (confirmBtn) {
      confirmBtn.disabled = true;
      confirmBtn.innerText = "Attach Selected (0)";
    }

    document.getElementById("attach-section-modal-overlay").classList.add("active");
    const container = document.getElementById("sections-attach-list");
    if (container) container.innerHTML = `<p class="media-empty">Loading reusable sections catalog...</p>`;

    try {
      const res = await fetch("/api/sections-crud?action=list");
      const data = await res.json();
      if (data.success) {
        attachSectionsData = data.sections || [];
        filterAndRenderAttachList();
      } else {
        if (container) container.innerHTML = `<p class="media-empty">Error loading reusable sections catalog.</p>`;
      }
    } catch(e) {
      if (container) container.innerHTML = `<p class="media-empty">Network connection error.</p>`;
    }
  }

  function filterAndRenderAttachList() {
    const q = document.getElementById("attach-search").value.trim().toLowerCase();
    const typeFilter = document.getElementById("attach-filter-type").value;
    const statusFilter = document.getElementById("attach-filter-status").value;
    const sortVal = document.getElementById("attach-sort").value;

    let filtered = [...attachSectionsData];

    // Search filter
    if (q) {
      filtered = filtered.filter(s =>
        (s.id || '').toLowerCase().includes(q) ||
        (s.name || '').toLowerCase().includes(q) ||
        (s.typeName || '').toLowerCase().includes(q)
      );
    }

    // Type filter
    if (typeFilter !== "all") {
      filtered = filtered.filter(s => s.type === typeFilter);
    }

    // Status filter
    if (statusFilter !== "all") {
      filtered = filtered.filter(s => s.status === statusFilter);
    }

    // Sorting
    if (sortVal === "updated") {
      filtered.sort((a, b) => new Date(b.lastUpdated).getTime() - new Date(a.lastUpdated).getTime());
    } else if (sortVal === "created") {
      filtered.sort((a, b) => a.id.localeCompare(b.id));
    } else if (sortVal === "used") {
      filtered.sort((a, b) => (b.usedIn?.length || 0) - (a.usedIn?.length || 0));
    } else if (sortVal === "alpha") {
      filtered.sort((a, b) => a.name.localeCompare(b.name));
    }

    renderAttachList(filtered);
  }

  function renderAttachList(list) {
    const container = document.getElementById("sections-attach-list");
    if (!container) return;

    if (list.length === 0) {
      container.innerHTML = `<p class="media-empty">No matching reusable sections found.</p>`;
      return;
    }

    container.innerHTML = list.map(sec => {
      const pageUsagesStr = sec.usedIn && sec.usedIn.length > 0 
        ? `Used on ${sec.usedIn.length} page${sec.usedIn.length > 1 ? 's' : ''}`
        : 'Not used';
      const statusClass = sec.status === 'published' ? 'badge-success' : sec.status === 'draft' ? 'badge-warning' : 'badge-danger';
      const fallbackPreviewImg = `/images/previews/${sec.type}.png`;

      return `
        <div class="section-attach-card" style="border: 1px solid var(--border-color); border-radius: 8px; background: var(--bg-surface-solid); padding: 0.75rem; display: flex; flex-direction: column; justify-content: space-between; position: relative;">
          <div style="position: absolute; top: 0.5rem; left: 0.5rem; z-index: 10;">
            <input type="checkbox" class="attach-checkbox" data-id="${sec.id}" data-name="${sec.name}" style="width: 16px; height: 16px; cursor: pointer;" />
          </div>
          <div style="width: 100%; height: 120px; background: var(--bg-base); border-radius: 4px; overflow: hidden; margin-bottom: 0.75rem; display: flex; align-items: center; justify-content: center; border: 1px solid var(--border-color);">
            <img src="${sec.previewImage || fallbackPreviewImg}" alt="${sec.name}" style="max-width: 100%; max-height: 100%; object-fit: contain;" onerror="this.src='/images/previews/hero.png'" />
          </div>
          <div style="flex: 1; min-width: 0; margin-bottom: 0.75rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 0.25rem;">
              <h5 style="margin: 0 0 0.25rem 0; font-size: 0.85rem; color: var(--text-main); font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: calc(100% - 70px);" title="${sec.name}">${sec.name}</h5>
              <span class="badge ${statusClass}" style="font-size: 0.6rem; padding: 0.15rem 0.35rem; border-radius: 4px; text-transform: uppercase;">${sec.status}</span>
            </div>
            <p style="margin: 0 0 0.25rem 0; font-size: 0.72rem; color: var(--text-muted); font-family: monospace; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Type: ${sec.typeName}</p>
            <p style="margin: 0 0 0.25rem 0; font-size: 0.72rem; color: var(--text-dim); font-weight: 500;">${pageUsagesStr}</p>
            <p style="margin: 0; font-size: 0.68rem; color: var(--text-dim);">Updated: ${new Date(sec.lastUpdated).toLocaleDateString()}</p>
          </div>
          <div style="display: flex; gap: 0.5rem; justify-content: space-between; align-items: center; border-top: 1px solid var(--border-color); padding-top: 0.5rem; margin-top: auto;">
            <button type="button" class="btn btn-outline btn-sm" onclick="previewSection('${sec.id}', '${sec.name}')" style="padding: 0.25rem 0.5rem; font-size: 0.72rem; flex: 1;">Preview</button>
            <button type="button" class="btn btn-primary btn-sm" onclick="attachSingleSection('${sec.id}', '${sec.name}')" style="padding: 0.25rem 0.5rem; font-size: 0.72rem; flex: 1;">Attach</button>
          </div>
        </div>
      `;
    }).join('');

    // Reset select all checkbox based on visiblity state
    const selectAll = document.getElementById("attach-select-all");
    if (selectAll) selectAll.checked = false;
    updateAttachSelectedButton();
  }

  function updateAttachSelectedButton() {
    const checkboxes = document.querySelectorAll(".attach-checkbox:checked");
    const btn = document.getElementById("confirm-attach-selected-btn");
    if (btn) {
      btn.disabled = checkboxes.length === 0;
      btn.innerText = `Attach Selected (${checkboxes.length})`;
    }
  }

  async function attachSingleSection(sectionId, name) {
    try {
      const res = await fetch(`/api/sections-crud?action=get&id=${sectionId}`);
      const data = await res.json();
      if (data.success) {
        const attachedBlock = {
          ...data.section,
          sectionId: sectionId
        };
        const targetIdx = blocks.length;
        blocks.push(attachedBlock);
        renderBlocks();
        document.getElementById("attach-section-modal-overlay").classList.remove("active");
        showToast(`✓ ${name || sectionId} attached successfully`);

        // Scroll to card element and highlight it
        setTimeout(() => {
          const blockCard = document.getElementById(`builder-block-${targetIdx}`);
          if (blockCard) {
            blockCard.scrollIntoView({ behavior: "smooth", block: "center" });
            blockCard.style.transition = "all 0.5s ease";
            blockCard.style.outline = "3px solid #4F46E5";
            blockCard.style.boxShadow = "0 0 20px rgba(79, 70, 229, 0.4)";
            setTimeout(() => {
              blockCard.style.outline = "";
              blockCard.style.boxShadow = "";
            }, 2500);
          }
        }, 50);
      } else {
        showToast("Error loading section details from API.");
      }
    } catch(e) {
      showToast("Network Connection error");
    }
  }

  async function attachMultipleSelected() {
    const checkboxes = document.querySelectorAll(".attach-checkbox:checked");
    if (checkboxes.length === 0) return;

    const ids = Array.from(checkboxes).map(cb => ({
      id: cb.getAttribute("data-id"),
      name: cb.getAttribute("data-name")
    }));

    const startIndex = blocks.length;
    let attachedNames = [];

    // Fetch and push all blocks
    for (const item of ids) {
      try {
        const res = await fetch(`/api/sections-crud?action=get&id=${item.id}`);
        const data = await res.json();
        if (data.success) {
          blocks.push({
            ...data.section,
            sectionId: item.id
          });
          attachedNames.push(item.name);
        }
      } catch (e) {
        console.error("Error attaching", item.id, e);
      }
    }

    if (attachedNames.length > 0) {
      renderBlocks();
      document.getElementById("attach-section-modal-overlay").classList.remove("active");
      showToast(`✓ Attached ${attachedNames.length} sections successfully`);

      // Scroll to the first added element and highlight all added elements
      setTimeout(() => {
        const firstCard = document.getElementById(`builder-block-${startIndex}`);
        if (firstCard) {
          firstCard.scrollIntoView({ behavior: "smooth", block: "center" });
        }

        for (let i = 0; i < attachedNames.length; i++) {
          const cardIdx = startIndex + i;
          const blockCard = document.getElementById(`builder-block-${cardIdx}`);
          if (blockCard) {
            blockCard.style.transition = "all 0.5s ease";
            blockCard.style.outline = "3px solid #4F46E5";
            blockCard.style.boxShadow = "0 0 20px rgba(79, 70, 229, 0.4)";
            setTimeout(() => {
              blockCard.style.outline = "";
              blockCard.style.boxShadow = "";
            }, 2500);
          }
        }
      }, 50);
    }
  }

  function previewSection(sectionId, name) {
    const overlay = document.getElementById("preview-overlay");
    const iframe = document.getElementById("preview-iframe");
    const title = document.getElementById("preview-section-title");

    if (overlay && iframe && title) {
      title.innerText = `Preview: ${name} (${sectionId})`;
      iframe.src = `/admin/sections/preview?id=${sectionId}`;
      overlay.classList.add("active");
    }
  }

  // Expose functions globally
  window.attachSingleSection = attachSingleSection;
  window.previewSection = previewSection;
  window.addNewBlock = addNewBlock;

  // Append new empty block record based on registry defaults
  function addNewBlock(type) {
    const config = BLOCK_REGISTRY.find(b => b.type === type);
    if (!config) return;
    
    // Deep clone defaults to prevent shared reference bugs!
    const blockData = JSON.parse(JSON.stringify(config.defaultValues));
    blocks.push(blockData);
    
    renderBlocks();
    showToast(`${config.name} added to stack!`);
  }

  // Reorder Block Up/Down
  window.moveBlock = function(index, direction) {
    const targetIdx = index + direction;
    if (targetIdx < 0 || targetIdx >= blocks.length) return;
    
    // Swap items
    const temp = blocks[index];
    blocks[index] = blocks[targetIdx];
    blocks[targetIdx] = temp;
    
    renderBlocks();
  }

  // Remove block
  window.deleteBlock = function(index) {
    window.customConfirm("Are you sure you want to delete this section block?", () => {
      blocks.splice(index, 1);
      renderBlocks();
      showToast("Block removed");
    });
  }

  // Synchronize inputs back to array state on change
  const ROOT_OBJECT = blocks;
  const updateUI = renderBlocks;

  function renderSubFieldsHTML(fields, parentObj, path = []) {
    let html = '';
    fields.forEach(field => {
      const currentPath = [...path, field.name];
      const pathStr = JSON.stringify(currentPath);
      const escPathStr = escHtml(pathStr);
      const pathId = currentPath.join('-');
      const val = parentObj[field.name] !== undefined ? parentObj[field.name] : (field.default !== undefined ? field.default : "");
      
      const isRequired = field.required ? '<span class="required">*</span>' : '';
      
      let inputFieldHtml = "";
      const inputId = `field-${pathId}`;
      const placeholder = field.placeholder || field.label || "";
      const helpText = field.helpText ? `<span class="field-help" style="font-size:0.75rem; color:var(--text-dim); display:block; margin-top:0.2rem;">${field.helpText}</span>` : '';
      
      // Validation attributes
      const validationAttr = `
        data-path='${escPathStr}'
        data-label='${escHtml(field.label)}'
        data-required='${field.required ? 'true' : 'false'}'
        data-validation='${JSON.stringify(field.validation || {})}'
      `;

      if (["text", "email", "tel", "url", "slug", "password", "hidden"].includes(field.type)) {
        inputFieldHtml = `<input type="${field.type}" id="${inputId}" value="${escHtml(val)}" oninput="syncPathValue('${escPathStr}', this.value)" placeholder="${escHtml(placeholder)}" ${field.required ? 'required' : ''} ${validationAttr} />`;
      } else if (field.type === "number") {
        const minAttr = field.validation?.min !== undefined ? `min="${field.validation.min}"` : '';
        const maxAttr = field.validation?.max !== undefined ? `max="${field.validation.max}"` : '';
        const stepAttr = field.validation?.step !== undefined ? `step="${field.validation.step}"` : '';
        inputFieldHtml = `<input type="number" id="${inputId}" value="${val}" ${minAttr} ${maxAttr} ${stepAttr} oninput="syncPathValue('${escPathStr}', parseFloat(this.value) || 0)" placeholder="${escHtml(placeholder)}" ${field.required ? 'required' : ''} ${validationAttr} />`;
      } else if (field.type === "range") {
        const minAttr = field.validation?.min !== undefined ? field.validation.min : 0;
        const maxAttr = field.validation?.max !== undefined ? field.validation.max : 100;
        const stepAttr = field.validation?.step !== undefined ? field.validation.step : 1;
        inputFieldHtml = `
          <div style="display:flex; align-items:center; gap:1rem;">
            <input type="range" id="${inputId}" min="${minAttr}" max="${maxAttr}" step="${stepAttr}" value="${val || minAttr}" oninput="syncPathValue('${escPathStr}', parseFloat(this.value) || 0); document.getElementById('val-disp-${pathId}').textContent = this.value" style="flex:1;" ${validationAttr} />
            <span id="val-disp-${pathId}" style="font-weight:600; font-size:0.85rem; min-width:30px; text-align:right;">${val || minAttr}</span>
          </div>
        `;
      } else if (field.type === "percentage") {
        inputFieldHtml = `
          <div style="display:flex; align-items:center; position:relative;">
            <input type="number" id="${inputId}" min="0" max="100" value="${val}" oninput="syncPathValue('${escPathStr}', parseFloat(this.value) || 0)" placeholder="0-100" style="padding-right:2rem;" ${validationAttr} />
            <span style="position:absolute; right:0.75rem; font-size:0.85rem; color:var(--text-dim); pointer-events:none;">%</span>
          </div>
        `;
      } else if (["textarea", "json", "css", "javascript", "code", "html", "markdown", "richtext"].includes(field.type)) {
        inputFieldHtml = `<textarea id="${inputId}" rows="4" class="form-textarea code-font" oninput="syncPathValue('${escPathStr}', this.value)" placeholder="${escHtml(placeholder)}" ${field.required ? 'required' : ''} ${validationAttr}>${val}</textarea>`;
      } else if (["checkbox", "toggle", "boolean"].includes(field.type)) {
        inputFieldHtml = `
          <div style="display:flex; align-items:center; gap:0.5rem; margin-top:0.25rem;">
            <input type="checkbox" id="${inputId}" ${val ? 'checked' : ''} onchange="syncPathValue('${escPathStr}', this.checked)" style="width:auto;" ${validationAttr} />
            <label for="${inputId}" style="font-weight:500; cursor:pointer; margin:0;">${field.label}</label>
          </div>
        `;
      } else if (field.type === "select") {
        const options = (field.options || []).map(opt => {
          const v = typeof opt === 'object' ? opt.value : opt;
          const l = typeof opt === 'object' ? opt.label : opt;
          return `<option value="${v}" ${val === v ? 'selected' : ''}>${escHtml(l)}</option>`;
        }).join('');
        inputFieldHtml = `<select id="${inputId}" onchange="syncPathValue('${escPathStr}', this.value)" ${validationAttr}>${options}</select>`;
      } else if (field.type === "multiselect") {
        const items = Array.isArray(val) ? val : [];
        const optionsHtml = (field.options || []).map(opt => {
          const v = typeof opt === 'object' ? opt.value : opt;
          const l = typeof opt === 'object' ? opt.label : opt;
          return `
            <label style="display:flex; align-items:center; gap:0.4rem; font-size:0.83rem; cursor:pointer;">
              <input type="checkbox" value="${v}" ${items.includes(v) ? 'checked' : ''} onchange="syncMultiselect('${escPathStr}', '${v}', this.checked)" style="width:auto;" />
              <span>${escHtml(l)}</span>
            </label>
          `;
        }).join('');
        inputFieldHtml = `
          <div class="multiselect-wrap" ${validationAttr} style="display:flex; flex-direction:column; gap:0.35rem; padding:0.5rem; border:1px solid var(--border-color); border-radius:6px; max-height:140px; overflow-y:auto; background:var(--bg-body);">
            ${optionsHtml || '<span style="font-size:0.75rem; color:var(--text-dim);">No options configured</span>'}
          </div>
        `;
      } else if (field.type === "radio") {
        const optionsHtml = (field.options || []).map((opt, oIdx) => {
          const v = typeof opt === 'object' ? opt.value : opt;
          const l = typeof opt === 'object' ? opt.label : opt;
          return `
            <label style="display:flex; align-items:center; gap:0.4rem; font-size:0.83rem; cursor:pointer;">
              <input type="radio" name="radio-${pathId}" value="${v}" ${val === v ? 'checked' : ''} onchange="syncPathValue('${escPathStr}', this.value)" style="width:auto;" />
              <span>${escHtml(l)}</span>
            </label>
          `;
