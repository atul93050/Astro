---
import AdminLayout from "../../layouts/admin/AdminLayout.astro";
import { getMenuLocations, getAllMenus } from "../../utils/menus";

export const prerender = false;

const locations = getMenuLocations();
const menus = getAllMenus();
---

<AdminLayout title="Menu Locations">

  <div class="page-header-flex">
    <div>
      <p class="page-sub">Assign a menu to each location slot. Header, Footer, Sidebar, and Mobile are driven entirely from here — no code changes needed.</p>
    </div>
    <button class="btn btn-primary" id="save-locations-btn">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
      Save Locations
    </button>
  </div>

  <div class="locations-grid">
    {Object.entries(locations).map(([key, loc]) => (
      <div class="location-card">
        <div class="location-info">
          <div class="location-icon">
            {key.includes('header') ? (
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="5" rx="1"></rect><rect x="3" y="10" width="18" height="11" rx="1"></rect></svg>
            ) : key.includes('footer') ? (
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="5" rx="1"></rect><rect x="3" y="3" width="18" height="6" rx="1"></rect></svg>
            ) : key.includes('mobile') ? (
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
            ) : (
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
            )}
          </div>
          <div>
            <h4 class="location-label">{loc.label}</h4>
            <p class="location-desc">{loc.description}</p>
            <code class="location-key">{key}</code>
          </div>
        </div>
        <div class="location-select-wrap">
          <select class="location-select" data-location={key}>
            <option value="">— Not assigned —</option>
            {menus.map(m => (
              <option value={m.slug} selected={loc.menuId === m.slug}>{m.name}</option>
            ))}
          </select>
          {loc.menuId && (
            <a href={`/admin/menu-editor?id=${loc.menuId}`} class="edit-assigned-link" title="Edit this menu">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
              Edit Menu
            </a>
          )}
        </div>
      </div>
    ))}
  </div>

  {menus.length === 0 && (
    <div class="info-banner">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
      No menus exist yet. <a href="/admin/menus">Create a menu first</a>, then come back to assign it here.
    </div>
  )}

  <div class="toast-notification" id="loc-toast"><div class="toast-content"><span id="loc-toast-msg"></span></div></div>

</AdminLayout>

<style is:global>
  .page-header-flex { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:2rem; gap:1rem; }
  .page-sub { color:var(--text-muted); font-size:0.88rem; margin-top:0.25rem; }
  .locations-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
  @media(max-width:900px) { .locations-grid { grid-template-columns:1fr; } }
  .location-card { background:var(--bg-surface); border:1px solid var(--border-color); border-radius:var(--radius-md); padding:1.25rem 1.5rem; display:flex; flex-direction:column; gap:1rem; }
  .location-info { display:flex; gap:0.85rem; align-items:flex-start; }
  .location-icon { width:36px; height:36px; background:var(--primary-light); color:var(--primary); border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .location-label { font-size:0.95rem; font-weight:700; color:var(--text-main); margin-bottom:0.15rem; }
  .location-desc { font-size:0.78rem; color:var(--text-dim); margin-bottom:0.35rem; }
  .location-key { font-family:monospace; font-size:0.72rem; color:var(--text-dim); background:rgba(156,163,175,0.07); padding:0.15rem 0.4rem; border-radius:4px; }
  .location-select-wrap { display:flex; align-items:center; gap:0.75rem; }
  .location-select { flex:1; }
  .edit-assigned-link { display:inline-flex; align-items:center; gap:0.3rem; font-size:0.78rem; color:var(--primary); text-decoration:none; white-space:nowrap; flex-shrink:0; }
  .edit-assigned-link:hover { text-decoration:underline; }
  .info-banner { display:flex; align-items:center; gap:0.75rem; padding:1rem 1.25rem; background:rgba(59,130,246,0.08); border:1px solid rgba(59,130,246,0.2); border-radius:var(--radius-sm); color:#93c5fd; font-size:0.88rem; margin-top:1.5rem; }
  .info-banner a { color:#60a5fa; text-decoration:underline; }
</style>

<script>
  function init() {
    const saveBtn = document.getElementById('save-locations-btn') as HTMLButtonElement;
    if (!saveBtn || saveBtn.dataset.init === 'true') return;
    saveBtn.dataset.init = 'true';

    saveBtn.addEventListener('click', async () => {
      saveBtn.disabled = true;
      saveBtn.textContent = 'Saving…';

      const selects = document.querySelectorAll<HTMLSelectElement>('.location-select');
      const payload: Record<string, string | null> = {};
      selects.forEach(s => { payload[s.dataset.location!] = s.value || null; });

      try {
        const res = await fetch('/api/menu-locations-crud', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();
        if (data.success) { showToast('Location assignments saved!'); setTimeout(() => location.reload(), 800); }
        else showToast(data.error || 'Save failed');
      } catch { showToast('Network error'); }
      finally { saveBtn.disabled = false; saveBtn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path></svg> Save Locations'; }
    });

    function showToast(msg: string) {
      const t = document.getElementById('loc-toast');
      const m = document.getElementById('loc-toast-msg');
      if (t && m) { m.textContent = msg; t.classList.add('active'); setTimeout(() => t.classList.remove('active'), 3000); }
    }
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:page-load', init);
  if (document.readyState !== 'loading') init();
</script>
