    if (downloadLink) {
      downloadLink.href = item.url;
      downloadLink.download = filename;
    }

    // Update Navigation buttons state
    const modalPrevBtn = document.getElementById("modal-prev-btn");
    const modalNextBtn = document.getElementById("modal-next-btn");
    if (modalPrevBtn && modalNextBtn && filteredMediaList.length > 0) {
      const idx = filteredMediaList.findIndex(m => m.url === item.url);
      modalPrevBtn.disabled = (idx <= 0);
      modalNextBtn.disabled = (idx >= filteredMediaList.length - 1 || idx === -1);
    }

    // Toggle Generate Thumbnails section
    const genContainer = document.getElementById("generate-variants-container");
    const genStatus = document.getElementById("variants-status-list");
    if (genContainer) {
      if (item.type === "image") {
        genContainer.style.display = "flex";
        if (item.variants && Object.keys(item.variants).length > 0) {
          if (genStatus) {
            genStatus.style.display = "flex";
            genStatus.innerHTML = `<strong style="display:block; margin-bottom:0.25rem;">Generated Formats:</strong>` + Object.entries(item.variants).map(([k, v]) => `<div>• ${k}: <a href="${v}" target="_blank" style="color:#6366F1; text-decoration:underline; word-break:break-all;">${v}</a></div>`).join('');
          }
        } else {
