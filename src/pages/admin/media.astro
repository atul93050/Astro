</style>

<script is:inline>
  let catalogMedia = [];
  let selectedAsset = null;
  let activeFolder = "all";
  let activeType = "all";
  let searchQuery = "";
  let bulkCheckedUrls = new Set();
  let currentPage = 1;
  let itemsPerPage = 10;
  let filteredMediaList = [];

  // Background remover state variables
  let originalRemoverImg = null;
  let currentRemoverData = null;

  function initMediaLibrary() {
    const grid = document.getElementById("main-media-grid");
    if (!grid || grid.dataset.listenerBound) return;
    grid.dataset.listenerBound = "true";

    loadMediaCatalog();
    setupDropzone();
    setupDrawerHandlers();
    setupFilters();
    initReplaceMedia();
    initBackgroundRemover();
  }

  // Set up search and filter inputs
  function setupFilters() {
    const searchInput = document.getElementById("search-input");
    const typeFilter = document.getElementById("type-filter");
    const folderFilter = document.getElementById("folder-filter");
    const itemsPerPageInput = document.getElementById("items-per-page");

    if (searchInput) {
      searchInput.addEventListener("input", (e) => {
        searchQuery = e.target.value.trim();
        currentPage = 1;
        filterAndRenderMedia();
      });
    }

    if (typeFilter) {
      typeFilter.addEventListener("change", (e) => {
        activeType = e.target.value;
        currentPage = 1;
        filterAndRenderMedia();
      });
    }

    if (folderFilter) {
      folderFilter.addEventListener("change", (e) => {
        activeFolder = e.target.value;
        currentPage = 1;
        filterAndRenderMedia();
      });
    }

    if (itemsPerPageInput) {
      itemsPerPageInput.addEventListener("input", (e) => {
        const val = parseInt(e.target.value, 10);
        if (!isNaN(val) && val > 0) {
          itemsPerPage = val;
          currentPage = 1;
          filterAndRenderMedia();
        }
      });
    }

    // Pagination buttons click handlers
    const prevBtn = document.getElementById("prev-page-btn");
    const nextBtn = document.getElementById("next-page-btn");
    if (prevBtn) {
      prevBtn.addEventListener("click", () => {
        if (currentPage > 1) {
          currentPage--;
          filterAndRenderMedia();
        }
      });
    }
    if (nextBtn) {
      nextBtn.addEventListener("click", () => {
        const totalPages = Math.ceil(getFilteredCount() / itemsPerPage) || 1;
        if (currentPage < totalPages) {
          currentPage++;
          filterAndRenderMedia();
        }
      });
    }

    // Folder Creation click handler
    const createFolderBtn = document.getElementById("create-folder-btn");
    const newFolderInput = document.getElementById("new-folder-name");
    if (createFolderBtn && newFolderInput) {
      createFolderBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        const name = newFolderInput.value.trim().replace(/^\/+|\/+$/g, "");
        if (!name) return;
        
        const folderPath = "/" + name;
        
        // Add to selectors
        const filters = [
          document.getElementById("folder-filter"),
          document.getElementById("bulk-move-folder"),
          document.getElementById("asset-folder")
        ];

        filters.forEach(sel => {
          if (sel && !sel.querySelector(`option[value="${folderPath}"]`)) {
            const opt = document.createElement("option");
            opt.value = folderPath;
            opt.innerText = folderPath;
            sel.appendChild(opt);
          }
        });

        newFolderInput.value = "";
        showToast(`Virtual folder "${folderPath}" created! Select items and move them.`);
      });
    }
  }

  // Helper function to calculate current active filtered items count
  function getFilteredCount() {
    const filtered = catalogMedia.filter(item => {
      if (activeFolder !== "all") {
        const itemFolder = item.folder || "";
        if (itemFolder !== activeFolder) return false;
      }
      if (activeType !== "all") {
        if (item.type !== activeType) return false;
      }
      if (searchQuery) {
        const query = searchQuery.toLowerCase();
        const titleMatch = (item.title || "").toLowerCase().includes(query);
        const altMatch = (item.alt || "").toLowerCase().includes(query);
        const urlMatch = (item.url || "").toLowerCase().includes(query);
        if (!titleMatch && !altMatch && !urlMatch) return false;
      }
      return true;
    });
    return filtered.length;
  }

  // Load Media from Endpoint API
  async function loadMediaCatalog() {
    try {
      const res = await fetch("/api/media-crud");
      const data = await res.json();

      if (data.success) {
        catalogMedia = data.media || [];
        rebuildFolderSelectors();
        filterAndRenderMedia();
        
        // Restore selection if matching
        if (selectedAsset) {
          const matched = catalogMedia.find(m => m.url === selectedAsset.url);
          if (matched) {
            selectAssetItem(matched);
          } else {
            closeDrawer();
          }
        }
      }
    } catch (e) {
      console.error("Failed to load catalog:", e);
    }
  }

  function rebuildFolderSelectors() {
    const folders = new Set();
    catalogMedia.forEach(item => {
      if (item.folder) folders.add(item.folder);
    });

    const folderFilter = document.getElementById("folder-filter");
    const bulkMoveFolder = document.getElementById("bulk-move-folder");
    const assetFolder = document.getElementById("asset-folder");

    const currentFilterVal = folderFilter ? folderFilter.value : "all";

    if (folderFilter) {
      folderFilter.innerHTML = `
        <option value="all">All Folders</option>
        <option value="">Root (/)</option>
        ${Array.from(folders).sort().map(f => `<option value="${f}">${f}</option>`).join('')}
      `;
      folderFilter.value = currentFilterVal;
    }

    if (bulkMoveFolder) {
      bulkMoveFolder.innerHTML = `
        <option value="">Move to Folder...</option>
        <option value="">Root (/)</option>
        ${Array.from(folders).sort().map(f => `<option value="${f}">${f}</option>`).join('')}
      `;
    }

    if (assetFolder) {
      const currentAssetFolderVal = selectedAsset ? (selectedAsset.folder || "") : "";
      assetFolder.innerHTML = `
        <option value="">Root (/)</option>
        ${Array.from(folders).sort().map(f => `<option value="${f}">${f}</option>`).join('')}
      `;
      assetFolder.value = currentAssetFolderVal;
    }
  }

  function filterAndRenderMedia() {
    const grid = document.getElementById("main-media-grid");
    const emptyMsg = document.getElementById("grid-empty-msg");
    const counter = document.getElementById("assets-count");
    if (!grid) return;

    // Remove all old media cards
    document.querySelectorAll(".media-card").forEach(el => el.remove());

    const filtered = catalogMedia.filter(item => {
      // 1. Folder
      if (activeFolder !== "all") {
        const itemFolder = item.folder || "";
        if (itemFolder !== activeFolder) return false;
      }
      // 2. Type
      if (activeType !== "all") {
        if (item.type !== activeType) return false;
      }
      // 3. Search query
      if (searchQuery) {
        const query = searchQuery.toLowerCase();
        const titleMatch = (item.title || "").toLowerCase().includes(query);
        const altMatch = (item.alt || "").toLowerCase().includes(query);
        const urlMatch = (item.url || "").toLowerCase().includes(query);
        if (!titleMatch && !altMatch && !urlMatch) return false;
      }
      return true;
    });

    filteredMediaList = filtered; // Keep track of the filtered list globally

    if (counter) counter.innerText = `${filtered.length} items`;

    // Pagination calculations
    const totalPages = Math.ceil(filtered.length / itemsPerPage) || 1;
    if (currentPage > totalPages) {
      currentPage = totalPages;
    }

    const paginationContainer = document.getElementById("media-pagination");
    const prevBtn = document.getElementById("prev-page-btn");
    const nextBtn = document.getElementById("next-page-btn");
    const pageInfo = document.getElementById("page-info");

    if (paginationContainer) {
      paginationContainer.style.display = filtered.length > 0 ? "flex" : "none";
    }
    if (prevBtn) prevBtn.disabled = currentPage <= 1;
    if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
    if (pageInfo) pageInfo.innerText = `Page ${currentPage} of ${totalPages}`;

    if (filtered.length === 0) {
      if (emptyMsg) emptyMsg.style.display = "block";
      updateBulkActionBar();
      return;
    }
    if (emptyMsg) emptyMsg.style.display = "none";

    const startIndex = (currentPage - 1) * itemsPerPage;
    const endIndex = startIndex + itemsPerPage;
    const paginatedItems = filtered.slice(startIndex, endIndex);

    paginatedItems.forEach(item => {
      const card = document.createElement("div");
      card.className = "media-card";
      card.setAttribute("data-url", item.url);
      
      let mediaPreviewHtml = "";
      if (item.type === "image" || item.type === "svg") {
        mediaPreviewHtml = `<img src="${item.url}" alt="${item.alt || ''}" style="width:100%; height:100%; object-fit:cover;" />`;
      } else {
        let icon = "📄";
        if (item.type === "video") icon = "🎥";
        if (item.type === "pdf") icon = "📕";
        mediaPreviewHtml = `
          <div style="width:100%; height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; background:#1e293b; color:#9ca3af; padding:0.5rem; text-align:center;">
            <span style="font-size:2rem; margin-bottom:0.25rem;">${icon}</span>
            <span style="font-size:0.68rem; font-weight:700; word-break:break-all; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">${item.title}</span>
          </div>
        `;
      }

      card.innerHTML = `
        ${mediaPreviewHtml}
        <input type="checkbox" class="media-bulk-checkbox" data-url="${item.url}" style="position:absolute; top:8px; left:8px; z-index:5; width:18px; height:18px; cursor:pointer;" ${bulkCheckedUrls.has(item.url) ? 'checked' : ''} />
      `;

      card.addEventListener("click", (e) => {
        if (e.target.classList.contains("media-bulk-checkbox")) {
          return; // handled by checkbox handler
        }
        selectAssetItem(item);
      });

      const checkbox = card.querySelector(".media-bulk-checkbox");
      if (checkbox) {
        checkbox.addEventListener("click", (e) => {
          e.stopPropagation();
        });
        checkbox.addEventListener("change", (e) => {
          if (e.target.checked) {
            bulkCheckedUrls.add(item.url);
          } else {
            bulkCheckedUrls.delete(item.url);
          }
          updateBulkActionBar();
          syncSelectAllCheckboxState();
        });
      }

      if (selectedAsset && selectedAsset.url === item.url) {
        card.classList.add("active-selected");
      }

      grid.appendChild(card);
    });

    updateBulkActionBar();
    syncSelectAllCheckboxState();
  }

  function updateBulkActionBar() {
    const bar = document.getElementById("bulk-actions-bar");
    const label = document.getElementById("bulk-selected-count");
    if (!bar) return;

    if (bulkCheckedUrls.size > 0) {
      bar.style.display = "flex";
      if (label) label.innerText = `${bulkCheckedUrls.size} items selected`;
    } else {
      bar.style.display = "none";
    }
  }

  function syncSelectAllCheckboxState() {
    const selectAllCheckbox = document.getElementById("select-all-media");
    if (!selectAllCheckbox) return;

    const visibleCheckboxes = document.querySelectorAll(".media-bulk-checkbox");
    if (visibleCheckboxes.length === 0) {
      selectAllCheckbox.checked = false;
      selectAllCheckbox.disabled = true;
      return;
    }

    selectAllCheckbox.disabled = false;
    let allChecked = true;
    visibleCheckboxes.forEach(cb => {
      if (!cb.checked) allChecked = false;
    });
    selectAllCheckbox.checked = allChecked;
  }

  // Get ratio recommendation
  function getAspectRecommendation(width, height) {
    if (!width || !height) return { ratio: "N/A", text: "Standard file" };
    const gcd = (a, b) => b ? gcd(b, a % b) : a;
    const divisor = gcd(width, height);
    const rWidth = width / divisor;
    const rHeight = height / divisor;
    let ratio = `${rWidth}:${rHeight}`;
    
    const decimal = width / height;
    let text = "General image size";
    
    if (Math.abs(decimal - 1.777) < 0.05) {
      ratio = "16:9";
      text = "Recommended for Hero Banner / Landscape Slider";
    } else if (Math.abs(decimal - 1.333) < 0.05) {
      ratio = "4:3";
      text = "Perfect for Featured Article Card / Grid Thumbnail";
    } else if (Math.abs(decimal - 1.0) < 0.05) {
      ratio = "1:1";
      text = "Perfect for User Avatar / Profile Image / Icon";
    } else if (Math.abs(decimal - 0.75) < 0.05) {
      ratio = "3:4";
      text = "Portrait aspect - Good for profile lists";
    } else if (Math.abs(decimal - 0.562) < 0.05) {
      ratio = "9:16";
      text = "Mobile aspect - Good for stories / vertical layout";
    }
    
    return { ratio, text };
  }

  // Dominant color extractor
  function extractDominantColors(imgEl, callback) {
    const canvas = document.createElement("canvas");
    const ctx = canvas.getContext("2d");
    canvas.width = 50;
    canvas.height = 50;
    
    const tempImg = new Image();
    tempImg.crossOrigin = "Anonymous";
    tempImg.onload = () => {
      try {
        ctx.drawImage(tempImg, 0, 0, 50, 50);
        const imgData = ctx.getImageData(0, 0, 50, 50).data;
        
        const colorMap = {};
        for (let i = 0; i < imgData.length; i += 4) {
          if (imgData[i+3] < 128) continue; // skip transparent pixels
          
          const r = Math.round(imgData[i] / 24) * 24;
          const g = Math.round(imgData[i+1] / 24) * 24;
          const b = Math.round(imgData[i+2] / 24) * 24;
          const hex = rgbToHex(r, g, b);
          colorMap[hex] = (colorMap[hex] || 0) + 1;
        }
        
        const sorted = Object.entries(colorMap)
          .filter(([color]) => color !== "#ffffff" && color !== "#000000") // filter out pure white/black
          .sort((a, b) => b[1] - a[1])
          .slice(0, 6)
          .map(([color]) => color);
        
        callback(sorted);
      } catch (err) {
        console.warn("Color extraction skipped: ", err);
        callback([]);
      }
    };
    tempImg.src = imgEl.src + (imgEl.src.indexOf('?') > -1 ? '&' : '?') + 't=' + Date.now();
  }
  
  function rgbToHex(r, g, b) {
    const toHex = c => {
      const hex = Math.max(0, Math.min(255, c)).toString(16);
      return hex.length === 1 ? "0" + hex : hex;
    };
    return "#" + toHex(r) + toHex(g) + toHex(b);
  }

  // Active Asset Selection in modal
  function selectAssetItem(item) {
    selectedAsset = item;
    
    // Highlight Card
    document.querySelectorAll(".media-card").forEach(el => {
      el.classList.remove("active-selected");
      if (el.getAttribute("data-url") === item.url) {
        el.classList.add("active-selected");
      }
    });

    // Populate Sidebar Details Panel & open modal
    const content = document.getElementById("drawer-content");
    const drawer = document.getElementById("asset-drawer");
    
    if (drawer) drawer.classList.add("modal-open");
    if (content) content.style.display = "flex";
    
    // Hide BG Remover workspace when selecting a new asset
    document.getElementById("bg-remover-workspace").style.display = "none";
    document.getElementById("preview-image-container").style.display = "flex";
    
    const previewImg = document.getElementById("drawer-preview-img");
    const docIcon = document.getElementById("document-preview-icon");
    const docTitle = document.getElementById("preview-file-title");
    const docSymbol = document.getElementById("preview-file-icon");
    
    if (item.type === "image" || item.type === "svg") {
      if (previewImg) {
        previewImg.src = item.url;
        previewImg.style.display = "block";
      }
      if (docIcon) docIcon.style.display = "none";
    } else {
      if (previewImg) previewImg.style.display = "none";
      if (docIcon) {
        docIcon.style.display = "flex";
        if (docTitle) docTitle.innerText = item.title;
        if (docSymbol) {
          let symbol = "📄";
          if (item.type === "video") symbol = "🎥";
          if (item.type === "pdf") symbol = "📕";
          if (item.type === "audio") symbol = "🎵";
          docSymbol.innerText = symbol;
        }
      }
    }

    // Fill metadata labels
    const filename = item.url.split("/").pop();
    document.getElementById("meta-filename").innerText = filename;
    document.getElementById("meta-filesize").innerText = formatBytes(item.size);
    document.getElementById("meta-uploadedat").innerText = new Date(item.uploadedAt).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' });
    document.getElementById("meta-uploadedby").innerText = item.uploadedBy || "admin";
    document.getElementById("meta-filetype").innerText = item.mimeType || (item.type === "image" ? "image/png" : "application/octet-stream");

    // Dimensions row
    const dimRow = document.getElementById("meta-dimensions-row");
    const dimVal = document.getElementById("meta-dimensions");
    const dimBadge = document.getElementById("dimension-badge");
    const aspectBadge = document.getElementById("aspect-ratio-badge");
    
    if (item.type === "image" && item.dimensions) {
      if (dimRow) dimRow.style.display = "flex";
      if (dimVal) dimVal.innerText = `${item.dimensions.width} by ${item.dimensions.height} pixels`;
      if (dimBadge) {
        dimBadge.style.display = "inline-flex";
        dimBadge.innerText = `Dimensions: ${item.dimensions.width}x${item.dimensions.height}`;
      }
      
      const rec = getAspectRecommendation(item.dimensions.width, item.dimensions.height);
      if (aspectBadge) {
        aspectBadge.style.display = "inline-flex";
        aspectBadge.innerText = `Aspect Ratio: ${rec.ratio}`;
        aspectBadge.title = rec.text;
      }
    } else {
      if (dimRow) dimRow.style.display = "none";
      if (dimBadge) dimBadge.style.display = "none";
      if (aspectBadge) aspectBadge.style.display = "none";
    }

    // Toggle BG Remover button
    const bgRemoverBtn = document.getElementById("bg-remover-btn");
    if (bgRemoverBtn) {
      bgRemoverBtn.style.display = (item.type === "image" && item.mimeType !== "image/svg+xml") ? "inline-flex" : "none";
    }

    // Fill Form inputs
    document.getElementById("asset-title").value = item.title || "";
    document.getElementById("asset-alt").value = item.alt || "";
    document.getElementById("asset-caption").value = item.caption || "";
    document.getElementById("asset-description").value = item.description || "";
    document.getElementById("asset-tags").value = (item.tags || []).join(", ");
    document.getElementById("asset-url-readonly").value = window.location.origin + item.url;
    
    const assetFolderSelect = document.getElementById("asset-folder");
