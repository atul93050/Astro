---
import AdminLayout from "../../layouts/admin/AdminLayout.astro";

export const prerender = false;
---

<AdminLayout title="Media Library">
  
  <div class="media-header">
    <div class="header-text">
      <p class="subtitle">Upload, view, and catalog static assets like images or banners directly to local storage.</p>
    </div>
    
    <!-- Upload Area Action -->
    <div class="upload-dropzone" id="media-dropzone">
      <form id="direct-upload-form" onsubmit="return false;">
        <input type="file" id="direct-upload-file" accept="image/*" style="display:none;" multiple />
        <div class="dropzone-text">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:0.5rem; opacity:0.7;">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
          <p>Drag & Drop or <span class="highlight-trigger" id="click-upload-trigger">Browse files</span></p>
          <span>Maximum size limit: 5MB</span>
        </div>
      </form>
    </div>
  </div>

  <div class="media-library-grid-layout">
    
    <!-- Main Media Grid display -->
    <div class="media-grid-container">
      <div class="media-filters-row" style="flex-wrap:wrap; gap:1rem;">
        <div style="display:inline-flex; align-items:center; gap:0.65rem;">
          <input type="checkbox" id="select-all-media" title="Select All Assets" style="width:18px; height:18px; cursor:pointer; margin:0;" />
          <h3>Media Library Assets</h3>
          <span class="assets-count-badge" id="assets-count">0 items</span>
        </div>
        
        <!-- Interactive Search & Filtering Controls Toolbar -->
        <div style="display:flex; gap:0.5rem; align-items:center; flex-wrap:wrap;">
          <input type="text" id="search-input" placeholder="Search files..." style="padding: 0.35rem 0.65rem; border-radius: 4px; border: 1px solid var(--border-color) || rgba(255,255,255,0.08); font-size: 0.8rem; max-width: 140px; background: var(--input-bg) || #0f172a; color: var(--text-main);" />
          
          <select id="type-filter" style="padding: 0.35rem 0.65rem; border-radius: 4px; border: 1px solid var(--border-color) || rgba(255,255,255,0.08); font-size: 0.8rem; background: var(--input-bg) || #0f172a; color: var(--text-main);">
            <option value="all">All Types</option>
            <option value="image">Images</option>
            <option value="svg">SVGs</option>
            <option value="pdf">PDFs</option>
            <option value="document">Documents</option>
            <option value="video">Videos</option>
          </select>
          
          <select id="folder-filter" style="padding: 0.35rem 0.65rem; border-radius: 4px; border: 1px solid var(--border-color) || rgba(255,255,255,0.08); font-size: 0.8rem; background: var(--input-bg) || #0f172a; color: var(--text-main);">
            <option value="all">All Folders</option>
            <option value="">Root (/)</option>
          </select>

          <!-- New Folder creation -->
          <div style="display:flex; gap:0.2rem; align-items:center;">
            <input type="text" id="new-folder-name" placeholder="New folder..." style="padding: 0.35rem 0.65rem; border-radius: 4px; border: 1px solid var(--border-color) || rgba(255,255,255,0.08); font-size: 0.8rem; max-width: 100px; background: var(--input-bg) || #0f172a; color: var(--text-main);" />
            <button type="button" class="btn btn-outline btn-sm" id="create-folder-btn" style="padding:0.35rem 0.5rem; font-size:0.8rem; height:29px;">+</button>
          </div>
        </div>
      </div>
      
      <!-- Bulk Actions Control Bar -->
      <div id="bulk-actions-bar" style="display:none; justify-content:space-between; align-items:center; background:rgba(99, 102, 241, 0.08); border: 1px solid var(--primary) || rgba(99,102,241,0.5); padding:0.5rem 0.85rem; border-radius:6px; margin-bottom:1rem; gap:1rem;">
        <span style="font-size:0.82rem; font-weight:600;" id="bulk-selected-count">0 items selected</span>
        <div style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap;">
          <select id="bulk-move-folder" style="padding:0.3rem 0.45rem; font-size:0.78rem; border-radius:4px; border:1px solid var(--border-color) || rgba(255,255,255,0.08); background:var(--input-bg) || #0f172a; color:var(--text-main);">
            <option value="">Move to Folder...</option>
            <option value="">Root (/)</option>
          </select>
          <button type="button" class="btn btn-outline btn-sm" id="bulk-move-btn" style="padding:0.3rem 0.55rem; font-size:0.78rem;">Move</button>
          <button type="button" class="btn btn-danger btn-sm" id="bulk-delete-btn" style="padding:0.3rem 0.55rem; font-size:0.78rem; background:#EF4444; border:none; color:white; font-weight:bold;">Delete</button>
        </div>
      </div>

      <div class="media-grid" id="main-media-grid">
        <!-- JS will populate media catalog cards -->
        <div class="media-grid-empty" id="grid-empty-msg">
          <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:1rem; opacity:0.4;">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
            <circle cx="8.5" cy="8.5" r="1.5"></circle>
            <polyline points="21 15 16 10 5 21"></polyline>
          </svg>
          <h4>Your Media Library is empty</h4>
          <p>Click Browse above to upload static images and resources.</p>
        </div>
      </div>
    </div>

    <!-- Asset Detail Panel Drawer (Sidebars) -->
    <div class="asset-details-drawer" id="asset-drawer">
      <div class="drawer-header">
        <h4>Attachment Details</h4>
        <button type="button" class="btn-icon-sm" id="close-drawer-btn" style="border:none;">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      
      <div class="drawer-body" id="drawer-content" style="display:none;">
        <div class="drawer-preview-wrap">
          <img src="" id="drawer-preview-img" alt="Preview" />
        </div>
        
        <div class="drawer-meta-info">
          <div class="meta-label-value">
            <span class="label">Filename:</span>
            <span class="value" id="meta-filename">image.png</span>
          </div>
          <div class="meta-label-value">
            <span class="label">File size:</span>
            <span class="value" id="meta-filesize">24 KB</span>
          </div>
          <div class="meta-label-value">
            <span class="label">Uploaded at:</span>
            <span class="value" id="meta-uploadedat">2026-06-01</span>
          </div>
        </div>

        <form id="asset-meta-form" onsubmit="return false;" style="margin-top:1.25rem; display:flex; flex-direction:column; gap:1rem;">
          <div class="form-group">
            <label for="asset-title">Attachment Title</label>
            <input type="text" id="asset-title" required />
          </div>
          
          <div class="form-group">
            <label for="asset-alt">Alt Description Text</label>
            <input type="text" id="asset-alt" placeholder="Description for screenreaders" />
          </div>

          <div class="form-group">
            <label for="asset-caption">Caption</label>
            <textarea id="asset-caption" rows="2"></textarea>
          </div>

          <div class="form-group">
            <label for="asset-folder">Virtual Folder Location</label>
            <select id="asset-folder" style="width:100%; border:1px solid var(--border-color); padding:0.5rem; border-radius:4px; background:var(--input-bg); color:var(--text-main);">
              <option value="">Root (/)</option>
            </select>
          </div>

          <div class="form-group">
            <label>Physical Asset URL</label>
            <div class="input-picker-wrap">
              <input type="text" id="asset-url-readonly" readonly style="font-family:monospace; font-size:0.78rem; opacity:0.85;" />
              <button type="button" class="btn btn-outline btn-sm" id="copy-url-btn">Copy</button>
            </div>
          </div>

          <!-- Dynamic Real-time Media Usage Scan List -->
          <div style="border-top:1px solid var(--border-color) || rgba(255,255,255,0.08); padding-top:1rem; margin-top:1rem;">
            <h5 style="font-size:0.8rem; font-weight:700; text-transform:uppercase; color:var(--text-muted); margin-bottom:0.5rem;">Page Usage Reference</h5>
            <div id="media-usage-list" style="display:flex; flex-direction:column; gap:0.4rem; max-height: 150px; overflow-y: auto;">
              <span style="font-size:0.78rem; color:var(--text-dim);">No active page references found on disk.</span>
            </div>
          </div>

          <div class="drawer-footer-actions">
            <button type="button" class="btn btn-primary btn-sm" id="save-asset-meta-btn">Save Metadata</button>
            <button type="button" class="btn btn-danger btn-sm btn-outline" id="delete-asset-btn" style="background-color:rgba(239, 68, 68, 0.08); border-color:var(--color-error); color:var(--color-error);">
              Delete Permanently
            </button>
          </div>
        </form>
      </div>
      
      <div class="drawer-fallback" id="drawer-fallback-msg">
        <p>Select any image from the media grid to configure its metadata and properties or grab its direct URL.</p>
      </div>
    </div>

  </div>

  <!-- Notification Banner -->
  <div class="toast-notification" id="toast-notify">
    <div class="toast-content">
      <span class="toast-message" id="toast-message">Asset updated!</span>
    </div>
  </div>

</AdminLayout>

<style is:global>
  .media-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .subtitle {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-top: 0.25rem;
  }

  /* Upload Dropzone Drag/Drop Box */
  .upload-dropzone {
    flex: 1;
    min-width: 320px;
    max-width: 480px;
    background: var(--bg-surface);
    border: 2px dashed var(--input-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-align: center;
    transition: var(--transition);
    cursor: pointer;
    box-shadow: 0 4px 12px var(--color-shadow);
  }
  .upload-dropzone:hover, .upload-dropzone.drag-active {
    border-color: var(--primary);
    background: var(--primary-light);
  }
  .dropzone-text p {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-main);
  }
  .highlight-trigger {
    color: var(--primary);
    text-decoration: underline;
  }
  .dropzone-text span {
    display: block;
    font-size: 0.72rem;
    color: var(--text-dim);
    margin-top: 0.25rem;
  }

  /* Grid layouts */
  .media-library-grid-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 1.5rem;
    align-items: start;
  }
  @media (max-width: 960px) {
    .media-library-grid-layout {
      grid-template-columns: 1fr;
    }
  }

  .media-grid-container {
    background: var(--bg-surface);
    border: 1px solid var(--bg-surface-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: 0 4px 15px var(--color-shadow);
    backdrop-filter: blur(10px);
    min-width: 0;
  }
  .media-filters-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.75rem;
  }
  .media-filters-row h3 {
    font-size: 1.05rem;
    font-weight: 700;
  }
  .assets-count-badge {
    padding: 0.25rem 0.65rem;
    background: rgba(156, 163, 175, 0.08);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 1rem;
    min-height: 250px;
  }
  .media-grid-empty {
    grid-column: span 12;
    text-align: center;
    padding: 5rem 2rem;
    color: var(--text-dim);
  }
  .media-grid-empty h4 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }
  .media-grid-empty p {
    font-size: 0.82rem;
  }

  /* Grid item card */
  .media-card {
    aspect-ratio: 1;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 2px solid transparent;
    cursor: pointer;
    position: relative;
    background: var(--bg-surface-solid);
    box-shadow: 0 2px 8px var(--color-shadow);
    transition: var(--transition);
  }
  .media-card:hover {
    transform: scale(1.04);
    border-color: var(--primary);
  }
  .media-card.active-selected {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.2);
  }
  .media-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Detail Drawer Sidebars Panel */
  .asset-details-drawer {
    background: var(--bg-surface);
    border: 1px solid var(--bg-surface-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 15px var(--color-shadow);
    backdrop-filter: blur(10px);
    overflow: hidden;
    position: sticky;
    top: 1.5rem;
  }
  .drawer-header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--bg-surface-border);
    background: rgba(156, 163, 175, 0.02);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .drawer-header h4 {
    font-size: 0.95rem;
    font-weight: 700;
  }
  .drawer-body {
    padding: 1.25rem;
  }
  .drawer-fallback {
    padding: 3rem 1.5rem;
    text-align: center;
    color: var(--text-dim);
    font-size: 0.82rem;
    line-height: 1.5;
  }

  /* Preview asset */
  .drawer-preview-wrap {
    width: 100%;
    aspect-ratio: 16/10;
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg-base);
    border: 1px solid var(--border-color);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .drawer-preview-wrap img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .drawer-meta-info {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .meta-label-value {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
  }
  .meta-label-value .label {
    color: var(--text-dim);
    font-weight: 600;
  }
  .meta-label-value .value {
    color: var(--text-muted);
    font-weight: 500;
    word-break: break-all;
    max-width: 70%;
  }

  .input-picker-wrap {
    display: flex;
    gap: 0.4rem;
  }
  .input-picker-wrap input {
    flex: 1;
  }

  .drawer-footer-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    padding-top: 1rem;
  }

  /* Toast Notification */
  .toast-notification {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: var(--bg-surface-solid);
    border-left: 4px solid var(--primary);
    border-top: 1px solid var(--bg-surface-border);
    border-bottom: 1px solid var(--bg-surface-border);
    border-right: 1px solid var(--bg-surface-border);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-sm);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35);
    z-index: 1100;
    transform: translateY(150%);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(8px);
  }
  .toast-notification.active {
    transform: translateY(0);
  }
  .toast-content {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-main);
  }
</style>

<script is:inline>
  let catalogMedia = [];
  let selectedAsset = null;
  let activeFolder = "all";
  let activeType = "all";
  let searchQuery = "";
  let bulkCheckedUrls = new Set();

  function initMediaLibrary() {
    const grid = document.getElementById("main-media-grid");
    if (!grid || grid.dataset.listenerBound) return;
    grid.dataset.listenerBound = "true";

    loadMediaCatalog();
    setupDropzone();
    setupDrawerHandlers();
    setupFilters();
  }

  // Set up search and filter inputs
  function setupFilters() {
    const searchInput = document.getElementById("search-input");
    const typeFilter = document.getElementById("type-filter");
    const folderFilter = document.getElementById("folder-filter");

    if (searchInput) {
      searchInput.addEventListener("input", (e) => {
        searchQuery = e.target.value.trim();
        filterAndRenderMedia();
      });
    }

    if (typeFilter) {
      typeFilter.addEventListener("change", (e) => {
        activeType = e.target.value;
        filterAndRenderMedia();
      });
    }

    if (folderFilter) {
      folderFilter.addEventListener("change", (e) => {
        activeFolder = e.target.value;
        filterAndRenderMedia();
      });
    }

    // Folder Creation click handler
    const createFolderBtn = document.getElementById("create-folder-btn");
    const newFolderInput = document.getElementById("new-folder-name");
    if (createFolderBtn && newFolderInput) {
      createFolderBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        const name = newFolderInput.value.trim().replace(/^\/+|\/+$/g, "");
        if (!name) return;
        
        const folderPath = "/" + name;
        
        // Add to selectors
        const filters = [
          document.getElementById("folder-filter"),
          document.getElementById("bulk-move-folder"),
          document.getElementById("asset-folder")
        ];

        filters.forEach(sel => {
          if (sel && !sel.querySelector(`option[value="${folderPath}"]`)) {
            const opt = document.createElement("option");
            opt.value = folderPath;
            opt.innerText = folderPath;
            sel.appendChild(opt);
          }
        });

        newFolderInput.value = "";
        showToast(`Virtual folder "${folderPath}" created! Select items and move them.`);
      });
    }
  }

  // Load Media from Endpoint API
  async function loadMediaCatalog() {
    try {
      const res = await fetch("/api/media-crud");
      const data = await res.json();

      if (data.success) {
        catalogMedia = data.media || [];
        rebuildFolderSelectors();
        filterAndRenderMedia();
        
        // Restore selection if matching
        if (selectedAsset) {
          const matched = catalogMedia.find(m => m.url === selectedAsset.url);
          if (matched) {
            selectAssetItem(matched);
          } else {
            closeDrawer();
          }
        }
      }
    } catch (e) {
      console.error("Failed to load catalog:", e);
    }
  }

  function rebuildFolderSelectors() {
    const folders = new Set();
    catalogMedia.forEach(item => {
      if (item.folder) folders.add(item.folder);
    });

    const folderFilter = document.getElementById("folder-filter");
    const bulkMoveFolder = document.getElementById("bulk-move-folder");
    const assetFolder = document.getElementById("asset-folder");

    const currentFilterVal = folderFilter ? folderFilter.value : "all";

    if (folderFilter) {
      folderFilter.innerHTML = `
        <option value="all">All Folders</option>
        <option value="">Root (/)</option>
        ${Array.from(folders).sort().map(f => `<option value="${f}">${f}</option>`).join('')}
      `;
      folderFilter.value = currentFilterVal;
    }

    if (bulkMoveFolder) {
      bulkMoveFolder.innerHTML = `
        <option value="">Move to Folder...</option>
        <option value="">Root (/)</option>
        ${Array.from(folders).sort().map(f => `<option value="${f}">${f}</option>`).join('')}
      `;
    }

    if (assetFolder) {
      const currentAssetFolderVal = selectedAsset ? (selectedAsset.folder || "") : "";
      assetFolder.innerHTML = `
        <option value="">Root (/)</option>
        ${Array.from(folders).sort().map(f => `<option value="${f}">${f}</option>`).join('')}
      `;
      assetFolder.value = currentAssetFolderVal;
    }
  }

  function filterAndRenderMedia() {
    const grid = document.getElementById("main-media-grid");
    const emptyMsg = document.getElementById("grid-empty-msg");
    const counter = document.getElementById("assets-count");
    if (!grid) return;

    // Remove all old media cards
    document.querySelectorAll(".media-card").forEach(el => el.remove());

    const filtered = catalogMedia.filter(item => {
      // 1. Folder
      if (activeFolder !== "all") {
        const itemFolder = item.folder || "";
        if (itemFolder !== activeFolder) return false;
      }
      // 2. Type
      if (activeType !== "all") {
        if (item.type !== activeType) return false;
      }
      // 3. Search query
      if (searchQuery) {
        const query = searchQuery.toLowerCase();
        const titleMatch = (item.title || "").toLowerCase().includes(query);
        const altMatch = (item.alt || "").toLowerCase().includes(query);
        const urlMatch = (item.url || "").toLowerCase().includes(query);
        if (!titleMatch && !altMatch && !urlMatch) return false;
      }
      return true;
    });

    if (counter) counter.innerText = `${filtered.length} items`;

    if (filtered.length === 0) {
      if (emptyMsg) emptyMsg.style.display = "block";
      updateBulkActionBar();
      return;
    }
    if (emptyMsg) emptyMsg.style.display = "none";

    filtered.forEach(item => {
      const card = document.createElement("div");
      card.className = "media-card";
      card.setAttribute("data-url", item.url);
      
      let mediaPreviewHtml = "";
      if (item.type === "image" || item.type === "svg") {
        mediaPreviewHtml = `<img src="${item.url}" alt="${item.alt || ''}" style="width:100%; height:100%; object-fit:cover;" />`;
      } else {
        let icon = "📄";
        if (item.type === "video") icon = "🎥";
        if (item.type === "pdf") icon = "📕";
        mediaPreviewHtml = `
          <div style="width:100%; height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; background:#1e293b; color:#9ca3af; padding:0.5rem; text-align:center;">
            <span style="font-size:2rem; margin-bottom:0.25rem;">${icon}</span>
            <span style="font-size:0.68rem; font-weight:700; word-break:break-all; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">${item.title}</span>
          </div>
        `;
      }

      card.innerHTML = `
        ${mediaPreviewHtml}
        <input type="checkbox" class="media-bulk-checkbox" data-url="${item.url}" style="position:absolute; top:8px; left:8px; z-index:5; width:18px; height:18px; cursor:pointer;" ${bulkCheckedUrls.has(item.url) ? 'checked' : ''} />
      `;

      card.addEventListener("click", (e) => {
        if (e.target.classList.contains("media-bulk-checkbox")) {
          return; // handled by checkbox handler
        }
        selectAssetItem(item);
      });

      const checkbox = card.querySelector(".media-bulk-checkbox");
      if (checkbox) {
        checkbox.addEventListener("click", (e) => {
          e.stopPropagation();
        });
        checkbox.addEventListener("change", (e) => {
          if (e.target.checked) {
            bulkCheckedUrls.add(item.url);
          } else {
            bulkCheckedUrls.delete(item.url);
          }
          updateBulkActionBar();
          syncSelectAllCheckboxState();
        });
      }

      if (selectedAsset && selectedAsset.url === item.url) {
        card.classList.add("active-selected");
      }

      grid.appendChild(card);
    });

    updateBulkActionBar();
    syncSelectAllCheckboxState();
  }

  function updateBulkActionBar() {
    const bar = document.getElementById("bulk-actions-bar");
    const label = document.getElementById("bulk-selected-count");
    if (!bar) return;

    if (bulkCheckedUrls.size > 0) {
      bar.style.display = "flex";
      if (label) label.innerText = `${bulkCheckedUrls.size} items selected`;
    } else {
      bar.style.display = "none";
    }
  }

  function syncSelectAllCheckboxState() {
    const selectAllCheckbox = document.getElementById("select-all-media");
    if (!selectAllCheckbox) return;

    const visibleCheckboxes = document.querySelectorAll(".media-bulk-checkbox");
    if (visibleCheckboxes.length === 0) {
      selectAllCheckbox.checked = false;
      selectAllCheckbox.disabled = true;
      return;
    }

    selectAllCheckbox.disabled = false;
    let allChecked = true;
    visibleCheckboxes.forEach(cb => {
      if (!cb.checked) allChecked = false;
    });
    selectAllCheckbox.checked = allChecked;
  }

  // Active Asset Selection in sidebar
  function selectAssetItem(item) {
    selectedAsset = item;
    
    // Highlight Card
    document.querySelectorAll(".media-card").forEach(el => {
      el.classList.remove("active-selected");
      if (el.getAttribute("data-url") === item.url) {
        el.classList.add("active-selected");
      }
    });

    // Populate Sidebar Details Panel
    const fallback = document.getElementById("drawer-fallback-msg");
    const content = document.getElementById("drawer-content");
    const preview = document.getElementById("drawer-preview-img");

    if (fallback) fallback.style.display = "none";
    if (content) content.style.display = "block";
    
    if (preview) {
      if (item.type === "image" || item.type === "svg") {
        preview.src = item.url;
        preview.style.display = "block";
      } else {
        preview.style.display = "none"; // Hide preview image for docs/videos
      }
    }

    // Fill metadata labels
    const filename = item.url.split("/").pop();
    document.getElementById("meta-filename").innerText = filename;
    document.getElementById("meta-filesize").innerText = formatBytes(item.size);
    document.getElementById("meta-uploadedat").innerText = new Date(item.uploadedAt).toLocaleString();

    // Fill Form inputs
    document.getElementById("asset-title").value = item.title || "";
    document.getElementById("asset-alt").value = item.alt || "";
    document.getElementById("asset-caption").value = item.caption || "";
    document.getElementById("asset-url-readonly").value = window.location.origin + item.url;
    
    const assetFolderSelect = document.getElementById("asset-folder");
    if (assetFolderSelect) {
      assetFolderSelect.value = item.folder || "";
    }

    // Render Usage Scan List
    const usageList = document.getElementById("media-usage-list");
    if (usageList) {
      const usage = item.usage || [];
      if (usage.length > 0) {
        usageList.innerHTML = usage.map(u => `
          <div style="background: rgba(156, 163, 175, 0.04); padding: 0.4rem; border-radius: 4px; border: 1px solid var(--border-color) || rgba(255,255,255,0.06); display: flex; flex-direction: column; gap: 0.15rem;">
            <span style="font-size: 0.78rem; font-weight: 700; color: var(--text-main);">${u.title}</span>
            <span style="font-size: 0.68rem; color: var(--text-dim); font-family: monospace;">${u.file} (${u.count} refs)</span>
          </div>
        `).join('');
      } else {
        usageList.innerHTML = `<span style="font-size:0.78rem; color:var(--text-dim);">No active page references found on disk.</span>`;
      }
    }
  }

  function closeDrawer() {
    selectedAsset = null;
    document.querySelectorAll(".media-card").forEach(el => el.classList.remove("active-selected"));
    
    const fallback = document.getElementById("drawer-fallback-msg");
    const content = document.getElementById("drawer-content");

    if (fallback) fallback.style.display = "block";
    if (content) content.style.display = "none";
  }

  // Setup click & save event handlers on Drawer Form
  function setupDrawerHandlers() {
    const closeBtn = document.getElementById("close-drawer-btn");
    if (closeBtn) closeBtn.addEventListener("click", closeDrawer);

    // Metadata Save Click
    const saveMetaBtn = document.getElementById("save-asset-meta-btn");
    if (saveMetaBtn) {
      saveMetaBtn.addEventListener("click", async () => {
        if (!selectedAsset) return;

        const title = document.getElementById("asset-title").value.trim();
        const alt = document.getElementById("asset-alt").value.trim();
        const caption = document.getElementById("asset-caption").value.trim();
        const folder = document.getElementById("asset-folder").value;

        if (!title) {
          showToast("Title is required!");
          return;
        }

        saveMetaBtn.disabled = true;
        saveMetaBtn.innerText = "Saving...";

        try {
          const res = await fetch("/api/media-crud", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              url: selectedAsset.url,
              title,
              alt,
              caption,
              folder
            })
          });
          const result = await res.json();

          if (result.success) {
            showToast("Metadata saved successfully!");
            loadMediaCatalog();
          } else {
            showToast("Error updating metadata");
          }
        } catch (e) {
          showToast("Network Error updating metadata");
        } finally {
          saveMetaBtn.disabled = false;
          saveMetaBtn.innerText = "Save Metadata";
        }
      });
    }

    // Asset Delete Click
    const deleteBtn = document.getElementById("delete-asset-btn");
    if (deleteBtn) {
      deleteBtn.addEventListener("click", () => {
        if (!selectedAsset) return;
        window.customConfirm("Are you sure you want to permanently delete this media asset? This will delete the physical file on disk and cannot be undone.", async () => {
          const restore = () => { deleteBtn.disabled = false; deleteBtn.innerText = "Delete Permanently"; };
          const doDelete = async (force) => {
            deleteBtn.disabled = true;
            deleteBtn.innerText = "Deleting...";
            try {
              const res = await fetch("/api/media-crud", {
                method: "DELETE",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ url: selectedAsset.url, force })
              });
              const result = await res.json();
              if (result.success) {
                showToast("Asset deleted permanently!");
                closeDrawer();
                loadMediaCatalog();
              } else if (result.requiresConfirmation) {
                const places = (result.inUse || []).flatMap(t => t.usage).map(u => `• ${u.title} (${u.count}×)`).join("\n");
                restore();
                window.customConfirm(`This asset is still in use:\n\n${places}\n\nDelete anyway? This may cause broken images.`, () => doDelete(true));
              } else {
                showToast("Error: " + (result.error || "Could not delete asset"));
                restore();
              }
            } catch (e) {
              showToast("Network Error deleting asset");
              restore();
            }
          };
          doDelete(false);
        });
      });
    }

    // URL Copy
    const copyBtn = document.getElementById("copy-url-btn");
    const urlInput = document.getElementById("asset-url-readonly");
    if (copyBtn && urlInput) {
      copyBtn.addEventListener("click", () => {
        urlInput.select();
        navigator.clipboard.writeText(urlInput.value);
        copyBtn.innerText = "Copied!";
        setTimeout(() => {
          copyBtn.innerText = "Copy";
        }, 1500);
      });
    }

    // Bulk Actions Handlers
    const bulkMoveBtn = document.getElementById("bulk-move-btn");
    const bulkMoveFolderSelect = document.getElementById("bulk-move-folder");
    if (bulkMoveBtn && bulkMoveFolderSelect) {
      bulkMoveBtn.addEventListener("click", async () => {
        const folderVal = bulkMoveFolderSelect.value;
        if (bulkCheckedUrls.size === 0) return;
        
        bulkMoveBtn.disabled = true;
        try {
          const res = await fetch("/api/media-crud", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              urls: Array.from(bulkCheckedUrls),
              folder: folderVal
            })
          });
          const result = await res.json();
          if (result.success) {
            showToast(`Successfully moved ${bulkCheckedUrls.size} items to "${folderVal || 'Root'}"`);
            bulkCheckedUrls.clear();
            loadMediaCatalog();
          } else {
            showToast("Error moving items.");
          }
        } catch (e) {
          showToast("Network error moving items.");
        } finally {
          bulkMoveBtn.disabled = false;
        }
      });
    }

    const bulkDeleteBtn = document.getElementById("bulk-delete-btn");
    if (bulkDeleteBtn) {
      bulkDeleteBtn.addEventListener("click", () => {
        if (bulkCheckedUrls.size === 0) return;
        window.customConfirm(`Are you sure you want to permanently delete these ${bulkCheckedUrls.size} selected items?`, async () => {
          const count = bulkCheckedUrls.size;
          const doBulkDelete = async (force) => {
            bulkDeleteBtn.disabled = true;
            try {
              const res = await fetch("/api/media-crud", {
                method: "DELETE",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ urls: Array.from(bulkCheckedUrls), force })
              });
              const result = await res.json();
              if (result.success) {
                showToast(`Successfully deleted ${count} items.`);
                bulkCheckedUrls.clear();
                loadMediaCatalog();
              } else if (result.requiresConfirmation) {
                const n = (result.inUse || []).length;
                bulkDeleteBtn.disabled = false;
                window.customConfirm(`${n} of the selected asset(s) are still in use across the site.\n\nDelete anyway? This may cause broken images.`, () => doBulkDelete(true));
              } else {
                showToast("Error deleting items.");
                bulkDeleteBtn.disabled = false;
              }
            } catch (e) {
              showToast("Network error deleting items.");
              bulkDeleteBtn.disabled = false;
            }
          };
          doBulkDelete(false);
        });
      });
    }

    // Select All Checkbox Handler
    const selectAllCheckbox = document.getElementById("select-all-media");
    if (selectAllCheckbox) {
      selectAllCheckbox.addEventListener("change", (e) => {
        const isChecked = e.target.checked;
        const visibleCheckboxes = document.querySelectorAll(".media-bulk-checkbox");
        visibleCheckboxes.forEach(cb => {
          cb.checked = isChecked;
          const url = cb.getAttribute("data-url");
          if (isChecked) {
            bulkCheckedUrls.add(url);
          } else {
            bulkCheckedUrls.delete(url);
          }
        });
        updateBulkActionBar();
      });
    }
  }

  // Setup drag & drop upload triggers
  function setupDropzone() {
    const dropzone = document.getElementById("media-dropzone");
    const clickTrigger = document.getElementById("click-upload-trigger");
    const fileInput = document.getElementById("direct-upload-file");

    if (!dropzone || !fileInput) return;

    if (clickTrigger) {
      clickTrigger.addEventListener("click", (e) => {
        e.stopPropagation();
        fileInput.click();
      });
    }

    dropzone.addEventListener("click", () => {
      fileInput.click();
    });

    ["dragenter", "dragover"].forEach(eventName => {
      dropzone.addEventListener(eventName, (e) => {
        e.preventDefault();
        e.stopPropagation();
        dropzone.classList.add("drag-active");
      }, false);
    });

    ["dragleave", "drop"].forEach(eventName => {
      dropzone.addEventListener(eventName, (e) => {
        e.preventDefault();
        e.stopPropagation();
        dropzone.classList.remove("drag-active");
      }, false);
    });

    dropzone.addEventListener("drop", (e) => {
      const dt = e.dataTransfer;
      const files = dt.files;
      handleUploadedFiles(files);
    });

    fileInput.addEventListener("change", () => {
      handleUploadedFiles(fileInput.files);
    });
  }

  // Process uploads to server sequentially
  async function handleUploadedFiles(files) {
    if (files.length === 0) return;
    
    showToast(`Uploading ${files.length} asset(s)...`);

    for (let i = 0; i < files.length; i++) {
      const file = files[i];
      const formData = new FormData();
      formData.append("file", file);
      formData.append("alt", file.name.split(".")[0]);
      formData.append("folder", activeFolder === "all" ? "" : activeFolder);

      try {
        const res = await fetch("/api/media-crud", {
          method: "POST",
          body: formData
        });
        const result = await res.json();
        
        if (result.success) {
          showToast(`File "${file.name}" uploaded!`);
        } else {
          showToast(`Failed uploading "${file.name}": ` + (result.error || ""));
        }
      } catch (e) {
        showToast(`Network Error uploading "${file.name}"`);
      }
    }

    loadMediaCatalog();
  }

  // File size format utility
  function formatBytes(bytes, decimals = 2) {
    if (bytes === 0) return "0 Bytes";
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ["Bytes", "KB", "MB", "GB"];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + " " + sizes[i];
  }

  // Toast banner utility
  const toast = document.getElementById("toast-notify");
  const toastMsg = document.getElementById("toast-message");
  
  function showToast(message) {
    if (toast && toastMsg) {
      toastMsg.innerText = message;
      toast.classList.add("active");
      setTimeout(() => {
        toast.classList.remove("active");
      }, 3000);
    }
  }

  document.addEventListener("DOMContentLoaded", initMediaLibrary);
  document.addEventListener("astro:page-load", initMediaLibrary);
  if (document.readyState === "interactive" || document.readyState === "complete") {
    initMediaLibrary();
  }
</script>
