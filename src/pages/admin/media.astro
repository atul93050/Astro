    if (usageList) {
      const usage = item.usage || [];
      if (usage.length > 0) {
        usageList.innerHTML = usage.map(u => `
          <div style="background: rgba(156, 163, 175, 0.04); padding: 0.4rem; border-radius: 4px; border: 1px solid var(--border-color) || rgba(255,255,255,0.06); display: flex; flex-direction: column; gap: 0.15rem;">
            <span style="font-size: 0.78rem; font-weight: 700; color: var(--text-main);">${u.title}</span>
            <span style="font-size: 0.68rem; color: var(--text-dim); font-family: monospace;">${u.file} (${u.count} refs)</span>
          </div>
        `).join('');
      } else {
        usageList.innerHTML = `<span style="font-size:0.75rem; color:var(--text-dim);">Not referenced anywhere on disk.</span>`;
      }
    }
