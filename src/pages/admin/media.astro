---
import AdminLayout from "../../layouts/admin/AdminLayout.astro";

export const prerender = false;
---

<AdminLayout title="Media Library">
  
  <div class="media-header">
    <div class="header-text">
      <p class="subtitle">Upload, view, and catalog static assets like images or banners directly to local storage.</p>
    </div>
    
    <!-- Upload Area Action -->
    <div class="upload-dropzone" id="media-dropzone">
      <form id="direct-upload-form" onsubmit="return false;">
        <input type="file" id="direct-upload-file" accept="image/*" style="display:none;" multiple />
        <div class="dropzone-text">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:0.5rem; opacity:0.7;">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
          <p>Drag & Drop or <span class="highlight-trigger" id="click-upload-trigger">Browse files</span></p>
          <span>Maximum size limit: 5MB</span>
        </div>
      </form>
    </div>
  </div>

  <div class="media-library-grid-layout">
    
    <!-- Main Media Grid display -->
    <div class="media-grid-container">
      <div class="media-filters-row" style="flex-wrap:wrap; gap:1rem;">
        <div style="display:inline-flex; align-items:center; gap:0.65rem;">
          <input type="checkbox" id="select-all-media" title="Select All Assets" style="width:18px; height:18px; cursor:pointer; margin:0;" />
          <h3>Media Library Assets</h3>
          <span class="assets-count-badge" id="assets-count">0 items</span>
        </div>
        
        <!-- Interactive Search & Filtering Controls Toolbar -->
        <div style="display:flex; gap:0.5rem; align-items:center; flex-wrap:wrap;">
          <input type="text" id="search-input" placeholder="Search files..." style="padding: 0.35rem 0.65rem; border-radius: 4px; border: 1px solid var(--border-color) || rgba(255,255,255,0.08); font-size: 0.8rem; max-width: 140px; background: var(--input-bg) || #0f172a; color: var(--text-main);" />
          
          <select id="type-filter" style="padding: 0.35rem 0.65rem; border-radius: 4px; border: 1px solid var(--border-color) || rgba(255,255,255,0.08); font-size: 0.8rem; background: var(--input-bg) || #0f172a; color: var(--text-main);">
            <option value="all">All Types</option>
            <option value="image">Images</option>
            <option value="svg">SVGs</option>
            <option value="pdf">PDFs</option>
            <option value="document">Documents</option>
            <option value="video">Videos</option>
          </select>
          
          <select id="folder-filter" style="padding: 0.35rem 0.65rem; border-radius: 4px; border: 1px solid var(--border-color) || rgba(255,255,255,0.08); font-size: 0.8rem; background: var(--input-bg) || #0f172a; color: var(--text-main);">
            <option value="all">All Folders</option>
            <option value="">Root (/)</option>
          </select>

          <!-- New Folder creation -->
          <div style="display:flex; gap:0.2rem; align-items:center;">
            <input type="text" id="new-folder-name" placeholder="New folder..." style="padding: 0.35rem 0.65rem; border-radius: 4px; border: 1px solid var(--border-color) || rgba(255,255,255,0.08); font-size: 0.8rem; max-width: 100px; background: var(--input-bg) || #0f172a; color: var(--text-main);" />
            <button type="button" class="btn btn-outline btn-sm" id="create-folder-btn" style="padding:0.35rem 0.5rem; font-size:0.8rem; height:29px;">+</button>
          </div>

          <!-- Items per page selection -->
          <div style="display:inline-flex; align-items:center; gap:0.35rem;">
            <span style="font-size:0.8rem; color:var(--text-muted); white-space:nowrap;">Show:</span>
            <input type="number" id="items-per-page" value="10" min="1" style="width: 58px; padding: 0.35rem 0.5rem; border-radius: 4px; border: 1px solid var(--border-color) || rgba(255,255,255,0.08); font-size: 0.8rem; background: var(--input-bg) || #0f172a; color: var(--text-main); text-align: center;" />
          </div>
        </div>
      </div>
      
      <!-- Bulk Actions Control Bar -->
      <div id="bulk-actions-bar" style="display:none; justify-content:space-between; align-items:center; background:rgba(99, 102, 241, 0.08); border: 1px solid var(--primary) || rgba(99,102,241,0.5); padding:0.5rem 0.85rem; border-radius:6px; margin-bottom:1rem; gap:1rem;">
        <span style="font-size:0.82rem; font-weight:600;" id="bulk-selected-count">0 items selected</span>
        <div style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap;">
          <select id="bulk-move-folder" style="padding:0.3rem 0.45rem; font-size:0.78rem; border-radius:4px; border:1px solid var(--border-color) || rgba(255,255,255,0.08); background:var(--input-bg) || #0f172a; color:var(--text-main);">
            <option value="">Move to Folder...</option>
            <option value="">Root (/)</option>
          </select>
          <button type="button" class="btn btn-outline btn-sm" id="bulk-move-btn" style="padding:0.3rem 0.55rem; font-size:0.78rem;">Move</button>
          <button type="button" class="btn btn-danger btn-sm" id="bulk-delete-btn" style="padding:0.3rem 0.55rem; font-size:0.78rem; background:#EF4444; border:none; color:white; font-weight:bold;">Delete</button>
        </div>
      </div>

      <div class="media-grid" id="main-media-grid">
        <!-- JS will populate media catalog cards -->
        <div class="media-grid-empty" id="grid-empty-msg">
          <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:1rem; opacity:0.4;">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
            <circle cx="8.5" cy="8.5" r="1.5"></circle>
            <polyline points="21 15 16 10 5 21"></polyline>
          </svg>
          <h4>Your Media Library is empty</h4>
          <p>Click Browse above to upload static images and resources.</p>
        </div>
      </div>

      <!-- Pagination Controls -->
      <div id="media-pagination" style="display:none; align-items:center; justify-content:center; gap:1rem; margin-top:1.5rem; padding-top:1rem; border-top:1px solid var(--border-color) || rgba(255,255,255,0.08);">
        <button type="button" class="btn btn-outline btn-sm" id="prev-page-btn" style="padding:0.4rem 0.75rem; font-size:0.8rem;">Previous</button>
        <span id="page-info" style="font-size:0.82rem; font-weight:600; color:var(--text-muted);">Page 1 of 1</span>
        <button type="button" class="btn btn-outline btn-sm" id="next-page-btn" style="padding:0.4rem 0.75rem; font-size:0.8rem;">Next</button>
      </div>
    </div>

    <!-- Asset Detail Panel Modal Overlay (originally asset-details-drawer) -->
    <div class="asset-details-drawer" id="asset-drawer">
      
      <!-- Modal Box Box-Window -->
      <div class="asset-details-modal-box">
        
        <!-- Header -->
        <div class="modal-box-header">
          <div class="header-left">
            <h3>Attachment details</h3>
          </div>
          <div class="header-right">
            <!-- Nav buttons for Prev / Next item -->
            <button type="button" class="nav-btn" id="modal-prev-btn" title="Previous media item">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <button type="button" class="nav-btn" id="modal-next-btn" title="Next media item">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
            
            <!-- Close button -->
            <button type="button" class="close-btn" id="close-drawer-btn" title="Close dialog">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
          </div>
        </div>

        <!-- Body -->
        <div class="modal-box-body" id="drawer-content" style="display:none;">
          
          <!-- Left side: Large preview of selected media -->
          <div class="modal-preview-column">
            
            <!-- Standard Image Preview -->
            <div class="modal-preview-wrapper" id="preview-image-container">
              <img src="" id="drawer-preview-img" alt="Preview" />
              <div id="document-preview-icon" style="display:none; flex-direction:column; align-items:center; justify-content:center; color:#9ca3af; text-align:center;">
                <span id="preview-file-icon" style="font-size:5rem; margin-bottom:1rem;">📄</span>
                <span id="preview-file-title" style="font-size:1.1rem; font-weight:700; word-break:break-all; max-width:80%;">File Name</span>
              </div>
            </div>

            <!-- Background Remover Canvas Workspace -->
            <div class="modal-preview-wrapper" id="bg-remover-workspace" style="display:none; flex-direction:column; gap:1rem;">
              <div style="position:relative; max-width:100%; max-height:80%; overflow:auto; background-image: linear-gradient(45deg, var(--border-color) 25%, transparent 25%), linear-gradient(-45deg, var(--border-color) 25%, transparent 25%), linear-gradient(45deg, transparent 75%, var(--border-color) 75%), linear-gradient(-45deg, transparent 75%, var(--border-color) 75%); background-size: 20px 20px; background-position: 0 0, 0 10px, 10px -10px, -10px 0px; background-color: var(--bg-surface-solid); border:1px dashed var(--primary); border-radius:4px; display:flex; align-items:center; justify-content:center;">
                <canvas id="bg-remover-canvas" style="cursor:crosshair; max-width:100%; height:auto; display:block;"></canvas>
              </div>
              <div class="bg-remover-controls" style="display:flex; gap:0.5rem; align-items:center; flex-wrap:wrap; background: var(--bg-base); border: 1px solid var(--border-color); padding:0.5rem; border-radius:4px; width:100%; box-sizing:border-box;">
                <span style="font-size:0.75rem; color:var(--text-muted);">Tolerance:</span>
                <input type="range" id="bg-remover-tolerance" min="1" max="100" value="20" style="width:100px; cursor:pointer;" />
                <span id="tolerance-val" style="font-size:0.75rem; font-family:monospace; color:var(--text-main);">20</span>
                <button type="button" class="btn btn-outline btn-sm" id="btn-apply-bg-remover" style="padding:0.25rem 0.5rem; font-size:0.75rem;">Apply Selection</button>
                <div style="flex:1;"></div>
                <button type="button" class="btn btn-sm" id="btn-save-bg-remover" style="background:#10B981; border:none; color:white; font-weight:600; padding:0.25rem 0.6rem; font-size:0.75rem;">Save Transparent</button>
                <button type="button" class="btn btn-outline btn-sm" id="btn-cancel-bg-remover" style="padding:0.25rem 0.5rem; font-size:0.75rem;">Cancel</button>
              </div>
              <p style="font-size:0.7rem; color:var(--text-dim); text-align:center; margin:0;">💡 Click on any color in the image above (e.g. background white) to make it transparent, adjust tolerance if needed.</p>
            </div>
            
            <div class="preview-actions">
              <button type="button" class="btn btn-outline btn-sm" id="bg-remover-btn" style="display:none; gap:0.4rem; align-items:center;">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Remove Background
              </button>
              <span id="dimension-badge" class="badge badge-outline">Dimensions: 1920x1080</span>
              <span id="aspect-ratio-badge" class="badge badge-outline" style="background:rgba(99,102,241,0.08); border-color:var(--primary); color:var(--primary);">Aspect Ratio: 16:9</span>
            </div>
          </div>
          
          <!-- Right side: Form & Metadata (Scrollable) -->
          <div class="modal-details-column">
            
            <!-- Technical details / File meta -->
            <div class="details-meta-section">
              <div class="meta-row">
                <span class="label">Uploaded on:</span>
                <span class="value" id="meta-uploadedat">June 19, 2026</span>
              </div>
              <div class="meta-row">
                <span class="label">Uploaded by:</span>
                <span class="value" id="meta-uploadedby">admin</span>
              </div>
              <div class="meta-row">
                <span class="label">File name:</span>
                <span class="value" id="meta-filename">image.png</span>
              </div>
              <div class="meta-row">
                <span class="label">File type:</span>
                <span class="value" id="meta-filetype">image/png</span>
              </div>
              <div class="meta-row">
                <span class="label">File size:</span>
                <span class="value" id="meta-filesize">24 KB</span>
              </div>
              <div class="meta-row" id="meta-dimensions-row">
                <span class="label">Dimensions:</span>
                <span class="value" id="meta-dimensions">1920 by 1080 pixels</span>
              </div>
            </div>

            <!-- Dynamic Dominant Colors Extractor (our suggestion!) -->
            <div id="dominant-colors-container" style="display:none; flex-direction:column; gap:0.4rem; padding-bottom:1rem; border-bottom:1px solid var(--border-color); margin-bottom:1rem;">
              <span style="font-size:0.75rem; font-weight:700; color:var(--text-muted); text-transform:uppercase;">Dominant Colors Palette</span>
              <div id="color-palette-list" style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap; margin-top:0.25rem;">
                <!-- pills will be generated -->
              </div>
            </div>

            <!-- Duplicate Status Warning Banner -->
            <div id="duplicate-warning" class="duplicate-warning-banner" style="display:none;">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" style="margin-top:2px; flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <div>
                <strong>Duplicate File Warning:</strong> An identical file already exists in the library:
                <div id="duplicate-links-list" style="margin-top:0.25rem; display:flex; flex-direction:column; gap:0.25rem;"></div>
              </div>
            </div>

            <!-- Main Edit Form -->
            <form id="asset-meta-form" onsubmit="return false;" style="display:flex; flex-direction:column; gap:0.85rem;">
              
              <div class="form-group-horizontal">
                <label for="asset-alt">Alternative Text</label>
                <div class="input-desc-wrapper">
                  <textarea id="asset-alt" rows="2" placeholder="Describe the purpose of the image. Leave empty if purely decorative."></textarea>
                  <span class="field-desc"><a href="https://www.w3.org/WAI/tutorials/images/decision-tree/" target="_blank" style="color:var(--primary); text-decoration:underline;">Learn how to describe the purpose of the image</a>.</span>
                </div>
              </div>

              <div class="form-group-horizontal">
                <label for="asset-title">Title</label>
                <input type="text" id="asset-title" required />
              </div>
              
              <div class="form-group-horizontal">
                <label for="asset-caption">Caption</label>
                <textarea id="asset-caption" rows="2" placeholder="Caption for display underneath the image..."></textarea>
              </div>

              <!-- Added Description field (missing from sidebar, exists in DB) -->
              <div class="form-group-horizontal">
                <label for="asset-description">Description</label>
                <textarea id="asset-description" rows="3" placeholder="Longer description or notes about this file..."></textarea>
              </div>

              <!-- Added Tags input (supported by backend PUT API!) -->
              <div class="form-group-horizontal">
                <label for="asset-tags">Tags</label>
                <input type="text" id="asset-tags" placeholder="comma-separated tags (e.g. blog, banner, logo)" />
              </div>

              <div class="form-group-horizontal">
                <label for="asset-folder">Folder</label>
                <select id="asset-folder">
                  <option value="">Root (/)</option>
                </select>
              </div>

              <div class="form-group-horizontal">
                <label>File URL</label>
                <div class="input-desc-wrapper">
                  <div class="input-picker-wrap">
                    <input type="text" id="asset-url-readonly" readonly style="font-family:monospace; font-size:0.75rem;" />
                    <button type="button" class="btn btn-outline btn-sm" id="copy-url-btn" style="white-space:nowrap;">Copy URL</button>
                  </div>
                  <div style="display:flex; gap:0.25rem; margin-top:0.25rem;">
                    <button type="button" class="btn btn-outline btn-sm" id="copy-markdown-btn" style="flex:1; padding:0.2rem; font-size:0.72rem;">Copy MD</button>
                    <button type="button" class="btn btn-outline btn-sm" id="copy-html-btn" style="flex:1; padding:0.2rem; font-size:0.72rem;">Copy HTML</button>
                  </div>
                </div>
              </div>

              <!-- Replace Media Section -->
              <div class="form-group-horizontal" style="border-top:1px solid var(--border-color); padding-top:1rem; margin-top:0.5rem;">
                <label>Replace File</label>
                <div class="input-desc-wrapper">
                  <input type="file" id="replace-file-input" accept="image/*,video/*,.svg,.pdf" style="display:none;" />
                  <button type="button" class="btn btn-outline btn-sm" id="btn-replace-media" style="width:100%;">
                    Upload Replacement File
                  </button>
                  <span class="field-desc">Overwrites the file on disk while keeping the same URL and filename (links will not break).</span>
                </div>
              </div>

              <!-- Optimization/Variants section -->
              <div id="generate-variants-container" style="display:none; flex-direction:column; gap:0.5rem; border-top:1px solid var(--border-color); padding-top:1rem; margin-top:0.5rem;">
                <label style="font-size:0.8rem; font-weight:700; text-transform:uppercase; color:var(--text-muted);">Image Optimization</label>
                <p style="font-size:0.75rem; color:var(--text-dim); margin-bottom:0.25rem;">Generate WebP format and responsive sizes for improved performance.</p>
                <button type="button" class="btn btn-outline btn-sm" id="generate-variants-btn">Generate Optimization Variants</button>
                <div id="variants-status-list" style="display:none; flex-direction:column; gap:0.25rem; background:rgba(255,255,255,0.03); padding:0.5rem; border-radius:4px; font-size:0.72rem; font-family:monospace; border:1px solid rgba(255,255,255,0.06); max-height:110px; overflow-y:auto;"></div>
              </div>

              <!-- Usage List references -->
              <div style="border-top:1px solid var(--border-color); padding-top:1rem; margin-top:0.5rem;">
                <label style="font-size:0.8rem; font-weight:700; text-transform:uppercase; color:var(--text-muted); display:block; margin-bottom:0.5rem;">Used In / Page References</label>
                <div id="media-usage-list" style="display:flex; flex-direction:column; gap:0.4rem; max-height: 120px; overflow-y: auto;">
                  <span style="font-size:0.75rem; color:var(--text-dim);">Not referenced anywhere on disk.</span>
                </div>
              </div>

              <!-- Footer/Actions row inside right column -->
              <div class="modal-footer-actions">
                <div class="action-links">
                  <a id="link-view-file" href="#" target="_blank">View media file</a>
                  <span class="sep">|</span>
                  <a id="link-download-file" href="#" download>Download file</a>
                  <span class="sep">|</span>
                  <button type="button" id="delete-asset-btn" class="delete-link">Delete permanently</button>
                </div>
                
                <button type="button" class="btn btn-primary" id="save-asset-meta-btn" style="align-self:flex-end; padding:0.4rem 1rem;">Save Metadata</button>
              </div>

            </form>
          </div>

        </div>
      </div>

  </div>

  <!-- Notification Banner -->
  <div class="toast-notification" id="toast-notify">
    <div class="toast-content">
      <span class="toast-message" id="toast-message">Asset updated!</span>
    </div>
  </div>

</AdminLayout>

<style is:global>
  .media-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .subtitle {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-top: 0.25rem;
  }

  /* Upload Dropzone Drag/Drop Box */
  .upload-dropzone {
    flex: 1;
    min-width: 320px;
    max-width: 480px;
    background: var(--bg-surface);
    border: 2px dashed var(--input-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-align: center;
    transition: var(--transition);
    cursor: pointer;
    box-shadow: 0 4px 12px var(--color-shadow);
  }
  .upload-dropzone:hover, .upload-dropzone.drag-active {
    border-color: var(--primary);
    background: var(--primary-light);
  }
  .dropzone-text p {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-main);
  }
  .highlight-trigger {
    color: var(--primary);
    text-decoration: underline;
  }
  .dropzone-text span {
    display: block;
    font-size: 0.72rem;
    color: var(--text-dim);
    margin-top: 0.25rem;
  }

  /* Grid layouts */
  .media-library-grid-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .media-grid-container {
    background: var(--bg-surface);
    border: 1px solid var(--bg-surface-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: 0 4px 15px var(--color-shadow);
    backdrop-filter: blur(10px);
    min-width: 0;
  }
  .media-filters-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.75rem;
  }
  .media-filters-row h3 {
    font-size: 1.05rem;
    font-weight: 700;
  }
  .assets-count-badge {
    padding: 0.25rem 0.65rem;
    background: rgba(156, 163, 175, 0.08);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 1rem;
    min-height: 250px;
  }
  .media-grid-empty {
    grid-column: span 12;
    text-align: center;
    padding: 5rem 2rem;
    color: var(--text-dim);
  }
  .media-grid-empty h4 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }
  .media-grid-empty p {
    font-size: 0.82rem;
  }

  /* Grid item card */
  .media-card {
    aspect-ratio: 1;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 2px solid transparent;
    cursor: pointer;
    position: relative;
    background: var(--bg-surface-solid);
    box-shadow: 0 2px 8px var(--color-shadow);
    transition: var(--transition);
  }
  .media-card:hover {
    transform: scale(1.04);
    border-color: var(--primary);
  }
  .media-card.active-selected {
