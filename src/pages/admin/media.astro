    // Duplicate Warning
    const dupWarning = document.getElementById("duplicate-warning");
    const dupLinks = document.getElementById("duplicate-links-list");
    if (dupWarning && dupLinks) {
      if (item.isDuplicate && item.duplicateOf && item.duplicateOf.length > 0) {
        dupWarning.style.display = "flex";
        dupLinks.innerHTML = item.duplicateOf.map(url => `
          <a href="${url}" target="_blank" style="color:#B45309; text-decoration:underline; font-size:0.75rem; word-break:break-all;">• ${url}</a>
