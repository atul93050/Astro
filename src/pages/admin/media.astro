      if (item.type === "image") {
        colorsContainer.style.display = "flex";
        colorsList.innerHTML = `<span style="font-size:0.75rem; color:var(--text-dim);">Extracting colors...</span>`;
        setTimeout(() => {
          const img = document.getElementById("drawer-preview-img");
