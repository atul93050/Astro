  // Modal navigation
  function navigateModal(direction) {
    if (!selectedAsset || filteredMediaList.length === 0) return;
    const idx = filteredMediaList.findIndex(item => item.url === selectedAsset.url);
    if (idx === -1) return;
    
    const newIdx = idx + direction;
    if (newIdx >= 0 && newIdx < filteredMediaList.length) {
      const nextAsset = filteredMediaList[newIdx];
      
      const targetPage = Math.floor(newIdx / itemsPerPage) + 1;
      if (currentPage !== targetPage) {
        currentPage = targetPage;
        filterAndRenderMedia();
      }
      
      selectAssetItem(nextAsset);
    }
  }

  function closeDrawer() {
    selectedAsset = null;
    document.querySelectorAll(".media-card").forEach(el => el.classList.remove("active-selected"));
    
    const drawer = document.getElementById("asset-drawer");
    if (drawer) drawer.classList.remove("modal-open");
  }

  // Setup click & save event handlers on Drawer Form
  function setupDrawerHandlers() {
    const closeBtn = document.getElementById("close-drawer-btn");
    if (closeBtn) closeBtn.addEventListener("click", closeDrawer);

    // Prev/Next modal navigation
    const prevBtn = document.getElementById("modal-prev-btn");
    const nextBtn = document.getElementById("modal-next-btn");
    if (prevBtn) {
      prevBtn.onclick = (e) => {
        e.stopPropagation();
        navigateModal(-1);
      };
    }
    if (nextBtn) {
      nextBtn.onclick = (e) => {
        e.stopPropagation();
        navigateModal(1);
      };
    }

    // Embed snippets copy buttons
    const copyUrlBtn = document.getElementById("copy-url-btn");
    const copyMdBtn = document.getElementById("copy-markdown-btn");
    const copyHtmlBtn = document.getElementById("copy-html-btn");
    
    if (copyUrlBtn) {
      copyUrlBtn.onclick = () => {
        const urlInput = document.getElementById("asset-url-readonly");
        urlInput.select();
        navigator.clipboard.writeText(urlInput.value);
        copyUrlBtn.innerText = "Copied!";
        setTimeout(() => { copyUrlBtn.innerText = "Copy URL"; }, 1500);
      };
    }
    if (copyMdBtn) {
      copyMdBtn.onclick = () => {
        const alt = document.getElementById("asset-alt").value.trim() || selectedAsset.title;
        const url = window.location.origin + selectedAsset.url;
        const text = `![${alt}](${url})`;
        navigator.clipboard.writeText(text);
        copyMdBtn.innerText = "Copied!";
        setTimeout(() => { copyMdBtn.innerText = "Copy MD"; }, 1500);
      };
    }
    if (copyHtmlBtn) {
      copyHtmlBtn.onclick = () => {
        const alt = document.getElementById("asset-alt").value.trim() || selectedAsset.title;
        const url = window.location.origin + selectedAsset.url;
        const text = `<img src="${url}" alt="${alt}" />`;
        navigator.clipboard.writeText(text);
        copyHtmlBtn.innerText = "Copied!";
        setTimeout(() => { copyHtmlBtn.innerText = "Copy HTML"; }, 1500);
      };
    }

    // Generate thumbnails & responsive formats click
    const genBtn = document.getElementById("generate-variants-btn");
    if (genBtn) {
      genBtn.onclick = async () => {
        if (!selectedAsset) return;
        genBtn.disabled = true;
        genBtn.innerText = "Generating...";
        try {
          const formData = new FormData();
          formData.append("action", "generate-variants");
          formData.append("url", selectedAsset.url);
          const res = await fetch("/api/media-crud", {
            method: "POST",
            body: formData
          });
          const result = await res.json();
          if (result.success) {
            showToast("Thumbnails generated successfully!");
            selectedAsset = result.media;
            selectAssetItem(selectedAsset);
            loadMediaCatalog();
          } else {
            showToast("Error: " + (result.error || "Generation failed"));
          }
        } catch (e) {
          showToast("Network error generating thumbnails");
        } finally {
          genBtn.disabled = false;
          genBtn.innerText = "Generate Optimization Variants";
        }
      };
    }

    // Metadata Save Click
    const saveMetaBtn = document.getElementById("save-asset-meta-btn");
    if (saveMetaBtn) {
      saveMetaBtn.addEventListener("click", async () => {
        if (!selectedAsset) return;

        const title = document.getElementById("asset-title").value.trim();
        const alt = document.getElementById("asset-alt").value.trim();
        const caption = document.getElementById("asset-caption").value.trim();
        const description = document.getElementById("asset-description").value.trim();
        const tags = document.getElementById("asset-tags").value.trim();
        const folder = document.getElementById("asset-folder").value;

        if (!title) {
          showToast("Title is required!");
          return;
        }

        saveMetaBtn.disabled = true;
        saveMetaBtn.innerText = "Saving...";

        try {
          const res = await fetch("/api/media-crud", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              url: selectedAsset.url,
              title,
              alt,
              caption,
              description,
              tags,
              folder
            })
          });
          const result = await res.json();

          if (result.success) {
            showToast("Metadata saved successfully!");
            loadMediaCatalog();
          } else {
            showToast("Error updating metadata");
          }
        } catch (e) {
          showToast("Network Error updating metadata");
        } finally {
          saveMetaBtn.disabled = false;
          saveMetaBtn.innerText = "Save Metadata";
        }
      });
    }

    // Asset Delete Click
    const deleteBtn = document.getElementById("delete-asset-btn");
    if (deleteBtn) {
      deleteBtn.addEventListener("click", (e) => {
        e.preventDefault();
        if (!selectedAsset) return;
        window.customConfirm("Are you sure you want to permanently delete this media asset? This will delete the physical file on disk and cannot be undone.", async () => {
          const restore = () => { deleteBtn.disabled = false; deleteBtn.innerText = "Delete permanently"; };
          const doDelete = async (force) => {
            deleteBtn.disabled = true;
            deleteBtn.innerText = "Deleting...";
            try {
              const res = await fetch("/api/media-crud", {
                method: "DELETE",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ url: selectedAsset.url, force })
              });
              const result = await res.json();
              if (result.success) {
                showToast("Asset deleted permanently!");
                closeDrawer();
                loadMediaCatalog();
              } else if (result.requiresConfirmation) {
                const places = (result.inUse || []).flatMap(t => t.usage).map(u => `• ${u.title} (${u.count}×)`).join("\n");
                restore();
                window.customConfirm(`This asset is still in use:\n\n${places}\n\nDelete anyway? This may cause broken images.`, () => doDelete(true));
              } else {
                showToast("Error: " + (result.error || "Could not delete asset"));
                restore();
              }
            } catch (e) {
              showToast("Network Error deleting asset");
              restore();
            }
          };
          doDelete(false);
        });
      });
    }

    // Bulk Actions Handlers
    const bulkMoveBtn = document.getElementById("bulk-move-btn");
    const bulkMoveFolderSelect = document.getElementById("bulk-move-folder");
    if (bulkMoveBtn && bulkMoveFolderSelect) {
      bulkMoveBtn.addEventListener("click", async () => {
        const folderVal = bulkMoveFolderSelect.value;
        if (bulkCheckedUrls.size === 0) return;
        
        bulkMoveBtn.disabled = true;
        try {
          const res = await fetch("/api/media-crud", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              urls: Array.from(bulkCheckedUrls),
              folder: folderVal
            })
          });
          const result = await res.json();
          if (result.success) {
            showToast(`Successfully moved ${bulkCheckedUrls.size} items to "${folderVal || 'Root'}"`);
            bulkCheckedUrls.clear();
            loadMediaCatalog();
          } else {
            showToast("Error moving items.");
          }
        } catch (e) {
          showToast("Network error moving items.");
        } finally {
          bulkMoveBtn.disabled = false;
        }
      });
    }

    const bulkDeleteBtn = document.getElementById("bulk-delete-btn");
    if (bulkDeleteBtn) {
      bulkDeleteBtn.addEventListener("click", () => {
        if (bulkCheckedUrls.size === 0) return;
        window.customConfirm(`Are you sure you want to permanently delete these ${bulkCheckedUrls.size} selected items?`, async () => {
          const count = bulkCheckedUrls.size;
          const doBulkDelete = async (force) => {
            bulkDeleteBtn.disabled = true;
            try {
              const res = await fetch("/api/media-crud", {
                method: "DELETE",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ urls: Array.from(bulkCheckedUrls), force })
              });
              const result = await res.json();
              if (result.success) {
                showToast(`Successfully deleted ${count} items.`);
                bulkCheckedUrls.clear();
                loadMediaCatalog();
              } else if (result.requiresConfirmation) {
                const n = (result.inUse || []).length;
                bulkDeleteBtn.disabled = false;
                window.customConfirm(`${n} of the selected asset(s) are still in use across the site.\n\nDelete anyway? This may cause broken images.`, () => doBulkDelete(true));
              } else {
                showToast("Error deleting items.");
                bulkDeleteBtn.disabled = false;
              }
            } catch (e) {
              showToast("Network error deleting items.");
              bulkDeleteBtn.disabled = false;
            }
          };
          doBulkDelete(false);
        });
      });
    }

    // Select All Checkbox Handler
    const selectAllCheckbox = document.getElementById("select-all-media");
    if (selectAllCheckbox) {
      selectAllCheckbox.addEventListener("change", (e) => {
        const isChecked = e.target.checked;
        const visibleCheckboxes = document.querySelectorAll(".media-bulk-checkbox");
        visibleCheckboxes.forEach(cb => {
          cb.checked = isChecked;
          const url = cb.getAttribute("data-url");
          if (isChecked) {
            bulkCheckedUrls.add(url);
          } else {
            bulkCheckedUrls.delete(url);
          }
        });
        updateBulkActionBar();
      });
    }
  }

  // Setup drag & drop upload triggers
  function setupDropzone() {
    const dropzone = document.getElementById("media-dropzone");
    const clickTrigger = document.getElementById("click-upload-trigger");
    const fileInput = document.getElementById("direct-upload-file");

    if (!dropzone || !fileInput) return;

    if (clickTrigger) {
      clickTrigger.addEventListener("click", (e) => {
        e.stopPropagation();
        fileInput.click();
      });
    }

    dropzone.addEventListener("click", () => {
      fileInput.click();
    });

    ["dragenter", "dragover"].forEach(eventName => {
      dropzone.addEventListener(eventName, (e) => {
        e.preventDefault();
        e.stopPropagation();
        dropzone.classList.add("drag-active");
      }, false);
    });

    ["dragleave", "drop"].forEach(eventName => {
      dropzone.addEventListener(eventName, (e) => {
        e.preventDefault();
        e.stopPropagation();
        dropzone.classList.remove("drag-active");
      }, false);
    });

    dropzone.addEventListener("drop", (e) => {
      const dt = e.dataTransfer;
      const files = dt.files;
      handleUploadedFiles(files);
    });

    fileInput.addEventListener("change", () => {
      handleUploadedFiles(fileInput.files);
    });
  }

  // Process uploads to server sequentially
  async function handleUploadedFiles(files) {
    if (files.length === 0) return;
    
    showToast(`Uploading ${files.length} asset(s)...`);

    for (let i = 0; i < files.length; i++) {
      const file = files[i];
      const formData = new FormData();
      formData.append("file", file);
      formData.append("alt", file.name.split(".")[0]);
      formData.append("folder", activeFolder === "all" ? "" : activeFolder);

      try {
        const res = await fetch("/api/media-crud", {
          method: "POST",
          body: formData
        });
        const result = await res.json();
        
        if (result.success) {
          showToast(`File "${file.name}" uploaded!`);
        } else {
          showToast(`Failed uploading "${file.name}": ` + (result.error || ""));
        }
      } catch (e) {
        showToast(`Network Error uploading "${file.name}"`);
      }
    }

    loadMediaCatalog();
  }

  // Initialize Replace Media Feature
  function initReplaceMedia() {
    const replaceBtn = document.getElementById("btn-replace-media");
    const replaceInput = document.getElementById("replace-file-input");
    if (!replaceBtn || !replaceInput) return;
    
    replaceBtn.onclick = (e) => {
      e.preventDefault();
      replaceInput.click();
    };
    
    replaceInput.onchange = async () => {
      if (replaceInput.files.length === 0 || !selectedAsset) return;
      
      const file = replaceInput.files[0];
      replaceBtn.disabled = true;
      replaceBtn.innerText = "Replacing file...";
      
      const formData = new FormData();
      formData.append("action", "replace");
      formData.append("url", selectedAsset.url);
      formData.append("file", file);
      
      try {
        const res = await fetch("/api/media-crud", {
          method: "POST",
          body: formData
        });
        const result = await res.json();
        if (result.success) {
          showToast("File replaced successfully!");
          selectedAsset = result.media;
          selectAssetItem(selectedAsset);
          loadMediaCatalog();
        } else {
          showToast("Replace failed: " + (result.error || ""));
        }
      } catch (e) {
        showToast("Network error replacing file");
      } finally {
        replaceBtn.disabled = false;
        replaceBtn.innerText = "Upload Replacement File";
        replaceInput.value = "";
      }
    };
  }

  // Initialize Canvas background remover tool
  function initBackgroundRemover() {
    const bgRemoverBtn = document.getElementById("bg-remover-btn");
    const bgRemoverWorkspace = document.getElementById("bg-remover-workspace");
    const previewContainer = document.getElementById("preview-image-container");
    const canvas = document.getElementById("bg-remover-canvas");
    const ctx = canvas.getContext("2d");
    const toleranceInput = document.getElementById("bg-remover-tolerance");
    const toleranceVal = document.getElementById("tolerance-val");
    
    if (!bgRemoverBtn) return;
    
    bgRemoverBtn.onclick = (e) => {
      e.preventDefault();
      if (!selectedAsset) return;
      previewContainer.style.display = "none";
      bgRemoverWorkspace.style.display = "flex";
      
      originalRemoverImg = new Image();
      if (selectedAsset.url.startsWith("http://") || selectedAsset.url.startsWith("https://")) {
        originalRemoverImg.crossOrigin = "Anonymous";
      }
      originalRemoverImg.onload = () => {
        canvas.width = originalRemoverImg.naturalWidth;
        canvas.height = originalRemoverImg.naturalHeight;
        ctx.drawImage(originalRemoverImg, 0, 0);
        currentRemoverData = ctx.getImageData(0, 0, canvas.width, canvas.height);
      };
      originalRemoverImg.src = selectedAsset.url + "?t=" + Date.now();
    };
    
    if (toleranceInput && toleranceVal) {
      toleranceInput.oninput = (e) => {
        toleranceVal.innerText = e.target.value;
      };
    }
    
    canvas.onclick = (e) => {
      if (!currentRemoverData) return;
      
      const rect = canvas.getBoundingClientRect();
      const x = Math.floor(((e.clientX - rect.left) / rect.width) * canvas.width);
      const y = Math.floor(((e.clientY - rect.top) / rect.height) * canvas.height);
      
      const idx = (y * canvas.width + x) * 4;
      const targetR = currentRemoverData.data[idx];
      const targetG = currentRemoverData.data[idx+1];
      const targetB = currentRemoverData.data[idx+2];
      const targetA = currentRemoverData.data[idx+3];
      
      if (targetA === 0) return; // already transparent
      
      const tolerance = parseInt(toleranceInput.value, 10);
      
      ctx.drawImage(originalRemoverImg, 0, 0);
      const imgData = ctx.getImageData(0, 0, canvas.width, canvas.height);
      const data = imgData.data;
      
      for (let i = 0; i < data.length; i += 4) {
        const r = data[i];
        const g = data[i+1];
        const b = data[i+2];
        const a = data[i+3];
        
        if (a === 0) continue;
        
        const dist = Math.sqrt(
          Math.pow(r - targetR, 2) +
          Math.pow(g - targetG, 2) +
          Math.pow(b - targetB, 2)
        );
        
        if (dist <= tolerance * 3) {
          data[i+3] = 0; // set alpha transparent
        }
      }
      
      ctx.putImageData(imgData, 0, 0);
    };
    
    const btnApply = document.getElementById("btn-apply-bg-remover");
    if (btnApply) {
      btnApply.onclick = () => {
        currentRemoverData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        showToast("Selection applied successfully!");
      };
    }
    
    const btnCancel = document.getElementById("btn-cancel-bg-remover");
    if (btnCancel) {
      btnCancel.onclick = () => {
        bgRemoverWorkspace.style.display = "none";
        previewContainer.style.display = "flex";
      };
    }
    
    const btnSave = document.getElementById("btn-save-bg-remover");
    if (btnSave) {
      btnSave.onclick = () => {
        if (!selectedAsset) return;
        btnSave.disabled = true;
        btnSave.innerText = "Saving...";
        
        canvas.toBlob(async (blob) => {
          const formData = new FormData();
          formData.append("action", "replace");
          formData.append("url", selectedAsset.url);
          formData.append("file", blob, selectedAsset.url.split("/").pop());
          
          try {
            const res = await fetch("/api/media-crud", {
              method: "POST",
              body: formData
            });
            const result = await res.json();
            if (result.success) {
              showToast("Background removed successfully!");
              bgRemoverWorkspace.style.display = "none";
              previewContainer.style.display = "flex";
              selectedAsset = result.media;
              selectAssetItem(selectedAsset);
              loadMediaCatalog();
            } else {
              showToast("Save failed: " + (result.error || ""));
            }
          } catch (e) {
            showToast("Network error saving transparent background image");
          } finally {
            btnSave.disabled = false;
            btnSave.innerText = "Save Transparent";
          }
        }, "image/png");
      };
    }
  }

  // File size format utility
  function formatBytes(bytes, decimals = 2) {
    if (bytes === 0) return "0 Bytes";
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ["Bytes", "KB", "MB", "GB"];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + " " + sizes[i];
  }

  // Toast banner utility
  const toast = document.getElementById("toast-notify");
  const toastMsg = document.getElementById("toast-message");
  
  function showToast(message) {
    if (toast && toastMsg) {
      toastMsg.innerText = message;
      toast.classList.add("active");
      setTimeout(() => {
        toast.classList.remove("active");
      }, 3000);
    }
  }

  document.addEventListener("DOMContentLoaded", initMediaLibrary);
  document.addEventListener("astro:page-load", initMediaLibrary);
  if (document.readyState === "interactive" || document.readyState === "complete") {
    initMediaLibrary();
  }
</script>
