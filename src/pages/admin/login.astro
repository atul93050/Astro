---
export const prerender = false;

// If already logged in, redirect immediately to admin dashboard
const session = Astro.cookies.get("cms_session")?.value;
if (session === "authenticated-admin-session-2026") {
  return Astro.redirect("/admin");
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login | Tangence CMS</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet">

  <style>
    :root {
      --primary: #6366F1;
      --primary-hover: #4F46E5;
      --bg-base: #080C14;
      --bg-surface: rgba(13, 19, 33, 0.75);
      --bg-surface-border: rgba(255, 255, 255, 0.06);
      --text-main: #F3F4F6;
      --text-muted: #9CA3AF;
      --border-color: rgba(255, 255, 255, 0.06);
      --input-bg: rgba(8, 12, 20, 0.85);
      --input-border: rgba(255, 255, 255, 0.08);
      --color-shadow: rgba(0, 0, 0, 0.4);
      --color-error: #EF4444;
      --radius-lg: 16px;
      --radius-sm: 8px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--bg-base);
      color: var(--text-main);
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      position: relative;
      overflow: hidden;
    }

    /* Ambient background glows */
    .glow-1 {
      position: absolute;
      top: -10%;
      right: -10%;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, rgba(99, 102, 241, 0) 70%);
      pointer-events: none;
    }
    .glow-2 {
      position: absolute;
      bottom: -10%;
      left: -10%;
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(16, 185, 129, 0.05) 0%, rgba(16, 185, 129, 0) 70%);
      pointer-events: none;
    }

    .login-container {
      width: 100%;
      max-width: 420px;
      background: var(--bg-surface);
      border: 1px solid var(--bg-surface-border);
      border-radius: var(--radius-lg);
      box-shadow: 0 10px 30px var(--color-shadow);
      backdrop-filter: blur(16px);
      padding: 2.5rem;
      z-index: 10;
      position: relative;
    }

    .login-header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .logo {
      width: 48px;
      height: 48px;
      background: linear-gradient(135deg, var(--primary) 0%, #a855f7 100%);
      border-radius: 12px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: 'Outfit', sans-serif;
      font-weight: 800;
      font-size: 1.65rem;
      color: white;
      box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
      margin-bottom: 1rem;
    }

    .login-header h2 {
      font-family: 'Outfit', sans-serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: white;
      margin-bottom: 0.35rem;
      letter-spacing: -0.01em;
    }

    .login-header p {
      font-size: 0.85rem;
      color: var(--text-muted);
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      margin-bottom: 1.25rem;
    }

    label {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    input {
      padding: 0.75rem 1rem;
      border-radius: var(--radius-sm);
      background-color: var(--input-bg);
      border: 1px solid var(--input-border);
      color: white;
      font-size: 0.92rem;
      outline: none;
      transition: all 0.2s ease;
      width: 100%;
    }

    input:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
    }

    .btn-login {
      width: 100%;
      padding: 0.75rem;
      background: linear-gradient(135deg, var(--primary) 0%, #4F46E5 100%);
      border: none;
      border-radius: var(--radius-sm);
      color: white;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      box-shadow: 0 4px 15px rgba(99, 102, 241, 0.25);
      transition: all 0.2s ease;
      margin-top: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }

    .btn-login:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(99, 102, 241, 0.35);
    }

    .btn-login:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .alert-banner {
      background: rgba(239, 68, 68, 0.08);
      border: 1px solid rgba(239, 68, 68, 0.15);
      color: var(--color-error);
      padding: 0.75rem 1rem;
      border-radius: var(--radius-sm);
      font-size: 0.85rem;
      margin-bottom: 1.25rem;
      display: none;
      align-items: center;
      gap: 0.5rem;
    }

    .alert-icon {
      font-weight: 700;
      flex-shrink: 0;
    }
  </style>
</head>
<body>
  <div class="glow-1"></div>
  <div class="glow-2"></div>

  <div class="login-container">
    
    <div class="login-header">
      <div class="logo">T</div>
      <h2>Tangence CMS Gate</h2>
      <p>Secure database-free administrator dashboard</p>
    </div>

    <!-- Alert error banner -->
    <div class="alert-banner" id="login-error-banner">
      <span class="alert-icon">✗</span>
      <span id="error-text">Invalid credentials</span>
    </div>

    <form id="admin-login-form" onsubmit="return false;">
      <div class="form-group">
        <label for="username">Email Address</label>
        <input type="email" id="username" placeholder="admin@tangence.com" required autocomplete="username" />
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" placeholder="••••••••••••" required autocomplete="current-password" />
      </div>

      <button type="submit" class="btn-login" id="submit-login-btn">
        <span id="btn-text">Sign In to Dashboard</span>
      </button>
    </form>

  </div>

  <script is:inline>
    function initLogin() {
      const form = document.getElementById("admin-login-form");
      if (!form) return;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const emailInput = document.getElementById("username");
        const passwordInput = document.getElementById("password");
        const submitBtn = document.getElementById("submit-login-btn");
        const btnText = document.getElementById("btn-text");
        const errorBanner = document.getElementById("login-error-banner");
        const errorText = document.getElementById("error-text");

        // Reset
        errorBanner.style.display = "none";
        submitBtn.disabled = true;
        btnText.innerText = "Signing In...";

        try {
          const res = await fetch("/api/login", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              username: emailInput.value.trim(),
              password: passwordInput.value
            })
          });
          const result = await res.json();

          if (result.success) {
            window.location.href = "/admin";
          } else {
            errorBanner.style.display = "flex";
            errorText.innerText = result.error || "Authentication failed";
            submitBtn.disabled = false;
            btnText.innerText = "Sign In to Dashboard";
          }
        } catch (err) {
          errorBanner.style.display = "flex";
          errorText.innerText = "Network connection failure. Please retry.";
          submitBtn.disabled = false;
          btnText.innerText = "Sign In to Dashboard";
        }
      });
    }

    document.addEventListener("DOMContentLoaded", initLogin);
    document.addEventListener("astro:page-load", initLogin);
    if (document.readyState === "interactive" || document.readyState === "complete") {
      initLogin();
    }
  </script>
</body>
</html>
