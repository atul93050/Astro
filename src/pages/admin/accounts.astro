---
import AdminLayout from "../../layouts/admin/AdminLayout.astro";

export const prerender = false;
---

<AdminLayout title="Admin Account Settings">
  
  <div class="settings-header" style="margin-bottom: 2rem;">
    <div class="header-text">
      <p class="subtitle" style="color:var(--text-muted); font-size:0.95rem; margin:0;">
        Manage credentials. Change admin passwords or register new administrator accounts.
      </p>
    </div>
  </div>

  <div class="settings-grid" style="display:grid; grid-template-columns: 1fr 1fr; gap:1.5rem; align-items:start; margin-bottom:6rem;">
    
    <!-- Change Password Card -->
    <div class="form-card">
      <div class="card-header">
        <h3>Change Password</h3>
      </div>
      <div class="card-body">
        <p class="section-desc" style="font-size:0.8rem; color:var(--text-dim); margin-top:-0.5rem; margin-bottom:1.5rem; line-height:1.4;">
          Select an administrator account and provide current credentials to update the password.
        </p>
        
        <div style="display:flex; flex-direction:column; gap:1rem;">
          <div class="form-group" style="display:flex; flex-direction:column; gap:0.4rem;">
            <label style="font-size:0.85rem; font-weight:600; color:var(--text-muted);">Select Admin Account</label>
            <select id="change-pass-username" style="font-size:0.9rem; padding:0.6rem 0.85rem; width:100%; border-radius:var(--radius-sm); background-color:var(--input-bg); border:1px solid var(--input-border); color:var(--text-main); outline:none;">
              <!-- Loaded dynamically -->
            </select>
          </div>
          <div class="form-group" style="display:flex; flex-direction:column; gap:0.4rem;">
            <label style="font-size:0.85rem; font-weight:600; color:var(--text-muted);">Current Password</label>
            <input type="password" id="change-pass-current" placeholder="Enter current password" style="width:100%; box-sizing:border-box; padding:0.65rem 0.85rem; border-radius:var(--radius-sm); background-color:var(--input-bg); border:1px solid var(--input-border); color:var(--text-main); outline:none;" />
          </div>
          <div class="form-group" style="display:flex; flex-direction:column; gap:0.4rem;">
            <label style="font-size:0.85rem; font-weight:600; color:var(--text-muted);">New Password</label>
            <input type="password" id="change-pass-new" placeholder="Enter new password" style="width:100%; box-sizing:border-box; padding:0.65rem 0.85rem; border-radius:var(--radius-sm); background-color:var(--input-bg); border:1px solid var(--input-border); color:var(--text-main); outline:none;" />
          </div>
          <button type="button" class="btn btn-outline" id="btn-change-password" style="align-self: flex-start; margin-top: 0.5rem; padding:0.6rem 1.5rem; font-size:0.9rem; font-weight:600; border-radius:var(--radius-sm); cursor:pointer;">
            Update Password
          </button>
        </div>
      </div>
    </div>

    <!-- Create New Admin Card -->
    <div class="form-card">
      <div class="card-header">
        <h3>Add New Administrator</h3>
      </div>
      <div class="card-body">
        <p class="section-desc" style="font-size:0.8rem; color:var(--text-dim); margin-top:-0.5rem; margin-bottom:1.5rem; line-height:1.4;">
          Register a new administrator email account. New admins can log in immediately.
        </p>
        
        <div style="display:flex; flex-direction:column; gap:1rem;">
          <div class="form-group" style="display:flex; flex-direction:column; gap:0.4rem;">
            <label style="font-size:0.85rem; font-weight:600; color:var(--text-muted);">Admin Email (Username)</label>
            <input type="text" id="new-admin-email" placeholder="e.g. atul@tangence.com" style="width:100%; box-sizing:border-box; padding:0.65rem 0.85rem; border-radius:var(--radius-sm); background-color:var(--input-bg); border:1px solid var(--input-border); color:var(--text-main); outline:none;" />
          </div>
          <div class="form-group" style="display:flex; flex-direction:column; gap:0.4rem;">
            <label style="font-size:0.85rem; font-weight:600; color:var(--text-muted);">Password</label>
            <input type="password" id="new-admin-password" placeholder="Enter secure password" style="width:100%; box-sizing:border-box; padding:0.65rem 0.85rem; border-radius:var(--radius-sm); background-color:var(--input-bg); border:1px solid var(--input-border); color:var(--text-main); outline:none;" />
          </div>
          <button type="button" class="btn btn-outline" id="btn-create-admin" style="align-self: flex-start; margin-top: 0.5rem; padding:0.6rem 1.5rem; font-size:0.9rem; font-weight:600; border-radius:var(--radius-sm); cursor:pointer;">
            Create Admin Account
          </button>
        </div>
      </div>
    </div>

  </div>

  <!-- Notification Banner -->
  <div class="toast-notification" id="toast-notify">
    <div class="toast-content">
      <span class="toast-message" id="toast-message">Success!</span>
    </div>
  </div>

</AdminLayout>

<script is:inline>
  function initAccounts() {
    loadAdminsList();
    setupControls();
  }

  function setupControls() {
    const changePassBtn = document.getElementById("btn-change-password");
    if (changePassBtn) {
      changePassBtn.addEventListener("click", changePasswordSubmit);
    }

    const createAdminBtn = document.getElementById("btn-create-admin");
    if (createAdminBtn) {
      createAdminBtn.addEventListener("click", createAdminSubmit);
    }
  }

  async function loadAdminsList() {
    try {
      const res = await fetch("/api/admin-users");
      const result = await res.json();
      if (result.success && result.users) {
        const select = document.getElementById("change-pass-username");
        if (select) {
          select.innerHTML = result.users.map(u => `<option value="${u.username}">${u.username} (${u.role})</option>`).join("");
        }
      }
    } catch (e) {
      console.error("Failed to load administrators list:", e);
    }
  }

  async function changePasswordSubmit() {
    const username = document.getElementById("change-pass-username").value;
    const currentPassword = document.getElementById("change-pass-current").value;
    const newPassword = document.getElementById("change-pass-new").value;

    if (!currentPassword || !newPassword) {
      showToast("Please fill in both current and new password fields.");
      return;
    }

    const changePassBtn = document.getElementById("btn-change-password");
    changePassBtn.disabled = true;
    changePassBtn.innerText = "Updating...";

    try {
      const res = await fetch("/api/admin-users", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ username, currentPassword, newPassword })
      });
      const data = await res.json();
      if (data.success) {
        showToast("Password updated successfully!");
        document.getElementById("change-pass-current").value = "";
        document.getElementById("change-pass-new").value = "";
      } else {
        showToast("Error: " + (data.error || "Update failed"));
      }
    } catch (e) {
      showToast("Network Error: Could not update password.");
    } finally {
      changePassBtn.disabled = false;
      changePassBtn.innerText = "Update Password";
    }
  }

  async function createAdminSubmit() {
    const username = document.getElementById("new-admin-email").value.trim();
    const password = document.getElementById("new-admin-password").value;

    if (!username || !password) {
      showToast("Please enter an email and password for the new admin.");
      return;
    }

    const createAdminBtn = document.getElementById("btn-create-admin");
    createAdminBtn.disabled = true;
    createAdminBtn.innerText = "Adding...";

    try {
      const res = await fetch("/api/admin-users", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ username, password })
      });
      const data = await res.json();
      if (data.success) {
        showToast("Administrator created successfully!");
        document.getElementById("new-admin-email").value = "";
        document.getElementById("new-admin-password").value = "";
        loadAdminsList();
      } else {
        showToast("Error: " + (data.error || "Failed to create administrator."));
      }
    } catch (e) {
      showToast("Network Error: Could not create administrator.");
    } finally {
      createAdminBtn.disabled = false;
      createAdminBtn.innerText = "Create Admin Account";
    }
  }

  function showToast(message) {
    const toast = document.getElementById("toast-notify");
    const toastMsg = document.getElementById("toast-message");
    if (toast && toastMsg) {
      toastMsg.innerText = message;
      toast.classList.add("visible");
      setTimeout(() => {
        toast.classList.remove("visible");
      }, 4000);
    }
  }

  // Hook layout on load
  document.addEventListener("DOMContentLoaded", initAccounts);
  document.addEventListener("astro:page-load", initAccounts);
  if (document.readyState === "interactive" || document.readyState === "complete") {
    initAccounts();
  }
</script>

<style is:global>
  .settings-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  @media (max-width: 1024px) {
    .settings-grid {
      grid-template-columns: 1fr;
    }
  }

  .form-card {
    background: var(--bg-surface);
    border: 1px solid var(--bg-surface-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 15px var(--color-shadow);
    backdrop-filter: blur(10px);
    overflow: hidden;
  }
  .card-header {
    padding: 1.15rem 1.5rem;
    border-bottom: 1px solid var(--bg-surface-border);
    background: rgba(156, 163, 175, 0.02);
  }
  .card-header h3 {
    font-size: 1.05rem;
    font-weight: 700;
  }
  .card-body {
    padding: 1.5rem;
  }
  .section-desc {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-top: -0.5rem;
    line-height: 1.4;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
  }
  input[type="text"], input[type="password"] {
    padding: 0.65rem 0.85rem;
    border-radius: var(--radius-sm);
    background-color: var(--input-bg);
    border: 1px solid var(--input-border);
    color: var(--text-main);
    font-size: 0.9rem;
    outline: none;
    transition: var(--transition);
    width: 100%;
    box-sizing: border-box;
  }
  input:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
  }

  /* Toast Notification */
  .toast-notification {
    position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9999;
    background: var(--bg-surface-solid); border: 1px solid var(--border-color);
    border-radius: 8px; padding: 0.85rem 1.25rem;
    box-shadow: 0 8px 30px rgba(0,0,0,0.35);
    transform: translateY(100px); opacity: 0;
    transition: transform 0.25s ease, opacity 0.25s ease;
    pointer-events: none;
  }
  .toast-notification.visible { transform: translateY(0); opacity: 1; }
  .toast-content { display: flex; align-items: center; gap: 0.5rem; }
  .toast-message { font-size: 0.88rem; color: var(--text-main); font-weight: 500; }
</style>
