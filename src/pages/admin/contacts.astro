---
import AdminLayout from "../../layouts/admin/AdminLayout.astro";
import fs from "node:fs";
import path from "node:path";
import { parse } from "yaml";

export const prerender = false;

// 1. Fetch all submissions from collection
const contactsDir = path.resolve("src/content/contacts");
if (!fs.existsSync(contactsDir)) {
  fs.mkdirSync(contactsDir, { recursive: true });
}

const files = fs.readdirSync(contactsDir).filter(f => f.endsWith(".md"));
const submissions = files.map(file => {
  const filePath = path.join(contactsDir, file);
  const content = fs.readFileSync(filePath, "utf-8");
  
  // Parse frontmatter
  const parts = content.split(/^---$/m);
  let data: any = {};
  let message = "";
  
  if (parts.length >= 3) {
    try {
      data = parse(parts[1]);
      message = parts.slice(2).join("---").trim();
    } catch (e) {
      console.error(`Error parsing contact YAML in ${file}:`, e);
    }
  }

  const name = data.name || "Anonymous";
  const email = data.email || "";
  const subject = data.subject || "No Subject";
  const rawSubmittedAt = data.submittedAt || fs.statSync(filePath).mtime.toISOString();
  const submittedAt = new Date(rawSubmittedAt).toLocaleString();
  
  return {
    filename: file,
    name,
    email,
    subject,
    message,
    submittedAt,
    timestamp: new Date(rawSubmittedAt).getTime()
  };
}).sort((a, b) => b.timestamp - a.timestamp); // Sort by newest submissions first
---

<AdminLayout title="Contacts Inbox">
  
  <div class="inbox-header">
    <div class="header-text">
      <p class="subtitle">Review and manage inquiry submissions captured by public contact forms. Stored locally.</p>
    </div>
  </div>

  <!-- Stats & Reports Overview -->
  <div class="stats-overview-container">
    <div class="stats-card">
      <div class="stats-card-icon text-primary">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
      </div>
      <div class="stats-card-details">
        <span class="stats-card-label">Total Leads</span>
        <h3 class="stats-card-value" id="stats-total-count">0</h3>
      </div>
    </div>
    
    <div class="stats-card">
      <div class="stats-card-icon text-success">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
      </div>
      <div class="stats-card-details">
        <span class="stats-card-label">Leads Today</span>
        <h3 class="stats-card-value" id="stats-today-count">0</h3>
      </div>
    </div>

    <div class="stats-card trend-card">
      <div class="stats-card-details">
        <span class="stats-card-label">Daily Lead Volume (Last 7 Days)</span>
        <div class="trend-chart" id="stats-trend-chart">
          <!-- Dynamically populated bars -->
        </div>
      </div>
    </div>
  </div>

  <div class="inbox-grid-layout">
    
    <!-- Main Inbox Table list -->
    <div class="inbox-list-container">
      <div class="controls-bar">
        <div class="search-input-wrap">
          <svg class="search-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          <input type="text" id="inbox-search" placeholder="Search by name, email, subject..." />
        </div>

        <div class="filter-controls-wrap">
          <select id="inbox-date-filter" class="admin-select-input" aria-label="Date filter preset">
            <option value="all">All Time</option>
            <option value="today">Today</option>
            <option value="yesterday">Yesterday</option>
            <option value="7days">Last 7 Days</option>
            <option value="30days">Last 30 Days</option>
            <option value="custom">Custom Range</option>
          </select>

          <div id="custom-date-inputs" class="custom-date-inputs" style="display: none;">
            <input type="date" id="filter-start-date" class="admin-date-input" title="Start Date" aria-label="Start Date" />
            <span class="date-sep">to</span>
            <input type="date" id="filter-end-date" class="admin-date-input" title="End Date" aria-label="End Date" />
          </div>

          <button type="button" id="export-csv-btn" class="btn btn-outline btn-sm btn-icon-export">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.35rem;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            Export CSV
          </button>
        </div>

        <span class="submissions-counter" id="inbox-counter">{submissions.length} submissions</span>
      </div>

      <div class="admin-table-wrapper" style="box-shadow: none;">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Sender</th>
              <th>Subject</th>
              <th>Date & Time</th>
              <th style="text-align: right;">Actions</th>
            </tr>
          </thead>
          <tbody id="inbox-tbody">
            {submissions.length === 0 ? (
              <tr id="empty-inbox-row">
                <td colspan="4" style="text-align: center; padding: 4rem; color: var(--text-dim);">
                  <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom: 1rem; opacity: 0.5;">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                  </svg>
                  <p style="font-weight: 600; font-size: 1.1rem; margin-bottom: 0.25rem;">Your Inbox is empty</p>
                  <p style="font-size: 0.85rem;">Inquiry submissions from public contact forms will appear here.</p>
                </td>
              </tr>
            ) : (
              submissions.map(msg => (
                <tr class="inbox-row" data-name={msg.name.toLowerCase()} data-email={msg.email.toLowerCase()} data-subject={msg.subject.toLowerCase()} data-filename={msg.filename}>
                  <td style="font-weight: 600;">
                    <div class="sender-cell">
                      <span class="sender-name">{msg.name}</span>
                      <span class="sender-email">{msg.email}</span>
                    </div>
                  </td>
                  <td>
                    <div class="subject-wrap">
                      <span class="subject-text">{msg.subject}</span>
                      <span class="subject-snippet">{msg.message.length > 55 ? `${msg.message.substring(0, 55)}...` : msg.message}</span>
                    </div>
                  </td>
                  <td style="color: var(--text-muted); font-size: 0.82rem; font-weight: 500;">{msg.submittedAt}</td>
                  <td style="text-align: right;">
                    <div class="actions-cell">
                      <button type="button" class="btn-action view-msg-btn" data-filename={msg.filename} title="Read Message Details">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                      </button>
                      <button type="button" class="btn-action delete-msg-btn" data-filename={msg.filename} title="Delete submission file">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                      </button>
                    </div>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Right Side Drawer: Message Content viewer panel -->
    <div class="message-details-drawer" id="inbox-drawer">
      <div class="drawer-header">
        <h4>Submission Details</h4>
        <button type="button" class="btn-icon-sm" id="close-inbox-drawer-btn" style="border:none;">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>

      <div class="drawer-body" id="inbox-drawer-content" style="display:none;">
        <div class="inbox-meta-card">
          <div class="meta-row">
            <span class="label">From:</span>
            <strong id="msg-sender-name">Atul Verma</strong>
          </div>
          <div class="meta-row">
            <span class="label">Email:</span>
            <a href="" id="msg-sender-email" style="color:var(--primary); text-decoration:underline;">atul@example.com</a>
          </div>
          <div class="meta-row">
            <span class="label">Date:</span>
            <span id="msg-submitted-at" style="color:var(--text-muted); font-size:0.85rem;">2026-06-01 15:30</span>
          </div>
          <div class="meta-row">
            <span class="label">Subject:</span>
            <span id="msg-subject" style="font-weight:600; color:var(--text-main);">Paid Ad Audit</span>
          </div>
        </div>

        <div class="inbox-message-content">
          <h5>Message Body</h5>
          <blockquote id="msg-body">
            <!-- Injected dynamic message -->
          </blockquote>
        </div>

        <div class="drawer-footer-actions">
          <a href="" id="reply-email-btn" class="btn btn-primary btn-sm" style="text-align:center;">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:0.25rem;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            Reply via Email
          </a>
          <button type="button" class="btn btn-danger btn-sm btn-outline" id="delete-drawer-msg-btn" style="background-color:rgba(239, 68, 68, 0.08); border-color:var(--color-error); color:var(--color-error);">
            Delete Message Permanently
          </button>
        </div>
      </div>

      <div class="drawer-fallback" id="inbox-drawer-fallback">
        <p>Select any contact record from the inbox grid list to read its detailed brief submission and compose replies.</p>
      </div>
    </div>

  </div>

  <!-- Notification Banner -->
  <div class="toast-notification" id="toast-notify">
    <div class="toast-content">
      <span class="toast-message" id="toast-message">Message deleted permanently!</span>
    </div>
  </div>

</AdminLayout>

<style>
  .subtitle {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-top: 0.25rem;
    margin-bottom: 2rem;
  }

  .inbox-grid-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 1.5rem;
    align-items: start;
  }
  @media (max-width: 1024px) {
    .inbox-grid-layout {
      grid-template-columns: 1fr;
    }
  }

  .inbox-list-container {
    background: var(--bg-surface);
    border: 1px solid var(--bg-surface-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: 0 4px 15px var(--color-shadow);
    backdrop-filter: blur(10px);
  }

  /* Table Specific cells */
  .sender-cell {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .sender-name {
    font-size: 0.92rem;
    color: var(--text-main);
  }
  .sender-email {
    font-size: 0.76rem;
    color: var(--text-dim);
    font-weight: 500;
  }
  .subject-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .subject-text {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text-main);
  }
  .subject-snippet {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .actions-cell {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
  }
  .btn-action {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-color);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: var(--transition);
  }
  .view-msg-btn:hover {
    background-color: var(--primary-light);
    color: var(--primary);
    border-color: var(--primary);
  }
  .delete-msg-btn:hover {
    background-color: rgba(239, 68, 68, 0.1);
    color: var(--color-error);
    border-color: var(--color-error);
  }

  /* Controls */
  .controls-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .search-input-wrap {
    position: relative;
    flex: 1;
    min-width: 250px;
    max-width: 400px;
  }
  .search-icon {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-dim);
    pointer-events: none;
  }
  .search-input-wrap input {
    width: 100%;
    padding: 0.55rem 0.85rem 0.55rem 2.25rem;
    border-radius: var(--radius-sm);
    background-color: var(--input-bg);
    border: 1px solid var(--input-border);
    color: var(--text-main);
    font-size: 0.88rem;
    transition: var(--transition);
  }
  .search-input-wrap input:focus {
    outline: none;
    border-color: var(--primary);
  }
  .submissions-counter {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-dim);
    padding: 0.25rem 0.65rem;
    background: rgba(156, 163, 175, 0.08);
    border: 1px solid var(--border-color);
    border-radius: 12px;
  }

  /* Details Drawer Right Sidebar */
  .message-details-drawer {
    background: var(--bg-surface);
    border: 1px solid var(--bg-surface-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 15px var(--color-shadow);
    backdrop-filter: blur(10px);
    overflow: hidden;
    position: sticky;
    top: 1.5rem;
  }
  .drawer-header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--bg-surface-border);
    background: rgba(156, 163, 175, 0.02);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .drawer-header h4 {
    font-size: 0.95rem;
    font-weight: 700;
  }
  .drawer-body {
    padding: 1.25rem;
  }
  .drawer-fallback {
    padding: 4rem 1.5rem;
    text-align: center;
    color: var(--text-dim);
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .inbox-meta-card {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .meta-row {
    display: flex;
    font-size: 0.85rem;
  }
  .meta-row .label {
    width: 65px;
    color: var(--text-dim);
    font-weight: 600;
    flex-shrink: 0;
  }
  .meta-row strong, .meta-row span, .meta-row a {
    word-break: break-all;
  }

  .inbox-message-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .inbox-message-content h5 {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }
  .inbox-message-content blockquote {
    background: var(--bg-surface-solid);
    border-left: 3px solid var(--primary);
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    border-right: 1px solid var(--border-color);
    padding: 0.85rem;
    border-radius: 4px;
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--text-muted);
    white-space: pre-wrap;
    font-family: inherit;
    min-height: 120px;
  }

  .drawer-footer-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    padding-top: 1rem;
  }

  /* Toast Notification */
  .toast-notification {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: var(--bg-surface-solid);
    border-left: 4px solid var(--primary);
    border-top: 1px solid var(--bg-surface-border);
    border-bottom: 1px solid var(--bg-surface-border);
    border-right: 1px solid var(--bg-surface-border);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-sm);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35);
    z-index: 1100;
    transform: translateY(150%);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(8px);
  }
  .toast-notification.active {
    transform: translateY(0);
  }
  .toast-content {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-main);
  }

  /* Stats Cards Styles */
  .stats-overview-container {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 900px) {
    .stats-overview-container {
      grid-template-columns: 1fr;
    }
  }
  .stats-card {
    background: var(--bg-surface);
    border: 1px solid var(--bg-surface-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    box-shadow: 0 4px 12px var(--color-shadow);
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .stats-card-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(156, 163, 175, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .text-primary {
    color: var(--primary);
  }
  .text-success {
    color: var(--color-success, #10b981);
  }
  .stats-card-details {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .stats-card-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .stats-card-value {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text-main);
    margin: 0;
  }

  /* Trend Chart Chart Bars */
  .trend-card {
    display: block !important;
  }
  .trend-card .stats-card-details {
    width: 100%;
  }
  .trend-chart {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    height: 52px;
    margin-top: 0.5rem;
    gap: 0.5rem;
  }
  .trend-bar-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    gap: 0.25rem;
  }
  .trend-bar-container {
    width: 16px;
    height: 38px;
    background: rgba(156, 163, 175, 0.15);
    border-radius: 4px;
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
  }
  .trend-bar {
    width: 100%;
    background: var(--primary);
    border-radius: 4px;
    transition: height 0.3s ease;
    cursor: help;
    min-height: 0px;
  }
  .trend-bar:hover {
    background: var(--primary-light, #a01c1c);
  }
  .trend-bar-label {
    font-size: 0.68rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  /* Filter Controls */
  .filter-controls-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .admin-select-input {
    padding: 0.55rem 1.8rem 0.55rem 0.75rem;
    border-radius: var(--radius-sm);
    background-color: var(--input-bg);
    border: 1px solid var(--input-border);
    color: var(--text-main);
    font-size: 0.88rem;
    font-weight: 500;
    outline: none;
    cursor: pointer;
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 0.5rem center;
    background-repeat: no-repeat;
    background-size: 1.25em 1.25em;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
  }
  .admin-select-input:focus {
    border-color: var(--primary);
  }
  .custom-date-inputs {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .admin-date-input {
    padding: 0.45rem 0.6rem;
    border-radius: var(--radius-sm);
    background-color: var(--input-bg);
    border: 1px solid var(--input-border);
    color: var(--text-main);
    font-size: 0.82rem;
    font-weight: 500;
    outline: none;
  }
  .admin-date-input:focus {
    border-color: var(--primary);
  }
  .date-sep {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 600;
  }
  .btn-icon-export {
    display: inline-flex;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.55rem 0.85rem;
    border: 1px solid var(--border-color);
    background: transparent;
    color: var(--text-main);
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: var(--transition);
  }
  .btn-icon-export:hover {
    background-color: rgba(156, 163, 175, 0.08);
    border-color: var(--text-muted);
  }
</style>

<script is:inline define:vars={{ submissions }}>
  let activeMsg = null;

  function initInbox() {
    const table = document.getElementById("inbox-tbody");
    if (!table || table.dataset.listenerBound) return;
    table.dataset.listenerBound = "true";

    calculateStats();
    setupFilters();
    setupDrawerHandlers();
  }

  function calculateStats() {
    // 1. Total Leads
    const totalCount = submissions.length;
    const totalEl = document.getElementById("stats-total-count");
    if (totalEl) totalEl.innerText = totalCount;

    // 2. Leads Today
    const now = new Date();
    const startOfToday = new Date(now.getFullYear(), now.getMonth(), now.getDate()).getTime();
    const todayCount = submissions.filter(s => s.timestamp >= startOfToday).length;
    const todayEl = document.getElementById("stats-today-count");
    if (todayEl) todayEl.innerText = todayCount;

    // 3. Daily Lead Volume (Last 7 Days Chart)
    const trendChart = document.getElementById("stats-trend-chart");
    if (trendChart) {
      trendChart.innerHTML = "";
      
      // Inline styles to ensure chart layout works regardless of cached CSS
      trendChart.style.display = "flex";
      trendChart.style.justifyContent = "space-between";
      trendChart.style.alignItems = "flex-end";
      trendChart.style.height = "52px";
      trendChart.style.marginTop = "0.5rem";
      trendChart.style.gap = "0.5rem";
      
      const days = [];
      for (let i = 6; i >= 0; i--) {
        const d = new Date();
        d.setDate(now.getDate() - i);
        const startOfDay = new Date(d.getFullYear(), d.getMonth(), d.getDate()).getTime();
        const endOfDay = startOfDay + 24 * 60 * 60 * 1000 - 1;
        const count = submissions.filter(s => s.timestamp >= startOfDay && s.timestamp <= endOfDay).length;
        
        const dayLabel = d.toLocaleDateString("en-US", { day: "numeric", month: "short" });
        days.push({ label: dayLabel, count, dateStr: d.toISOString().split("T")[0] });
      }

      const maxCount = Math.max(...days.map(d => d.count), 1);

      days.forEach(day => {
        const pct = (day.count / maxCount) * 100;
        
        const wrapper = document.createElement("div");
        wrapper.className = "trend-bar-wrapper";
        wrapper.style.display = "flex";
        wrapper.style.flexDirection = "column";
        wrapper.style.alignItems = "center";
        wrapper.style.flex = "1";
        wrapper.style.gap = "0.25rem";
        
        const barContainer = document.createElement("div");
        barContainer.className = "trend-bar-container";
        barContainer.style.width = "16px";
        barContainer.style.height = "38px";
        barContainer.style.backgroundColor = "rgba(156, 163, 175, 0.25)";
        barContainer.style.borderRadius = "4px";
        barContainer.style.display = "flex";
        barContainer.style.alignItems = "flex-end";
        barContainer.style.position = "relative";
        barContainer.style.overflow = "hidden";
        
        const bar = document.createElement("div");
        bar.className = "trend-bar";
        bar.style.width = "100%";
        bar.style.height = `${pct}%`;
        bar.style.backgroundColor = "var(--primary)";
        bar.style.borderRadius = "4px";
        bar.style.transition = "height 0.3s ease";
        bar.title = `${day.dateStr}: ${day.count} lead${day.count === 1 ? "" : "s"}`;
        
        const label = document.createElement("span");
        label.className = "trend-bar-label";
        label.innerText = day.label;
        label.style.fontSize = "0.68rem";
        label.style.color = "var(--text-muted)";
        label.style.fontWeight = "600";
        
        barContainer.appendChild(bar);
        wrapper.appendChild(barContainer);
        wrapper.appendChild(label);
        trendChart.appendChild(wrapper);
      });
    }
  }

  function setupFilters() {
    const searchInput = document.getElementById("inbox-search");
    const dateFilter = document.getElementById("inbox-date-filter");
    const startDateInput = document.getElementById("filter-start-date");
    const endDateInput = document.getElementById("filter-end-date");
    const exportBtn = document.getElementById("export-csv-btn");

    if (searchInput) searchInput.addEventListener("input", applyFilters);
    if (dateFilter) dateFilter.addEventListener("change", applyFilters);
    if (startDateInput) startDateInput.addEventListener("change", applyFilters);
    if (endDateInput) endDateInput.addEventListener("change", applyFilters);
    if (exportBtn) exportBtn.addEventListener("click", exportToCSV);
  }

  function applyFilters() {
    const searchInput = document.getElementById("inbox-search");
    const dateFilter = document.getElementById("inbox-date-filter");
    const customDateInputs = document.getElementById("custom-date-inputs");
    const startDateInput = document.getElementById("filter-start-date");
    const endDateInput = document.getElementById("filter-end-date");
    
    const rows = document.querySelectorAll(".inbox-row");
    const emptyRow = document.getElementById("empty-inbox-row");
    const counter = document.getElementById("inbox-counter");

    if (!dateFilter) return;

    const q = searchInput ? searchInput.value.toLowerCase().trim() : "";
    const filterVal = dateFilter.value;

    if (filterVal === "custom") {
      customDateInputs.style.display = "flex";
    } else {
      customDateInputs.style.display = "none";
    }

    let startTimestamp = 0;
    let endTimestamp = Infinity;
    const now = new Date();

    if (filterVal === "today") {
      startTimestamp = new Date(now.getFullYear(), now.getMonth(), now.getDate()).getTime();
    } else if (filterVal === "yesterday") {
      const yesterday = new Date();
      yesterday.setDate(now.getDate() - 1);
      startTimestamp = new Date(yesterday.getFullYear(), yesterday.getMonth(), yesterday.getDate()).getTime();
      endTimestamp = startTimestamp + 24 * 60 * 60 * 1000 - 1;
    } else if (filterVal === "7days") {
      const sevenDaysAgo = new Date();
      sevenDaysAgo.setDate(now.getDate() - 7);
      startTimestamp = new Date(sevenDaysAgo.getFullYear(), sevenDaysAgo.getMonth(), sevenDaysAgo.getDate()).getTime();
    } else if (filterVal === "30days") {
      const thirtyDaysAgo = new Date();
      thirtyDaysAgo.setDate(now.getDate() - 30);
      startTimestamp = new Date(thirtyDaysAgo.getFullYear(), thirtyDaysAgo.getMonth(), thirtyDaysAgo.getDate()).getTime();
    } else if (filterVal === "custom") {
      if (startDateInput && startDateInput.value) {
        startTimestamp = new Date(startDateInput.value + "T00:00:00").getTime();
      }
      if (endDateInput && endDateInput.value) {
        endTimestamp = new Date(endDateInput.value + "T23:59:59").getTime();
      }
    }

    let visibleCount = 0;

    rows.forEach(row => {
      const name = row.getAttribute("data-name") || "";
      const email = row.getAttribute("data-email") || "";
      const subject = row.getAttribute("data-subject") || "";
      const filename = row.getAttribute("data-filename");

      const msg = submissions.find(s => s.filename === filename);
      const timestamp = msg ? msg.timestamp : 0;

      const textMatch = name.includes(q) || email.includes(q) || subject.includes(q);
      const dateMatch = timestamp >= startTimestamp && timestamp <= endTimestamp;

      if (textMatch && dateMatch) {
        row.style.display = "";
        visibleCount++;
      } else {
        row.style.display = "none";
      }
    });

    if (counter) counter.innerText = `${visibleCount} submissions`;
    if (emptyRow) emptyRow.style.display = (visibleCount === 0 && rows.length > 0) ? "" : "none";
  }

  function exportToCSV() {
    const visibleRows = Array.from(document.querySelectorAll(".inbox-row")).filter(row => row.style.display !== "none");
    
    if (visibleRows.length === 0) {
      showToast("No leads matching filters to export.");
      return;
    }

    const headers = ["Name", "Email", "Subject", "Submitted At", "Message"];
    const csvRows = [headers.join(",")];

    visibleRows.forEach(row => {
      const filename = row.getAttribute("data-filename");
      const msg = submissions.find(s => s.filename === filename);
      if (msg) {
        const name = `"${msg.name.replace(/"/g, '""')}"`;
        const email = `"${msg.email.replace(/"/g, '""')}"`;
        const subject = `"${msg.subject.replace(/"/g, '""')}"`;
        const date = `"${msg.submittedAt.replace(/"/g, '""')}"`;
        const message = `"${msg.message.replace(/"/g, '""').replace(/\r?\n/g, ' ')}"`;
        
        csvRows.push([name, email, subject, date, message].join(","));
      }
    });

    const csvString = csvRows.join("\n");
    const blob = new Blob([csvString], { type: "text/csv;charset=utf-8;" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.setAttribute("href", url);
    const dateStr = new Date().toISOString().split("T")[0];
    link.setAttribute("download", `tangence-leads-${dateStr}.csv`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    showToast("Leads exported successfully to CSV!");
  }

  // Bind Details Drawer panel clicks
  function setupDrawerHandlers() {
    const closeBtn = document.getElementById("close-inbox-drawer-btn");
    if (closeBtn) closeBtn.addEventListener("click", closeInboxDrawer);

    // Dynamic row clicks
    document.querySelectorAll(".inbox-row").forEach(row => {
      row.addEventListener("click", (e) => {
        // Prevent trigger if clicking delete button inside cell
        if (e.target.closest(".delete-msg-btn")) return;
        
        const filename = row.getAttribute("data-filename");
        const msg = submissions.find(s => s.filename === filename);
        if (msg) selectMessage(row, msg);
      });
    });

    // Delete row buttons clicks
    document.querySelectorAll(".delete-msg-btn").forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const filename = btn.getAttribute("data-filename");
        triggerDeleteMessage(filename);
      });
    });

    // Delete inside drawer button click
    const drawerDeleteBtn = document.getElementById("delete-drawer-msg-btn");
    if (drawerDeleteBtn) {
      drawerDeleteBtn.addEventListener("click", () => {
        if (activeMsg) triggerDeleteMessage(activeMsg.filename);
      });
    }
  }

  function selectMessage(rowEl, msg) {
    activeMsg = msg;
    
    // Highlight Row
    document.querySelectorAll(".inbox-row").forEach(el => el.classList.remove("active-selected"));
    rowEl.classList.add("active-selected");

    const fallback = document.getElementById("inbox-drawer-fallback");
    const content = document.getElementById("inbox-drawer-content");

    if (fallback) fallback.style.display = "none";
    if (content) content.style.display = "block";

    // Fill Meta
    document.getElementById("msg-sender-name").innerText = msg.name;
    
    const emailLink = document.getElementById("msg-sender-email");
    emailLink.href = `mailto:${msg.email}`;
    emailLink.innerText = msg.email;
    
    document.getElementById("msg-submitted-at").innerText = msg.submittedAt;
    document.getElementById("msg-subject").innerText = msg.subject;
    document.getElementById("msg-body").innerText = msg.message;

    // Compose Reply link mailto
    const replyLink = document.getElementById("reply-email-btn");
    replyLink.href = `mailto:${msg.email}?subject=RE: ${encodeURIComponent(msg.subject)}`;
  }

  function closeInboxDrawer() {
    activeMsg = null;
    document.querySelectorAll(".inbox-row").forEach(el => el.classList.remove("active-selected"));
    
    const fallback = document.getElementById("inbox-drawer-fallback");
    const content = document.getElementById("inbox-drawer-content");

    if (fallback) fallback.style.display = "block";
    if (content) content.style.display = "none";
  }

  // Delete message execution API trigger
  function triggerDeleteMessage(filename) {
    window.customConfirm("Are you sure you want to permanently delete this contact submission file? This cannot be undone.", async () => {
      showToast("Deleting submission record...");

      try {
        const res = await fetch("/api/contact-delete", {
          method: "DELETE",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ filename })
        });
        const data = await res.json();

        if (data.success) {
          showToast("Submission deleted permanently!");
          closeInboxDrawer();
          setTimeout(() => {
            window.location.reload();
          }, 1000);
        } else {
          showToast("Error: " + data.error);
        }
      } catch (e) {
        showToast("Network Error: Could not delete message record.");
      }
    });
  }

  // Toast banner utility
  const toast = document.getElementById("toast-notify");
  const toastMsg = document.getElementById("toast-message");
  
  function showToast(message) {
    if (toast && toastMsg) {
      toastMsg.innerText = message;
      toast.classList.add("active");
      setTimeout(() => {
        toast.classList.remove("active");
      }, 3000);
    }
  }

  // Bind init functions
  document.addEventListener("DOMContentLoaded", initInbox);
  document.addEventListener("astro:page-load", initInbox);
  if (document.readyState === "interactive" || document.readyState === "complete") {
    initInbox();
  }
</script>
