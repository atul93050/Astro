  <!-- Notification Banner -->
  <div class="toast-notification" id="toast-notify">
    <div class="toast-content">
      <span class="toast-message" id="toast-message">Page saved successfully!</span>
    </div>
  </div>

  <!-- Client-Side Controller & Interactivity -->
  <script is:inline>
    function initCMS() {
      const cmsForm = document.getElementById("cms-form");
      if (!cmsForm || cmsForm.classList.contains("cms-js-active")) return;
      cmsForm.classList.add("cms-js-active");

      // 1. Tab Switching Controller
      const tabButtons = document.querySelectorAll(".tab-btn");
      const sections = document.querySelectorAll(".form-section");

      tabButtons.forEach(btn => {
        btn.addEventListener("click", () => {
          const tabId = btn.getAttribute("data-tab");

          tabButtons.forEach(b => b.classList.remove("active"));
          sections.forEach(s => s.classList.remove("active"));

          btn.classList.add("active");
          document.getElementById(`tab-${tabId}`).classList.add("active");
        });
      });

      // 2. Real-time SEO Scoring & Character Counter logic
      const seoTitleInput = document.getElementById("seoTitle");
      const seoDescInput = document.getElementById("seoDescription");
      const seoKeywordInput = document.getElementById("seoFocusKeyword");
      const seoCanonicalInput = document.getElementById("seoCanonical");
      const seoOgImageInput = document.getElementById("seoOgImage");
      const seoSchemaTypeSelect = document.getElementById("seoSchemaType");
      const seoSchemaMarkupInput = document.getElementById("seoSchemaMarkup");
      const customSchemaGroup = document.getElementById("custom-schema-group");
      
      const previewTitle = document.getElementById("google-preview-title");
      const previewDesc = document.getElementById("google-preview-desc");

      function updateSeoIndicators() {
        const titleVal = seoTitleInput ? seoTitleInput.value.trim() : "";
        const descVal = seoDescInput ? seoDescInput.value.trim() : "";
        const keywordVal = seoKeywordInput ? seoKeywordInput.value.trim().toLowerCase() : "";
        const canonicalVal = seoCanonicalInput ? seoCanonicalInput.value.trim() : "";
        const ogImageVal = seoOgImageInput ? seoOgImageInput.value.trim() : "";
        const schemaTypeVal = seoSchemaTypeSelect ? seoSchemaTypeSelect.value : "none";
        const schemaMarkupVal = seoSchemaMarkupInput ? seoSchemaMarkupInput.value.trim() : "";

        // Mirror previews
        if (previewTitle) previewTitle.textContent = titleVal || "Page Title";
        if (previewDesc) previewDesc.textContent = descVal || "Please provide a meta description...";

        let score = 0;
        const checks = [];

        // Title Check (25 pts)
        if (titleVal.length > 0) {
          if (titleVal.length >= 30 && titleVal.length <= 60) {
            score += 25;
            checks.push({ name: "Meta Title length is perfect (30-60 chars)", passed: true });
          } else {
            score += 10;
            checks.push({ name: "Meta Title length should be between 30 and 60 chars (currently " + titleVal.length + " chars)", passed: false });
          }
        } else {
          checks.push({ name: "Meta Title is missing", passed: false });
        }

        // Description Check (25 pts)
        if (descVal.length > 0) {
          if (descVal.length >= 120 && descVal.length <= 160) {
            score += 25;
            checks.push({ name: "Meta Description length is perfect (120-160 chars)", passed: true });
          } else {
            score += 10;
            checks.push({ name: "Meta Description length should be between 120 and 160 chars (currently " + descVal.length + " chars)", passed: false });
          }
        } else {
          checks.push({ name: "Meta Description is missing", passed: false });
        }

        // Keyword Check (20 pts)
        if (keywordVal.length > 0) {
          score += 10;
          checks.push({ name: "Focus Keyword provided", passed: true });
          
          const keywordInTitle = titleVal.toLowerCase().includes(keywordVal);
          const keywordInDesc = descVal.toLowerCase().includes(keywordVal);

          if (keywordInTitle) {
            score += 5;
            checks.push({ name: "Focus keyword found in Meta Title", passed: true });
          } else {
            checks.push({ name: "Focus keyword not found in Meta Title", passed: false });
          }

          if (keywordInDesc) {
            score += 5;
            checks.push({ name: "Focus keyword found in Meta Description", passed: true });
          } else {
            checks.push({ name: "Focus keyword not found in Meta Description", passed: false });
          }
        } else {
          checks.push({ name: "Focus Keyword is missing", passed: false });
        }

        // Canonical URL Check (10 pts)
        if (canonicalVal.length > 0) {
          score += 10;
          checks.push({ name: "Canonical URL provided", passed: true });
        } else {
          checks.push({ name: "Canonical URL is missing (recommended)", passed: false });
        }

        // OG Image URL Check (10 pts)
        if (ogImageVal.length > 0) {
          score += 10;
          checks.push({ name: "Open Graph (OG) Image URL provided", passed: true });
        } else {
          checks.push({ name: "Open Graph (OG) Image is missing", passed: false });
        }

        // JSON-LD Schema Check (10 pts)
        if (schemaTypeVal !== "none") {
          if (schemaTypeVal === "custom") {
            if (schemaMarkupVal.length > 0) {
              try {
                JSON.parse(schemaMarkupVal);
                score += 10;
                checks.push({ name: "Custom JSON-LD Schema markup is valid JSON", passed: true });
              } catch(e) {
                checks.push({ name: "Custom JSON-LD Schema markup is NOT valid JSON", passed: false });
              }
            } else {
              checks.push({ name: "Custom JSON-LD Schema markup is empty", passed: false });
            }
          } else {
            score += 10;
            checks.push({ name: "JSON-LD Schema Type set to " + schemaTypeVal, passed: true });
          }
        } else {
          checks.push({ name: "JSON-LD Schema structured data is missing", passed: false });
        }

        // Update Score Circle and Ring
        const scoreRing = document.getElementById("seo-score-ring");
        const scoreText = document.getElementById("seo-score-text");
        const healthText = document.getElementById("seo-health-text");

        if (scoreRing) {
          scoreRing.setAttribute("stroke-dasharray", `${score}, 100`);
          
          let strokeColor = "var(--color-error) || #EF4444";
          let health = "Poor SEO";
          if (score >= 80) {
            strokeColor = "var(--color-success) || #10B981";
            health = "Excellent SEO";
          } else if (score >= 50) {
            strokeColor = "var(--color-warning) || #F59E0B";
            health = "Needs Tweaks";
          }
          
          scoreRing.style.stroke = strokeColor;
          if (healthText) {
            healthText.innerText = health;
            healthText.style.color = strokeColor;
          }
        }

        if (scoreText) scoreText.innerText = `${score}%`;

        // Render Checklist
        const checksList = document.getElementById("seo-checks-list");
        if (checksList) {
          checksList.innerHTML = checks.map(c => `
            <li style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.78rem; color: var(--text-muted) || #9CA3AF;">
              <span class="seo-check-icon" style="color: ${c.passed ? 'var(--color-success) || #10B981' : 'var(--color-error) || #EF4444'}; font-weight: bold;">
                ${c.passed ? '✓' : '✗'}
              </span>
              <span>${c.name}</span>
            </li>
          `).join('');
        }
      }

      // Bind Listeners
      if (seoTitleInput) seoTitleInput.addEventListener("input", updateSeoIndicators);
      if (seoDescInput) seoDescInput.addEventListener("input", updateSeoIndicators);
      if (seoKeywordInput) seoKeywordInput.addEventListener("input", updateSeoIndicators);
      if (seoCanonicalInput) seoCanonicalInput.addEventListener("input", updateSeoIndicators);
      if (seoOgImageInput) seoOgImageInput.addEventListener("input", updateSeoIndicators);
      if (seoSchemaMarkupInput) seoSchemaMarkupInput.addEventListener("input", updateSeoIndicators);
      if (seoSchemaTypeSelect) {
        seoSchemaTypeSelect.addEventListener("change", () => {
          if (customSchemaGroup) {
            customSchemaGroup.style.display = seoSchemaTypeSelect.value !== "none" ? "block" : "none";
          }
          updateSeoIndicators();
        });
        if (customSchemaGroup) {
          customSchemaGroup.style.display = seoSchemaTypeSelect.value !== "none" ? "block" : "none";
        }
      }

      // Initial run
      updateSeoIndicators();

      // 3. Image Upload Local Object Preview
      function setupImagePreview(fileInputId, imgPreviewId) {
        const input = document.getElementById(fileInputId);
        const img = document.getElementById(imgPreviewId);
        
        if (input && img) {
          input.addEventListener("change", function() {
            const file = this.files[0];
            if (file) {
              const reader = new FileReader();
              reader.onload = function(e) {
                img.src = e.target.result;
              }
              reader.readAsDataURL(file);
            }
          });
        }
      }

      setupImagePreview("heroImageFile", "preview-hero");
      setupImagePreview("missionImageFile", "preview-mission");
      setupImagePreview("visionImageFile", "preview-vision");

      // Dynamic photo preview listener for dynamic team members
      document.addEventListener("change", function(e) {
        if (e.target && e.target.classList.contains("member-file-input")) {
          const file = e.target.files[0];
          if (file) {
            const img = e.target.closest(".member-photo-preview").querySelector(".preview-team");
            if (img) {
              const reader = new FileReader();
              reader.onload = function(ev) {
                img.src = ev.target.result;
              }
              reader.readAsDataURL(file);
            }
          }
        }
      });

      // 4. Dynamic Team Member Management
      const teamList = document.getElementById("team-list");
      const addMemberBtn = document.getElementById("add-member-btn");

      function updateTeamIndices() {
        if (!teamList) return;
        const cards = teamList.querySelectorAll(".team-member-card");
        cards.forEach((card, index) => {
          card.setAttribute("data-index", index);
          card.querySelector("h4").textContent = `Member #${index + 1}`;
        });
      }

      if (addMemberBtn && teamList) {
        // Add Member click
        addMemberBtn.addEventListener("click", () => {
          const index = teamList.querySelectorAll(".team-member-card").length;
          
          const newCard = document.createElement("div");
          newCard.className = "team-member-card";
          newCard.setAttribute("data-index", index);
          newCard.innerHTML = `
            <div class="member-card-header">
              <h4>Member #${index + 1}</h4>
              <button type="button" class="remove-member-btn" title="Remove Member">&times;</button>
            </div>
            <div class="member-card-body">
              <div class="form-group">
                <label>Full Name <span class="required">*</span></label>
                <input type="text" name="teamName[]" placeholder="e.g. Atul Verma" required />
              </div>
              <div class="form-group">
                <label>Job Title <span class="required">*</span></label>
                <input type="text" name="teamRole[]" placeholder="e.g. Founder & CEO" required />
              </div>
              <div class="form-group">
                <label>Short Bio</label>
                <textarea name="teamBio[]" rows="2" placeholder="Brief tagline or description..."></textarea>
              </div>
              <div class="form-group image-upload-group">
                <label>Member Photo</label>
                <div class="member-photo-preview">
                  <img class="preview-team" src="/uploads/team-placeholder.png" />
                  <div class="photo-inputs">
                    <input type="text" name="teamImageExisting[]" value="" class="hidden-path-input" readonly />
                    <input type="file" name="teamImageFile[]" accept="image/*" class="member-file-input" />
                  </div>
                </div>
              </div>
            </div>
          `;
          
          teamList.appendChild(newCard);
          newCard.scrollIntoView({ behavior: "smooth", block: "center" });
        });

        // Remove Member click delegated
        teamList.addEventListener("click", (e) => {
          if (e.target && e.target.classList.contains("remove-member-btn")) {
            const card = e.target.closest(".team-member-card");
            if (card) {
              card.classList.add("removing");
              card.style.opacity = "0";
              card.style.transform = "scale(0.9)";
              setTimeout(() => {
                card.remove();
                updateTeamIndices();
              }, 200);
            }
          }
        });
      }

      // 5. Async CMS Form Submission via Fetch API
      const statusAlert = document.getElementById("status-alert");
      const saveButton = document.getElementById("save-button");

      function showAlert(type, title, desc) {
        if (!statusAlert) return;
        statusAlert.className = `alert alert-${type}`;
        statusAlert.querySelector(".alert-title").textContent = title;
        statusAlert.querySelector(".alert-desc").textContent = desc;
        window.scrollTo({ top: 0, behavior: "smooth" });
      }

      if (statusAlert) {
        const closeBtn = statusAlert.querySelector(".alert-close");
        if (closeBtn) {
          closeBtn.addEventListener("click", () => {
            statusAlert.classList.add("hidden");
          });
        }
      }

      // Explicitly trigger form validation and submit on saveButton click
      if (saveButton) {
        saveButton.addEventListener("click", (e) => {
          e.preventDefault();
          cmsForm.requestSubmit();
        });
      }

      cmsForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!saveButton) return;

        // Show loader state
        const origBtnContent = saveButton.innerHTML;
        saveButton.disabled = true;
        saveButton.innerHTML = `<svg class="spinner" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3" style="animation: spin 1s linear infinite;"><circle cx="12" cy="12" r="10" opacity="0.25"></circle><path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"></path></svg> Saving...`;

        // Clear previous inputs error messages
        document.querySelectorAll(".error-msg").forEach(el => el.textContent = "");

        const formData = new FormData(cmsForm);

        try {
          const response = await fetch("/api/about-update", {
            method: "POST",
            body: formData
          });

          const data = await response.json();

          if (response.ok && data.success) {
            showAlert("success", "Success!", data.message || "About Us content has been successfully updated on disk.");
            setTimeout(() => {
              window.location.reload();
            }, 1200);
          } else {
            showAlert("error", "Updates Failed", "Please check your inputs and try again.");
            if (data.errors) {
              Object.keys(data.errors).forEach(key => {
                const errSpan = document.getElementById(`err-${key}`);
                if (errSpan) {
                  errSpan.textContent = data.errors[key];
                }
              });
            }
          }
        } catch (err) {
          console.error("Fetch submit error:", err);
          showAlert("error", "System Exception", "An unexpected error occurred while communicating with the server.");
        } finally {
          setTimeout(() => {
            saveButton.disabled = false;
            saveButton.innerHTML = origBtnContent;
          }, 1000);
        }
      // 6. Schema Type Selector Toggle
      const schemaTypeSelect = document.getElementById("seoSchemaType");
      const customSchemaGroup = document.getElementById("custom-schema-group");
      if (schemaTypeSelect && customSchemaGroup) {
        schemaTypeSelect.addEventListener("change", () => {
          customSchemaGroup.style.display = schemaTypeSelect.value !== "none" ? "block" : "none";
        });
        // Initial trigger on load
        customSchemaGroup.style.display = schemaTypeSelect.value !== "none" ? "block" : "none";
      }

      // 7. Media Selector Modal Controller
      let activeMediaPickerTarget = "";
      const toast = document.getElementById("toast-notify");
      const toastMsg = document.getElementById("toast-message");

      function showToast(message) {
        if (toast && toastMsg) {
          toastMsg.innerText = message;
          toast.classList.add("active");
          setTimeout(() => {
            toast.classList.remove("active");
          }, 3000);
        }
      }

      function openMediaModal(targetId) {
        activeMediaPickerTarget = targetId;
        const modal = document.getElementById("media-picker-overlay");
        if (modal) modal.classList.add("active");
        loadMediaCatalogGrid();
      }

      function hideMediaModal() {
        const modal = document.getElementById("media-picker-overlay");
        if (modal) modal.classList.remove("active");
        activeMediaPickerTarget = "";
      }

      async function loadMediaCatalogGrid() {
        const grid = document.getElementById("media-picker-grid");
        if (!grid) return;

        try {
          const res = await fetch("/api/media-crud");
          const data = await res.json();

          if (data.success && data.media.length > 0) {
            grid.innerHTML = data.media.map(item => `
              <div class="media-picker-item" onclick="selectMediaAsset('${item.url}')" title="${item.alt || item.title}">
                <img src="${item.url}" alt="${item.alt || ''}" />
              </div>
            `).join('');
          } else {
            grid.innerHTML = `<p class="media-empty">No catalog images. Upload a new asset.</p>`;
          }
        } catch (e) {
          grid.innerHTML = `<p class="media-empty" style="color:var(--color-error);">Error loading media catalog files.</p>`;
        }
      }

      window.selectMediaAsset = function(url) {
        if (activeMediaPickerTarget) {
          const targetInput = document.getElementById(activeMediaPickerTarget);
          if (targetInput) {
            targetInput.value = url;
            const changeEvent = new Event('input', { bubbles: true });
            targetInput.dispatchEvent(changeEvent);
          }
          hideMediaModal();
        }
      };

      async function uploadMediaFile() {
        const fileInput = document.getElementById("media-upload-file");
        const uploadBtn = document.getElementById("upload-media-btn");
        const fileSelectBtn = document.getElementById("trigger-file-select");

        if (!fileInput || fileInput.files.length === 0) return;

        const file = fileInput.files[0];
        const formData = new FormData();
        formData.append("file", file);
        formData.append("alt", file.name.split(".")[0]);

        uploadBtn.disabled = true;
        uploadBtn.innerText = "Uploading...";

        try {
          const res = await fetch("/api/media-crud", {
            method: "POST",
            body: formData
          });
          const result = await res.json();

          if (result.success) {
            showToast("Asset uploaded successfully!");
            fileInput.value = "";
            fileSelectBtn.innerText = "Choose Upload File";
            uploadBtn.innerText = "Upload";
            selectMediaAsset(result.media.url);
          } else {
            showToast("Error: " + (result.error || "Upload failed"));
            uploadBtn.disabled = false;
            uploadBtn.innerText = "Upload";
          }
        } catch (e) {
          showToast("Network Error: Could not upload file asset");
          uploadBtn.disabled = false;
          uploadBtn.innerText = "Upload";
        }
      }

      const closePickerX = document.getElementById("close-media-modal");
      const closePickerBtn = document.getElementById("close-media-picker-btn");
      if (closePickerX) closePickerX.addEventListener("click", hideMediaModal);
      if (closePickerBtn) closePickerBtn.addEventListener("click", hideMediaModal);

      const fileSelectBtn = document.getElementById("trigger-file-select");
      const fileInput = document.getElementById("media-upload-file");
      const uploadBtn = document.getElementById("upload-media-btn");

      if (fileSelectBtn && fileInput) {
        fileSelectBtn.addEventListener("click", () => fileInput.click());
        fileInput.addEventListener("change", () => {
          if (fileInput.files.length > 0) {
            fileSelectBtn.innerText = fileInput.files[0].name;
            if (uploadBtn) uploadBtn.disabled = false;
          } else {
            fileSelectBtn.innerText = "Choose Upload File";
            if (uploadBtn) uploadBtn.disabled = true;
          }
        });
      }

      if (uploadBtn) {
        uploadBtn.addEventListener("click", uploadMediaFile);
      }

      document.addEventListener("click", (e) => {
        if (e.target && e.target.classList.contains("media-picker-trigger")) {
          const targetId = e.target.getAttribute("data-target");
          openMediaModal(targetId);
        }
      });
    }

    // Initialize CMS hooks on DOM ready & View Transitions reload
    document.addEventListener("DOMContentLoaded", initCMS);
    document.addEventListener("astro:page-load", initCMS);
    // Safe execution check in case script is loaded dynamically
    if (document.readyState === "interactive" || document.readyState === "complete") {
      initCMS();
    }
  </script>

  <style is:global>
    /* CSS animations and spinner styling */
    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    .spinner {
      animation: spin 1s linear infinite;
    }
    .team-member-card.removing {
      transition: all 0.2s ease;
    }
  </style>
</AdminLayout>
