---
import AdminLayout from "../../layouts/admin/AdminLayout.astro";
import fs from "node:fs";
import path from "node:path";

export const prerender = false;

// Read the markdown file directly from disk to avoid cache delays
const markdownPath = path.resolve("src/content/about/about.md");
let fileContent = "";
try {
  fileContent = fs.readFileSync(markdownPath, "utf-8");
} catch (e) {
  // If file doesn't exist, use fallback content
  fileContent = `---
title: "About Us"
seoTitle: "About Us"
seoDescription: ""
hero:
  title: ""
  description: ""
  image: ""
mission:
  title: ""
  description: ""
  image: ""
vision:
  title: ""
  description: ""
  image: ""
team: []
---
`;
}

// Custom simple robust YAML parser to load data into the form
function parseYAML(yaml: string) {
  const lines = yaml.split("\n");
  const result: any = {
    title: "",
    seoTitle: "",
    seoDescription: "",
    seoFocusKeyword: "",
    seoCanonical: "",
    seoRobots: "",
    seoOgTitle: "",
    seoOgDescription: "",
    seoOgImage: "",
    seoTwitterCard: "",
    seoSchemaType: "",
    seoSchemaMarkup: "",
    hero: { title: "", description: "", image: "" },
    mission: { title: "", description: "", image: "" },
    vision: { title: "", description: "", image: "" },
    team: [],
  };

  let currentSection = "";
  let currentMember: any = null;

  const cleanVal = (val: string) => {
    let clean = val.trim();
    if (clean.startsWith('"') && clean.endsWith('"')) {
      clean = clean.substring(1, clean.length - 1);
    } else if (clean.startsWith("'") && clean.endsWith("'")) {
      clean = clean.substring(1, clean.length - 1);
    }
    return clean.replace(/\\"/g, '"').replace(/\\n/g, "\n");
  };

  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) continue;

    // Detect section header
    if (trimmed === "hero:") {
      currentSection = "hero";
      continue;
    } else if (trimmed === "mission:") {
      currentSection = "mission";
      continue;
    } else if (trimmed === "vision:") {
      currentSection = "vision";
      continue;
    } else if (trimmed === "team:") {
      currentSection = "team";
      continue;
    }

    // Match standard key-value
    const kvMatch = trimmed.match(/^([a-zA-Z0-9_]+)\s*:\s*(.*)$/);
    if (kvMatch) {
      const key = kvMatch[1];
      const val = cleanVal(kvMatch[2]);

      // If root fields
      if (!currentSection) {
        if (key === "title" || key === "seoTitle" || key === "seoDescription" || key === "seoFocusKeyword" || key === "seoCanonical" || key === "seoRobots" || key === "seoOgTitle" || key === "seoOgDescription" || key === "seoOgImage" || key === "seoTwitterCard" || key === "seoSchemaType" || key === "seoSchemaMarkup") {
          result[key] = val;
        }
      } else if (currentSection === "hero" || currentSection === "mission" || currentSection === "vision") {
        if (key === "title" || key === "description" || key === "image") {
          result[currentSection][key] = val;
        }
      }
    } else if (trimmed.startsWith("-") && currentSection === "team") {
      // Start of a team list item
      const itemContent = trimmed.substring(1).trim();
      const kv = itemContent.match(/^([a-zA-Z0-9_]+)\s*:\s*(.*)$/);
      currentMember = { name: "", role: "", bio: "", image: "" };
      if (kv) {
        currentMember[kv[1]] = cleanVal(kv[2]);
      }
      result.team.push(currentMember);
    } else if (currentMember && currentSection === "team") {
      // Inside a team list item
      const kv = trimmed.match(/^([a-zA-Z0-9_]+)\s*:\s*(.*)$/);
      if (kv) {
        currentMember[kv[1]] = cleanVal(kv[2]);
      }
    }
  }

  return result;
}

const match = fileContent.match(/^---\r?\n([\s\S]*?)\r?\n---\r?\n([\s\S]*)$/);
const yamlString = match ? match[1] : "";
const markdownBody = match ? match[2].trim() : fileContent.trim();
const cmsData = parseYAML(yamlString);
---

<AdminLayout title="Edit About Us Page">
  <div class="cms-header">
    <div class="cms-title-area">
      <span class="badge">CMS Core</span>
      <h1>Edit About Us</h1>
      <p class="subtitle">Modify sections, manage team members, and optimize SEO meta fields without a database.</p>
    </div>
    <div class="cms-actions-area">
      <a href="/about-us" target="_blank" class="btn btn-outline">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
        View Live Page
      </a>
      <button type="submit" form="cms-form" class="btn btn-primary" id="save-button">
        <svg class="icon-save" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
        <span>Save Changes</span>
      </button>
    </div>
  </div>

  <!-- Notification Banner -->
  <div id="status-alert" class="alert hidden">
    <div class="alert-icon"></div>
    <div class="alert-content">
      <h4 class="alert-title"></h4>
      <p class="alert-desc"></p>
    </div>
    <button class="alert-close">&times;</button>
  </div>

  <!-- Main Grid Form -->
  <form id="cms-form" method="POST" enctype="multipart/form-data" class="cms-grid-layout">
    <!-- Left Navigation Sticky Tabs -->
    <div class="cms-tabs">
      <button type="button" class="tab-btn active" data-tab="hero">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
        Hero Section
      </button>
      <button type="button" class="tab-btn" data-tab="mission-vision">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
        Mission & Vision
      </button>
      <button type="button" class="tab-btn" data-tab="team">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
        Team Section
      </button>
      <button type="button" class="tab-btn" data-tab="seo">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
        SEO & Metadata
      </button>
      <button type="button" class="tab-btn" data-tab="body">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
        Page Story Content
      </button>
    </div>

    <!-- Main Content Form Cards -->
    <div class="cms-form-content">
      
      <!-- HERO TAB -->
      <div class="form-section active" id="tab-hero">
        <div class="card">
          <div class="card-header">
            <h3>General & Hero Section</h3>
            <p>Define the core page header details and primary CTA image.</p>
          </div>
          <div class="card-body">
            <div class="form-group">
              <label for="title">Page Title <span class="required">*</span></label>
              <input type="text" id="title" name="title" value={cmsData.title} placeholder="e.g. About Us" required />
              <span class="error-msg" id="err-title"></span>
            </div>

            <div class="form-group">
              <label for="heroTitle">Hero Title <span class="required">*</span></label>
              <input type="text" id="heroTitle" name="heroTitle" value={cmsData.hero.title} placeholder="e.g. Built for the long game" required />
              <span class="error-msg" id="err-heroTitle"></span>
            </div>

            <div class="form-group">
              <label for="heroDescription">Hero Description <span class="required">*</span></label>
              <textarea id="heroDescription" name="heroDescription" rows="4" placeholder="Enter brief hero introduction..." required>{cmsData.hero.description}</textarea>
              <span class="error-msg" id="err-heroDescription"></span>
            </div>

            <div class="form-group image-upload-group">
              <label>Hero Featured Image</label>
              <div class="image-preview-container">
                <img id="preview-hero" src={cmsData.hero.image || "/uploads/about-hero.png"} alt="Hero Preview" />
                <div class="image-inputs">
                  <input type="text" name="heroImageExisting" value={cmsData.hero.image} class="hidden-path-input" readonly />
                  <input type="file" id="heroImageFile" name="heroImageFile" accept="image/*" class="file-input" />
                  <span class="input-tip">Click to upload a new image or leave blank to keep current.</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- MISSION & VISION TAB -->
      <div class="form-section" id="tab-mission-vision">
        <div class="card">
          <div class="card-header">
            <h3>Our Mission</h3>
            <p>Outline the short term goal and fundamental values.</p>
          </div>
          <div class="card-body">
            <div class="form-group">
              <label for="missionTitle">Mission Title <span class="required">*</span></label>
              <input type="text" id="missionTitle" name="missionTitle" value={cmsData.mission.title} placeholder="e.g. Our Mission" required />
              <span class="error-msg" id="err-missionTitle"></span>
            </div>

            <div class="form-group">
              <label for="missionDescription">Mission Description <span class="required">*</span></label>
              <textarea id="missionDescription" name="missionDescription" rows="4" placeholder="Describe the mission statement..." required>{cmsData.mission.description}</textarea>
              <span class="error-msg" id="err-missionDescription"></span>
            </div>

            <div class="form-group image-upload-group">
              <label>Mission Section Image</label>
              <div class="image-preview-container">
                <img id="preview-mission" src={cmsData.mission.image || "/uploads/mission.png"} alt="Mission Preview" />
                <div class="image-inputs">
                  <input type="text" name="missionImageExisting" value={cmsData.mission.image} class="hidden-path-input" readonly />
                  <input type="file" id="missionImageFile" name="missionImageFile" accept="image/*" class="file-input" />
                  <span class="input-tip">Upload section graphic.</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="card" style="margin-top: 2rem;">
          <div class="card-header">
            <h3>Our Vision</h3>
            <p>Describe the future objective and long-term legacy.</p>
          </div>
          <div class="card-body">
            <div class="form-group">
              <label for="visionTitle">Vision Title <span class="required">*</span></label>
              <input type="text" id="visionTitle" name="visionTitle" value={cmsData.vision.title} placeholder="e.g. Our Vision" required />
              <span class="error-msg" id="err-visionTitle"></span>
            </div>

            <div class="form-group">
              <label for="visionDescription">Vision Description <span class="required">*</span></label>
              <textarea id="visionDescription" name="visionDescription" rows="4" placeholder="Describe the vision statement..." required>{cmsData.vision.description}</textarea>
              <span class="error-msg" id="err-visionDescription"></span>
            </div>

            <div class="form-group image-upload-group">
              <label>Vision Section Image</label>
              <div class="image-preview-container">
                <img id="preview-vision" src={cmsData.vision.image || "/uploads/vision.png"} alt="Vision Preview" />
                <div class="image-inputs">
                  <input type="text" name="visionImageExisting" value={cmsData.vision.image} class="hidden-path-input" readonly />
                  <input type="file" id="visionImageFile" name="visionImageFile" accept="image/*" class="file-input" />
                  <span class="input-tip">Upload section graphic.</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- TEAM TAB -->
      <div class="form-section" id="tab-team">
        <div class="card">
          <div class="card-header flex-header">
            <div>
              <h3>Team Members</h3>
              <p>Add, edit, or remove staff displayed on the About Us page.</p>
            </div>
            <button type="button" class="btn btn-outline btn-sm" id="add-member-btn">
              + Add Member
            </button>
          </div>
          <div class="card-body">
            <div id="team-list" class="team-grid">
              <!-- Team Member Subcards injected dynamically & rendered initially -->
              {cmsData.team.map((member: any, index: number) => (
                <div class="team-member-card" data-index={index}>
                  <div class="member-card-header">
                    <h4>Member #{index + 1}</h4>
                    <button type="button" class="remove-member-btn" title="Remove Member">&times;</button>
                  </div>
                  <div class="member-card-body">
                    <div class="form-group">
                      <label>Full Name <span class="required">*</span></label>
                      <input type="text" name="teamName[]" value={member.name} placeholder="e.g. Atul Verma" required />
                    </div>
                    <div class="form-group">
                      <label>Job Title <span class="required">*</span></label>
                      <input type="text" name="teamRole[]" value={member.role} placeholder="e.g. Founder & CEO" required />
                    </div>
                    <div class="form-group">
                      <label>Short Bio</label>
                      <textarea name="teamBio[]" rows="2" placeholder="Brief tagline or description...">{member.bio}</textarea>
                    </div>
                    <div class="form-group image-upload-group">
                      <label>Member Photo</label>
                      <div class="member-photo-preview">
                        <img class="preview-team" src={member.image || "/uploads/team-placeholder.png"} />
                        <div class="photo-inputs">
                          <input type="text" name="teamImageExisting[]" value={member.image} class="hidden-path-input" readonly />
                          <input type="file" name="teamImageFile[]" accept="image/*" class="member-file-input" />
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- SEO TAB -->
      <div class="form-section" id="tab-seo">
        <div class="card">
          <div class="card-header">
            <h3>SEO & Metadata Optimization</h3>
            <p>Optimize your search engine rankings and snippet preview.</p>
          </div>
          <div class="card-body">
            <div class="form-group">
              <label for="seoTitle">SEO Title <span class="required">*</span></label>
              <input type="text" id="seoTitle" name="seoTitle" value={cmsData.seoTitle} placeholder="Search snippet title" required />
              <span class="error-msg" id="err-seoTitle"></span>
            </div>

            <div class="form-group">
              <label for="seoDescription">SEO Meta Description <span class="required">*</span></label>
              <textarea id="seoDescription" name="seoDescription" rows="4" placeholder="Brief search index snippet description..." required>{cmsData.seoDescription}</textarea>
              <span class="error-msg" id="err-seoDescription"></span>
            </div>

            <div class="form-group">
              <label for="seoFocusKeyword">Focus Keyword</label>
              <input type="text" id="seoFocusKeyword" name="seoFocusKeyword" value={cmsData.seoFocusKeyword || ""} placeholder="e.g. digital agency" />
            </div>

            <!-- Collapsible Advanced SEO Controls -->
            <details class="advanced-details" style="margin-top: 1.5rem; cursor: pointer;">
              <summary style="font-weight: 600; color: var(--primary); outline: none;">Advanced SEO Configurations</summary>
              
              <div class="form-group" style="margin-top:1rem;">
                <label for="seoCanonical">Canonical URL</label>
                <input type="url" id="seoCanonical" name="seoCanonical" value={cmsData.seoCanonical || ""} placeholder="https://www.tangence.in/about-us" />
              </div>

              <div class="form-group">
                <label for="seoRobots">Robots Meta</label>
                <input type="text" id="seoRobots" name="seoRobots" value={cmsData.seoRobots || "index, follow"} placeholder="index, follow" />
              </div>

              <div class="form-group">
                <label for="seoOgTitle">OG Title</label>
                <input type="text" id="seoOgTitle" name="seoOgTitle" value={cmsData.seoOgTitle || ""} />
              </div>

              <div class="form-group">
                <label for="seoOgDescription">OG Description</label>
                <textarea id="seoOgDescription" name="seoOgDescription" rows="2">{cmsData.seoOgDescription || ""}</textarea>
              </div>

              <div class="form-group">
                <label for="seoOgImage">OG Image URL</label>
                <div class="input-picker-wrap" style="display:flex; gap:0.4rem;">
                  <input type="text" id="seoOgImage" name="seoOgImage" value={cmsData.seoOgImage || ""} style="flex:1;" />
                  <button type="button" class="btn btn-outline btn-sm media-picker-trigger" data-target="seoOgImage">Pick</button>
                </div>
              </div>

              <div class="form-group">
                <label for="seoTwitterCard">Twitter Card</label>
                <select id="seoTwitterCard" name="seoTwitterCard">
                  <option value="summary" selected={cmsData.seoTwitterCard === "summary"}>Summary</option>
                  <option value="summary_large_image" selected={cmsData.seoTwitterCard === "summary_large_image" || !cmsData.seoTwitterCard}>Summary Large Image</option>
                </select>
              </div>

              <div class="form-group">
                <label for="seoSchemaType">JSON-LD Schema Type</label>
                <select id="seoSchemaType" name="seoSchemaType">
                  <option value="none" selected={cmsData.seoSchemaType === "none" || !cmsData.seoSchemaType}>None (Auto / Omit)</option>
                  <option value="organization" selected={cmsData.seoSchemaType === "organization"}>Organization</option>
                  <option value="faq" selected={cmsData.seoSchemaType === "faq"}>FAQ Page Schema</option>
                  <option value="article" selected={cmsData.seoSchemaType === "article"}>Article Details</option>
                  <option value="custom" selected={cmsData.seoSchemaType === "custom"}>Custom Input</option>
                </select>
              </div>

              <div class="form-group" id="custom-schema-group" style="display:none;">
                <label for="seoSchemaMarkup">JSON-LD Schema Markup</label>
                <textarea id="seoSchemaMarkup" name="seoSchemaMarkup" rows="4" placeholder="JSON format structured markup payload">{cmsData.seoSchemaMarkup || ""}</textarea>
              </div>
            </details>

            <!-- Real-time SEO checklist warnings widget -->
            <div class="seo-score-meter-wrap" style="margin-top: 1.5rem; display: flex; align-items: center; gap: 1.25rem; background: rgba(156, 163, 175, 0.03); padding: 0.85rem; border-radius: 8px; border: 1px solid var(--border-color) || rgba(255,255,255,0.08);">
              <div class="seo-gauge" style="width: 65px; height: 65px; flex-shrink: 0;">
                <svg viewBox="0 0 36 36" class="circular-chart" style="display: block; max-width: 100%; max-height: 100%;">
                  <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" style="fill: none; stroke: rgba(156, 163, 175, 0.1); stroke-width: 2.8;"></path>
                  <path class="circle" id="seo-score-ring" stroke-dasharray="0, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" style="fill: none; stroke-width: 2.8; stroke-linecap: round; transition: stroke-dasharray 0.35s ease;"></path>
                  <text x="18" y="20.35" class="percentage" id="seo-score-text" style="fill: white; font-weight: 700; font-size: 9px; text-anchor: middle;">0%</text>
                </svg>
              </div>
              <div class="seo-score-label" style="display: flex; flex-direction: column;">
                <span id="seo-health-text" style="font-size: 0.92rem; font-weight: 700;">Not Rated</span>
              </div>
            </div>

            <div class="seo-checklist" style="margin-top: 1.25rem; border-top: 1px solid var(--border-color) || rgba(255,255,255,0.08); padding-top: 1rem;">
              <h5 style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.05em; margin-bottom: 0.5rem;">SEO Checklist</h5>
              <ul id="seo-checks-list" style="list-style: none; display: flex; flex-direction: column; gap: 0.4rem; padding-left: 0;">
                <!-- JS loaded dynamically -->
              </ul>
            </div>

            <!-- SEO Preview Card -->
            <div class="seo-preview-card" style="margin-top:1.5rem;">
              <span class="preview-url">www.tangence.in &rsaquo; about-us</span>
              <h4 id="google-preview-title" class="preview-title">{cmsData.seoTitle || "Page Title"}</h4>
              <p id="google-preview-desc" class="preview-desc">{cmsData.seoDescription || "Please provide a meta description to see how this page will display in Google Search Results."}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- BODY CONTENT TAB -->
      <div class="form-section" id="tab-body">
        <div class="card">
          <div class="card-header">
            <h3>Markdown Body Content</h3>
            <p>Edit the rich-text story content at the bottom of the page in markdown.</p>
          </div>
          <div class="card-body">
            <div class="form-group">
              <label for="body">Our Story Markdown Body</label>
              <textarea id="body" name="body" rows="15" class="code-textarea" placeholder="# Our Story\n\nWrite your rich markdown here...">{markdownBody}</textarea>
              <span class="input-tip">Markdown headers, lists, links, and styling are fully supported and compiled.</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </form>

  <style>
    /* CMS Page Layout Styling */
    .cms-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2.5rem;
      border-bottom: 1px solid var(--bg-surface-border);
      padding-bottom: 1.5rem;
    }

    .cms-title-area h1 {
      font-size: 2.2rem;
      font-weight: 800;
      color: white;
      margin-top: 0.25rem;
    }

    .badge {
      background: var(--primary-light);
      color: var(--primary);
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border: 1px solid rgba(99, 102, 241, 0.2);
    }

    .subtitle {
      color: var(--text-muted);
      font-size: 0.95rem;
      margin-top: 0.25rem;
    }

    .cms-actions-area {
      display: flex;
      gap: 1rem;
    }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
