---
import AdminLayout from '../../../layouts/admin/AdminLayout.astro';

export const prerender = false;
---

<AdminLayout title="Blog Categories">

  <!-- Page Header -->
  <div class="cats-header">
    <div class="cats-header-text">
      <p class="cats-subtitle">
        Organise your blog posts into categories. Assign a name, slug, description and a colour accent to each category.
      </p>
    </div>
  </div>

  <!-- Two-Column Layout -->
  <div class="cats-layout">

    <!-- LEFT COLUMN: Create / Edit Form -->
    <div class="cats-form-col">
      <div class="form-card">
        <div class="card-header">
          <div class="card-header-inner">
            <div class="card-header-icon">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 5v14M5 12h14"/>
              </svg>
            </div>
            <h3 id="form-title">New Category</h3>
          </div>
        </div>

        <div class="card-body">
          <form id="cat-form" onsubmit="return false;">
            <input type="hidden" id="edit-id" value="" />

            <!-- Name -->
            <div class="field-group">
              <label for="cat-name">Category Name <span class="required-star">*</span></label>
              <input
                type="text"
                id="cat-name"
                placeholder="e.g. Web Development"
                autocomplete="off"
              />
            </div>

            <!-- Slug -->
            <div class="field-group">
              <label for="cat-slug">Slug <span class="required-star">*</span></label>
              <div class="slug-field-wrap">
                <span class="slug-prefix">/blog/</span>
                <input
                  type="text"
                  id="cat-slug"
                  placeholder="web-development"
                  autocomplete="off"
                  style="border-radius: 0 var(--radius-sm) var(--radius-sm) 0 !important; border-left: none !important;"
                />
              </div>
              <span class="field-help">Auto-generated from name. You can edit manually.</span>
            </div>

            <!-- Description -->
            <div class="field-group">
              <label for="cat-description">Description</label>
              <textarea
                id="cat-description"
                rows="3"
                placeholder="Brief description of this category…"
                style="resize: vertical; min-height: 80px;"
              ></textarea>
            </div>

            <!-- Color -->
            <div class="field-group">
              <label for="cat-color">Accent Color</label>
              <div class="color-field-wrap">
                <input
                  type="color"
                  id="cat-color"
                  value="#6366F1"
                />
                <span id="cat-color-hex" class="color-hex-label">#6366F1</span>
                <div class="color-presets">
                  <button type="button" class="color-preset-dot" data-color="#6366F1" style="background:#6366F1;" title="Indigo"></button>
                  <button type="button" class="color-preset-dot" data-color="#10B981" style="background:#10B981;" title="Emerald"></button>
                  <button type="button" class="color-preset-dot" data-color="#3B82F6" style="background:#3B82F6;" title="Blue"></button>
                  <button type="button" class="color-preset-dot" data-color="#F59E0B" style="background:#F59E0B;" title="Amber"></button>
                  <button type="button" class="color-preset-dot" data-color="#EF4444" style="background:#EF4444;" title="Red"></button>
                  <button type="button" class="color-preset-dot" data-color="#8B5CF6" style="background:#8B5CF6;" title="Violet"></button>
                  <button type="button" class="color-preset-dot" data-color="#EC4899" style="background:#EC4899;" title="Pink"></button>
                  <button type="button" class="color-preset-dot" data-color="#14B8A6" style="background:#14B8A6;" title="Teal"></button>
                </div>
              </div>
            </div>

            <!-- Form Actions -->
            <div class="form-actions">
              <button type="button" id="btn-cancel-edit" class="btn btn-outline" style="display:none;">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                Cancel
              </button>
              <button type="submit" id="btn-save-cat" class="btn btn-primary" form="cat-form">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                <span id="btn-save-label">Save Category</span>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- RIGHT COLUMN: Categories Table -->
    <div class="cats-table-col">
      <div class="admin-table-wrapper">
        <div class="table-top-bar">
          <div class="table-top-left">
            <h3 class="table-title">All Categories</h3>
            <span class="cat-count-badge" id="cat-count-badge">0</span>
          </div>
          <button class="btn btn-outline btn-sm" id="btn-refresh" title="Refresh list">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
            Refresh
          </button>
        </div>

        <div id="table-loading" class="table-loading-state">
          <div class="loading-spinner"></div>
          <span>Loading categories…</span>
        </div>

        <div id="table-empty" class="table-empty-state" style="display:none;">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--text-dim); margin-bottom:0.75rem;"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
          <p>No categories found. Create your first one!</p>
        </div>

        <table class="admin-table" id="cats-table" style="display:none;">
          <thead>
            <tr>
              <th style="width:40px;"></th>
              <th>Name</th>
              <th>Slug</th>
              <th>Description</th>
              <th style="text-align:center;">Posts</th>
              <th style="text-align:right; padding-right:1.5rem;">Actions</th>
            </tr>
          </thead>
          <tbody id="cats-tbody">
            <!-- JS rendered -->
          </tbody>
        </table>
      </div>
    </div>

  </div>

  <!-- Toast Notification -->
  <div class="toast-notification" id="toast-notify">
    <div class="toast-content">
      <span class="toast-icon" id="toast-icon">✓</span>
      <span class="toast-message" id="toast-message">Saved!</span>
    </div>
  </div>

</AdminLayout>

<style is:global>
  /* ── Page Header ─────────────────────────────────── */
  .cats-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
    gap: 1rem;
  }
  .cats-subtitle {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin: 0;
    line-height: 1.5;
  }

  /* ── Two-column layout ───────────────────────────── */
  .cats-layout {
    display: grid;
    grid-template-columns: 35% 1fr;
    gap: 1.5rem;
    align-items: start;
    margin-bottom: 6rem;
  }
  @media (max-width: 1100px) {
    .cats-layout {
      grid-template-columns: 1fr;
    }
    .cats-table-col {
      order: -1;
    }
  }

  /* ── Form Card ───────────────────────────────────── */
  .form-card {
    background: var(--bg-surface);
    border: 1px solid var(--bg-surface-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 20px var(--color-shadow);
    backdrop-filter: blur(12px);
    overflow: hidden;
    position: sticky;
    top: 1.5rem;
  }
  .card-header {
    padding: 1.15rem 1.5rem;
    border-bottom: 1px solid var(--bg-surface-border);
    background: rgba(156, 163, 175, 0.02);
  }
  .card-header-inner {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .card-header-icon {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    background: var(--primary-light);
    color: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .card-header h3 {
    font-size: 1.0rem;
    font-weight: 700;
    color: var(--text-main);
  }
  .card-body {
    padding: 1.5rem;
  }

  /* ── Form Fields ─────────────────────────────────── */
  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1.15rem;
  }
  .required-star {
    color: var(--color-error);
    font-weight: 700;
  }

  /* Slug field */
  .slug-field-wrap {
    display: flex;
    align-items: stretch;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--input-border);
    transition: var(--transition);
  }
  .slug-field-wrap:focus-within {
    border-color: var(--primary) !important;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15) !important;
  }
  .slug-prefix {
    display: flex;
    align-items: center;
    padding: 0 0.75rem;
    background: rgba(156, 163, 175, 0.05);
    border-right: 1px solid var(--input-border);
    font-size: 0.82rem;
    color: var(--text-dim);
    white-space: nowrap;
    flex-shrink: 0;
    font-family: 'Courier New', monospace;
  }
  .slug-field-wrap input {
    border: none !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    flex: 1;
    min-width: 0;
  }

  /* Color field */
  .color-field-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  input[type="color"] {
    width: 42px !important;
    height: 38px !important;
    padding: 3px !important;
    border-radius: var(--radius-sm) !important;
    border: 1px solid var(--input-border) !important;
    background: var(--input-bg) !important;
    cursor: pointer;
    flex-shrink: 0;
  }
  input[type="color"]::-webkit-color-swatch-wrapper {
    padding: 2px;
  }
  input[type="color"]::-webkit-color-swatch {
    border: none;
    border-radius: 4px;
  }
  .color-hex-label {
    font-family: 'Courier New', monospace;
    font-size: 0.82rem;
    color: var(--text-muted);
    background: rgba(156,163,175,0.06);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 0.2rem 0.55rem;
    letter-spacing: 0.04em;
    min-width: 72px;
    text-align: center;
  }
  .color-presets {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .color-preset-dot {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.12);
    cursor: pointer;
    transition: var(--transition);
    padding: 0;
    flex-shrink: 0;
  }
  .color-preset-dot:hover {
    transform: scale(1.2);
    border-color: rgba(255,255,255,0.5);
  }
  .color-preset-dot.active {
    border-color: white;
    box-shadow: 0 0 0 2px rgba(255,255,255,0.3);
  }

  /* Form actions row */
  .form-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: flex-end;
    margin-top: 0.5rem;
    padding-top: 1.15rem;
    border-top: 1px solid var(--bg-surface-border);
  }

  /* ── Table Column ─────────────────────────────────── */
  .table-top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.15rem 1.5rem;
    border-bottom: 1px solid var(--bg-surface-border);
    gap: 1rem;
  }
  .table-top-left {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .table-title {
    font-size: 1.0rem;
    font-weight: 700;
    color: var(--text-main);
  }
  .cat-count-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 22px;
    border-radius: 11px;
    padding: 0 0.5rem;
    background: var(--primary-light);
    color: var(--primary);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  /* Loading State */
  .table-loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 3.5rem 2rem;
    color: var(--text-dim);
    font-size: 0.88rem;
  }
  .loading-spinner {
    width: 28px;
    height: 28px;
    border: 3px solid var(--bg-surface-border);
    border-top-color: var(--primary);
    border-radius: 50%;
    animation: spin 0.75s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Empty State */
  .table-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3.5rem 2rem;
    color: var(--text-dim);
    font-size: 0.9rem;
    text-align: center;
  }

  /* Color Swatch in Table */
  .color-swatch {
    width: 15px;
    height: 15px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.1);
    display: inline-block;
    flex-shrink: 0;
  }
  .cat-name-cell {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 600;
  }
  .slug-code {
    font-family: 'Courier New', monospace;
    font-size: 0.8rem;
    color: var(--text-dim);
    background: rgba(156,163,175,0.06);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 0.1rem 0.45rem;
  }
  .desc-truncate {
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text-muted);
    font-size: 0.86rem;
  }
  .post-count-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 22px;
    border-radius: 11px;
    padding: 0 0.5rem;
    background: rgba(156,163,175,0.06);
    border: 1px solid var(--border-color);
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 600;
  }
  .actions-cell {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.4rem;
  }

  /* Row edit highlight */
  .cats-row-editing td {
    background: rgba(99, 102, 241, 0.04) !important;
  }

  /* Toast overrides */
  .toast-notification {
    min-width: 260px;
  }
  .toast-content {
    display: flex !important;
    align-items: center !important;
    gap: 0.65rem !important;
  }
  .toast-icon {
    font-size: 1rem;
    flex-shrink: 0;
  }
  .toast-notification.toast-error {
    border-left-color: var(--color-error) !important;
  }
  .toast-notification.toast-success {
    border-left-color: var(--color-success) !important;
  }
  .toast-notification.toast-warning {
    border-left-color: var(--color-warning) !important;
  }
</style>

<script is:inline>
  // ─────────────────────────────────────────────────────────────────────────────
  // STATE
  // ─────────────────────────────────────────────────────────────────────────────
  let allCategories = [];
  let editingId = null;

  // ─────────────────────────────────────────────────────────────────────────────
  // INIT
  // ─────────────────────────────────────────────────────────────────────────────
  function initCategories() {
    // Guard against double-init (Astro page-load fires multiple times)
    const form = document.getElementById('cat-form');
    if (!form || form.dataset.init) return;
    form.dataset.init = 'true';

    bindForm();
    bindColorPicker();
    bindSlugAuto();
    bindRefresh();
    loadCategories();
  }

  // ─────────────────────────────────────────────────────────────────────────────
  // BIND: Form Submit
  // ─────────────────────────────────────────────────────────────────────────────
  function bindForm() {
    const form = document.getElementById('cat-form');
    form.addEventListener('submit', handleFormSubmit);

    const cancelBtn = document.getElementById('btn-cancel-edit');
    cancelBtn.addEventListener('click', resetForm);
  }

  async function handleFormSubmit(e) {
    e.preventDefault();

    const name        = document.getElementById('cat-name').value.trim();
    const slug        = document.getElementById('cat-slug').value.trim();
    const description = document.getElementById('cat-description').value.trim();
    const color       = document.getElementById('cat-color').value;

    if (!name) { showToast('Please enter a category name.', 'warning'); return; }
    if (!slug) { showToast('Please enter a slug.', 'warning'); return; }

    const saveBtn   = document.getElementById('btn-save-cat');
    const saveLabel = document.getElementById('btn-save-label');
    saveBtn.disabled = true;
    saveLabel.textContent = editingId ? 'Updating…' : 'Saving…';

    try {
      let res, data;

      if (editingId) {
        // PUT – update existing
        res = await fetch('/api/blog-crud', {
          method: 'PUT',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'category', id: editingId, name, slug, description, color })
        });
      } else {
        // POST – create new
        res = await fetch('/api/blog-crud', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'category', name, slug, description, color })
        });
      }

      data = await res.json();

      if (data.success) {
        showToast(editingId ? 'Category updated successfully!' : 'Category created successfully!', 'success');
        resetForm();
        await loadCategories();
      } else {
        showToast('Error: ' + (data.error || 'Operation failed.'), 'error');
      }
    } catch (err) {
      showToast('Network error. Please try again.', 'error');
      console.error(err);
    } finally {
      saveBtn.disabled = false;
      saveLabel.textContent = editingId ? 'Update Category' : 'Save Category';
    }
  }

  // ─────────────────────────────────────────────────────────────────────────────
  // BIND: Color Picker
  // ─────────────────────────────────────────────────────────────────────────────
  function bindColorPicker() {
    const colorInput  = document.getElementById('cat-color');
    const colorHexEl  = document.getElementById('cat-color-hex');
    const presetDots  = document.querySelectorAll('.color-preset-dot');

    colorInput.addEventListener('input', () => {
      colorHexEl.textContent = colorInput.value.toUpperCase();
      syncPresetActive(colorInput.value);
    });

    presetDots.forEach(dot => {
      dot.addEventListener('click', () => {
        const c = dot.dataset.color;
        colorInput.value = c;
        colorHexEl.textContent = c.toUpperCase();
        syncPresetActive(c);
      });
    });
  }

  function syncPresetActive(color) {
    document.querySelectorAll('.color-preset-dot').forEach(dot => {
      dot.classList.toggle('active', dot.dataset.color.toLowerCase() === color.toLowerCase());
    });
  }

  // ─────────────────────────────────────────────────────────────────────────────
  // BIND: Auto Slug
  // ─────────────────────────────────────────────────────────────────────────────
  function bindSlugAuto() {
    const nameInput = document.getElementById('cat-name');
    const slugInput = document.getElementById('cat-slug');
    let slugManuallyEdited = false;

    nameInput.addEventListener('input', () => {
      if (!slugManuallyEdited) {
        slugInput.value = slugify(nameInput.value);
      }
    });

    slugInput.addEventListener('input', () => {
      slugManuallyEdited = !!slugInput.value;
      slugInput.value = slugify(slugInput.value);
    });

    // Reset manual flag when form is reset
    document.getElementById('cat-form').addEventListener('reset-slug-flag', () => {
      slugManuallyEdited = false;
    });
  }

  function slugify(str) {
    return str
      .toLowerCase()
      .trim()
      .replace(/[^\w\s-]/g, '')
      .replace(/[\s_]+/g, '-')
      .replace(/-+/g, '-')
      .replace(/^-+|-+$/g, '');
  }

  // ─────────────────────────────────────────────────────────────────────────────
  // BIND: Refresh
  // ─────────────────────────────────────────────────────────────────────────────
  function bindRefresh() {
    const btn = document.getElementById('btn-refresh');
    if (btn) btn.addEventListener('click', loadCategories);
  }

  // ─────────────────────────────────────────────────────────────────────────────
  // LOAD CATEGORIES
  // ─────────────────────────────────────────────────────────────────────────────
  async function loadCategories() {
    showTableState('loading');

    try {
      const res = await fetch('/api/blog-crud?action=categories', {
        credentials: 'include'
      });
      const data = await res.json();

      if (data.success && Array.isArray(data.categories)) {
        allCategories = data.categories;
        renderTable(allCategories);
      } else {
        showTableState('empty');
        showToast('Failed to load categories.', 'error');
      }
    } catch (err) {
      showTableState('empty');
      showToast('Network error while loading categories.', 'error');
      console.error(err);
    }
  }

  // ─────────────────────────────────────────────────────────────────────────────
  // RENDER TABLE
  // ─────────────────────────────────────────────────────────────────────────────
  function renderTable(cats) {
    const tbody = document.getElementById('cats-tbody');
    const badge = document.getElementById('cat-count-badge');
    if (!tbody) return;

    badge.textContent = cats.length;

    if (cats.length === 0) {
      showTableState('empty');
      return;
    }

    showTableState('table');

    tbody.innerHTML = cats.map(cat => {
      const isUncategorized = (cat.slug || '').toLowerCase() === 'uncategorized' ||
                              (cat.name || '').toLowerCase() === 'uncategorized';
      const desc = cat.description ? cat.description : '';
      const truncDesc = desc.length > 60 ? desc.slice(0, 60) + '…' : desc;
      const postCount = cat.postCount ?? cat.post_count ?? 0;
      const color = cat.color || '#6366F1';
      const isEditing = editingId && editingId === (cat.id || cat._id);

      return `
        <tr class="${isEditing ? 'cats-row-editing' : ''}" data-id="${cat.id || cat._id || ''}">
          <td style="padding-left:1.5rem;">
            <span class="color-swatch" style="background:${color};"></span>
          </td>
          <td>
            <div class="cat-name-cell">
              <span>${escHtml(cat.name)}</span>
              ${isUncategorized ? '<span style="font-size:0.7rem;color:var(--text-dim);font-weight:500;margin-left:0.3rem;">(default)</span>' : ''}
            </div>
          </td>
          <td>
            <span class="slug-code">${escHtml(cat.slug || '')}</span>
          </td>
          <td>
            <span class="desc-truncate" title="${escHtml(desc)}">${escHtml(truncDesc) || '<span style="color:var(--text-dim);font-style:italic;">—</span>'}</span>
          </td>
          <td style="text-align:center;">
            <span class="post-count-badge">${postCount}</span>
          </td>
          <td>
            <div class="actions-cell">
              <button
                class="btn-action edit-btn"
                onclick="window.startEdit('${escAttr(String(cat.id || cat._id || ''))}', '${escAttr(cat.name)}', '${escAttr(cat.slug || '')}', '${escAttr(cat.description || '')}', '${escAttr(cat.color || '#6366F1')}')"
                title="Edit category"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
              ${!isUncategorized ? `
              <button
                class="btn-action delete-btn"
                onclick="window.confirmDelete('${escAttr(String(cat.id || cat._id || ''))}', '${escAttr(cat.name)}')"
                title="Delete category"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
              </button>` : `
              <button class="btn-action" disabled title="Cannot delete default category" style="opacity:0.25; cursor:not-allowed;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
              </button>`}
            </div>
          </td>
        </tr>
      `;
    }).join('');
  }

  // ─────────────────────────────────────────────────────────────────────────────
  // TABLE STATES
  // ─────────────────────────────────────────────────────────────────────────────
  function showTableState(state) {
    const loading = document.getElementById('table-loading');
    const empty   = document.getElementById('table-empty');
    const table   = document.getElementById('cats-table');
    if (!loading || !empty || !table) return;

    loading.style.display = state === 'loading' ? 'flex' : 'none';
    empty.style.display   = state === 'empty'   ? 'flex' : 'none';
    table.style.display   = state === 'table'   ? 'table' : 'none';
  }

  // ─────────────────────────────────────────────────────────────────────────────
  // EDIT
  // ─────────────────────────────────────────────────────────────────────────────
  window.startEdit = function(id, name, slug, description, color) {
    editingId = id;

    document.getElementById('edit-id').value         = id;
    document.getElementById('cat-name').value        = name;
    document.getElementById('cat-slug').value        = slug;
    document.getElementById('cat-description').value = description;
    document.getElementById('cat-color').value       = color;
    document.getElementById('cat-color-hex').textContent = color.toUpperCase();
    syncPresetActive(color);

    document.getElementById('form-title').textContent     = 'Edit Category';
    document.getElementById('btn-save-label').textContent = 'Update Category';
    document.getElementById('btn-cancel-edit').style.display = 'flex';

    // Update header icon to pencil
    const iconEl = document.querySelector('.card-header-icon');
    if (iconEl) {
      iconEl.innerHTML = `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`;
    }

    // Highlight editing row in table
    document.querySelectorAll('#cats-tbody tr').forEach(row => {
      row.classList.toggle('cats-row-editing', row.dataset.id === id);
    });

    // Scroll form into view on mobile
    document.querySelector('.cats-form-col').scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  // ─────────────────────────────────────────────────────────────────────────────
  // DELETE
  // ─────────────────────────────────────────────────────────────────────────────
  window.confirmDelete = function(id, name) {
    if (window.customConfirm) {
      window.customConfirm(
        `Delete the category "<strong>${name}</strong>"? Posts in this category will be moved to <em>Uncategorized</em>.`,
        () => deleteCategory(id)
      );
    } else {
      if (confirm(`Delete category "${name}"? Posts in this category will be moved to Uncategorized.`)) {
        deleteCategory(id);
      }
    }
  };

  async function deleteCategory(id) {
    try {
      const res = await fetch('/api/blog-crud', {
        method: 'DELETE',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'category', id })
      });
      const data = await res.json();

      if (data.success) {
        showToast('Category deleted successfully.', 'success');
        if (editingId === id) resetForm();
        await loadCategories();
      } else {
        showToast('Error: ' + (data.error || 'Delete failed.'), 'error');
      }
    } catch (err) {
      showToast('Network error. Please try again.', 'error');
      console.error(err);
    }
  }

  // ─────────────────────────────────────────────────────────────────────────────
  // RESET FORM
  // ─────────────────────────────────────────────────────────────────────────────
  function resetForm() {
    editingId = null;

    document.getElementById('edit-id').value         = '';
    document.getElementById('cat-name').value        = '';
    document.getElementById('cat-slug').value        = '';
    document.getElementById('cat-description').value = '';
    document.getElementById('cat-color').value       = '#6366F1';
    document.getElementById('cat-color-hex').textContent = '#6366F1';
    syncPresetActive('#6366F1');

    document.getElementById('form-title').textContent     = 'New Category';
    document.getElementById('btn-save-label').textContent = 'Save Category';
    document.getElementById('btn-cancel-edit').style.display = 'none';

    // Restore add icon
    const iconEl = document.querySelector('.card-header-icon');
    if (iconEl) {
      iconEl.innerHTML = `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>`;
    }

    // Remove row highlights
    document.querySelectorAll('#cats-tbody tr').forEach(row => {
      row.classList.remove('cats-row-editing');
    });

    // Dispatch event so slug auto can reset manual flag
    document.getElementById('cat-form').dispatchEvent(new Event('reset-slug-flag'));
  }

  // ─────────────────────────────────────────────────────────────────────────────
  // TOAST
  // ─────────────────────────────────────────────────────────────────────────────
  function showToast(message, type = 'success') {
    const toast   = document.getElementById('toast-notify');
    const msgEl   = document.getElementById('toast-message');
    const iconEl  = document.getElementById('toast-icon');
    if (!toast || !msgEl) return;

    const icons = { success: '✓', error: '✕', warning: '⚠' };
    iconEl.textContent  = icons[type] || '✓';
    msgEl.textContent   = message;

    toast.classList.remove('toast-success', 'toast-error', 'toast-warning', 'active', 'visible');
    toast.classList.add(`toast-${type}`);

    // Force reflow so transition fires
    void toast.offsetWidth;
    toast.classList.add('active');

    clearTimeout(toast._toastTimer);
    toast._toastTimer = setTimeout(() => {
      toast.classList.remove('active');
    }, 4000);
  }

  // ─────────────────────────────────────────────────────────────────────────────
  // HELPERS
  // ─────────────────────────────────────────────────────────────────────────────
  function escHtml(str) {
    if (!str) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function escAttr(str) {
    if (!str) return '';
    return String(str)
      .replace(/\\/g, '\\\\')
      .replace(/'/g, "\\'")
      .replace(/"/g, '\\"');
  }

  // ─────────────────────────────────────────────────────────────────────────────
  // BOOTSTRAP
  // ─────────────────────────────────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', initCategories);
  document.addEventListener('astro:page-load', initCategories);
  if (document.readyState === 'interactive' || document.readyState === 'complete') {
    initCategories();
  }
</script>
