---
import AdminLayout from '../../../layouts/admin/AdminLayout.astro';

export const prerender = false;
---

<AdminLayout title="Blog Authors">

  <!-- Page Header -->
  <div class="authors-header">
    <div class="header-text">
      <p class="subtitle">Manage blog author profiles, roles, and social links. Authors appear on published blog posts.</p>
    </div>
    <div class="header-actions">
      <button class="btn btn-primary" id="btn-new-author">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        <span>New Author</span>
      </button>
    </div>
  </div>

  <!-- Search bar -->
  <div class="authors-controls">
    <div class="search-wrap">
      <svg class="search-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="text" id="authors-search" placeholder="Search authors by name, email, or role…" />
    </div>
    <div class="role-filter-wrap">
      <select id="role-filter">
        <option value="all">All Roles</option>
        <option value="author">Author</option>
        <option value="editor">Editor</option>
        <option value="administrator">Administrator</option>
        <option value="contributor">Contributor</option>
      </select>
    </div>
  </div>

  <!-- Section heading -->
  <div class="section-title-wrap">
    <h3>Author Profiles <span id="authors-count-badge" class="count-chip">0</span></h3>
  </div>

  <!-- Authors Grid -->
  <div class="authors-grid" id="authors-grid">
    <!-- JS populated -->
    <div class="authors-empty" id="authors-empty">
      <svg viewBox="0 0 24 24" width="52" height="52" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.35; margin-bottom:1rem;">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
        <circle cx="9" cy="7" r="4"></circle>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
      </svg>
      <p class="empty-title">No authors yet</p>
      <p class="empty-sub">Click "New Author" to add your first author profile.</p>
    </div>
  </div>

  <!-- ===================== SLIDE-IN PANEL ===================== -->
  <div class="panel-overlay" id="panel-overlay"></div>
  <div class="author-panel" id="author-panel">
    <div class="panel-header">
      <h3 id="panel-title">New Author</h3>
      <button class="panel-close-btn" id="panel-close-btn" aria-label="Close panel">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>

    <div class="panel-body">
      <input type="hidden" id="form-author-id" value="" />

      <!-- Avatar Preview -->
      <div class="avatar-preview-row">
        <div class="avatar-preview-circle" id="avatar-preview-circle">
          <span id="avatar-preview-initials">?</span>
          <img id="avatar-preview-img" src="" alt="" style="display:none;" />
        </div>
        <div class="avatar-preview-info">
          <p class="avatar-label">Author Avatar</p>
          <p class="avatar-hint">Provide a URL or pick from media library</p>
        </div>
      </div>

      <form id="author-form" onsubmit="return false;" autocomplete="off">

        <!-- Row: Name + Slug -->
        <div class="form-row two-col">
          <div class="form-group">
            <label for="form-name">Full Name <span class="required-star">*</span></label>
            <input type="text" id="form-name" placeholder="e.g. Atul Verma" required />
          </div>
          <div class="form-group">
            <label for="form-slug">Slug</label>
            <input type="text" id="form-slug" placeholder="e.g. atul-verma" />
          </div>
        </div>

        <!-- Row: Email + Role -->
        <div class="form-row two-col">
          <div class="form-group">
            <label for="form-email">Email</label>
            <input type="email" id="form-email" placeholder="author@example.com" />
          </div>
          <div class="form-group">
            <label for="form-role">Role</label>
            <select id="form-role">
              <option value="author">Author</option>
              <option value="editor">Editor</option>
              <option value="administrator">Administrator</option>
              <option value="contributor">Contributor</option>
            </select>
          </div>
        </div>

        <!-- Bio -->
        <div class="form-group">
          <label for="form-bio">Bio</label>
          <textarea id="form-bio" rows="4" placeholder="A short bio about this author…"></textarea>
        </div>

        <!-- Avatar URL -->
        <div class="form-group">
          <label for="form-avatar">Avatar URL</label>
          <div class="input-action-row">
            <input type="text" id="form-avatar" placeholder="https://example.com/avatar.jpg or /media/avatar.jpg" />
            <button type="button" class="btn btn-outline btn-sm" id="btn-pick-media">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
              Pick from Media
            </button>
          </div>
        </div>

        <!-- Website + Twitter -->
        <div class="form-row two-col">
          <div class="form-group">
            <label for="form-website">Website</label>
            <input type="url" id="form-website" placeholder="https://yoursite.com" />
          </div>
          <div class="form-group">
            <label for="form-twitter">Twitter / X</label>
            <div class="social-input-wrap">
              <span class="social-prefix">@</span>
              <input type="text" id="form-twitter" placeholder="username" />
            </div>
          </div>
        </div>

        <!-- LinkedIn -->
        <div class="form-group">
          <label for="form-linkedin">LinkedIn URL</label>
          <input type="url" id="form-linkedin" placeholder="https://linkedin.com/in/username" />
        </div>

      </form>
    </div>

    <div class="panel-footer">
      <button class="btn btn-outline" id="btn-cancel-panel">Cancel</button>
      <button class="btn btn-primary" id="btn-save-author">
        <span id="save-btn-text">Save Author</span>
      </button>
    </div>
  </div>

  <!-- ===================== MEDIA GALLERY MODAL ===================== -->
  <div class="media-modal-overlay" id="media-modal-overlay">
    <div class="media-modal">
      <div class="media-modal-header">
        <h4>Pick from Media Library</h4>
        <button class="panel-close-btn" id="media-modal-close">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="media-modal-search">
        <input type="text" id="media-search-input" placeholder="Search images…" />
      </div>
      <div class="media-modal-grid" id="media-modal-grid">
        <div class="media-modal-loading" id="media-modal-loading">
          <div class="spinner"></div>
          <p>Loading media…</p>
        </div>
      </div>
      <div class="media-modal-footer">
        <button class="btn btn-outline" id="media-modal-cancel">Cancel</button>
        <button class="btn btn-primary" id="media-modal-select" disabled>
          Use Selected Image
        </button>
      </div>
    </div>
  </div>

  <!-- ===================== DELETE CONFIRM MODAL ===================== -->
  <div class="confirm-modal-overlay" id="delete-modal-overlay">
    <div class="confirm-modal">
      <div class="confirm-modal-header">
        <h4>Delete Author</h4>
        <button class="panel-close-btn" id="cancel-delete-x">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="confirm-modal-body">
        <p>Are you sure you want to delete <strong id="delete-author-name">this author</strong>?</p>
        <p class="warning-text">This will permanently remove their profile. Posts associated with this author will need to be reassigned. This action cannot be undone.</p>
      </div>
      <div class="confirm-modal-footer">
        <button class="btn btn-outline" id="cancel-delete-btn">Cancel</button>
        <button class="btn btn-danger" id="confirm-delete-btn">
          <span id="delete-btn-text">Yes, Delete Author</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast-notification" id="toast-notify">
    <div class="toast-content">
      <span class="toast-icon" id="toast-icon">✓</span>
      <span class="toast-message" id="toast-message">Done!</span>
    </div>
  </div>

</AdminLayout>

<style is:global>
  /* ======= Layout Header ======= */
  .authors-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.75rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .subtitle {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin: 0;
  }
  .header-actions { display: flex; gap: 0.75rem; }

  /* ======= Controls bar ======= */
  .authors-controls {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .search-wrap {
    position: relative;
    flex: 1;
    min-width: 240px;
    max-width: 480px;
  }
  .search-icon {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }
  .search-wrap input {
    width: 100%;
    box-sizing: border-box;
    padding: 0.65rem 0.85rem 0.65rem 2.5rem;
  }
  .role-filter-wrap select {
    padding: 0.65rem 2.5rem 0.65rem 1rem;
    background-color: var(--input-bg, #0f172a);
    border: 1px solid var(--input-border, rgba(255,255,255,0.08));
    color: var(--text-main);
    border-radius: var(--radius-sm);
    outline: none;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    min-width: 160px;
  }

  /* ======= Section title ======= */
  .section-title-wrap {
    margin-bottom: 1.25rem;
    border-left: 3px solid var(--primary);
    padding-left: 0.75rem;
  }
  .section-title-wrap h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .count-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.1rem 0.55rem;
    background: rgba(99,102,241,0.12);
    border: 1px solid rgba(99,102,241,0.22);
    border-radius: 50px;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--primary);
  }

  /* ======= Authors Grid ======= */
  .authors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 4rem;
  }
  @media (max-width: 1100px) {
    .authors-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 680px) {
    .authors-grid { grid-template-columns: 1fr; }
  }

  .authors-empty {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 5rem 2rem;
    color: var(--text-muted);
    text-align: center;
  }
  .empty-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-muted);
    margin-bottom: 0.3rem;
  }
  .empty-sub { font-size: 0.85rem; color: var(--text-muted); opacity: 0.7; }

  /* ======= Author Card ======= */
  .author-card {
    background: var(--bg-surface, rgba(13,19,33,0.75));
    border: 1px solid var(--bg-surface-border, rgba(255,255,255,0.06));
    border-radius: var(--radius-lg);
    backdrop-filter: blur(12px);
    box-shadow: 0 4px 20px rgba(0,0,0,0.25);
    overflow: hidden;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .author-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 32px rgba(0,0,0,0.38);
    border-color: rgba(99,102,241,0.25);
  }
  .author-card-accent-bar {
    height: 4px;
    width: 100%;
  }
  .author-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }

  /* Avatar */
  .author-avatar-wrap {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .author-avatar {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.35rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    border: 2px solid rgba(255,255,255,0.1);
    overflow: hidden;
    box-shadow: 0 4px 14px rgba(0,0,0,0.3);
  }
  .author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .author-name-block {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }
  .author-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-main);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .author-role-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.18rem 0.55rem;
    border-radius: 50px;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    width: fit-content;
  }
  .role-author     { background: rgba(99,102,241,0.12); color: #818cf8; border: 1px solid rgba(99,102,241,0.2); }
  .role-editor     { background: rgba(16,185,129,0.12); color: #34d399; border: 1px solid rgba(16,185,129,0.2); }
  .role-administrator { background: rgba(245,158,11,0.12); color: #fbbf24; border: 1px solid rgba(245,158,11,0.2); }
  .role-contributor { background: rgba(156,163,175,0.1); color: #9ca3af; border: 1px solid rgba(156,163,175,0.15); }

  /* Details */
  .author-meta-row {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .author-meta-row svg { flex-shrink: 0; opacity: 0.6; }

  .author-bio {
    font-size: 0.83rem;
    color: var(--text-muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    opacity: 0.85;
  }

  .author-stats-row {
    display: flex;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border-color, rgba(255,255,255,0.06));
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .stat-value {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--text-main);
  }
  .stat-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    font-weight: 600;
  }

  /* Social links row */
  .author-social-row {
    display: flex;
    gap: 0.5rem;
    margin-top: auto;
  }
  .social-btn {
    width: 30px;
    height: 30px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(156,163,175,0.06);
    border: 1px solid var(--border-color, rgba(255,255,255,0.06));
    color: var(--text-muted);
    text-decoration: none;
    transition: var(--transition);
    font-size: 0.75rem;
    font-weight: 700;
  }
  .social-btn:hover { color: var(--text-main); background: rgba(99,102,241,0.12); border-color: rgba(99,102,241,0.2); }

  /* Card footer actions */
  .author-card-footer {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    border-top: 1px solid var(--bg-surface-border, rgba(255,255,255,0.06));
    background: rgba(156,163,175,0.015);
  }
  .btn-action {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-color, rgba(255,255,255,0.06));
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: var(--transition);
  }
  .btn-action:hover:not(:disabled) { color: var(--text-main); background: rgba(156,163,175,0.08); }
  .delete-action:hover:not(:disabled) { color: var(--color-error); border-color: rgba(239,68,68,0.2); background: rgba(239,68,68,0.06); }
  .btn-action:disabled { opacity: 0.35; cursor: not-allowed; }

  /* ======= Slide-in Panel ======= */
  .panel-overlay {
    position: fixed;
    inset: 0;
    background: rgba(8,12,20,0.65);
    backdrop-filter: blur(6px);
    z-index: 900;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.28s ease;
  }
  .panel-overlay.active { opacity: 1; pointer-events: auto; }

  .author-panel {
    position: fixed;
    top: 0;
    right: 0;
    height: 100dvh;
    width: 520px;
    max-width: 95vw;
    background: var(--bg-surface-solid, #0D1321);
    border-left: 1px solid var(--bg-surface-border, rgba(255,255,255,0.06));
    box-shadow: -12px 0 40px rgba(0,0,0,0.5);
    z-index: 950;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.32s cubic-bezier(0.4,0,0.2,1);
  }
  .author-panel.open { transform: translateX(0); }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--bg-surface-border, rgba(255,255,255,0.06));
    background: rgba(99,102,241,0.03);
    flex-shrink: 0;
  }
  .panel-header h3 { font-size: 1.1rem; font-weight: 700; }

  .panel-close-btn {
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.3rem;
    border-radius: var(--radius-sm);
    transition: var(--transition);
  }
  .panel-close-btn:hover { color: var(--text-main); background: rgba(156,163,175,0.08); }

  .panel-body {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    scrollbar-width: thin;
    scrollbar-color: rgba(156,163,175,0.15) transparent;
  }

  .panel-footer {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--bg-surface-border, rgba(255,255,255,0.06));
    background: rgba(156,163,175,0.015);
    flex-shrink: 0;
  }

  /* Avatar preview in panel */
  .avatar-preview-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: rgba(99,102,241,0.04);
    border: 1px solid rgba(99,102,241,0.12);
    border-radius: var(--radius-md);
  }
  .avatar-preview-circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6366F1, #10B981);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 800;
    color: #fff;
    flex-shrink: 0;
    overflow: hidden;
    border: 2px solid rgba(255,255,255,0.1);
    box-shadow: 0 4px 14px rgba(0,0,0,0.3);
  }
  .avatar-preview-circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .avatar-label { font-size: 0.9rem; font-weight: 700; margin-bottom: 0.2rem; }
  .avatar-hint { font-size: 0.78rem; color: var(--text-muted); }

  /* Form elements */
  .form-row { display: flex; gap: 1rem; }
  .form-row.two-col > .form-group { flex: 1; min-width: 0; }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
  }
  .required-star { color: var(--color-error); margin-left: 0.1rem; }

  input[type="text"],
  input[type="email"],
  input[type="url"],
  select,
  textarea {
    padding: 0.65rem 0.9rem;
    border-radius: var(--radius-sm);
    background: var(--input-bg, rgba(15,23,42,0.8));
    border: 1px solid var(--input-border, rgba(255,255,255,0.08));
    color: var(--text-main);
    font-size: 0.9rem;
    outline: none;
    transition: var(--transition);
    width: 100%;
    box-sizing: border-box;
    font-family: inherit;
  }
  input:focus, select:focus, textarea:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.14);
  }
  textarea { resize: vertical; min-height: 90px; }

  .input-action-row {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
  }
  .input-action-row input { flex: 1; }

  .social-input-wrap {
    display: flex;
    align-items: center;
    background: var(--input-bg, rgba(15,23,42,0.8));
    border: 1px solid var(--input-border, rgba(255,255,255,0.08));
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: var(--transition);
  }
  .social-input-wrap:focus-within {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.14);
  }
  .social-prefix {
    padding: 0 0.65rem;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-muted);
    background: rgba(156,163,175,0.04);
    border-right: 1px solid var(--input-border, rgba(255,255,255,0.08));
    display: flex;
    align-items: center;
  }
  .social-input-wrap input {
    border: none;
    background: transparent;
    box-shadow: none;
    flex: 1;
  }
  .social-input-wrap input:focus { box-shadow: none; }

  /* ======= Media Modal ======= */
  .media-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(8,12,20,0.8);
    backdrop-filter: blur(8px);
    z-index: 1050;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
  }
  .media-modal-overlay.active { opacity: 1; pointer-events: auto; }
  .media-modal {
    background: var(--bg-surface-solid, #0D1321);
    border: 1px solid var(--bg-surface-border, rgba(255,255,255,0.07));
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    width: 100%;
    max-width: 720px;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    transform: scale(0.92);
    transition: transform 0.24s cubic-bezier(0.34,1.56,0.64,1);
  }
  .media-modal-overlay.active .media-modal { transform: scale(1); }
  .media-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.1rem 1.5rem;
    border-bottom: 1px solid var(--bg-surface-border, rgba(255,255,255,0.06));
    flex-shrink: 0;
  }
  .media-modal-header h4 { font-size: 1rem; font-weight: 700; }
  .media-modal-search {
    padding: 0.85rem 1.5rem;
    border-bottom: 1px solid var(--border-color, rgba(255,255,255,0.06));
    flex-shrink: 0;
  }
  .media-modal-search input { width: 100%; box-sizing: border-box; }
  .media-modal-grid {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 0.85rem;
    align-content: start;
    scrollbar-width: thin;
    scrollbar-color: rgba(156,163,175,0.15) transparent;
  }
  .media-modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--bg-surface-border, rgba(255,255,255,0.06));
    flex-shrink: 0;
  }
  .media-modal-loading {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    gap: 0.75rem;
    color: var(--text-muted);
    font-size: 0.88rem;
  }
  .spinner {
    width: 28px;
    height: 28px;
    border: 3px solid rgba(99,102,241,0.2);
    border-top-color: var(--primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .media-thumb {
    aspect-ratio: 1;
    border-radius: var(--radius-sm);
    border: 2px solid transparent;
    overflow: hidden;
    cursor: pointer;
    transition: var(--transition);
    background: rgba(156,163,175,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .media-thumb:hover { border-color: rgba(99,102,241,0.45); transform: scale(1.04); }
  .media-thumb.selected-media { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(16,185,129,0.2); }
  .media-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .media-thumb-check {
    position: absolute;
    top: 5px;
    right: 5px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--accent);
    color: white;
    display: none;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 900;
  }
  .media-thumb.selected-media .media-thumb-check { display: flex; }

  /* ======= Delete Confirm Modal ======= */
  .confirm-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(8,12,20,0.75);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1100;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
  }
  .confirm-modal-overlay.active { opacity: 1; pointer-events: auto; }
  .confirm-modal {
    background: var(--bg-surface-solid, #0D1321);
    border: 1px solid var(--bg-surface-border, rgba(255,255,255,0.07));
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 500px;
    padding: 1.75rem;
    box-shadow: 0 10px 40px rgba(0,0,0,0.55);
    transform: scale(0.9);
    transition: transform 0.22s cubic-bezier(0.34,1.56,0.64,1);
  }
  .confirm-modal-overlay.active .confirm-modal { transform: scale(1); }
  .confirm-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .confirm-modal-header h4 { font-size: 1.15rem; font-weight: 700; }
  .confirm-modal-body p {
    font-size: 0.92rem;
    line-height: 1.5;
    margin-bottom: 0.75rem;
    color: var(--text-muted);
  }
  .warning-text {
    background: rgba(239,68,68,0.05);
    padding: 0.75rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(239,68,68,0.15);
    color: var(--color-error) !important;
    font-size: 0.83rem !important;
  }
  .confirm-modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  /* ======= Toast ======= */
  .toast-notification {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: var(--bg-surface-solid, #0D1321);
    border-left: 4px solid var(--primary);
    border-top: 1px solid var(--bg-surface-border, rgba(255,255,255,0.07));
    border-bottom: 1px solid var(--bg-surface-border, rgba(255,255,255,0.07));
    border-right: 1px solid var(--bg-surface-border, rgba(255,255,255,0.07));
    padding: 1rem 1.35rem;
    border-radius: var(--radius-sm);
    box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    z-index: 2000;
    transform: translateY(150%);
    transition: transform 0.3s cubic-bezier(0.16,1,0.3,1);
    backdrop-filter: blur(8px);
    min-width: 240px;
    max-width: 360px;
  }
  .toast-notification.active { transform: translateY(0); }
  .toast-notification.toast-error { border-left-color: var(--color-error); }
  .toast-notification.toast-success { border-left-color: var(--accent); }
  .toast-content { display: flex; align-items: center; gap: 0.6rem; font-size: 0.9rem; font-weight: 500; color: var(--text-main); }
  .toast-icon { font-size: 1rem; }
</style>

<script is:inline>
  // ─── State ────────────────────────────────────────────────────────────────
  var authorsData = [];
  var filteredAuthors = [];
  var pendingDeleteId = null;
  var selectedMediaUrl = null;
  var mediaGallery = [];

  // Gradient palettes for avatar backgrounds
  var avatarGradients = [
    'linear-gradient(135deg,#6366F1,#8B5CF6)',
    'linear-gradient(135deg,#10B981,#059669)',
    'linear-gradient(135deg,#F59E0B,#EF4444)',
    'linear-gradient(135deg,#3B82F6,#6366F1)',
    'linear-gradient(135deg,#EC4899,#8B5CF6)',
    'linear-gradient(135deg,#14B8A6,#3B82F6)',
    'linear-gradient(135deg,#F97316,#EF4444)',
    'linear-gradient(135deg,#6366F1,#10B981)',
  ];

  function getGradient(name) {
    var code = 0;
    for (var i = 0; i < (name || '').length; i++) code += name.charCodeAt(i);
    return avatarGradients[code % avatarGradients.length];
  }

  function getInitials(name) {
    if (!name) return '?';
    var parts = name.trim().split(/\s+/);
    if (parts.length === 1) return parts[0][0].toUpperCase();
    return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
  }

  function getRoleClass(role) {
    var map = { author: 'role-author', editor: 'role-editor', administrator: 'role-administrator', contributor: 'role-contributor' };
    return map[(role || 'author').toLowerCase()] || 'role-contributor';
  }

  // ─── Init ─────────────────────────────────────────────────────────────────
  function initAuthors() {
    var grid = document.getElementById('authors-grid');
    if (!grid || grid.dataset.bound) return;
    grid.dataset.bound = 'true';

    loadAuthors();
    bindControls();
  }

  // ─── API Calls ────────────────────────────────────────────────────────────
  async function loadAuthors() {
    try {
      var res = await fetch('/api/blog-crud?action=authors', { credentials: 'include' });
      var data = await res.json();
      authorsData = (data.authors || data.data || []);
    } catch (e) {
      authorsData = [];
    }
    applyFilters();
  }

  async function saveAuthor() {
    var id = document.getElementById('form-author-id').value.trim();
    var name = document.getElementById('form-name').value.trim();
    if (!name) { showToast('Name is required.', 'error'); return; }

    var payload = {
      action: 'author',
      name,
      slug: document.getElementById('form-slug').value.trim(),
      email: document.getElementById('form-email').value.trim(),
      bio: document.getElementById('form-bio').value.trim(),
      role: document.getElementById('form-role').value,
      avatar: document.getElementById('form-avatar').value.trim(),
      website: document.getElementById('form-website').value.trim(),
      twitter: document.getElementById('form-twitter').value.trim(),
      linkedin: document.getElementById('form-linkedin').value.trim(),
    };

    var saveBtn = document.getElementById('btn-save-author');
    var saveTxt = document.getElementById('save-btn-text');
    saveBtn.disabled = true;
    saveTxt.innerText = 'Saving…';

    try {
      var method = id ? 'PUT' : 'POST';
      if (id) payload.id = id;

      var res = await fetch('/api/blog-crud', {
        method,
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      var data = await res.json();

      if (data.success) {
        showToast(id ? 'Author updated successfully!' : 'Author created!', 'success');
        closePanel();
        await loadAuthors();
      } else {
        showToast('Error: ' + (data.error || 'Save failed.'), 'error');
      }
    } catch (e) {
      showToast('Network error: could not save author.', 'error');
    } finally {
      saveBtn.disabled = false;
      saveTxt.innerText = 'Save Author';
    }
  }

  async function deleteAuthor() {
    if (!pendingDeleteId) return;
    var btn = document.getElementById('confirm-delete-btn');
    var txt = document.getElementById('delete-btn-text');
    btn.disabled = true;
    txt.innerText = 'Deleting…';

    try {
      var res = await fetch('/api/blog-crud', {
        method: 'DELETE',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'author', id: pendingDeleteId }),
      });
      var data = await res.json();
      if (data.success) {
        showToast('Author deleted.', 'success');
        hideDeleteModal();
        await loadAuthors();
      } else {
        showToast('Error: ' + (data.error || 'Delete failed.'), 'error');
      }
    } catch (e) {
      showToast('Network error during deletion.', 'error');
    } finally {
      btn.disabled = false;
      txt.innerText = 'Yes, Delete Author';
    }
  }

  // ─── Rendering ────────────────────────────────────────────────────────────
  function applyFilters() {
    var q = (document.getElementById('authors-search')?.value || '').toLowerCase();
    var role = document.getElementById('role-filter')?.value || 'all';

    filteredAuthors = authorsData.filter(function(a) {
      var matchQ = !q || (a.name || '').toLowerCase().includes(q) || (a.email || '').toLowerCase().includes(q) || (a.role || '').toLowerCase().includes(q);
      var matchRole = role === 'all' || (a.role || '').toLowerCase() === role;
      return matchQ && matchRole;
    });

    renderAuthors();
  }

  function renderAuthors() {
    var grid = document.getElementById('authors-grid');
    var empty = document.getElementById('authors-empty');
    var badge = document.getElementById('authors-count-badge');
    if (!grid) return;

    // Remove existing cards
    grid.querySelectorAll('.author-card').forEach(function(el) { el.remove(); });

    if (badge) badge.innerText = filteredAuthors.length;

    if (filteredAuthors.length === 0) {
      if (empty) empty.style.display = 'flex';
      return;
    }
    if (empty) empty.style.display = 'none';

    filteredAuthors.forEach(function(author, idx) {
      var card = buildAuthorCard(author, idx);
      grid.appendChild(card);
    });
  }

  function buildAuthorCard(author, idx) {
    var initials = getInitials(author.name);
    var gradient = getGradient(author.name);
    var roleClass = getRoleClass(author.role);
    var roleLabel = (author.role || 'author');
    roleLabel = roleLabel.charAt(0).toUpperCase() + roleLabel.slice(1);
    var postCount = author.postCount || author.post_count || 0;
    var isAdmin = (author.role || '').toLowerCase() === 'administrator';

    // Accent bar color per role
    var accentGradient = gradient;

    var card = document.createElement('div');
    card.className = 'author-card';
    card.setAttribute('data-id', author.id || author._id || '');
    card.setAttribute('data-name', (author.name || '').toLowerCase());
    card.setAttribute('data-email', (author.email || '').toLowerCase());
    card.setAttribute('data-role', (author.role || '').toLowerCase());

    var avatarHtml = '';
    if (author.avatar) {
      avatarHtml = '<img src="' + author.avatar + '" alt="' + (author.name || '') + '" onerror="this.style.display=\'none\'; this.previousElementSibling.style.display=\'flex\';" />'
        + '<span style="display:none; width:100%; height:100%; align-items:center; justify-content:center; font-size:1.35rem; font-weight:800;">' + initials + '</span>';
    } else {
      avatarHtml = '<span style="font-size:1.35rem; font-weight:800;">' + initials + '</span>';
    }

    var socialHtml = '';
    if (author.website) {
      socialHtml += '<a href="' + author.website + '" target="_blank" rel="noopener" class="social-btn" title="Website"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg></a>';
    }
    if (author.twitter) {
      socialHtml += '<a href="https://twitter.com/' + author.twitter.replace('@','') + '" target="_blank" rel="noopener" class="social-btn" title="Twitter / X">𝕏</a>';
    }
    if (author.linkedin) {
      socialHtml += '<a href="' + author.linkedin + '" target="_blank" rel="noopener" class="social-btn" title="LinkedIn"><svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg></a>';
    }

    var bioHtml = author.bio
      ? '<p class="author-bio">' + escHtml(author.bio) + '</p>'
      : '<p class="author-bio" style="opacity:0.4; font-style:italic;">No bio provided.</p>';

    card.innerHTML = [
      '<div class="author-card-accent-bar" style="background:' + accentGradient + ';"></div>',
      '<div class="author-card-body">',
        '<div class="author-avatar-wrap">',
          '<div class="author-avatar" style="background:' + gradient + ';">' + avatarHtml + '</div>',
          '<div class="author-name-block">',
            '<span class="author-name">' + escHtml(author.name || 'Unnamed Author') + '</span>',
            '<span class="author-role-badge ' + roleClass + '">' + roleLabel + '</span>',
          '</div>',
        '</div>',
        (author.email ? '<div class="author-meta-row"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>' + escHtml(author.email) + '</div>' : ''),
        bioHtml,
        '<div class="author-stats-row">',
          '<div class="stat-item"><span class="stat-value">' + postCount + '</span><span class="stat-label">Posts</span></div>',
          (author.role ? '<div class="stat-item"><span class="stat-value" style="font-size:0.88rem; padding-top:0.15rem;">' + roleLabel + '</span><span class="stat-label">Role</span></div>' : ''),
        '</div>',
        (socialHtml ? '<div class="author-social-row">' + socialHtml + '</div>' : ''),
      '</div>',
      '<div class="author-card-footer">',
        '<button class="btn-action edit-action" data-id="' + (author.id || author._id || '') + '" title="Edit Author"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4z"></path></svg></button>',
        '<button class="btn-action delete-action" data-id="' + (author.id || author._id || '') + '" data-name="' + escHtml(author.name || '') + '" ' + (isAdmin ? 'disabled title="Administrator authors cannot be deleted"' : 'title="Delete Author"') + '><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg></button>',
      '</div>',
    ].join('');

    return card;
  }

  function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ─── Panel Open / Close ───────────────────────────────────────────────────
  function openPanel(author) {
    var isEdit = !!author;
    document.getElementById('panel-title').innerText = isEdit ? 'Edit Author' : 'New Author';
    document.getElementById('save-btn-text').innerText = isEdit ? 'Update Author' : 'Save Author';
    document.getElementById('form-author-id').value = author ? (author.id || author._id || '') : '';

    document.getElementById('form-name').value = author?.name || '';
    document.getElementById('form-slug').value = author?.slug || '';
    document.getElementById('form-email').value = author?.email || '';
    document.getElementById('form-bio').value = author?.bio || '';
    document.getElementById('form-role').value = author?.role || 'author';
    document.getElementById('form-avatar').value = author?.avatar || '';
    document.getElementById('form-website').value = author?.website || '';
    document.getElementById('form-twitter').value = author?.twitter || '';
    document.getElementById('form-linkedin').value = author?.linkedin || '';

    updateAvatarPreview(author?.name || '', author?.avatar || '');

    document.getElementById('panel-overlay').classList.add('active');
    document.getElementById('author-panel').classList.add('open');
    document.getElementById('form-name').focus();
  }

  function closePanel() {
    document.getElementById('panel-overlay').classList.remove('active');
    document.getElementById('author-panel').classList.remove('open');
  }

  function updateAvatarPreview(name, url) {
    var circle = document.getElementById('avatar-preview-circle');
    var initials = document.getElementById('avatar-preview-initials');
    var img = document.getElementById('avatar-preview-img');
    if (!circle) return;

    circle.style.background = getGradient(name || 'Author');
    initials.innerText = getInitials(name || '');

    if (url) {
      img.src = url;
      img.style.display = 'block';
      initials.style.display = 'none';
      img.onerror = function() {
        img.style.display = 'none';
        initials.style.display = 'block';
      };
    } else {
      img.style.display = 'none';
      initials.style.display = 'block';
    }
  }

  // ─── Delete Modal ─────────────────────────────────────────────────────────
  function showDeleteModal(id, name) {
    pendingDeleteId = id;
    document.getElementById('delete-author-name').innerText = '"' + name + '"';
    document.getElementById('delete-modal-overlay').classList.add('active');
  }

  function hideDeleteModal() {
    pendingDeleteId = null;
    document.getElementById('delete-modal-overlay').classList.remove('active');
  }

  // ─── Media Gallery ─────────────────────────────────────────────────────────
  async function openMediaModal() {
    selectedMediaUrl = null;
    document.getElementById('media-modal-overlay').classList.add('active');
    document.getElementById('media-modal-select').disabled = true;
    document.getElementById('media-search-input').value = '';

    var loadingEl = document.getElementById('media-modal-loading');
    if (loadingEl) loadingEl.style.display = 'flex';

    // Clear existing thumbs
    document.querySelectorAll('.media-thumb').forEach(function(el) { el.remove(); });

    try {
      var res = await fetch('/api/media-crud?action=list', { credentials: 'include' });
      var data = await res.json();
      mediaGallery = (data.media || data.files || []).filter(function(m) {
        return (m.type === 'image' || m.type === 'svg' || (m.url && /\.(jpg|jpeg|png|gif|webp|svg|avif)$/i.test(m.url)));
      });
    } catch (e) {
      mediaGallery = [];
    }

    if (loadingEl) loadingEl.style.display = 'none';
    renderMediaGallery('');
  }

  function renderMediaGallery(query) {
    var grid = document.getElementById('media-modal-grid');
    if (!grid) return;
    grid.querySelectorAll('.media-thumb').forEach(function(el) { el.remove(); });

    var filtered = mediaGallery.filter(function(m) {
      if (!query) return true;
      return (m.title || m.url || '').toLowerCase().includes(query.toLowerCase());
    });

    if (filtered.length === 0) {
      var noRes = document.createElement('div');
      noRes.className = 'media-modal-loading';
      noRes.innerHTML = '<p style="color:var(--text-muted);">No images found.</p>';
      grid.appendChild(noRes);
      return;
    }

    filtered.forEach(function(item) {
      var thumb = document.createElement('div');
      thumb.className = 'media-thumb';
      thumb.setAttribute('data-url', item.url);
      thumb.innerHTML = [
        '<img src="' + item.url + '" alt="' + escHtml(item.title || '') + '" loading="lazy" />',
        '<span class="media-thumb-check">✓</span>',
      ].join('');

      thumb.addEventListener('click', function() {
        document.querySelectorAll('.media-thumb').forEach(function(t) { t.classList.remove('selected-media'); });
        thumb.classList.add('selected-media');
        selectedMediaUrl = item.url;
        document.getElementById('media-modal-select').disabled = false;
      });

      grid.appendChild(thumb);
    });
  }

  function closeMediaModal() {
    selectedMediaUrl = null;
    document.getElementById('media-modal-overlay').classList.remove('active');
    document.getElementById('media-modal-select').disabled = true;
  }

  // ─── Bind all events ──────────────────────────────────────────────────────
  function bindControls() {
    // New Author button
    var btnNew = document.getElementById('btn-new-author');
    if (btnNew) btnNew.addEventListener('click', function() { openPanel(null); });

    // Panel close
    var panelClose = document.getElementById('panel-close-btn');
    var panelCancel = document.getElementById('btn-cancel-panel');
    var overlay = document.getElementById('panel-overlay');
    if (panelClose) panelClose.addEventListener('click', closePanel);
    if (panelCancel) panelCancel.addEventListener('click', closePanel);
    if (overlay) overlay.addEventListener('click', closePanel);

    // Save author
    var saveBtn = document.getElementById('btn-save-author');
    if (saveBtn) saveBtn.addEventListener('click', saveAuthor);

    // Auto-generate slug from name
    var nameInput = document.getElementById('form-name');
    var slugInput = document.getElementById('form-slug');
    if (nameInput && slugInput) {
      nameInput.addEventListener('input', function() {
        var id = document.getElementById('form-author-id').value;
        if (!id) {
          slugInput.value = nameInput.value.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
        }
        updateAvatarPreview(nameInput.value, document.getElementById('form-avatar').value);
      });
    }

    // Avatar URL preview update
    var avatarInput = document.getElementById('form-avatar');
    if (avatarInput) {
      avatarInput.addEventListener('input', function() {
        updateAvatarPreview(document.getElementById('form-name').value, avatarInput.value);
      });
    }

    // Search + filter
    var searchInput = document.getElementById('authors-search');
    var roleFilter = document.getElementById('role-filter');
    if (searchInput) searchInput.addEventListener('input', applyFilters);
    if (roleFilter) roleFilter.addEventListener('change', applyFilters);

    // Grid delegation (edit / delete)
    var grid = document.getElementById('authors-grid');
    if (grid) {
      grid.addEventListener('click', function(e) {
        var editBtn = e.target.closest('.edit-action');
        var deleteBtn = e.target.closest('.delete-action');

        if (editBtn && !editBtn.disabled) {
          var id = editBtn.getAttribute('data-id');
          var author = authorsData.find(function(a) { return (a.id || a._id) == id; });
          if (author) openPanel(author);
        }

        if (deleteBtn && !deleteBtn.disabled) {
          var id = deleteBtn.getAttribute('data-id');
          var name = deleteBtn.getAttribute('data-name');
          showDeleteModal(id, name);
        }
      });
    }

    // Delete modal controls
    var cancelX = document.getElementById('cancel-delete-x');
    var cancelBtn = document.getElementById('cancel-delete-btn');
    var confirmBtn = document.getElementById('confirm-delete-btn');
    if (cancelX) cancelX.addEventListener('click', hideDeleteModal);
    if (cancelBtn) cancelBtn.addEventListener('click', hideDeleteModal);
    if (confirmBtn) confirmBtn.addEventListener('click', deleteAuthor);

    // Media picker
    var pickMediaBtn = document.getElementById('btn-pick-media');
    if (pickMediaBtn) pickMediaBtn.addEventListener('click', openMediaModal);

    var mediaClose = document.getElementById('media-modal-close');
    var mediaCancel = document.getElementById('media-modal-cancel');
    var mediaSelect = document.getElementById('media-modal-select');
    var mediaSearch = document.getElementById('media-search-input');

    if (mediaClose) mediaClose.addEventListener('click', closeMediaModal);
    if (mediaCancel) mediaCancel.addEventListener('click', closeMediaModal);

    if (mediaSearch) {
      mediaSearch.addEventListener('input', function() {
        renderMediaGallery(mediaSearch.value);
      });
    }

    if (mediaSelect) {
      mediaSelect.addEventListener('click', function() {
        if (selectedMediaUrl) {
          document.getElementById('form-avatar').value = selectedMediaUrl;
          updateAvatarPreview(document.getElementById('form-name').value, selectedMediaUrl);
          closeMediaModal();
          showToast('Image selected!', 'success');
        }
      });
    }

    // Media modal overlay click to close
    var mediaOverlay = document.getElementById('media-modal-overlay');
    if (mediaOverlay) {
      mediaOverlay.addEventListener('click', function(e) {
        if (e.target === mediaOverlay) closeMediaModal();
      });
    }

    // Delete modal overlay click to close
    var delOverlay = document.getElementById('delete-modal-overlay');
    if (delOverlay) {
      delOverlay.addEventListener('click', function(e) {
        if (e.target === delOverlay) hideDeleteModal();
      });
    }

    // ESC key to close panels
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        if (document.getElementById('media-modal-overlay').classList.contains('active')) { closeMediaModal(); return; }
        if (document.getElementById('delete-modal-overlay').classList.contains('active')) { hideDeleteModal(); return; }
        if (document.getElementById('author-panel').classList.contains('open')) { closePanel(); return; }
      }
    });
  }

  // ─── Toast ────────────────────────────────────────────────────────────────
  function showToast(message, type) {
    var toast = document.getElementById('toast-notify');
    var msgEl = document.getElementById('toast-message');
    var iconEl = document.getElementById('toast-icon');
    if (!toast || !msgEl) return;

    toast.classList.remove('toast-error', 'toast-success', 'active');

    msgEl.innerText = message;
    if (type === 'error') {
      iconEl.innerText = '✕';
      toast.classList.add('toast-error');
    } else {
      iconEl.innerText = '✓';
      toast.classList.add('toast-success');
    }

    setTimeout(function() { toast.classList.add('active'); }, 10);
    setTimeout(function() { toast.classList.remove('active'); }, 3800);
  }

  // ─── Bootstrap ────────────────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', initAuthors);
  document.addEventListener('astro:page-load', initAuthors);
  if (document.readyState === 'interactive' || document.readyState === 'complete') {
    initAuthors();
  }
</script>
