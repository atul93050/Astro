---
import AdminLayout from "../../layouts/admin/AdminLayout.astro";
import fs from "node:fs";
import path from "node:path";

export const prerender = false;

// 1. Fetch current settings
const SETTINGS_FILE = path.resolve("src/data/global-settings.json");
let settings = {
  navigation: [] as any[],
  footerNavigation: [] as any[]
};

if (fs.existsSync(SETTINGS_FILE)) {
  try {
    const data = fs.readFileSync(SETTINGS_FILE, "utf-8");
    const parsed = JSON.parse(data);
    settings.navigation = parsed.navigation || [];
    settings.footerNavigation = parsed.footerNavigation || [];
  } catch (e) {
    console.error("Error reading settings in menus.astro:", e);
  }
}
---

<AdminLayout title="Menu Manager">
  
  <div class="menus-header">
    <div class="header-text">
      <p class="subtitle">Manage header dropdown navigation menus (with submenus parent/child nesting) and footer navigation links lists.</p>
    </div>
    <div class="header-actions">
      <button class="btn btn-primary" id="save-menus-btn">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
        <span>Save Menus</span>
      </button>
    </div>
  </div>

  <form id="menus-manager-form" onsubmit="return false;">
    
    <div class="menus-layout-grid">
      
      <!-- Left Column: Header Dropdown Menu Manager -->
      <div class="menus-card-wrapper">
        <div class="form-card">
          <div class="card-header block-header-flex">
            <h3>Header Navigation Menu</h3>
            <button type="button" class="btn btn-outline btn-sm" id="add-header-menu-btn">
              <span>+ Add Top Item</span>
            </button>
          </div>
          <div class="card-body">
            <div class="menu-items-tree" id="header-menu-container">
              <!-- JS Injected dynamic links lists -->
            </div>
            <div class="menu-empty-state" id="header-menu-empty" style="display:none;">
              <p>No header menu items. Click "+ Add Top Item" to begin.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Footer Links Menu Manager -->
      <div class="menus-card-wrapper">
        <div class="form-card">
          <div class="card-header block-header-flex">
            <h3>Footer Quick Links Menu</h3>
            <button type="button" class="btn btn-outline btn-sm" id="add-footer-menu-btn">
              <span>+ Add Footer Link</span>
            </button>
          </div>
          <div class="card-body">
            <div class="menu-items-tree" id="footer-menu-container">
              <!-- JS Injected dynamic links lists -->
            </div>
            <div class="menu-empty-state" id="footer-menu-empty" style="display:none;">
              <p>No footer links. Click "+ Add Footer Link" to begin.</p>
            </div>
          </div>
        </div>
      </div>

    </div>

  </form>

  <!-- Toast Toast Notifications -->
  <div class="toast-notification" id="toast-notify">
    <div class="toast-content">
      <span class="toast-message" id="toast-message">Menus saved successfully!</span>
    </div>
  </div>

</AdminLayout>

<style is:global>
  .menus-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    gap: 1.5rem;
  }
  .menus-layout-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  @media (max-width: 1024px) {
    .menus-layout-grid {
      grid-template-columns: 1fr;
    }
  }

  .menu-items-tree {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .menu-node-card {
    background: rgba(156, 163, 175, 0.02);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 1rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: var(--transition);
  }
  .menu-node-card:hover {
    border-color: rgba(99, 102, 241, 0.2);
  }

  .menu-node-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .menu-node-inputs {
    display: flex;
    gap: 0.5rem;
    flex: 1;
  }
  @media (max-width: 640px) {
    .menu-node-inputs {
      flex-direction: column;
    }
  }

  .menu-node-actions {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  /* Submenus block */
  .sub-menu-container {
    border-left: 2px dashed rgba(99, 102, 241, 0.2);
    padding-left: 1.25rem;
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .sub-menu-node {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    background: rgba(156, 163, 175, 0.01);
    border: 1px dashed var(--border-color);
    border-radius: 6px;
    padding: 0.65rem;
  }

  .menu-empty-state {
    text-align: center;
    padding: 3rem 1.5rem;
    color: var(--text-dim);
    font-size: 0.88rem;
    border: 1px dashed var(--border-color);
    border-radius: var(--radius-sm);
    background: rgba(156, 163, 175, 0.005);
  }

  /* Icons buttons */
  .btn-action-sm {
    width: 26px;
    height: 26px;
    border-radius: 4px;
    border: 1px solid var(--border-color);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
  }
  .btn-action-sm:hover {
    color: var(--text-main);
    background-color: rgba(156, 163, 175, 0.08);
  }
  .btn-delete-node:hover {
    color: var(--color-error);
    border-color: rgba(239, 68, 68, 0.2);
    background-color: rgba(239, 68, 68, 0.05);
  }
</style>

<script is:inline define:vars={{ settings }}>
  let headerMenu = settings.navigation || [];
  let footerMenu = settings.footerNavigation || [];

  const ICONS = {
    arrowUp: `<svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"></polyline></svg>`,
    arrowDown: `<svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>`,
    delete: `<svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>`,
    plus: `<svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>`
  };

  function initMenus() {
    const saveBtn = document.getElementById("save-menus-btn");
    if (!saveBtn || saveBtn.dataset.listenerBound) return;
    saveBtn.dataset.listenerBound = "true";

    renderHeaderMenu();
    renderFooterMenu();

    // Bind triggers
    saveBtn.addEventListener("click", submitMenusForm);
    document.getElementById("add-header-menu-btn").addEventListener("click", addTopHeaderItem);
    document.getElementById("add-footer-menu-btn").addEventListener("click", addFooterItem);
  }

  // HEADER MENU LOGIC
  function renderHeaderMenu() {
    const container = document.getElementById("header-menu-container");
    const emptyState = document.getElementById("header-menu-empty");
    if (!container) return;
    container.innerHTML = "";

    if (headerMenu.length === 0) {
      emptyState.style.display = "block";
      return;
    }
    emptyState.style.display = "none";

    headerMenu.forEach((item, idx) => {
      const card = document.createElement("div");
      card.className = "menu-node-card";
      
      const childrenHtml = (item.children || []).map((sub, sIdx) => `
        <div class="sub-menu-node">
          <div class="menu-node-inputs">
            <input type="text" value="${sub.text}" placeholder="Sub Label" oninput="syncSubLink(${idx}, ${sIdx}, 'text', this.value)" style="flex:0.4; font-size:0.8rem; padding:0.4rem 0.6rem;" />
            <input type="text" value="${sub.link}" placeholder="Sub Destination Link" oninput="syncSubLink(${idx}, ${sIdx}, 'link', this.value)" style="flex:0.6; font-size:0.8rem; padding:0.4rem 0.6rem;" />
          </div>
          <div class="menu-node-actions">
            <button type="button" class="btn-action-sm btn-delete-node" onclick="deleteSubLink(${idx}, ${sIdx})" title="Delete Sub Link">${ICONS.delete}</button>
          </div>
        </div>
      `).join('');

      card.innerHTML = `
        <div class="menu-node-controls">
          <div class="menu-node-inputs">
            <input type="text" value="${item.text}" placeholder="Menu Label" oninput="syncTopLink(${idx}, 'text', this.value)" style="flex:0.4; font-weight:600;" />
            <input type="text" value="${item.link || ''}" placeholder="Link (e.g. /about-us or #)" oninput="syncTopLink(${idx}, 'link', this.value)" style="flex:0.6;" />
          </div>
          <div class="menu-node-actions">
            <button type="button" class="btn-action-sm" onclick="addHeaderSubItem(${idx})" title="Add Submenu Link" style="color:var(--primary);">${ICONS.plus}</button>
            <button type="button" class="btn-action-sm" onclick="moveHeaderItem(${idx}, -1)" title="Move Up">${ICONS.arrowUp}</button>
            <button type="button" class="btn-action-sm" onclick="moveHeaderItem(${idx}, 1)" title="Move Down">${ICONS.arrowDown}</button>
            <button type="button" class="btn-action-sm btn-delete-node" onclick="deleteHeaderItem(${idx})" title="Delete Menu Item">${ICONS.delete}</button>
          </div>
        </div>
        ${(item.children && item.children.length > 0) ? `<div class="sub-menu-container">${childrenHtml}</div>` : ''}
      `;
      container.appendChild(card);
    });
  }

  window.syncTopLink = function(idx, field, val) {
    headerMenu[idx][field] = val;
  };
  window.syncSubLink = function(idx, sIdx, field, val) {
    headerMenu[idx].children[sIdx][field] = val;
  };
  window.addHeaderSubItem = function(idx) {
    if (!headerMenu[idx].children) headerMenu[idx].children = [];
    headerMenu[idx].children.push({ text: "New Sub Link", link: "/" });
    renderHeaderMenu();
  };
  window.deleteSubLink = function(idx, sIdx) {
    headerMenu[idx].children.splice(sIdx, 1);
    renderHeaderMenu();
  };
  window.moveHeaderItem = function(idx, dir) {
    const targetIdx = idx + dir;
    if (targetIdx < 0 || targetIdx >= headerMenu.length) return;
    const temp = headerMenu[idx];
    headerMenu[idx] = headerMenu[targetIdx];
    headerMenu[targetIdx] = temp;
    renderHeaderMenu();
  };
  window.deleteHeaderItem = function(idx) {
    window.customConfirm("Delete this Header menu item and all its submenus?", () => {
      headerMenu.splice(idx, 1);
      renderHeaderMenu();
    });
  };
  function addTopHeaderItem() {
    headerMenu.push({ text: "New Link", link: "/", children: [] });
    renderHeaderMenu();
  }

  // FOOTER MENU LOGIC
  function renderFooterMenu() {
    const container = document.getElementById("footer-menu-container");
    const emptyState = document.getElementById("footer-menu-empty");
    if (!container) return;
    container.innerHTML = "";

    if (footerMenu.length === 0) {
      emptyState.style.display = "block";
      return;
    }
    emptyState.style.display = "none";

    footerMenu.forEach((item, idx) => {
      const card = document.createElement("div");
      card.className = "menu-node-card";
      
      card.innerHTML = `
        <div class="menu-node-controls">
          <div class="menu-node-inputs">
            <input type="text" value="${item.text}" placeholder="Link Label" oninput="syncFooterLink(${idx}, 'text', this.value)" style="flex:0.3; font-weight:600;" />
            <input type="text" value="${item.link}" placeholder="Destination URL (e.g. /privacy)" oninput="syncFooterLink(${idx}, 'link', this.value)" style="flex:0.5;" />
            <div style="display:flex; align-items:center; gap:0.35rem; flex:0.2;">
              <input type="checkbox" id="foot-tab-${idx}" ${item.newTab ? 'checked' : ''} onchange="syncFooterLink(${idx}, 'newTab', this.checked)" style="width:auto;" />
              <label for="foot-tab-${idx}" style="cursor:pointer; font-size:0.75rem;">New Tab</label>
            </div>
          </div>
          <div class="menu-node-actions">
            <button type="button" class="btn-action-sm" onclick="moveFooterItem(${idx}, -1)" title="Move Up">${ICONS.arrowUp}</button>
            <button type="button" class="btn-action-sm" onclick="moveFooterItem(${idx}, 1)" title="Move Down">${ICONS.arrowDown}</button>
            <button type="button" class="btn-action-sm btn-delete-node" onclick="deleteFooterItem(${idx})" title="Delete Link">${ICONS.delete}</button>
          </div>
        </div>
      `;
      container.appendChild(card);
    });
  }

  window.syncFooterLink = function(idx, field, val) {
    footerMenu[idx][field] = val;
  };
  window.moveFooterItem = function(idx, dir) {
    const targetIdx = idx + dir;
    if (targetIdx < 0 || targetIdx >= footerMenu.length) return;
    const temp = footerMenu[idx];
    footerMenu[idx] = footerMenu[targetIdx];
    footerMenu[targetIdx] = temp;
    renderFooterMenu();
  };
  window.deleteFooterItem = function(idx) {
    window.customConfirm("Delete this footer navigation link?", () => {
      footerMenu.splice(idx, 1);
      renderFooterMenu();
    });
  };
  function addFooterItem() {
    footerMenu.push({ text: "Privacy Policy", link: "/privacy", newTab: false });
    renderFooterMenu();
  }

  // SAVE MENUS FORM
  async function submitMenusForm() {
    const saveBtn = document.getElementById("save-menus-btn");
    const saveLabel = saveBtn.querySelector("span");
    saveBtn.disabled = true;
    saveLabel.innerText = "Saving Menus...";

    try {
      // 1. Fetch current settings first
      const getRes = await fetch("/api/settings-update");
      const getData = await getRes.json();
      
      if (!getData.success) {
        showToast("Error loading current settings payload.");
        saveBtn.disabled = false;
        saveLabel.innerText = "Save Menus";
        return;
      }

      // 2. Merge modified navigation links
      const payload = {
        ...getData.settings,
        navigation: headerMenu,
        footerNavigation: footerMenu
      };

      // 3. POST back to endpoint
      const postRes = await fetch("/api/settings-update", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      const postData = await postRes.json();

      if (postData.success) {
        showToast("Header & Footer navigation menus updated!");
      } else {
        showToast("Error: " + (postData.error || "Failed to update menus."));
      }
    } catch(e) {
      showToast("Network Error: Settings update failed.");
    } finally {
      saveBtn.disabled = false;
      saveLabel.innerText = "Save Menus";
    }
  }

  function showToast(message) {
    const notify = document.getElementById("toast-notify");
    const msgSpan = document.getElementById("toast-message");
    if (notify && msgSpan) {
      msgSpan.innerText = message;
      notify.classList.add("active");
      setTimeout(() => {
        notify.classList.remove("active");
      }, 3000);
    }
  }

  document.addEventListener("DOMContentLoaded", initMenus);
  document.addEventListener("astro:page-load", initMenus);
  if (document.readyState === "interactive" || document.readyState === "complete") {
    initMenus();
  }
</script>
