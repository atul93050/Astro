---
import AdminLayout from "../../layouts/admin/AdminLayout.astro";
import { getAllMenus, getMenuLocations } from "../../utils/menus";

export const prerender = false;

const menus = getAllMenus();
const locations = getMenuLocations();

// Build reverse map: menuId → location labels
const menuLocMap: Record<string, string[]> = {};
for (const [key, loc] of Object.entries(locations)) {
  if (loc.menuId) {
    if (!menuLocMap[loc.menuId]) menuLocMap[loc.menuId] = [];
    menuLocMap[loc.menuId].push(loc.label);
  }
}
---

<AdminLayout title="Menus">

  <div class="page-header-flex">
    <div>
      <p class="page-sub">Create and manage all navigation menus. Assign them to locations in <a href="/admin/menu-locations" style="color:var(--primary);">Menu Locations</a>.</p>
    </div>
    <button class="btn btn-primary" id="create-menu-btn">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      New Menu
    </button>
  </div>

  {menus.length === 0 ? (
    <div class="empty-state">
      <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--text-dim); margin-bottom:1rem;"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
      <h3>No menus yet</h3>
      <p>Click <strong>New Menu</strong> to create your first navigation menu.</p>
    </div>
  ) : (
    <div class="admin-table-wrapper">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Menu Name</th>
            <th>Items</th>
            <th>Assigned To</th>
            <th>Last Updated</th>
            <th style="text-align:right;">Actions</th>
          </tr>
        </thead>
        <tbody>
          {menus.map(menu => (
            <tr>
              <td>
                <strong style="color:var(--text-main);">{menu.name}</strong>
                <div style="font-size:0.78rem; color:var(--text-dim); margin-top:2px; font-family:monospace;">{menu.slug}</div>
              </td>
              <td>
                <span class="status-badge" style="background:rgba(99,102,241,0.1); color:var(--primary); border-color:rgba(99,102,241,0.2);">
                  {menu.items?.length ?? 0} items
                </span>
              </td>
              <td>
                {(menuLocMap[menu.slug] || []).length > 0 ? (
                  <div style="display:flex; flex-wrap:wrap; gap:0.35rem;">
                    {(menuLocMap[menu.slug] || []).map(loc => (
                      <span class="loc-tag">{loc}</span>
                    ))}
                  </div>
                ) : (
                  <span style="color:var(--text-dim); font-size:0.82rem;">— Unassigned</span>
                )}
              </td>
              <td style="color:var(--text-muted); font-size:0.83rem;">
                {menu.updatedAt ? new Date(menu.updatedAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : '—'}
              </td>
              <td>
                <div style="display:flex; gap:0.5rem; justify-content:flex-end;">
                  <a href={`/admin/menu-editor?id=${menu.slug}`} class="btn btn-outline btn-sm" title="Edit Menu">
                    <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                    Edit
                  </a>
                  <button class="btn btn-outline btn-sm" data-action="duplicate" data-id={menu.slug} data-name={menu.name}>
                    <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                    Duplicate
                  </button>
                  <button class="btn btn-outline btn-sm" data-action="export" data-id={menu.slug}>
                    <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                    Export
                  </button>
                  <button class="btn btn-sm" data-action="delete" data-id={menu.slug} style="background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); color:#ef4444;">
                    <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <!-- Quick links -->
  <div class="quick-links-grid">
    <a href="/admin/menu-locations" class="quick-link-card">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
      <div><strong>Menu Locations</strong><small>Assign menus to header, footer, sidebar slots</small></div>
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </a>
    <a href="/admin/mega-menus" class="quick-link-card">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
      <div><strong>Mega Menus</strong><small>Build multi-column dropdown panels</small></div>
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </a>
    <a href="/admin/menu-settings" class="quick-link-card">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9z"></path></svg>
      <div><strong>Menu Settings</strong><small>Global animation, breakpoint, alignment</small></div>
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </a>
  </div>

  <!-- Create Menu Modal -->
  <div class="modal-overlay" id="create-modal">
    <div class="modal-panel">
      <div class="modal-head">
        <h3>Create New Menu</h3>
        <button class="modal-close" id="close-create-modal">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="modal-body">
        <div class="form-field">
          <label for="new-menu-name">Menu Name *</label>
          <input type="text" id="new-menu-name" placeholder="e.g. Main Navigation" />
        </div>
        <div class="form-field">
          <label for="new-menu-desc">Description</label>
          <input type="text" id="new-menu-desc" placeholder="Optional description" />
        </div>
      </div>
      <div class="modal-foot">
        <button class="btn btn-outline" id="cancel-create-modal">Cancel</button>
        <button class="btn btn-primary" id="confirm-create-menu">Create Menu</button>
      </div>
    </div>
  </div>

  <div class="toast-notification" id="menus-toast"><div class="toast-content"><span id="menus-toast-msg"></span></div></div>

</AdminLayout>

<style is:global>
  .page-header-flex { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:2rem; gap:1rem; }
  .page-sub { color:var(--text-muted); font-size:0.88rem; margin-top:0.25rem; }
  .empty-state { text-align:center; padding:4rem 2rem; border:1px dashed var(--border-color); border-radius:var(--radius-lg); color:var(--text-dim); }
  .empty-state h3 { font-size:1.1rem; color:var(--text-muted); margin-bottom:0.5rem; }
  .loc-tag { display:inline-block; padding:0.15rem 0.55rem; background:rgba(16,185,129,0.1); color:#10B981; border:1px solid rgba(16,185,129,0.2); border-radius:10px; font-size:0.72rem; font-weight:600; }
  .quick-links-grid { display:grid; grid-template-columns: repeat(3,1fr); gap:1rem; margin-top:2rem; }
  @media(max-width:900px) { .quick-links-grid { grid-template-columns:1fr; } }
  .quick-link-card { display:flex; align-items:center; gap:1rem; padding:1.15rem 1.35rem; background:var(--bg-surface); border:1px solid var(--border-color); border-radius:var(--radius-md); transition:var(--transition); text-decoration:none; color:var(--text-main); }
  .quick-link-card:hover { border-color:var(--primary); background:var(--primary-light); }
  .quick-link-card > div { flex:1; }
  .quick-link-card strong { display:block; font-size:0.92rem; }
  .quick-link-card small { color:var(--text-dim); font-size:0.78rem; }
  .modal-overlay { position:fixed; inset:0; background:rgba(8,12,20,0.8); backdrop-filter:blur(8px); z-index:9000; display:flex; align-items:center; justify-content:center; opacity:0; pointer-events:none; transition:opacity 0.2s ease; }
  .modal-overlay.active { opacity:1; pointer-events:auto; }
  .modal-panel { background:var(--bg-surface-solid); border:1px solid var(--border-color); border-radius:var(--radius-lg); width:90%; max-width:480px; box-shadow:0 20px 50px rgba(0,0,0,0.4); transform:scale(0.95); transition:transform 0.2s ease; }
  .modal-overlay.active .modal-panel { transform:scale(1); }
  .modal-head { display:flex; justify-content:space-between; align-items:center; padding:1.25rem 1.5rem; border-bottom:1px solid var(--border-color); }
  .modal-head h3 { font-size:1.05rem; font-weight:700; }
  .modal-close { background:none; border:none; color:var(--text-muted); cursor:pointer; padding:0.25rem; border-radius:4px; }
  .modal-close:hover { color:var(--text-main); }
  .modal-body { padding:1.5rem; display:flex; flex-direction:column; gap:1rem; }
  .modal-body .form-field label { display:block; font-size:0.8rem; font-weight:600; color:var(--text-muted); margin-bottom:0.4rem; }
  .modal-foot { padding:1rem 1.5rem; border-top:1px solid var(--border-color); display:flex; justify-content:flex-end; gap:0.75rem; }
</style>

<script>
  function init() {
    // Create modal
    const createBtn = document.getElementById('create-menu-btn');
    const modal = document.getElementById('create-modal');
    const closeModal = document.getElementById('close-create-modal');
    const cancelModal = document.getElementById('cancel-create-modal');
    const confirmCreate = document.getElementById('confirm-create-menu');
    const nameInput = document.getElementById('new-menu-name') as HTMLInputElement;
    const descInput = document.getElementById('new-menu-desc') as HTMLInputElement;

    const openModal = () => { modal?.classList.add('active'); nameInput?.focus(); };
    const closeModalFn = () => { modal?.classList.remove('active'); if(nameInput) nameInput.value=''; if(descInput) descInput.value=''; };

    createBtn?.addEventListener('click', openModal);
    closeModal?.addEventListener('click', closeModalFn);
    cancelModal?.addEventListener('click', closeModalFn);
    modal?.addEventListener('click', (e) => { if(e.target === modal) closeModalFn(); });

    confirmCreate?.addEventListener('click', async () => {
      const name = nameInput?.value.trim();
      if (!name) { nameInput?.focus(); return; }
      confirmCreate.textContent = 'Creating…';
      (confirmCreate as HTMLButtonElement).disabled = true;
      try {
        const res = await fetch('/api/menus-crud', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, description: descInput?.value || '' }),
        });
        const data = await res.json();
        if (data.success) {
          window.location.href = `/admin/menu-editor?id=${data.menu.slug}`;
        } else {
          showToast(data.error || 'Failed to create menu');
          (confirmCreate as HTMLButtonElement).disabled = false;
          confirmCreate.textContent = 'Create Menu';
        }
      } catch { showToast('Network error'); (confirmCreate as HTMLButtonElement).disabled = false; confirmCreate.textContent = 'Create Menu'; }
    });

    nameInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter') confirmCreate?.click(); });

    // Row actions
    document.querySelectorAll('[data-action]').forEach(btn => {
      btn.addEventListener('click', async function(this: HTMLElement) {
        const action = this.dataset.action;
        const id = this.dataset.id!;

        if (action === 'delete') {
          window.customConfirm(`Delete menu "${id}"? This cannot be undone.`, async () => {
            const res = await fetch('/api/menus-crud', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
            const data = await res.json();
            if (data.success) window.location.reload();
            else showToast(data.error || 'Delete failed');
          });
        }

        if (action === 'duplicate') {
          const newName = `${this.dataset.name} (Copy)`;
          const getRes = await fetch(`/api/menus-crud?id=${id}`);
          const original = await getRes.json();
          const slug = newName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
          const res = await fetch('/api/menus-crud', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: newName, description: original.description, items: original.items }),
          });
          const data = await res.json();
          if (data.success) { showToast('Menu duplicated!'); setTimeout(() => window.location.reload(), 800); }
          else showToast(data.error || 'Duplicate failed');
        }

        if (action === 'export') {
          const res = await fetch(`/api/menus-crud?id=${id}`);
          const menu = await res.json();
          const blob = new Blob([JSON.stringify(menu, null, 2)], { type: 'application/json' });
          const a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = `menu-${id}.json`;
          a.click();
        }
      });
    });

    function showToast(msg: string) {
      const t = document.getElementById('menus-toast');
      const m = document.getElementById('menus-toast-msg');
      if (t && m) { m.textContent = msg; t.classList.add('active'); setTimeout(() => t.classList.remove('active'), 3000); }
    }
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('astro:page-load', init);
  if (document.readyState !== 'loading') init();
</script>
