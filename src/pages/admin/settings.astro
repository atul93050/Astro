---
import AdminLayout from "../../layouts/admin/AdminLayout.astro";
import fs from "node:fs";
import path from "node:path";

export const prerender = false;

// 1. Fetch initial configuration settings
const SETTINGS_FILE = path.resolve("src/data/global-settings.json");
let settings = {
  headerScripts: "",
  bodyStartScripts: "",
  bodyEndScripts: "",
  footerScripts: "",
  logo: {
    headerLogoUrl: "/images/tangence-black.png",
    footerLogoUrl: "/images/scroll-logo.svg"
  },
  socialLinks: {
    facebook: "",
    linkedin: "",
    twitter: "",
    instagram: ""
  },
  contactInfo: {
    phone: "+91-995-812-9810",
    email: "info@tangence.com",
    description: "Performance marketing built to outlast algorithm changes, recessions, and growth-hack fads. Since 2006.",
    offices: [] as Array<{ title: string; icon: string; address: string }>,
    cities: [] as string[]
  },
  navigation: [
    { text: "Home", link: "/" },
    { text: "About Us", link: "/about-us" },
    { text: "Contact", link: "/contact" }
  ],
  redirects: [] as Array<{ from: string; to: string; type?: string; active?: boolean }>
};

if (fs.existsSync(SETTINGS_FILE)) {
  try {
    const data = fs.readFileSync(SETTINGS_FILE, "utf-8");
    settings = { ...settings, ...JSON.parse(data) };
  } catch (e) {
    console.error("Error reading settings in settings.astro:", e);
  }
}
import "../../styles/admin/css/settings.css"
---

<AdminLayout title="Global Settings">
  
  <div class="settings-header">
    <div class="header-text">
      <p class="subtitle">Inject tracking scripts, manage brand logos, social page links, support contact details, corporate Noida/Mumbai addresses, and target cities coverage.</p>
    </div>
  </div>

  <form id="global-settings-form" onsubmit="return false;">
    
    <div class="settings-grid">
      
      <!-- Left Column: Brand Assets & Social Links -->
      <div class="settings-col-left">
        
        <!-- Brand Asset Settings -->
        <div class="form-card">
          <div class="card-header">
            <h3>Brand Assets & Social Links</h3>
          </div>
          <div class="card-body">
            <p class="section-desc">Manage logo assets, telephone contacts, social pages, and corporate Noida/Mumbai addresses.</p>
            
            <h4 style="margin-top: 1.25rem; font-size: 0.9rem; font-weight: 700; border-bottom: 1px solid var(--border-color); padding-bottom: 0.4rem; color: var(--primary);">Brand Logos</h4>
            <div class="form-group" style="margin-top: 0.5rem;">
              <label for="header-logo-url">Header Logo URL</label>
              <div class="input-picker-wrap">
                <input type="text" id="header-logo-url" value={settings.logo?.headerLogoUrl || "/images/tangence-black.png"} />
                <button type="button" class="btn btn-outline  media-picker-trigger" data-target="header-logo-url">Pick</button>
              </div>
            </div>
            <div class="form-group" style="margin-top: 0.75rem;">
              <label for="footer-logo-url">Footer Logo URL</label>
              <div class="input-picker-wrap">
                <input type="text" id="footer-logo-url" value={settings.logo?.footerLogoUrl || "/images/scroll-logo.svg"} />
                <button type="button" class="btn btn-outline media-picker-trigger" data-target="footer-logo-url">Pick</button>
              </div>
            </div>

            <h4 style="margin-top: 1.5rem; font-size: 0.9rem; font-weight: 700; border-bottom: 1px solid var(--border-color); padding-bottom: 0.4rem; color: var(--primary);">Contact Info & Social Links</h4>
            <div class="form-group" style="margin-top: 0.5rem;">
              <label for="contact-phone">Contact Phone Number</label>
              <input type="text" id="contact-phone" value={settings.contactInfo?.phone || "+91-995-812-9810"} placeholder="e.g. +91-995-812-9810" />
            </div>
            <div class="form-group" style="margin-top: 0.75rem;">
              <label for="contact-email">Support Email</label>
              <input type="text" id="contact-email" value={settings.contactInfo?.email || "info@tangence.com"} placeholder="e.g. info@tangence.com" />
            </div>
            <div class="form-group" style="margin-top: 0.75rem;">
              <label for="footer-desc">Footer Description</label>
              <textarea id="footer-desc" rows="3" placeholder="Performance marketing since 2006...">{settings.contactInfo?.description || ""}</textarea>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; margin-top:0.75rem;">
              <div class="form-group">
                <label for="social-facebook">Facebook Link</label>
                <input type="text" id="social-facebook" value={settings.socialLinks?.facebook || ""} placeholder="https://..." />
              </div>
              <div class="form-group">
                <label for="social-linkedin">LinkedIn Link</label>
                <input type="text" id="social-linkedin" value={settings.socialLinks?.linkedin || ""} placeholder="https://..." />
              </div>
              <div class="form-group">
                <label for="social-twitter">Twitter / X Link</label>
                <input type="text" id="social-twitter" value={settings.socialLinks?.twitter || ""} placeholder="https://..." />
              </div>
              <div class="form-group">
                <label for="social-instagram">Instagram Link</label>
                <input type="text" id="social-instagram" value={settings.socialLinks?.instagram || ""} placeholder="https://..." />
              </div>
            </div>

            <h4 style="margin-top: 1.5rem; font-size: 0.9rem; font-weight: 700; border-bottom: 1px solid var(--border-color); padding-bottom: 0.4rem; color: var(--primary); display:flex; justify-content:space-between; align-items:center;">
              <span>Office Addresses</span>
              <button type="button" class="btn btn-outline btn-sm" id="add-office-btn" style="padding: 0.2rem 0.5rem; font-size: 0.72rem;">+ Add Office</button>
            </h4>
            <div class="repeater-items-wrap" id="offices-container" style="margin-top:0.75rem; gap:0.5rem;">
              <!-- Loaded dynamically -->
            </div>
            
            <h4 style="margin-top: 1.5rem; font-size: 0.9rem; font-weight: 700; border-bottom: 1px solid var(--border-color); padding-bottom: 0.4rem; color: var(--primary); display:flex; justify-content:space-between; align-items:center;">
              <span>Target Cities Coverage</span>
              <button type="button" class="btn btn-outline btn-sm" id="add-city-btn" style="padding: 0.2rem 0.5rem; font-size: 0.72rem;">+ Add City</button>
            </h4>
            <div class="repeater-items-wrap" id="cities-container" style="margin-top:0.75rem; gap:0.4rem;">
              <!-- Loaded dynamically -->
            </div>
          </div>
        </div>

      </div>

      <!-- Right Column: Scripts and Pixels -->
      <div class="settings-col-right">
        
        <!-- Header / Footer / Body script Injections -->
        <div class="form-card">
          <div class="card-header">
            <h3>Global Script & Pixel Injection</h3>
          </div>
          <div class="card-body" style="display:flex; flex-direction:column; gap:1.25rem;">
            <div class="form-group">
              <label for="header-scripts">Header Scripts (Injects before <code>&lt;/head&gt;</code>)</label>
              <textarea id="header-scripts" rows="4" placeholder="<!-- Place custom meta tags, GTM head script, Google Analytics here -->">{settings.headerScripts}</textarea>
            </div>

            <div class="form-group">
              <label for="body-start-scripts">Body Start Scripts (Injects right after <code>&lt;body&gt;</code>)</label>
              <textarea id="body-start-scripts" rows="3" placeholder="<!-- Place GTM Noscript iframe or Facebook Pixel Noscript image here -->">{settings.bodyStartScripts || ""}</textarea>
            </div>

            <div class="form-group">
              <label for="body-end-scripts">Body End Scripts (Injects right before <code>&lt;/body&gt;</code>)</label>
              <textarea id="body-end-scripts" rows="3" placeholder="<!-- Place generic tracking body triggers or fallback analytics here -->">{settings.bodyEndScripts || ""}</textarea>
            </div>
            
            <div class="form-group">
              <label for="footer-scripts">Footer Scripts (Injects at the very end of page)</label>
              <textarea id="footer-scripts" rows="4" placeholder="<!-- Place custom chatbots, widgets, or heatmaps here -->">{settings.footerScripts}</textarea>
            </div>
          </div>
        </div>

      </div>

    </div>

    <!-- Bottom Save bar -->
    <div class="bottom-action-save-bar">
      <button type="button" class="btn btn-primary" id="save-settings-btn" style="padding:0.75rem 2rem;">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right:0.25rem;"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
        <span id="save-btn-label">Save Global Configurations</span>
      </button>
    </div>

  </form>

  <!-- Reusable Media Library Selector Modal Dialog -->
  <div class="confirm-modal-overlay" id="media-picker-overlay">
    <div class="confirm-modal media-modal" style="max-width: 650px;">
      <div class="confirm-modal-header">
        <h4>Select Asset from Media Catalog</h4>
        <button type="button" class="close-modal-btn" id="close-media-modal">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="media-modal-actions">
        <form id="media-upload-form" onsubmit="return false;" style="display:flex; gap:0.5rem; width:100%;">
          <input type="file" id="media-upload-file" accept="image/*" style="display:none;" />
          <button type="button" class="btn btn-outline btn-sm" id="trigger-file-select" style="flex:1;">
            Choose Upload File
          </button>
          <button type="button" class="btn btn-primary btn-sm" id="upload-media-btn" disabled>
            Upload
          </button>
        </form>
      </div>
      <div class="media-picker-grid" id="media-picker-grid" style="max-height:280px; overflow-y:auto; overflow-x:hidden;">
        <p class="media-empty">No catalog images. Upload a new asset.</p>
      </div>
      <div class="confirm-modal-footer">
        <button type="button" class="btn btn-outline" id="close-media-picker-btn">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Notification Banner -->
  <div class="toast-notification" id="toast-notify">
    <div class="toast-content">
      <span class="toast-message" id="toast-message">Settings saved successfully!</span>
    </div>
  </div>

</AdminLayout>

<style is:global>
  .subtitle {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-top: 0.25rem;
    margin-bottom: 2rem;
  }
  
  .settings-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 1.5rem;
    align-items: start;
    margin-bottom: 6rem; /* space for save bar */
  }
  @media (max-width: 1024px) {
    .settings-grid {
      grid-template-columns: 1fr;
    }
  }

  .form-card {
    background: var(--bg-surface);
    border: 1px solid var(--bg-surface-border);
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 15px var(--color-shadow);
    backdrop-filter: blur(10px);
    overflow: hidden;
  }
  .card-header {
    padding: 1.15rem 1.5rem;
    border-bottom: 1px solid var(--bg-surface-border);
    background: rgba(156, 163, 175, 0.02);
  }
  .card-header h3 {
    font-size: 1.05rem;
    font-weight: 700;
  }
  .card-body {
    padding: 1.5rem;
  }
  .section-desc {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-top: -0.5rem;
    line-height: 1.4;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
  }
  textarea, input[type="text"] {
    padding: 0.65rem 0.85rem;
    border-radius: var(--radius-sm);
    background-color: var(--input-bg);
    border: 1px solid var(--input-border);
    color: var(--text-main);
    font-size: 0.9rem;
    outline: none;
    transition: var(--transition);
    width: 100%;
    box-sizing: border-box;
  }
  textarea:focus, input:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
  }
  textarea {
    font-family: monospace;
    font-size: 0.85rem;
  }

  /* Repeaters */
  .repeater-items-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .repeater-item-row {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: var(--transition);
  }
  .repeater-item-row:hover {
    border-color: var(--primary);
  }
  .btn-icon-sm {
    width: 28px;
    height: 28px;
    border-radius: 4px;
    border: 1px solid var(--border-color);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
    flex-shrink: 0;
  }
  .btn-icon-sm:hover {
    color: var(--text-main);
    background: rgba(156, 163, 175, 0.08);
  }
  .btn-delete-row:hover {
    color: var(--color-error);
    background: rgba(239, 68, 68, 0.08);
    border-color: var(--color-error);
  }

  /* Bottom Actions Bar styling */
  .bottom-action-save-bar {
    position: fixed;
    bottom: 0;
    left: 270px;
    right: 0;
    background: var(--bg-surface-solid);
    border-top: 1px solid var(--bg-surface-border);
    padding: 1rem 2.5rem;
    display: flex;
    justify-content: flex-end;
    box-shadow: 0 -4px 15px rgba(0,0,0,0.15);
    z-index: 99;
    backdrop-filter: blur(10px);
    transition: left 0.3s ease;
  }
  @media (max-width: 768px) {
    .bottom-action-save-bar {
      left: 0;
      padding: 1rem 1.5rem;
    }
  }

  /* Toast Notification */
  .toast-notification {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: var(--bg-surface-solid);
    border-left: 4px solid var(--primary);
    border-top: 1px solid var(--bg-surface-border);
    border-bottom: 1px solid var(--bg-surface-border);
    border-right: 1px solid var(--bg-surface-border);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-sm);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35);
    z-index: 1100;
    transform: translateY(150%);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(8px);
  }
  .toast-notification.active {
    transform: translateY(0);
  }
  .toast-content {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-main);
  }

  /* Confirmation / Media Selector Modal Custom Glassmorphism */
  .confirm-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(8, 12, 20, 0.75);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .confirm-modal-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }
  .confirm-modal {
    background: var(--bg-surface-solid);
    border: 1px solid var(--bg-surface-border);
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 500px;
    padding: 1.75rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    transform: scale(0.9);
    transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .confirm-modal-overlay.active .confirm-modal {
    transform: scale(1);
  }
  .confirm-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .confirm-modal-header h4 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-main);
  }
  .close-modal-btn {
    background: transparent;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    transition: var(--transition);
  }
  .close-modal-btn:hover {
    color: var(--text-main);
  }
  .confirm-modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .media-modal-actions {
    margin-bottom: 1rem;
    background: rgba(156, 163, 175, 0.03);
    padding: 0.75rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
  }
  .media-picker-item {
    aspect-ratio: 1;
    border-radius: 6px;
    overflow: hidden;
    border: 2px solid transparent;
    cursor: pointer;
    position: relative;
    background: rgba(156, 163, 175, 0.03);
    transition: var(--transition);
  }
  .media-picker-item:hover {
    transform: scale(1.03);
    border-color: var(--primary);
  }
  .media-picker-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script is:inline define:vars={{ settings }}>
  let offices = settings.contactInfo?.offices || [];
  let cities = settings.contactInfo?.cities || [];
  let activeMediaPickerTarget = "";

  function initSettings() {
    const form = document.getElementById("global-settings-form");
    if (!form || form.dataset.listenerBound) return;
    form.dataset.listenerBound = "true";

    renderOffices();
    renderCities();
    setupControls();
  }

  const ICONS = {
    delete: `<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>`
  };

  function setupControls() {
    // Add Office click
    const addOfficeBtn = document.getElementById("add-office-btn");
    if (addOfficeBtn) {
      addOfficeBtn.addEventListener("click", () => {
        offices.push({ title: "", icon: "/images/icons/Path-529.png", address: "" });
        renderOffices();
      });
    }

    // Add City click
    const addCityBtn = document.getElementById("add-city-btn");
    if (addCityBtn) {
      addCityBtn.addEventListener("click", () => {
        cities.push("");
        renderCities();
      });
    }

    // Save Settings click
    const saveBtn = document.getElementById("save-settings-btn");
    if (saveBtn) {
      saveBtn.addEventListener("click", saveSettingsSubmit);
    }

    // Media modal triggers setup - use global GWP picker
    document.addEventListener("click", (e) => {
      if (e.target && e.target.classList.contains("media-picker-trigger")) {
        const targetId = e.target.getAttribute("data-target");
        window.openWPMediaPicker({
          title: 'Select Image',
          btnLabel: 'Use this image',
          onSelect: function(url) {
            const input = document.getElementById(targetId);
            if (input) {
              input.value = url;
              input.dispatchEvent(new Event('input'));
            }
          }
        });
      }
    });

    const closePickerX = document.getElementById("close-media-modal");
    const closePickerBtn = document.getElementById("close-media-picker-btn");
    if (closePickerX) closePickerX.addEventListener("click", hideMediaModal);
    if (closePickerBtn) closePickerBtn.addEventListener("click", hideMediaModal);

    const fileSelectBtn = document.getElementById("trigger-file-select");
    const fileInput = document.getElementById("media-upload-file");
    const uploadBtn = document.getElementById("upload-media-btn");

    if (fileSelectBtn && fileInput) {
      fileSelectBtn.addEventListener("click", () => fileInput.click());
      fileInput.addEventListener("change", () => {
        if (fileInput.files.length > 0) {
          fileSelectBtn.innerText = fileInput.files[0].name;
          if (uploadBtn) uploadBtn.disabled = false;
        } else {
          fileSelectBtn.innerText = "Choose Upload File";
          if (uploadBtn) uploadBtn.disabled = true;
        }
      });
    }

    if (uploadBtn) {
      uploadBtn.addEventListener("click", uploadMediaFile);
    }


  }

  // --- OFFICES REPEATER ---
  window.syncOfficeField = function(index, field, value) {
    offices[index][field] = value;
  };
  window.deleteOffice = function(index) {
    offices.splice(index, 1);
    renderOffices();
  };
  function renderOffices() {
    const container = document.getElementById("offices-container");
    if (!container) return;
    container.innerHTML = "";
    offices.forEach((item, idx) => {
      const row = document.createElement("div");
      row.className = "repeater-item-row";
      row.style = "display:flex; flex-direction:column; gap:0.5rem; padding:0.65rem; background:var(--bg-surface-solid); border:1px solid var(--border-color); border-radius:4px;";
      row.innerHTML = `
        <div style="display:flex; justify-content:space-between; align-items:center; width:100%;">
          <span style="font-weight:700; font-size:0.75rem; color:var(--text-dim);">Office #${idx + 1}</span>
          <button type="button" class="btn-icon-sm" onclick="deleteOffice(${idx})" style="width:24px; height:24px;">${ICONS.delete}</button>
        </div>
        <div style="display:grid; grid-template-columns:1fr 1.2fr; gap:0.5rem; width:100%;">
          <input type="text" value="${item.title || ''}" oninput="syncOfficeField(${idx}, 'title', this.value)" placeholder="Office Title (e.g. Noida)" style="font-size:0.8rem; padding:0.4rem;" />
          <input type="text" value="${item.icon || ''}" oninput="syncOfficeField(${idx}, 'icon', this.value)" placeholder="Icon URL Path" style="font-size:0.8rem; padding:0.4rem;" />
        </div>
        <input type="text" value="${item.address || ''}" oninput="syncOfficeField(${idx}, 'address', this.value)" placeholder="Physical Address" style="font-size:0.8rem; padding:0.4rem; width:100%;" />
      `;
      container.appendChild(row);
    });
  }

  // --- CITIES REPEATER ---
  window.syncCityValue = function(index, value) {
    cities[index] = value;
  };
  window.deleteCity = function(index) {
    cities.splice(index, 1);
    renderCities();
  };
  function renderCities() {
    const container = document.getElementById("cities-container");
    if (!container) return;
    container.innerHTML = "";
    cities.forEach((item, idx) => {
      const row = document.createElement("div");
      row.className = "repeater-item-row";
      row.style = "display:flex; gap:0.5rem; padding:0.4rem; align-items:center; background:var(--bg-surface-solid); border:1px solid var(--border-color); border-radius:4px;";
      row.innerHTML = `
        <input type="text" value="${item || ''}" oninput="syncCityValue(${idx}, this.value)" placeholder="City Name (e.g. Noida)" style="font-size:0.8rem; padding:0.4rem; flex:1;" />
        <button type="button" class="btn-icon-sm" onclick="deleteCity(${idx})" style="width:24px; height:24px;">${ICONS.delete}</button>
      `;
      container.appendChild(row);
    });
  }

  // --- MEDIA PICKER INTERACTION ---
  function openMediaModal(targetId) {
    activeMediaPickerTarget = targetId;
    const modal = document.getElementById("media-picker-overlay");
    if (modal) modal.classList.add("active");
    loadMediaCatalogGrid();
  }

  function hideMediaModal() {
    const modal = document.getElementById("media-picker-overlay");
    if (modal) modal.classList.remove("active");
    activeMediaPickerTarget = "";
  }

  async function loadMediaCatalogGrid() {
    const grid = document.getElementById("media-picker-grid");
    if (!grid) return;

    try {
      const res = await fetch("/api/media-crud");
      const data = await res.json();

      if (data.success && data.media.length > 0) {
        grid.innerHTML = data.media.map(item => `
          <div class="media-picker-item" onclick="selectMediaAsset('${item.url}')" title="${item.alt || item.title}">
            <img src="${item.url}" alt="${item.alt || ''}" />
          </div>
        `).join('');
      } else {
        grid.innerHTML = `<p class="media-empty">No catalog images. Upload a new asset.</p>`;
      }
    } catch (e) {
      grid.innerHTML = `<p class="media-empty" style="color:var(--color-error);">Error loading media catalog files.</p>`;
    }
  }

  window.selectMediaAsset = function(url) {
    if (activeMediaPickerTarget) {
      const targetInput = document.getElementById(activeMediaPickerTarget);
      if (targetInput) {
        targetInput.value = url;
        const changeEvent = new Event('input', { bubbles: true });
        targetInput.dispatchEvent(changeEvent);
      }
      hideMediaModal();
    }
  };

  async function uploadMediaFile() {
    const fileInput = document.getElementById("media-upload-file");
    const uploadBtn = document.getElementById("upload-media-btn");
    const fileSelectBtn = document.getElementById("trigger-file-select");

    if (!fileInput || fileInput.files.length === 0) return;

    const file = fileInput.files[0];
    const formData = new FormData();
    formData.append("file", file);
    formData.append("alt", file.name.split(".")[0]);

    uploadBtn.disabled = true;
    uploadBtn.innerText = "Uploading...";

    try {
      const res = await fetch("/api/media-crud", {
        method: "POST",
        body: formData
      });
      const result = await res.json();

      if (result.success) {
        showToast("Asset uploaded successfully!");
        fileInput.value = "";
        fileSelectBtn.innerText = "Choose Upload File";
        uploadBtn.innerText = "Upload";
        selectMediaAsset(result.media.url);
      } else {
        showToast("Error: " + (result.error || "Upload failed"));
        uploadBtn.disabled = false;
        uploadBtn.innerText = "Upload";
      }
    } catch (e) {
      showToast("Network Error: Could not upload file asset");
      uploadBtn.disabled = false;
      uploadBtn.innerText = "Upload";
    }
  }



  // --- SAVE settings TO SERVER ---
  async function saveSettingsSubmit() {
    const headerScripts = document.getElementById("header-scripts").value;
    const footerScripts = document.getElementById("footer-scripts").value;
    const bodyStartScripts = document.getElementById("body-start-scripts").value;
    const bodyEndScripts = document.getElementById("body-end-scripts").value;

    const logo = {
      headerLogoUrl: document.getElementById("header-logo-url").value.trim(),
      footerLogoUrl: document.getElementById("footer-logo-url").value.trim()
    };

    const socialLinks = {
      facebook: document.getElementById("social-facebook").value.trim(),
      linkedin: document.getElementById("social-linkedin").value.trim(),
      twitter: document.getElementById("social-twitter").value.trim(),
      instagram: document.getElementById("social-instagram").value.trim()
    };

    const contactInfo = {
      phone: document.getElementById("contact-phone").value.trim(),
      email: document.getElementById("contact-email").value.trim(),
      description: document.getElementById("footer-desc").value.trim(),
      offices,
      cities
    };

    const saveBtn = document.getElementById("save-settings-btn");
    const saveLabel = document.getElementById("save-btn-label");
    saveBtn.disabled = true;
    saveLabel.innerText = "Saving Configuration...";

    try {
      // 1. Fetch current settings payload first to preserve menus and redirects
      const getRes = await fetch("/api/settings-update");
      const getData = await getRes.json();
      
      if (!getData.success) {
        showToast("Error loading settings configuration.");
        saveBtn.disabled = false;
        saveLabel.innerText = "Save Global Configurations";
        return;
      }

      const payload = {
        ...getData.settings, // preserves navigation, footerNavigation, redirects
        headerScripts,
        footerScripts,
        bodyStartScripts,
        bodyEndScripts,
        logo,
        socialLinks,
        contactInfo
      };

      const res = await fetch("/api/settings-update", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      const data = await res.json();

      if (data.success) {
        showToast("Global configurations saved successfully!");
      } else {
        showToast("Error: " + (data.error || "Save failed"));
      }
    } catch (e) {
      showToast("Network Error: Could not save global configurations");
    } finally {
      saveBtn.disabled = false;
      saveLabel.innerText = "Save Global Configurations";
    }
  }

  // Toast banner utility
  const toast = document.getElementById("toast-notify");
  const toastMsg = document.getElementById("toast-message");
  
  function showToast(message) {
    if (toast && toastMsg) {
      toastMsg.innerText = message;
      toast.classList.add("active");
      setTimeout(() => {
        toast.classList.remove("active");
      }, 4000);
    }
  }

  // Hook layout on load
  document.addEventListener("DOMContentLoaded", initSettings);
  document.addEventListener("astro:page-load", initSettings);
  if (document.readyState === "interactive" || document.readyState === "complete") {
    initSettings();
  }
</script>
