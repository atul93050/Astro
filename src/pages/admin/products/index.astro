---
import AdminLayout from '../../../layouts/admin/AdminLayout.astro';

export const prerender = false;
---
<AdminLayout title="Products">

  <div class="page-header-flex" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:2rem;">
    <div>
      <p class="page-sub" style="color:var(--text-muted); margin:0;">Create, edit, and organize all your e-commerce products and variants.</p>
    </div>
    <a href="/admin/products/create" class="btn btn-primary" style="display:inline-flex; align-items:center; gap:0.5rem;">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      New Product
    </a>
  </div>

  <!-- Filters Row -->
  <div class="filters-row" style="display:flex; justify-content:space-between; align-items:center; gap:1rem; margin-bottom:1.5rem; flex-wrap:wrap; background:var(--bg-surface); padding:1rem; border:1px solid var(--border-color); border-radius:var(--radius-md);">
    <div style="display:flex; gap:0.75rem; align-items:center; flex-wrap:wrap;">
      <select id="category-filter" class="admin-select-input" style="background:var(--input-bg); border:1px solid var(--input-border); color:var(--text-main); padding:0.4rem 0.75rem; border-radius:var(--radius-sm); font-size:0.85rem; outline:none;" aria-label="Filter by category">
        <option value="">All Categories</option>
      </select>
      <select id="status-filter" class="admin-select-input" style="background:var(--input-bg); border:1px solid var(--input-border); color:var(--text-main); padding:0.4rem 0.75rem; border-radius:var(--radius-sm); font-size:0.85rem; outline:none;" aria-label="Filter by status">
        <option value="all">All Statuses</option>
        <option value="published">Published</option>
        <option value="draft">Draft</option>
      </select>
      <button type="button" id="btn-filter" class="btn btn-outline btn-sm">Filter</button>
    </div>
    <div style="display:flex; gap:0.5rem; align-items:center;">
      <div style="position:relative; display:flex; align-items:center;">
        <input type="search" id="search-input" placeholder="Search products..." style="background:var(--input-bg); border:1px solid var(--input-border); color:var(--text-main); padding:0.4rem 0.75rem; padding-left:2rem; border-radius:var(--radius-sm); font-size:0.85rem; outline:none; width:220px;" autocomplete="off" />
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" style="position:absolute; left:0.75rem; color:var(--text-dim);"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </div>
    </div>
  </div>

  <!-- Table Container -->
  <div class="admin-table-wrapper" style="background:var(--bg-surface); border:1px solid var(--border-color); border-radius:var(--radius-lg); overflow:hidden; margin-bottom:5rem;">
    <div id="table-loading" style="display:flex; flex-direction:column; align-items:center; padding:5rem; gap:1rem; color:var(--text-dim);">
      <div class="loading-spinner" style="width:30px; height:30px; border:3px solid var(--border-color); border-top-color:var(--primary); border-radius:50%; animation:spin 0.8s linear infinite;"></div>
      <span>Loading products...</span>
    </div>

    <div id="table-empty" style="display:none; flex-direction:column; align-items:center; padding:5rem; color:var(--text-dim); text-align:center;">
      <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:1rem; color:var(--text-dim);"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
      <h3>No products found</h3>
      <p style="margin-top:0.25rem;">Create a product to list it here.</p>
    </div>

    <table class="admin-table" id="products-table" style="display:none; width:100%; border-collapse:collapse; text-align:left; font-size:0.9rem;">
      <thead>
        <tr style="border-bottom:1px solid var(--border-color); background:rgba(255,255,255,0.01);">
          <th style="padding:1rem 1.5rem; font-weight:600; color:var(--text-muted); width:70px;">Image</th>
          <th style="padding:1rem 1.5rem; font-weight:600; color:var(--text-muted);">Product</th>
          <th style="padding:1rem 1.5rem; font-weight:600; color:var(--text-muted);">Category</th>
          <th style="padding:1rem 1.5rem; font-weight:600; color:var(--text-muted);">Price</th>
          <th style="padding:1rem 1.5rem; font-weight:600; color:var(--text-muted); width:120px;">Stock</th>
          <th style="padding:1rem 1.5rem; font-weight:600; color:var(--text-muted); width:100px;">Status</th>
          <th style="padding:1rem 1.5rem; font-weight:600; color:var(--text-muted); text-align:right; width:180px;">Actions</th>
        </tr>
      </thead>
      <tbody id="products-tbody">
        <!-- Rendered via JS -->
      </tbody>
    </table>
  </div>

  <div class="toast-notification" id="toast"><div class="toast-content"><span id="toast-msg"></span></div></div>

</AdminLayout>

<style is:global>
  @keyframes spin { to { transform: rotate(360deg); } }
  .admin-table tbody tr { border-bottom: 1px solid var(--border-color); transition: var(--transition); }
  .admin-table tbody tr:hover { background: rgba(255,255,255,0.02); }
  .stock-badge { display:inline-flex; align-items:center; padding:0.25rem 0.5rem; border-radius:4px; font-size:0.75rem; font-weight:600; border:1px solid transparent; }
  .stock-instock { background: rgba(16,185,129,0.1); color:#10B981; border-color: rgba(16,185,129,0.2); }
  .stock-low { background: rgba(245,158,11,0.1); color:#f59e0b; border-color: rgba(245,158,11,0.2); }
  .stock-outofstock { background: rgba(239,68,68,0.1); color:#ef4444; border-color: rgba(239,68,68,0.2); }
  .status-badge { display:inline-flex; align-items:center; padding:0.25rem 0.5rem; border-radius:4px; font-size:0.75rem; font-weight:600; border:1px solid transparent; }
  .status-published { background: rgba(16,185,129,0.1); color:#10B981; border-color: rgba(16,185,129,0.2); }
  .status-draft { background: rgba(156,163,175,0.1); color:#9ca3af; border-color: rgba(156,163,175,0.2); }
</style>

<script>
  let allProducts: any[] = [];
  let categories: any[] = [];

  function showToast(msg: string) {
    const t = document.getElementById('toast');
    const m = document.getElementById('toast-msg');
    if (t && m) { m.textContent = msg; t.classList.add('active'); setTimeout(() => t.classList.remove('active'), 3000); }
  }

  async function loadCategories() {
    try {
      const res = await fetch('/api/products-crud?action=categories');
      const data = await res.json();
      if (data.success) {
        categories = data.categories || [];
        const filterSel = document.getElementById('category-filter') as HTMLSelectElement;
        if (filterSel) {
          filterSel.innerHTML = '<option value="">All Categories</option>' + categories.map(c => 
            `<option value="${c.slug}">${c.name}</option>`
          ).join('');
        }
      }
    } catch (err) {}
  }

  async function loadProducts() {
    const table = document.getElementById('products-table');
    const loading = document.getElementById('table-loading');
    const empty = document.getElementById('table-empty');
    const tbody = document.getElementById('products-tbody');
    if (!tbody || !loading || !empty || !table) return;

    table.style.display = 'none';
    loading.style.display = 'flex';
    empty.style.display = 'none';

    try {
      const cat = (document.getElementById('category-filter') as HTMLSelectElement)?.value || '';
      const status = (document.getElementById('status-filter') as HTMLSelectElement)?.value || 'all';
      const search = (document.getElementById('search-input') as HTMLInputElement)?.value || '';

      const url = `/api/products-crud?action=list&category=${cat}&status=${status}&search=${search}`;
      const res = await fetch(url);
      const data = await res.json();

      loading.style.display = 'none';
      if (data.success && data.products && data.products.length > 0) {
        allProducts = data.products;
        tbody.innerHTML = allProducts.map(p => {
          // Calculate Price Range
          let priceStr = `₹${p.basePrice}`;
          if (p.variants && p.variants.length > 0) {
            const prices = p.variants.map((v: any) => v.price || 0);
            const minPrice = Math.min(...prices);
            const maxPrice = Math.max(...prices);
            priceStr = minPrice === maxPrice ? `₹${minPrice}` : `₹${minPrice} - ₹${maxPrice}`;
          }

          // Calculate Total Stock & Stock Status
          let totalStock = p.stock || 0;
          if (p.variants && p.variants.length > 0) {
            totalStock = p.variants.reduce((sum: number, v: any) => sum + (v.stock || 0), 0);
          }
          const threshold = p.lowStockThreshold || 5;
          let stockClass = 'stock-instock';
          let stockLabel = 'In Stock';
          if (totalStock === 0) {
            stockClass = 'stock-outofstock';
            stockLabel = 'Out of Stock';
          } else if (totalStock <= threshold) {
            stockClass = 'stock-low';
            stockLabel = `Low (${totalStock})`;
          } else {
            stockLabel = `In Stock (${totalStock})`;
          }

          const catName = categories.find(c => c.slug === p.category)?.name || p.category || '—';

          return `
            <tr>
              <td style="padding:1rem 1.5rem; vertical-align:middle;">
                ${p.featuredImage ? `<img src="${p.featuredImage}" style="width:40px; height:40px; border-radius:6px; object-fit:cover; border:1px solid var(--border-color);" />` : `
                  <div style="width:40px; height:40px; border-radius:6px; background:rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:center; color:var(--text-dim); border:1px solid var(--border-color);">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  </div>
                `}
              </td>
              <td style="padding:1rem 1.5rem; vertical-align:middle;">
                <strong style="color:var(--text-main); font-weight:600; display:block;">${p.name || 'Untitled'}</strong>
                <span style="font-size:0.75rem; color:var(--text-dim); font-family:monospace; display:block; margin-top:2px;">${p.slug}</span>
              </td>
              <td style="padding:1rem 1.5rem; vertical-align:middle; color:var(--text-muted);">${catName}</td>
              <td style="padding:1rem 1.5rem; vertical-align:middle; font-weight:500; color:var(--text-main);">${priceStr}</td>
              <td style="padding:1rem 1.5rem; vertical-align:middle;">
                <span class="stock-badge ${stockClass}">${stockLabel}</span>
              </td>
              <td style="padding:1rem 1.5rem; vertical-align:middle;">
                <span class="status-badge status-${p.status || 'draft'}">${p.status === 'published' ? 'Published' : 'Draft'}</span>
              </td>
              <td style="padding:1rem 1.5rem; vertical-align:middle; text-align:right;">
                <div style="display:inline-flex; gap:0.4rem;">
                  <a href="/admin/products/edit?slug=${p.slug}" class="btn btn-outline btn-sm" style="padding:0.25rem 0.6rem; font-size:0.78rem;">Edit</a>
                  <button class="btn btn-outline btn-sm" onclick="duplicateProduct('${p.slug}')" style="padding:0.25rem 0.6rem; font-size:0.78rem;">Duplicate</button>
                  <button class="btn btn-sm" onclick="deleteProduct('${p.slug}')" style="padding:0.25rem 0.6rem; font-size:0.78rem; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); color:#ef4444;">Delete</button>
                </div>
              </td>
            </tr>
          `;
        }).join('');
        table.style.display = 'table';
      } else {
        empty.style.display = 'flex';
      }
    } catch {
      loading.style.display = 'none';
      empty.style.display = 'flex';
    }
  }

  (window as any).duplicateProduct = async function(slug: string) {
    try {
      const res = await fetch('/api/products-crud', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'duplicate', slug })
      });
      const data = await res.json();
      if (data.success) {
        showToast('Product duplicated!');
        loadProducts();
      } else {
        showToast(data.error || 'Duplicate failed');
      }
    } catch {
      showToast('Network error');
    }
  }

  (window as any).deleteProduct = function(slug: string) {
    if (window.customConfirm) {
      window.customConfirm(`Delete product "${slug}" permanently?`, async () => {
        try {
          const res = await fetch('/api/products-crud', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug })
          });
          const data = await res.json();
          if (data.success) {
            showToast('Product deleted');
            loadProducts();
          } else {
            showToast(data.error || 'Delete failed');
          }
        } catch {
          showToast('Network error');
        }
      });
    }
  }

  function init() {
    loadCategories().then(() => {
      loadProducts();
    });

    document.getElementById('btn-filter')?.addEventListener('click', loadProducts);
    document.getElementById('search-input')?.addEventListener('input', (e) => {
      // Small debounce
      clearTimeout((window as any).searchTimeout);
      (window as any).searchTimeout = setTimeout(loadProducts, 300);
    });
  }

  if (document.readyState !== 'loading') {
    init();
  } else {
    document.addEventListener('DOMContentLoaded', init);
  }
  document.addEventListener('astro:page-load', init);
</script>
