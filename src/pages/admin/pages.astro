  }

  /* Date display styling */
  .date-cell {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .date-time {
    font-size: 0.76rem;
    color: var(--text-muted);
  }

  /* Search Query Highlight style */
  .highlight-match {
    background: rgba(245, 158, 11, 0.25);
    color: var(--color-warning);
    font-weight: bold;
    border-bottom: 1.5px solid var(--color-warning);
    border-radius: 2px;
    padding: 0 1px;
  }

  /* Slide-over Outline panel styling */
  .slideover-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(8, 12, 20, 0.7);
    backdrop-filter: blur(5px);
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  .slideover-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }
  .slideover-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    max-width: 420px;
    background: var(--bg-surface-solid);
    border-left: 1px solid var(--bg-surface-border);
    box-shadow: -5px 0 30px rgba(0,0,0,0.5);
    transform: translateX(100%);
    transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .slideover-overlay.active .slideover-panel {
    transform: translateX(0);
  }
  .outline-timeline-list::before {
    content: '';
    position: absolute;
    top: 0.5rem;
    bottom: 0.5rem;
    left: 0.35rem;
    width: 2px;
    background: var(--bg-surface-border);
  }
  .outline-item {
    position: relative;
    padding-bottom: 1rem;
    padding-left: 1.25rem;
    text-align: left;
  }
  .outline-item::before {
    content: '';
    position: absolute;
    left: -1.25rem;
    top: 0.3rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--primary);
    border: 2px solid var(--bg-surface-solid);
    box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
  }
  .outline-item-title {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text-main);
    text-transform: capitalize;
  }
  .outline-item-subtitle {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: monospace;
    margin-top: 0.15rem;
  }

  /* Modals and Toasts */
  .confirm-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(8, 12, 20, 0.75);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .confirm-modal-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }
  .confirm-modal {
    background: var(--bg-surface-solid);
    border: 1px solid var(--bg-surface-border);
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 500px;
    padding: 1.75rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    transform: scale(0.9);
    transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .confirm-modal-overlay.active .confirm-modal {
    transform: scale(1);
  }
  .confirm-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .confirm-modal-header h4 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-main);
  }
  .close-modal-btn {
    background: transparent;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    transition: var(--transition);
  }
  .close-modal-btn:hover {
    color: var(--text-main);
  }
  .confirm-modal-body p {
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 0.75rem;
    color: var(--text-muted);
  }
  .warning-text {
    background: rgba(239, 68, 68, 0.05);
    padding: 0.75rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(239, 68, 68, 0.15);
    color: var(--color-error) !important;
    font-size: 0.85rem !important;
  }
  .confirm-modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .btn-danger {
    background-color: var(--color-error);
    color: white;
  }
  .btn-danger:hover {
    background-color: #DC2626;
  }

  .toast-notification {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: var(--bg-surface-solid);
    border-left: 4px solid var(--primary);
    border-top: 1px solid var(--bg-surface-border);
    border-bottom: 1px solid var(--bg-surface-border);
    border-right: 1px solid var(--bg-surface-border);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-sm);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35);
    z-index: 1100;
    transform: translateY(150%);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(8px);
  }
  .toast-notification.active {
    transform: translateY(0);
  }
  .toast-content {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-main);
  }

  /* Custom additions */
  .btn-xs {
    padding: 0.25rem 0.5rem;
    font-size: 0.72rem;
    border-radius: 3px;
    height: auto;
  }
  .btn-secondary {
    background-color: var(--bg-surface-border);
    color: var(--text-main);
    border: 1px solid var(--border-color);
  }
  .btn-secondary:hover {
    background-color: rgba(156, 163, 175, 0.15);
  }
  .text-pink { color: #EC4899 !important; }
  .text-purple { color: #A855F7 !important; }
  .text-orange { color: #F97316 !important; }
  .text-gold { color: #EAB308 !important; }
</style>

<script is:inline>
  let activeDeleteSlug = "";
  let activeQuickEditSlug = "";
  let activeDuplicateSlug = "";
  let currentSortBy = "";
  let currentSortDirection = "asc"; // "asc" or "desc"

  function initPagesList() {
    const searchInput = document.getElementById("pages-search");
    if (!searchInput || searchInput.dataset.listenerBound) return;
    searchInput.dataset.listenerBound = "true";

    // Initialize Bulk Select Options
    updateBulkOptions("all");

    // ─── Filter bindings ───────────────────────────────────────────
    searchInput.addEventListener("input", filterPages);
    
    // Status Tabs clicks
    const tabs = document.querySelectorAll(".status-tab");
    tabs.forEach(tab => {
      tab.addEventListener("click", () => {
        tabs.forEach(t => t.classList.remove("active"));
        tab.classList.add("active");
        const status = tab.getAttribute("data-status");
        updateBulkOptions(status);
        filterPages();
      });
    });

    // Filters row events
    const monthFilter = document.getElementById("date-month-filter");
    const startDateFilter = document.getElementById("start-date-filter");
    const endDateFilter = document.getElementById("end-date-filter");
    const seoFilter = document.getElementById("seo-audit-filter");
    const filterBtn = document.getElementById("apply-filters-btn");
    const resetBtn = document.getElementById("reset-filters-btn");

    if (monthFilter) monthFilter.addEventListener("change", filterPages);
    if (seoFilter) seoFilter.addEventListener("change", filterPages);
    if (filterBtn) filterBtn.addEventListener("click", filterPages);
    
    if (resetBtn) {
      resetBtn.addEventListener("click", () => {
        searchInput.value = "";
        tabs.forEach(t => t.classList.remove("active"));
        if (tabs[0]) tabs[0].classList.add("active");
        updateBulkOptions("all");
        if (monthFilter) monthFilter.value = "";
        if (startDateFilter) startDateFilter.value = "";
        if (endDateFilter) endDateFilter.value = "";
        if (seoFilter) seoFilter.value = "all";
        filterPages();
      });
    }

    // Dynamic Bulk Action dropdown populator matching WP
    function updateBulkOptions(tabStatus) {
      const select = document.getElementById("bulk-action-select");
      if (!select) return;
      select.innerHTML = "";
      if (tabStatus === "trash") {
        select.innerHTML = `
          <option value="">Bulk Actions</option>
          <option value="restore">Restore Selected</option>
          <option value="delete">Delete Permanently</option>
        `;
      } else {
        select.innerHTML = `
          <option value="">Bulk Actions</option>
          <option value="publish">Publish Selected</option>
          <option value="draft">Make Draft Selected</option>
          <option value="trash">Move to Trash</option>
        `;
      }
    }

    // Combined filtering engine
    function filterPages() {
      const q = searchInput.value.trim().toLowerCase();
      const activeTab = document.querySelector(".status-tab.active");
      const status = activeTab ? activeTab.getAttribute("data-status") : "all";
      const monthCode = monthFilter ? monthFilter.value : "";
      const seoVal = seoFilter ? seoFilter.value : "all";
      
      const startVal = startDateFilter ? startDateFilter.value : "";
      const endVal = endDateFilter ? endDateFilter.value : "";
      const startDate = startVal ? new Date(startVal) : null;
      if (startDate) startDate.setHours(0,0,0,0);
      const endDate = endVal ? new Date(endVal) : null;
      if (endDate) endDate.setHours(23,59,59,999);

      const rows = document.querySelectorAll(".page-row");
      let count = 0;

      rows.forEach(row => {
        const title = row.getAttribute("data-title") || "";
        const slug = row.getAttribute("data-slug") || "";
        const rowStatus = row.getAttribute("data-status") || "";
        const timestamp = parseInt(row.getAttribute("data-timestamp") || "0");
        const monthYear = row.getAttribute("data-monthyear") || "";
        const seoScore = parseInt(row.getAttribute("data-seo") || "0");

        // Match queries
        const matchQ = !q || title.includes(q) || slug.includes(q);
        
        // WP Parity: 'all' tab shows everything EXCEPT trash. Trash tab shows only trashed pages.
        const matchStatus = (status === "all" && rowStatus !== "trash") || (status !== "all" && rowStatus === status);
        
        const matchMonth = !monthCode || monthYear === monthCode;
        
        let matchCustomDate = true;
        if (startDate || endDate) {
          const rowDate = new Date(timestamp);
          if (startDate && rowDate < startDate) matchCustomDate = false;
          if (endDate && rowDate > endDate) matchCustomDate = false;
        }

        let matchSEO = true;
        if (seoVal === "excellent") matchSEO = seoScore >= 80;
        else if (seoVal === "medium") matchSEO = seoScore >= 50 && seoScore < 80;
        else if (seoVal === "bad") matchSEO = seoScore < 50;

        if (matchQ && matchStatus && matchMonth && matchCustomDate && matchSEO) {
          row.style.display = "table-row";
          count++;
          highlightText(row, q);
        } else {
          row.style.display = "none";
        }
      });

      // Handle empty row display
      const emptyRow = document.getElementById("empty-row");
      if (emptyRow) {
        emptyRow.style.display = count === 0 ? "table-row" : "none";
      }
    }

    // Dynamic search term highlighter
    function highlightText(row, query) {
      const targets = row.querySelectorAll(".highlight-target");
      targets.forEach(el => {
        const originalText = el.dataset.originalText || el.textContent;
        if (!el.dataset.originalText) {
          el.dataset.originalText = originalText;
        }
        
        if (!query) {
          el.innerHTML = originalText;
          return;
        }

        const escapedQuery = query.replace(/[-\/\\^$*+?.()|[\]{}]/g, '\\$&');
        const regex = new RegExp(`(${escapedQuery})`, 'gi');
        
        // Only replace text content nodes inside, to avoid destroying nested HTML structure (like SVGs)
        if (el.children.length === 0) {
          el.innerHTML = originalText.replace(regex, '<mark class="highlight-match">$1</mark>');
        } else {
          // If has children, replace inside text nodes of spans
          const textSpan = el.querySelector("span");
          if (textSpan) {
            const rawSpanText = textSpan.dataset.originalText || textSpan.textContent;
            if (!textSpan.dataset.originalText) textSpan.dataset.originalText = rawSpanText;
            textSpan.innerHTML = rawSpanText.replace(regex, '<mark class="highlight-match">$1</mark>');
          }
        }
      });
    }

    // ─── Sorting bindings ──────────────────────────────────────────
    const sortableHeaders = document.querySelectorAll(".sortable");
    sortableHeaders.forEach(header => {
      header.addEventListener("click", () => {
        const sortBy = header.getAttribute("data-sort");
        if (currentSortBy === sortBy) {
          currentSortDirection = currentSortDirection === "asc" ? "desc" : "asc";
        } else {
          currentSortBy = sortBy;
          currentSortDirection = "asc";
        }

        // Update indicator icons
        sortableHeaders.forEach(sh => {
          const icon = sh.querySelector(".sort-indicator");
          if (icon) icon.innerText = "↕";
        });
        const currentIcon = header.querySelector(".sort-indicator");
        if (currentIcon) {
          currentIcon.innerText = currentSortDirection === "asc" ? "↑" : "↓";
        }

        sortRows(sortBy, currentSortDirection);
      });
    });

    function sortRows(sortBy, direction) {
      const tbody = document.getElementById("pages-tbody");
      if (!tbody) return;
      const rows = Array.from(tbody.querySelectorAll("tr.page-row"));
      
      rows.sort((a, b) => {
        let valA, valB;
        if (sortBy === "title") {
          valA = a.getAttribute("data-title") || "";
          valB = b.getAttribute("data-title") || "";
          return direction === "asc" ? valA.localeCompare(valB) : valB.localeCompare(valA);
        } else if (sortBy === "date") {
          valA = parseInt(a.getAttribute("data-timestamp") || "0");
          valB = parseInt(b.getAttribute("data-timestamp") || "0");
          return direction === "asc" ? valA - valB : valB - valA;
        }
        return 0;
      });

      // Re-append rows in sorted order
      rows.forEach(row => tbody.appendChild(row));
    }

    // ─── Select Checkboxes & Bulk Actions ──────────────────────────
    const selectAllCheckbox = document.getElementById("select-all-pages");
    if (selectAllCheckbox) {
      selectAllCheckbox.addEventListener("change", (e) => {
        const checked = e.target.checked;
        const rowCheckboxes = document.querySelectorAll(".page-checkbox");
        rowCheckboxes.forEach(cb => {
          const row = cb.closest(".page-row");
          if (row && row.style.display !== "none") {
            cb.checked = checked;
          }
        });
      });
    }

    const bulkApplyBtn = document.getElementById("bulk-action-apply");
    if (bulkApplyBtn) {
      bulkApplyBtn.addEventListener("click", executeBulkAction);
    }

    async function executeBulkAction() {
      const actionSelect = document.getElementById("bulk-action-select");
      const action = actionSelect ? actionSelect.value : "";
      if (!action) {
        showToast("Please choose a bulk action first.");
        return;
      }

      const selectedCbs = document.querySelectorAll(".page-checkbox:checked");
      if (selectedCbs.length === 0) {
        showToast("No pages selected.");
        return;
      }

      const slugs = Array.from(selectedCbs).map(cb => cb.getAttribute("data-slug"));

      if (action === "delete") {
        window.customConfirm(`Are you absolutely sure you want to permanently delete the ${slugs.length} selected page(s)? This action cannot be undone.`, async () => {
          bulkApplyBtn.disabled = true;
          showToast(`Deleting ${slugs.length} page(s)...`);
          let successCount = 0;
          
          for (const slug of slugs) {
            try {
              const res = await fetch("/api/pages-crud", {
                method: "DELETE",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ slug })
              });
              const data = await res.json();
              if (data.success) successCount++;
            } catch(e) {}
          }

          showToast(`Successfully deleted ${successCount} of ${slugs.length} pages.`);
          setTimeout(() => window.location.reload(), 1200);
        });
      } else if (action === "publish" || action === "draft" || action === "trash" || action === "restore") {
        const newStatus = action === "publish" ? "published" : action === "draft" ? "draft" : action === "trash" ? "trash" : "draft";
        const statusLabel = action === "trash" ? "trashed" : action === "restore" ? "restored" : newStatus;
        bulkApplyBtn.disabled = true;
        showToast(`Updating status of ${slugs.length} page(s) to ${statusLabel}...`);
        let successCount = 0;

        for (const slug of slugs) {
          try {
            // Fetch current details
            const getRes = await fetch(`/api/pages-crud?action=get&slug=${slug}`);
            const getData = await getRes.json();
            if (getData.success) {
              const page = getData.page;
              page.status = newStatus;
              page.originalSlug = slug;
              page.body = getData.body || "";

              // PUT updated details
              const putRes = await fetch("/api/pages-crud", {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(page)
              });
              const putData = await putRes.json();
              if (putData.success) successCount++;
            }
          } catch(e) {}
        }

        showToast(`Successfully updated ${successCount} of ${slugs.length} pages.`);
        setTimeout(() => window.location.reload(), 1200);
      }
    }

    // ─── Modal Close Binds ─────────────────────────────────────────
    const cancelDeleteX = document.getElementById("cancel-delete-x");
    const cancelDeleteBtn = document.getElementById("cancel-delete-btn");
    if (cancelDeleteX) cancelDeleteX.addEventListener("click", hideDeleteModal);
    if (cancelDeleteBtn) cancelDeleteBtn.addEventListener("click", hideDeleteModal);

    const confirmDeleteBtn = document.getElementById("confirm-delete-btn");
    if (confirmDeleteBtn) confirmDeleteBtn.addEventListener("click", executeDeletePage);

    // Quick Edit close bindings
    const cancelQEditX = document.getElementById("cancel-quick-edit-x");
    const cancelQEditBtn = document.getElementById("cancel-quick-edit-btn");
    if (cancelQEditX) cancelQEditX.addEventListener("click", hideQuickEditModal);
    if (cancelQEditBtn) cancelQEditBtn.addEventListener("click", hideQuickEditModal);

    const confirmQEditBtn = document.getElementById("confirm-quick-edit-btn");
    if (confirmQEditBtn) confirmQEditBtn.addEventListener("click", saveQuickEdit);

    // Duplicate layout close bindings
    const cancelDuplicateX = document.getElementById("cancel-duplicate-x");
    const cancelDuplicateBtn = document.getElementById("cancel-duplicate-btn");
    if (cancelDuplicateX) cancelDuplicateX.addEventListener("click", hideDuplicateModal);
    if (cancelDuplicateBtn) cancelDuplicateBtn.addEventListener("click", hideDuplicateModal);

    const confirmDuplicateBtn = document.getElementById("confirm-duplicate-btn");
    if (confirmDuplicateBtn) confirmDuplicateBtn.addEventListener("click", executeDuplication);

    // Analytics close bindings
    const closeAnalyticsX = document.getElementById("close-analytics-x");
    const closeAnalyticsBtn = document.getElementById("close-analytics-btn");
    if (closeAnalyticsX) closeAnalyticsX.addEventListener("click", hideAnalyticsModal);
    if (closeAnalyticsBtn) closeAnalyticsBtn.addEventListener("click", hideAnalyticsModal);

    // Outline slide-over close bindings
    const closeOutlineBtn = document.getElementById("close-outline-btn");
    if (closeOutlineBtn) closeOutlineBtn.addEventListener("click", hideOutlineSidebar);

    // ─── Table Hover actions handler (Delegated clicks) ────────────
    document.addEventListener("click", (e) => {
      // 1. Permanently delete (Trash - only visible when page status is trash)
      const deleteTrigger = e.target.closest(".delete-btn");
      if (deleteTrigger && !deleteTrigger.disabled) {
        const slug = deleteTrigger.getAttribute("data-slug");
        const title = deleteTrigger.getAttribute("data-title");
        openDeleteModal(slug, title);
        return;
      }

      // 2. Move to Trash action (regular page hover action)
      const trashTrigger = e.target.closest(".trash-trigger");
      if (trashTrigger) {
        const slug = trashTrigger.getAttribute("data-slug");
        const title = trashTrigger.getAttribute("data-title");
        moveToTrash(slug, title);
        return;
      }

      // 3. Restore page action (only visible for trashed pages)
      const restoreTrigger = e.target.closest(".restore-trigger");
      if (restoreTrigger) {
        const slug = restoreTrigger.getAttribute("data-slug");
        restorePage(slug);
        return;
      }

      // 4. Duplicate layout
      const duplicateTrigger = e.target.closest(".duplicate-trigger");
      if (duplicateTrigger) {
        const slug = duplicateTrigger.getAttribute("data-slug");
        openDuplicateModal(slug);
        return;
      }

      // 5. Quick Edit trigger
      const qeTrigger = e.target.closest(".quick-edit-trigger");
      if (qeTrigger) {
        const slug = qeTrigger.getAttribute("data-slug");
        openQuickEditModal(slug);
        return;
      }

      // 6. Copy Link trigger
      const copyTrigger = e.target.closest(".copy-link-trigger");
      if (copyTrigger) {
        const slug = copyTrigger.getAttribute("data-slug");
        copyPageLink(slug);
        return;
      }

      // 7. Outline sidebar outline
      const outlineTrigger = e.target.closest(".outline-trigger");
      if (outlineTrigger) {
        const slug = outlineTrigger.getAttribute("data-slug");
        openOutlineSidebar(slug);
        return;
      }

      // 8. Analytics dashboard modal
      const analyticsTrigger = e.target.closest(".analytics-trigger");
      if (analyticsTrigger) {
        const slug = analyticsTrigger.getAttribute("data-slug");
        openAnalyticsModal(slug);
        return;
      }

      // 9. Instant status badge click toggle
      const statusToggle = e.target.closest(".status-badge-toggle");
      if (statusToggle) {
        const slug = statusToggle.getAttribute("data-slug");
        togglePageStatus(slug, statusToggle);
        return;
      }

      // 10. Set homepage slug swap action
      const homepageTrigger = e.target.closest(".set-homepage-trigger");
      if (homepageTrigger) {
        const slug = homepageTrigger.getAttribute("data-slug");
        triggerSetHomepage(slug);
        return;
      }

      // 11. Get AI SEO suggestions inside card
      const aiBtn = e.target.closest(".get-ai-seo-btn");
      if (aiBtn) {
        const slug = aiBtn.getAttribute("data-slug");
        generateAISEOTips(slug, aiBtn);
        return;
      }

      // 12. Apply AI SEO recommendation
      const applyAIBtn = e.target.closest(".apply-ai-seo-btn");
      if (applyAIBtn) {
        const slug = applyAIBtn.getAttribute("data-slug");
        applyAISEOTips(slug);
        return;
      }
    });

    // Run initial filter check to block trash pages from All tab on page load
    filterPages();
  }

  // ─── Delete Modal helpers ────────────────────────────────────────
  function openDeleteModal(slug, title) {
    activeDeleteSlug = slug;
    const titleEl = document.getElementById("delete-page-title");
    const slugEl = document.getElementById("delete-page-slug");
    const overlay = document.getElementById("delete-modal-overlay");

    if (titleEl) titleEl.innerText = `"${title}"`;
    if (slugEl) slugEl.innerText = slug;
    if (overlay) overlay.classList.add("active");
  }

  function hideDeleteModal() {
    activeDeleteSlug = "";
    const overlay = document.getElementById("delete-modal-overlay");
    if (overlay) overlay.classList.remove("active");
  }

  async function executeDeletePage() {
    if (!activeDeleteSlug) return;
    
    const confirmBtn = document.getElementById("confirm-delete-btn");
    const btnText = document.getElementById("delete-btn-text");
    
    confirmBtn.disabled = true;
    btnText.innerText = "Deleting...";

    try {
      const res = await fetch("/api/pages-crud", {
        method: "DELETE",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ slug: activeDeleteSlug })
      });
      const data = await res.json();
      
      if (data.success) {
        showToast("Page deleted permanently!");
        setTimeout(() => window.location.reload(), 1000);
      } else {
        showToast("Error: " + (data.error || "Could not delete page file."));
        confirmBtn.disabled = false;
        btnText.innerText = "Yes, Delete Page";
        hideDeleteModal();
      }
    } catch(e) {
      showToast("Network connection error.");
      confirmBtn.disabled = false;
      btnText.innerText = "Yes, Delete Page";
      hideDeleteModal();
    }
  }

  // ─── Move to Trash helper ────────────────────────────────────────
  async function moveToTrash(slug, title) {
    showToast(`Moving "${title}" to Trash...`);
    try {
      // 1. Fetch current details
      const getRes = await fetch(`/api/pages-crud?action=get&slug=${slug}`);
      const getData = await getRes.json();
      if (getData.success) {
        const page = getData.page;
        page.status = "trash";
        page.originalSlug = slug;
        page.body = getData.body || "";

        // 2. PUT updated status
        const putRes = await fetch("/api/pages-crud", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(page)
        });
        const putData = await putRes.json();
        
        if (putData.success) {
          showToast(`"${title}" moved to Trash successfully!`);
          setTimeout(() => window.location.reload(), 1000);
        } else {
          throw new Error(putData.error);
        }
      } else {
        throw new Error(getData.error);
      }
    } catch(e) {
      showToast("Failed to move to Trash: " + e.message);
    }
  }

  // ─── Restore Page helper ─────────────────────────────────────────
  async function restorePage(slug) {
    showToast("Restoring page...");
    try {
      // 1. Fetch current details
      const getRes = await fetch(`/api/pages-crud?action=get&slug=${slug}`);
      const getData = await getRes.json();
      if (getData.success) {
        const page = getData.page;
        page.status = "draft"; // Restore as draft
        page.originalSlug = slug;
        page.body = getData.body || "";

        // 2. PUT restored status
        const putRes = await fetch("/api/pages-crud", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(page)
        });
        const putData = await putRes.json();
        
        if (putData.success) {
          showToast("Page restored successfully as Draft!");
          setTimeout(() => window.location.reload(), 1000);
        } else {
          throw new Error(putData.error);
        }
      } else {
        throw new Error(getData.error);
      }
    } catch(e) {
      showToast("Failed to restore: " + e.message);
    }
  }

  // ─── Quick Edit Modal helpers ────────────────────────────────────
  function openQuickEditModal(slug) {
    activeQuickEditSlug = slug;
    const row = document.querySelector(`.page-row[data-slug="${slug}"]`);
    if (!row) return;

    const title = row.getAttribute("data-title") || "";
    const status = row.getAttribute("data-status") || "draft";
    const metaTitle = row.getAttribute("data-metatitle") || "";
    const metaDesc = row.getAttribute("data-metadescription") || "";
    const focusKeyword = row.getAttribute("data-focuskeyword") || "";

    const titleInput = document.getElementById("quick-edit-title");
    const slugInput = document.getElementById("quick-edit-slug");
    const statusSelect = document.getElementById("quick-edit-status");
    const metaTitleInput = document.getElementById("quick-edit-meta-title");
    const metaDescInput = document.getElementById("quick-edit-meta-desc");
    const focusInput = document.getElementById("quick-edit-focus-keyword");

    // Pre-populate fields
    if (titleInput) titleInput.value = row.querySelector(".page-title-link")?.dataset.originalText || row.querySelector(".page-title-link")?.textContent || title;
    if (slugInput) {
      slugInput.value = slug;
      // Disable editing slug for core pages
      if (["index", "about-us", "contact"].includes(slug)) {
        slugInput.disabled = true;
        slugInput.title = "Core page slug cannot be changed";
      } else {
        slugInput.disabled = false;
        slugInput.removeAttribute("title");
      }
    }
    if (statusSelect) statusSelect.value = status;
    if (metaTitleInput) metaTitleInput.value = metaTitle;
    if (metaDescInput) metaDescInput.value = metaDesc;
    if (focusInput) focusInput.value = focusKeyword;

    const overlay = document.getElementById("quick-edit-modal-overlay");
    if (overlay) overlay.classList.add("active");
  }

  function hideQuickEditModal() {
    activeQuickEditSlug = "";
    const overlay = document.getElementById("quick-edit-modal-overlay");
    if (overlay) overlay.classList.remove("active");
  }

  async function saveQuickEdit() {
    if (!activeQuickEditSlug) return;

    const titleInput = document.getElementById("quick-edit-title");
    const slugInput = document.getElementById("quick-edit-slug");
    const statusSelect = document.getElementById("quick-edit-status");
    const metaTitleInput = document.getElementById("quick-edit-meta-title");
    const metaDescInput = document.getElementById("quick-edit-meta-desc");
    const focusInput = document.getElementById("quick-edit-focus-keyword");

    const newTitle = titleInput ? titleInput.value.trim() : "";
    const newSlug = slugInput ? slugInput.value.trim().toLowerCase() : "";
    const newStatus = statusSelect ? statusSelect.value : "draft";

    if (!newTitle || !newSlug) {
      showToast("Page Title and Slug are required.");
      return;
    }

    const confirmBtn = document.getElementById("confirm-quick-edit-btn");
    const btnText = document.getElementById("quick-edit-btn-text");
    confirmBtn.disabled = true;
    btnText.innerText = "Saving...";

    try {
      // 1. Fetch current details
      const getRes = await fetch(`/api/pages-crud?action=get&slug=${activeQuickEditSlug}`);
      const getData = await getRes.json();
      if (!getData.success) {
        throw new Error(getData.error || "Failed to load page contents.");
      }

      // 2. Modify details
      const page = getData.page;
      page.title = newTitle;
      page.slug = newSlug;
      page.status = newStatus;
      page.originalSlug = activeQuickEditSlug;
      page.body = getData.body || "";
      
      // Update SEO node
      if (!page.seo) page.seo = {};
      page.seo.metaTitle = metaTitleInput ? metaTitleInput.value.trim() : "";
      page.seo.metaDescription = metaDescInput ? metaDescInput.value.trim() : "";
      page.seo.focusKeyword = focusInput ? focusInput.value.trim() : "";

      // 3. Put updated details
      const putRes = await fetch("/api/pages-crud", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(page)
      });
      const putData = await putRes.json();
      if (putData.success) {
        showToast("Metadata saved successfully!");
        setTimeout(() => window.location.reload(), 1000);
      } else {
        throw new Error(putData.error || "Could not save metadata details.");
      }
    } catch(e) {
      showToast("Error: " + e.message);
      confirmBtn.disabled = false;
      btnText.innerText = "Save Metadata";
    }
  }

  // ─── Duplication Modal helpers ───────────────────────────────────
  function openDuplicateModal(slug) {
    activeDuplicateSlug = slug;
    const row = document.querySelector(`.page-row[data-slug="${slug}"]`);
    const pageTitle = row ? (row.querySelector(".page-title-link")?.dataset.originalText || row.querySelector(".page-title-link")?.textContent || slug) : slug;

    const titleInput = document.getElementById("duplicate-title");
    const slugInput = document.getElementById("duplicate-slug");

    if (titleInput) titleInput.value = `${pageTitle} Copy`;
    if (slugInput) slugInput.value = `${slug}-copy-${Math.floor(Math.random() * 100)}`;

    const overlay = document.getElementById("duplicate-modal-overlay");
    if (overlay) overlay.classList.add("active");
  }

  function hideDuplicateModal() {
    activeDuplicateSlug = "";
    const overlay = document.getElementById("duplicate-modal-overlay");
    if (overlay) overlay.classList.remove("active");
  }

  async function executeDuplication() {
    if (!activeDuplicateSlug) return;

    const titleInput = document.getElementById("duplicate-title");
    const slugInput = document.getElementById("duplicate-slug");
    const newTitle = titleInput ? titleInput.value.trim() : "";
    const newSlug = slugInput ? slugInput.value.trim().toLowerCase() : "";

    if (!newTitle || !newSlug) {
      showToast("Title and Slug are required.");
      return;
    }

    const confirmBtn = document.getElementById("confirm-duplicate-btn");
    const btnText = document.getElementById("duplicate-btn-text");
    confirmBtn.disabled = true;
    btnText.innerText = "Duplicating...";

    try {
      // 1. Fetch source page contents
      const getRes = await fetch(`/api/pages-crud?action=get&slug=${activeDuplicateSlug}`);
      const getData = await getRes.json();
      
      if (!getData.success) {
        throw new Error(getData.error || "Failed to load source page details.");
      }
      
      // 2. Swap metadata
      const payload = {
        ...getData.page,
        title: newTitle,
        slug: newSlug,
        status: "draft",
        body: getData.body || ""
      };
      
      // 3. POST new duplicate
      const postRes = await fetch("/api/pages-crud", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      const postData = await postRes.json();
      
      if (postData.success) {
        showToast("Page layout duplicated successfully!");
        setTimeout(() => window.location.reload(), 1000);
      } else {
        throw new Error(postData.error || "Failed to create cloned page copy.");
      }
    } catch (e) {
      showToast("Error: " + e.message);
      confirmBtn.disabled = false;
      btnText.innerText = "Duplicate Layout";
    }
  }

  // ─── Copy Link helper ────────────────────────────────────────────
  function copyPageLink(slug) {
    const origin = window.location.origin;
    const pageUrl = slug === "index" ? `${origin}/` : `${origin}/${slug}`;
    
    navigator.clipboard.writeText(pageUrl).then(() => {
      showToast("Public link copied to clipboard!");
    }).catch(() => {
      showToast("Failed to copy link.");
    });
  }

  // ─── Click status badge to instantly toggle status ───────────────
  async function togglePageStatus(slug, badgeEl) {
    const isPublished = badgeEl.classList.contains("published");
    const newStatus = isPublished ? "draft" : "published";
    
    badgeEl.style.opacity = "0.5";
    badgeEl.innerText = "Saving...";

    try {
      const getRes = await fetch(`/api/pages-crud?action=get&slug=${slug}`);
      const getData = await getRes.json();
      if (getData.success) {
        const page = getData.page;
        page.status = newStatus;
        page.originalSlug = slug;
        page.body = getData.body || "";

        const putRes = await fetch("/api/pages-crud", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(page)
        });
        const putData = await putRes.json();
        
        if (putData.success) {
          showToast(`Page status toggled to ${newStatus}!`);
          badgeEl.classList.toggle("published", newStatus === "published");
          badgeEl.classList.toggle("draft", newStatus === "draft");
          badgeEl.innerText = newStatus;
          
          // Update row attribute status
          const row = badgeEl.closest(".page-row");
          if (row) {
            row.setAttribute("data-status", newStatus);
            row.className = `page-row status-${newStatus}`;
          }

          // Recalculate Stats in Header counts without reloading
          updateQuickStatsCounts();
        } else {
          throw new Error(putData.error);
        }
      } else {
        throw new Error(getData.error);
      }
    } catch(e) {
      showToast("Error changing status: " + e.message);
      badgeEl.innerText = isPublished ? "published" : "draft";
    } finally {
      badgeEl.style.opacity = "";
    }
  }

  function updateQuickStatsCounts() {
    const rows = document.querySelectorAll(".page-row");
    const total = Array.from(rows).filter(r => r.getAttribute("data-status") !== "trash").length;
    let published = 0;
    let drafts = 0;
    
    rows.forEach(r => {
      const status = r.getAttribute("data-status");
      if (status === "published") published++;
      else if (status === "draft") drafts++;
    });

    const totalEl = document.getElementById("stat-total-pages");
    const pubEl = document.getElementById("stat-published-pages");
    const draftEl = document.getElementById("stat-draft-pages");

    if (totalEl) totalEl.innerText = total;
    if (pubEl) pubEl.innerText = published;
    if (draftEl) draftEl.innerText = drafts;
  }

  // ─── Set Homepage swap slug routine ──────────────────────────────
  function triggerSetHomepage(slug) {
    window.customConfirm(`Are you sure you want to make "${slug}" the new homepage? This will swap slugs: "${slug}" will become the main homepage (slug: index) and the current homepage will be saved as a backup page.`, async () => {
      showToast("Setting new homepage... Swapping slugs...");
      
      try {
        // 1. Get current index home page details
        const getHomeRes = await fetch("/api/pages-crud?action=get&slug=index");
        const getHomeData = await getHomeRes.json();
        if (!getHomeData.success) throw new Error("Could not fetch current homepage details.");

        // 2. Get target page details
        const getTargetRes = await fetch(`/api/pages-crud?action=get&slug=${slug}`);
        const getTargetData = await getTargetRes.json();
        if (!getTargetData.success) throw new Error("Could not fetch target page details.");

        // 3. Rename old homepage slug to a backup slug (e.g. index-backup-123)
        const oldHomeBackupSlug = `home-backup-${Math.floor(Date.now() / 1000)}`;
        const oldHomePage = getHomeData.page;
        oldHomePage.slug = oldHomeBackupSlug;
        oldHomePage.originalSlug = "index";
        oldHomePage.title = `${oldHomePage.title || 'Home'} (Backup)`;
        oldHomePage.body = getHomeData.body || "";

        const renameOldRes = await fetch("/api/pages-crud", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(oldHomePage)
        });
        const renameOldData = await renameOldRes.json();
        if (!renameOldData.success) throw new Error("Failed to rename old homepage.");

        // 4. Rename target page slug to 'index'
        const newHomePage = getTargetData.page;
        newHomePage.slug = "index";
        newHomePage.originalSlug = slug;
        newHomePage.body = getTargetData.body || "";

        const renameNewRes = await fetch("/api/pages-crud", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(newHomePage)
        });
        const renameNewData = await renameNewRes.json();
        
        if (renameNewData.success) {
          showToast("Homepage swapped successfully!");
          setTimeout(() => window.location.reload(), 1000);
        } else {
          throw new Error("Failed to set index slug to target page.");
        }
      } catch(e) {
        showToast("Homepage Swapping Error: " + e.message);
      }
    });
  }

  // ─── Outline Sidebar slide-over logic ─────────────────────────────
  function openOutlineSidebar(slug) {
    const row = document.querySelector(`.page-row[data-slug="${slug}"]`);
    if (!row) return;

    const title = row.querySelector(".page-title-link")?.dataset.originalText || row.querySelector(".page-title-link")?.textContent || slug;
    const structureStr = row.getAttribute("data-structure") || "[]";
    const blocks = JSON.parse(structureStr);

    const titleEl = document.getElementById("outline-page-title");
    if (titleEl) titleEl.innerText = title;

    const timeline = document.getElementById("outline-timeline");
    if (timeline) {
      timeline.innerHTML = "";
      if (blocks.length === 0) {
        timeline.innerHTML = `<p style="font-size: 0.82rem; color: var(--text-dim); text-align: center; padding: 2rem 0;">No builder sections configured on this page.</p>`;
      } else {
        blocks.forEach(block => {
          const item = document.createElement("div");
          item.className = "outline-item";
          item.innerHTML = `
            <div class="outline-item-title">${block.type.replace(/_/g, ' ')}</div>
            <div class="outline-item-subtitle">ID: ${block.id || 'none'}</div>
          `;
          timeline.appendChild(item);
        });
      }
    }

    const overlay = document.getElementById("outline-slideover-overlay");
    if (overlay) overlay.classList.add("active");
  }

  function hideOutlineSidebar() {
    const overlay = document.getElementById("outline-slideover-overlay");
    if (overlay) overlay.classList.remove("active");
  }

  // ─── Analytics Modal Dashboard & Line Chart drawing ────────────────
  function openAnalyticsModal(slug) {
    const row = document.querySelector(`.page-row[data-slug="${slug}"]`);
    const pageTitle = row ? (row.querySelector(".page-title-link")?.dataset.originalText || row.querySelector(".page-title-link")?.textContent || slug) : slug;

    const titleEl = document.getElementById("analytics-page-title");
    if (titleEl) titleEl.innerText = `Traffic Analytics: "${pageTitle}"`;

    // Generate mock analytics
    const seed = pageTitle.length;
    const views = Math.floor((seed * 145) + (Math.random() * 200) + 120);
    const avgSeconds = Math.floor((seed * 8) + 40);
    const m = Math.floor(avgSeconds / 60);
    const s = avgSeconds % 60;
    const bounce = (45 + (seed % 20) + (Math.random() * 5)).toFixed(1);
    const conversion = (2.1 + ((seed % 5) / 2)).toFixed(1);

    document.getElementById("analytics-views").innerText = views.toLocaleString();
    document.getElementById("analytics-time").innerText = `${m}m ${s}s`;
    document.getElementById("analytics-bounce").innerText = `${bounce}%`;
    document.getElementById("analytics-conversion").innerText = `${conversion}%`;

    // Weekly views trend
    const trendVal = [
      Math.floor(views * 0.12),
      Math.floor(views * 0.15),
      Math.floor(views * 0.11),
      Math.floor(views * 0.18),
      Math.floor(views * 0.14),
      Math.floor(views * 0.16),
      Math.floor(views * 0.19)
    ];

    const overlay = document.getElementById("analytics-modal-overlay");
    if (overlay) {
      overlay.classList.add("active");
      setTimeout(() => {
        drawAnalyticsChart("analytics-chart-canvas", trendVal);
      }, 50);
    }
  }

  function hideAnalyticsModal() {
    const overlay = document.getElementById("analytics-modal-overlay");
    if (overlay) overlay.classList.remove("active");
  }

  function drawAnalyticsChart(canvasId, dataPoints) {
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    const width = canvas.width;
    const height = canvas.height;
    
    // Clear canvas
    ctx.clearRect(0, 0, width, height);
    
    // Grid Lines & Labels
    ctx.strokeStyle = "rgba(156, 163, 175, 0.08)";
    ctx.lineWidth = 1;
    for (let i = 0; i <= 4; i++) {
      const y = height - 20 - (i * (height - 30) / 4);
      ctx.beginPath();
      ctx.moveTo(25, y);
      ctx.lineTo(width - 10, y);
      ctx.stroke();
    }
    
    // Data Trend Line
    const maxVal = Math.max(...dataPoints, 10);
    const points = dataPoints.map((val, idx) => {
      const x = 30 + idx * (width - 50) / (dataPoints.length - 1);
      const y = height - 20 - (val * (height - 35) / maxVal);
      return { x, y };
    });
    
    // Draw Area under the line
    ctx.fillStyle = "rgba(99, 102, 241, 0.06)";
    ctx.beginPath();
    ctx.moveTo(points[0].x, height - 20);
    points.forEach(p => ctx.lineTo(p.x, p.y));
    ctx.lineTo(points[points.length - 1].x, height - 20);
    ctx.closePath();
    ctx.fill();
    
    // Draw Line
    ctx.strokeStyle = "#6366F1";
    ctx.lineWidth = 2.5;
    ctx.beginPath();
    ctx.moveTo(points[0].x, points[0].y);
    points.forEach(p => ctx.lineTo(p.x, p.y));
    ctx.stroke();
    
    // Draw points & Labels
    const labels = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
    points.forEach((p, idx) => {
      ctx.fillStyle = "#10B981";
      ctx.beginPath();
      ctx.arc(p.x, p.y, 4.5, 0, Math.PI * 2);
      ctx.fill();
      ctx.strokeStyle = "#0B0F19";
      ctx.lineWidth = 2;
      ctx.stroke();
      
      ctx.fillStyle = "rgba(156, 163, 175, 0.5)";
      ctx.font = "9px sans-serif";
      ctx.textAlign = "center";
      ctx.fillText(labels[idx], p.x, height - 5);
      
      ctx.fillStyle = "rgba(243, 244, 246, 0.9)";
      ctx.fillText(dataPoints[idx], p.x, p.y - 8);
    });
  }

  // ─── AI SEO recommendations tips generator ───────────────────────
  let aiGeneratedTips = {};

  function generateAISEOTips(slug, buttonEl) {
    const box = document.getElementById(`ai-seo-box-${slug}`);
    const tipsText = document.getElementById(`ai-tips-${slug}`);
    if (!box || !tipsText) return;

    const row = document.querySelector(`.page-row[data-slug="${slug}"]`);
    if (!row) return;

    buttonEl.disabled = true;
    buttonEl.innerText = "Analyzing SEO...";

    const title = row.getAttribute("data-title") || "";
    const metaTitle = row.getAttribute("data-metatitle") || "";
    const metaDesc = row.getAttribute("data-metadescription") || "";
    const focusKeyword = row.getAttribute("data-focuskeyword") || "";

    setTimeout(() => {
      let tips = "";
      let proposedTitle = metaTitle || title.toUpperCase();
      let proposedDesc = metaDesc || `Explore professional outlines on the ${title} page.`;
      let proposedKeyword = focusKeyword || title;

      if (!focusKeyword) {
        tips += `• Define focus keyword: set to "${title}". `;
        proposedKeyword = title;
      }
      if (metaTitle.length < 30) {
        proposedTitle = `${title.charAt(0).toUpperCase() + title.slice(1)} Page Builder`;
        tips += `• Expand Meta Title to 45 chars. `;
      }
      if (metaDesc.length < 120) {
        proposedDesc = `Looking for details on ${title}? Learn more about our values, expert services, and professional CMS resources.`;
        tips += `• Expand Meta Description to 140 chars. `;
      }

      if (tips === "") {
        tips = "✓ SEO attributes are already optimized. No recommendations needed!";
        box.querySelector(".apply-ai-seo-btn").style.display = "none";
      } else {
        box.querySelector(".apply-ai-seo-btn").style.display = "block";
      }

      tipsText.innerText = tips;
      box.style.display = "block";

      aiGeneratedTips[slug] = {
        metaTitle: proposedTitle,
        metaDescription: proposedDesc,
        focusKeyword: proposedKeyword
      };

      buttonEl.innerText = "AI Tips Loaded ✓";
    }, 600);
  }

  async function applyAISEOTips(slug) {
    const tips = aiGeneratedTips[slug];
    if (!tips) return;

    showToast("Applying AI suggestions...");
    try {
      const getRes = await fetch(`/api/pages-crud?action=get&slug=${slug}`);
      const getData = await getRes.json();
      if (!getData.success) throw new Error(getData.error);

      const page = getData.page;
      page.originalSlug = slug;
      page.body = getData.body || "";
      if (!page.seo) page.seo = {};
      page.seo.metaTitle = tips.metaTitle;
      page.seo.metaDescription = tips.metaDescription;
      page.seo.focusKeyword = tips.focusKeyword;

      const putRes = await fetch("/api/pages-crud", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(page)
      });
      const putData = await putRes.json();

      if (putData.success) {
        showToast("SEO optimized successfully!");
        setTimeout(() => window.location.reload(), 1000);
      } else {
        throw new Error(putData.error);
      }
    } catch(e) {
      showToast("Failed applying AI recommendations: " + e.message);
    }
  }

  // ─── General Toast Notification ──────────────────────────────────
  function showToast(message) {
    const notify = document.getElementById("toast-notify");
    const msgSpan = document.getElementById("toast-message");
    if (notify && msgSpan) {
      msgSpan.innerText = message;
      notify.classList.add("active");
      setTimeout(() => {
        notify.classList.remove("active");
      }, 3000);
    }
  }

  // Bind list initialization
  document.addEventListener("DOMContentLoaded", initPagesList);
  document.addEventListener("astro:page-load", initPagesList);
  if (document.readyState === "interactive" || document.readyState === "complete") {
    initPagesList();
  }
