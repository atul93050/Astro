---
import AdminLayout from "../../layouts/admin/AdminLayout.astro";
import fs from "node:fs";
import path from "node:path";
import { parse } from "yaml";

export const prerender = false;

// Gather all pages
const pagesDir = path.resolve("src/content/pages");
if (!fs.existsSync(pagesDir)) {
  fs.mkdirSync(pagesDir, { recursive: true });
}

const files = fs.readdirSync(pagesDir).filter(f => f.endsWith(".md"));
const allPages = files.map(file => {
  const filePath = path.join(pagesDir, file);
  const content = fs.readFileSync(filePath, "utf-8");
  
  // Parse frontmatter
  const parts = content.split(/^---$/m);
  let data: any = {};
  if (parts.length >= 3) {
    try {
      data = parse(parts[1]);
    } catch (e) {
      console.error(`Error parsing YAML in ${file}:`, e);
    }
  }

  const title = data.title || "Untitled Page";
  const slug = data.slug || path.basename(file, ".md");
  const status = data.status || "draft";
  const seo = data.seo || {};

  // Formatted date computations
  const dateObj = data.lastUpdated ? new Date(data.lastUpdated) : fs.statSync(filePath).mtime;
  const rawTimestamp = dateObj.getTime();
  
  const pad = (n: number) => n.toString().padStart(2, '0');
  const yyyy = dateObj.getFullYear();
  const mm = pad(dateObj.getMonth() + 1);
  const dd = pad(dateObj.getDate());
  let hours = dateObj.getHours();
  const minutes = pad(dateObj.getMinutes());
  const ampm = hours >= 12 ? 'pm' : 'am';
  hours = hours % 12;
  hours = hours ? hours : 12;
  const displayDate = `${yyyy}/${mm}/${dd} at ${hours}:${minutes} ${ampm}`;
  const monthYearCode = `${yyyy}-${mm}`;
  const monthName = dateObj.toLocaleString('en-US', { month: 'long' });
  const monthYearLabel = `${monthName} ${yyyy}`;

  // Page builder blocks complexity
  const blocks = data.blocks || [];
  const blocksCount = blocks.length;
  const blockStructure = JSON.stringify(blocks.map((b: any) => ({ type: b.type, id: b.sectionId || '' })));

  // SEO details
  const metaTitle = seo.metaTitle || "";
  const metaDescription = seo.metaDescription || "";
  const focusKeyword = seo.focusKeyword || "";

  // SEO Health check scoring
  let seoScore = 0;
  const seoChecks = [];
  
  if (seo.metaTitle) {
    const len = seo.metaTitle.length;
    if (len >= 30 && len <= 60) {
      seoScore += 30;
      seoChecks.push({ name: "Title length optimal", passed: true });
    } else {
      seoChecks.push({ name: "Title length sub-optimal (30-60 chars recommended)", passed: false });
    }
  } else {
    seoChecks.push({ name: "Meta Title is missing", passed: false });
  }

  if (seo.metaDescription) {
    const len = seo.metaDescription.length;
    if (len >= 120 && len <= 160) {
      seoScore += 30;
      seoChecks.push({ name: "Description length optimal", passed: true });
    } else {
      seoChecks.push({ name: "Description length sub-optimal (120-160 chars recommended)", passed: false });
    }
  } else {
    seoChecks.push({ name: "Meta Description is missing", passed: false });
  }

  if (seo.focusKeyword && seo.focusKeyword.trim()) {
    seoScore += 20;
    seoChecks.push({ name: "Focus Keyword provided", passed: true });
  } else {
    seoChecks.push({ name: "Focus Keyword is missing", passed: false });
  }

  if (seo.schemaType && seo.schemaType !== "none") {
    seoScore += 20;
    seoChecks.push({ name: "JSON-LD Schema structured data present", passed: true });
  } else {
    seoChecks.push({ name: "JSON-LD Schema is omitted", passed: false });
  }

  let seoLabel = "Bad";
  let seoColor = "var(--color-error)";
  if (seoScore >= 80) {
    seoLabel = "Excellent";
    seoColor = "var(--color-success)";
  } else if (seoScore >= 50) {
    seoLabel = "Medium";
    seoColor = "var(--color-warning)";
  }

  return {
    title,
    slug,
    status,
    rawTimestamp,
    displayDate,
    monthYearCode,
    monthYearLabel,
    blocksCount,
    blockStructure,
    metaTitle,
    metaDescription,
    focusKeyword,
    seoScore,
    seoLabel,
    seoColor,
    seoChecks,
  };
});

// Compute unique months/years of pages
const monthYears = allPages.map(page => ({
  value: page.monthYearCode,
  label: page.monthYearLabel
}));
const uniqueMonthYears = Array.from(new Map(monthYears.map(item => [item.value, item])).values());
uniqueMonthYears.sort((a, b) => b.value.localeCompare(a.value));
---

<AdminLayout title="Pages Management">
  
  <div class="dashboard-header">
    <div class="header-text">
      <p class="subtitle">Create, delete, duplicate, and configure structural landing pages builder templates.</p>
    </div>
    <div class="header-actions">
      <a href="/admin/editor" class="btn btn-primary">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        <span>Create New Page</span>
      </a>
    </div>
  </div>

  <!-- Quick Stats Cards Row -->
  <div class="quick-stats-grid">
    <div class="stat-card">
      <div class="stat-icon" style="background: rgba(99, 102, 241, 0.12); color: var(--primary);">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
      </div>
      <div class="stat-info">
        <span class="stat-label">Total Pages</span>
        <span class="stat-value" id="stat-total-pages">{allPages.length}</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background: rgba(16, 185, 129, 0.12); color: var(--accent);">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
      </div>
      <div class="stat-info">
        <span class="stat-label">Published</span>
        <span class="stat-value" id="stat-published-pages">{allPages.filter(p => p.status === 'published').length}</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background: rgba(245, 158, 11, 0.12); color: var(--color-warning);">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
      </div>
      <div class="stat-info">
        <span class="stat-label">Drafts</span>
        <span class="stat-value" id="stat-draft-pages">{allPages.filter(p => p.status === 'draft').length}</span>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-icon" style="background: rgba(59, 130, 246, 0.12); color: #3B82F6;">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
      </div>
      <div class="stat-info">
        <span class="stat-label">Excellent SEO</span>
        <span class="stat-value" id="stat-seo-ratio">
          {allPages.length > 0 ? Math.round((allPages.filter(p => p.seoScore >= 80).length / allPages.length) * 100) : 0}%
        </span>
      </div>
    </div>
  </div>

  <!-- WordPress-Style Status Tabs -->
  <div class="status-tabs-row">
    <button class="status-tab active" data-status="all" aria-label="Show all pages">All <span class="count">({allPages.filter(p => p.status !== 'trash').length})</span></button>
    <span class="tab-separator">|</span>
    <button class="status-tab" data-status="published" aria-label="Show published pages">Published <span class="count">({allPages.filter(p => p.status === 'published').length})</span></button>
    <span class="tab-separator">|</span>
    <button class="status-tab" data-status="draft" aria-label="Show draft pages">Drafts <span class="count">({allPages.filter(p => p.status === 'draft').length})</span></button>
    <span class="tab-separator">|</span>
    <button class="status-tab text-danger" data-status="trash" aria-label="Show trashed pages">Trash <span class="count">({allPages.filter(p => p.status === 'trash').length})</span></button>
  </div>

  <!-- Upgraded Controls bar -->
  <div class="controls-bar">
    <div class="controls-top-row">
      <div class="bulk-actions-wrap">
        <select id="bulk-action-select" class="admin-select" aria-label="Bulk actions selector">
          <option value="">Bulk Actions</option>
          <option value="publish">Publish Selected</option>
          <option value="draft">Make Draft Selected</option>
          <option value="trash">Move to Trash</option>
        </select>
        <button class="btn btn-secondary btn-sm" id="bulk-action-apply" style="height: 38px;">Apply</button>
      </div>

      <div class="search-input-wrap">
        <svg class="search-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" id="pages-search" placeholder="Search by page name, slug..." />
      </div>
    </div>

    <div class="controls-bottom-row">
      <div class="filter-group">
        <!-- Date Dropdown Filter -->
        <select id="date-month-filter" class="admin-select" aria-label="Filter by month">
          <option value="">All dates</option>
          {uniqueMonthYears.map(my => (
            <option value={my.value}>{my.label}</option>
          ))}
        </select>

        <!-- Custom Date Range Picker -->
        <div class="custom-date-range">
          <input type="date" id="start-date-filter" aria-label="Start Date" title="Start Date" />
          <span class="range-dash">to</span>
          <input type="date" id="end-date-filter" aria-label="End Date" title="End Date" />
        </div>

        <!-- SEO Score Audit Filter -->
        <select id="seo-audit-filter" class="admin-select" aria-label="Filter by SEO score status">
          <option value="all">All SEO Scores</option>
          <option value="excellent">Excellent SEO (>=80%)</option>
          <option value="medium">Medium SEO (50-79%)</option>
          <option value="bad">Bad SEO (<50%)</option>
        </select>
      </div>

      <div class="filter-actions">
        <button class="btn btn-primary btn-sm" id="apply-filters-btn" style="height: 38px;">Filter</button>
        <button class="btn btn-outline btn-sm" id="reset-filters-btn" style="height: 38px;">Reset</button>
      </div>
    </div>
  </div>

  <!-- Dynamic Pages Table -->
  <div class="admin-table-wrapper">
    <table class="admin-table">
      <thead>
        <tr>
          <th style="width: 45px; text-align: center;"><input type="checkbox" id="select-all-pages" style="cursor: pointer; transform: scale(1.1);" aria-label="Select all pages" /></th>
          <th class="sortable" data-sort="title" style="cursor: pointer; user-select: none;">
            <div style="display: flex; align-items: center; gap: 0.35rem;">
              <span>Page Name</span>
              <span class="sort-indicator" id="sort-icon-title">↕</span>
            </div>
          </th>
          <th>Slug / Link</th>
          <th>Author</th>
          <th style="text-align: center;"><span title="Comments" style="cursor: help;">💬</span></th>
          <th>SEO Score</th>
          <th style="text-align: center;">PageSpeed</th>
          <th class="sortable" data-sort="date" style="cursor: pointer; user-select: none;">
            <div style="display: flex; align-items: center; gap: 0.35rem;">
              <span>Date</span>
              <span class="sort-indicator" id="sort-icon-date">↕</span>
            </div>
          </th>
        </tr>
      </thead>
      <tbody id="pages-tbody">
        {allPages.length === 0 ? (
          <tr id="empty-row">
            <td colspan="8" style="text-align: center; padding: 3rem; color: var(--text-dim);">
              <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem; opacity: 0.5;">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="8" y1="12" x2="16" y2="12"></line>
              </svg>
              <p style="font-weight: 600; font-size: 1.1rem; margin-bottom: 0.25rem;">No dynamic pages yet</p>
              <p style="font-size: 0.85rem;">Click "Create New Page" above to add your first Page Builder landing page.</p>
            </td>
          </tr>
        ) : (
          allPages.map(page => {
            const isCore = ["index", "about-us", "contact"].includes(page.slug);
            const pageSpeedScore = Math.max(78, 100 - (page.blocksCount * 2));
            return (
              <tr 
                class={`page-row status-${page.status}`} 
                data-title={page.title.toLowerCase()} 
                data-slug={page.slug.toLowerCase()} 
                data-status={page.status}
                data-timestamp={page.rawTimestamp}
                data-monthyear={page.monthYearCode}
                data-seo={page.seoScore}
                data-pagespeed={pageSpeedScore}
                data-metatitle={page.metaTitle}
                data-metadescription={page.metaDescription}
                data-focuskeyword={page.focusKeyword}
                data-structure={page.blockStructure}
              >
                <td style="text-align: center; vertical-align: middle;">
                  <input type="checkbox" class="page-checkbox" data-slug={page.slug} style="cursor: pointer; transform: scale(1.1);" aria-label={`Select page ${page.title}`} />
                </td>
                <td>
                  <div class="title-cell-wrap">
                    <div class="title-cell" style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                      <a href={`/admin/editor?slug=${page.slug}`} class="page-title-link highlight-target">{page.title}</a>
                      {isCore && (
                        <span class="status-badge core-tag">Core</span>
                      )}
                      <span class="complexity-badge" title={`${page.blocksCount} Page Builder block sections`}>
                        {page.blocksCount} sections
                      </span>
                    </div>
                    
                    <!-- Hover Action Row -->
                    <div class="row-actions">
                      {page.status === 'trash' ? (
                        <>
                          <button class="row-act-btn restore-trigger text-success" data-slug={page.slug}>Restore</button>
                          <span class="divider">|</span>
                          <button class="row-act-btn delete-btn text-danger" data-slug={page.slug} data-title={page.title}>Delete Permanently</button>
                        </>
                      ) : (
                        <>
                          <a href={`/admin/editor?slug=${page.slug}`} class="row-act-btn text-primary">Edit</a>
                          <span class="divider">|</span>
                          <button class="row-act-btn quick-edit-trigger text-warning" data-slug={page.slug}>Quick Edit</button>
                          <span class="divider">|</span>
                          {isCore ? (
                            <span class="row-act-btn text-muted" style="cursor: not-allowed; opacity: 0.5;" title="Core pages cannot be deleted">Trash</span>
                          ) : (
                            <button class="row-act-btn trash-trigger text-danger" data-slug={page.slug} data-title={page.title}>Trash</button>
                          )}
                          <span class="divider">|</span>
                          <a href={page.slug === 'index' ? '/' : `/${page.slug}`} target="_blank" class="row-act-btn text-success">View</a>
                          <span class="divider">|</span>
                          <button class="row-act-btn copy-link-trigger text-info" data-slug={page.slug}>Copy Link</button>
                          <span class="divider">|</span>
                          <button class="row-act-btn duplicate-trigger text-orange" data-slug={page.slug}>Duplicate</button>
                          <span class="divider">|</span>
                          <button class="row-act-btn outline-trigger text-pink" data-slug={page.slug}>Outline</button>
                          <span class="divider">|</span>
                          <button class="row-act-btn analytics-trigger text-purple" data-slug={page.slug}>Analytics</button>
                          {!isCore && (
                            <>
                              <span class="divider">|</span>
                              <button class="row-act-btn set-homepage-trigger text-gold" data-slug={page.slug}>Set Homepage</button>
                            </>
                          )}
                        </>
                      )}
                    </div>
                  </div>
                </td>
                <td>
                  <a href={page.slug === 'index' ? '/' : `/${page.slug}`} target="_blank" class="slug-link highlight-target">
                    <span>{page.slug === 'index' ? '/' : `/${page.slug}`}</span>
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left:4px;"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                  </a>
                </td>
                <td style="color: var(--text-muted); font-size: 0.88rem;">Super Admin</td>
                <td style="text-align: center; color: var(--text-dim); font-size: 0.88rem;">—</td>
                <td>
                  <div class="seo-badge-wrap interactive-seo-badge" title="Hover for details" data-slug={page.slug}>
                    <span class="seo-color-dot" style={`background-color: ${page.seoColor};`}></span>
                    <span style="font-weight: 600; font-size:0.85rem;">{page.seoScore}%</span>
                    <span class="seo-health-label">{page.seoLabel}</span>
                    
                    <!-- Advanced SEO Tooltip Card -->
                    <div class="seo-tooltip-card">
                      <h5 style="margin-bottom: 0.5rem; font-weight: 700; color: var(--text-main); font-size: 0.88rem;">SEO Checks ({page.seoScore}%)</h5>
                      <ul class="seo-checks-list" style="list-style: none; padding: 0; margin: 0 0 0.75rem 0;">
                        {page.seoChecks.map((check: any) => (
                          <li style="font-size: 0.78rem; display: flex; align-items: center; gap: 0.35rem; margin-bottom: 0.25rem; text-align: left;">
                            <span style={`color: ${check.passed ? 'var(--color-success)' : 'var(--color-error)'}; font-weight: bold;`}>
                              {check.passed ? '✓' : '✗'}
                            </span>
                            <span style={`color: ${check.passed ? 'var(--text-main)' : 'var(--text-muted)'};`}>{check.name}</span>
                          </li>
                        ))}
                      </ul>
                      
                      <!-- AI Recommendations box -->
                      <div class="ai-seo-recommendations-box" id={`ai-seo-box-${page.slug}`} style="display: none; border-top: 1px solid var(--bg-surface-border); padding-top: 0.5rem; margin-top: 0.5rem; text-align: left;">
                        <h6 style="color: var(--primary); font-size: 0.78rem; margin: 0 0 0.35rem 0; font-weight: 700; text-transform: uppercase; letter-spacing: 0.02em;">AI Recommendations:</h6>
                        <p class="ai-tips-text" id={`ai-tips-${page.slug}`} style="font-size: 0.75rem; margin: 0 0 0.5rem 0; line-height: 1.4; color: var(--text-muted);"></p>
                        <button class="btn btn-primary btn-xs apply-ai-seo-btn" data-slug={page.slug} style="padding: 0.2rem 0.5rem; font-size: 0.7rem; height: auto; width: 100%;">Apply Optimization</button>
                      </div>
                      
                      <button class="btn btn-secondary btn-xs get-ai-seo-btn" data-slug={page.slug} style="width: 100%; font-size: 0.72rem; padding: 0.3rem; margin-top: 0.25rem;">
                        <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:2px; display:inline-block; vertical-align:middle;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                        Get AI SEO Tips
                      </button>
                    </div>
                  </div>
                </td>
                <td style="text-align: center; vertical-align: middle;">
                  <div class="pagespeed-badge-wrap" title={`Simulated Core Web Vitals:\n- LCP (Largest Contentful Paint): ${((100-pageSpeedScore)/10 + 0.8).toFixed(1)}s\n- CLS (Cumulative Layout Shift): ${((100-pageSpeedScore)/1000).toFixed(3)}\n- FID (First Input Delay): ${Math.round((100-pageSpeedScore)/2 + 5)}ms`}>
                    <div class="pagespeed-circle" style={`--score: ${pageSpeedScore}; --color: ${pageSpeedScore >= 90 ? 'var(--color-success)' : pageSpeedScore >= 80 ? 'var(--color-warning)' : 'var(--color-error)'};`}>
                      <span class="pagespeed-value">{pageSpeedScore}</span>
                    </div>
                  </div>
                </td>
                <td>
                  <div class="date-cell">
                    <span class={`status-badge status-badge-toggle ${page.status}`} data-slug={page.slug} title="Click to instantly toggle status" style="cursor: pointer; user-select: none;">
                      {page.status}
                    </span>
                    <span class="date-time">{page.displayDate}</span>
                  </div>
                </td>
              </tr>
            );
          })
        )}
      </tbody>
    </table>
  </div>

  <!-- Delete Confirmation Modal -->
  <div class="confirm-modal-overlay" id="delete-modal-overlay">
    <div class="confirm-modal">
      <div class="confirm-modal-header">
        <h4>Delete Page Permanently</h4>
        <button class="close-modal-btn" id="cancel-delete-x">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="confirm-modal-body">
        <p>Are you absolutely sure you want to delete <strong id="delete-page-title">"Our Services"</strong>?</p>
        <p class="warning-text">This will physically delete the Markdown configuration file <code>src/content/pages/<span id="delete-page-slug">our-services</span>.md</code> and all associated revision backup history. This action cannot be undone.</p>
      </div>
      <div class="confirm-modal-footer">
        <button class="btn btn-outline" id="cancel-delete-btn">Cancel</button>
        <button class="btn btn-danger" id="confirm-delete-btn">
          <span id="delete-btn-text">Yes, Delete Page</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Quick Edit Modal -->
  <div class="confirm-modal-overlay" id="quick-edit-modal-overlay">
    <div class="confirm-modal" style="max-width: 550px;">
      <div class="confirm-modal-header">
        <h4>Quick Edit Page Metadata</h4>
        <button class="close-modal-btn" id="cancel-quick-edit-x">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="confirm-modal-body">
        <form id="quick-edit-form" onsubmit="return false;" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="form-group" style="grid-column: span 2;">
