            <input type="text" id="duplicate-title" class="admin-input" style="width: 100%; padding: 0.6rem 0.85rem; background: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-main); border-radius: var(--radius-sm);" required />
          </div>
          <div class="form-group" style="margin-bottom: 0.5rem;">
            <label for="duplicate-slug" style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.35rem; color: var(--text-muted);">New Page Slug</label>
            <input type="text" id="duplicate-slug" class="admin-input" style="width: 100%; padding: 0.6rem 0.85rem; background: var(--input-bg); border: 1px solid var(--input-border); color: var(--text-main); border-radius: var(--radius-sm);" required />
          </div>
        </form>
      </div>
      <div class="confirm-modal-footer">
        <button class="btn btn-outline" id="cancel-duplicate-btn">Cancel</button>
        <button class="btn btn-primary" id="confirm-duplicate-btn">
          <span id="duplicate-btn-text">Duplicate Layout</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Quick Page Analytics Modal -->
  <div class="confirm-modal-overlay" id="analytics-modal-overlay">
    <div class="confirm-modal" style="max-width: 550px;">
      <div class="confirm-modal-header">
        <h4 id="analytics-page-title">Page Traffic Analytics</h4>
        <button class="close-modal-btn" id="close-analytics-x">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="confirm-modal-body">
        <div class="analytics-stats-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem; margin-bottom: 1.25rem; text-align: center;">
          <div style="background: rgba(156, 163, 175, 0.03); padding: 0.5rem; border: 1px solid var(--bg-surface-border); border-radius: var(--radius-sm);">
