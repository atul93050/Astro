  .interactive-seo-badge:hover .seo-tooltip-card {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  /* PageSpeed Score styling */
  .pagespeed-badge-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .pagespeed-circle {
    position: relative;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: radial-gradient(closest-side, var(--bg-surface-solid) 75%, transparent 76% 100%),
                conic-gradient(var(--color) calc(var(--score) * 1%), rgba(156, 163, 175, 0.1) 0);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 5px rgba(0,0,0,0.15);
  }
  .pagespeed-value {
    font-size: 0.72rem;
    font-weight: 700;
