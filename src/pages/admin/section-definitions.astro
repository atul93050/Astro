---
import AdminLayout from "../../layouts/admin/AdminLayout.astro";
import fs from "node:fs";
import path from "node:path";

export const prerender = false;

const definitionsPath = path.resolve("src/data/section-definitions.json");
const schemasPath = path.resolve("src/data/field-schemas.json");

let allDefinitions: any[] = [];
let allSchemas: any[] = [];

try {
  if (fs.existsSync(definitionsPath)) {
    allDefinitions = JSON.parse(fs.readFileSync(definitionsPath, "utf-8"));
  }
} catch (e) {
  console.error("Failed to load section definitions:", e);
}

try {
  if (fs.existsSync(schemasPath)) {
    allSchemas = JSON.parse(fs.readFileSync(schemasPath, "utf-8"));
  }
} catch (e) {}

// Annotate each definition with its resolved schema name
const definitionsWithMeta = allDefinitions.map(def => ({
  ...def,
  schemaName: allSchemas.find((s: any) => s.schema_key === def.schema_ref)?.schema_name || null,
  schemaFieldCount: allSchemas.find((s: any) => s.schema_key === def.schema_ref)?.fields?.length ?? null
}));
import "../../styles/admin/css/section-defination.css";
---

<AdminLayout title="Section Definitions — Developer Mode">

  <div class="dashboard-header">
    <div class="header-text">
      <p class="subtitle">Developers define Section Definitions here — each pairs a <strong>Field Schema</strong> with an <strong>Astro component</strong>. Multiple definitions can share one schema with different designs.</p>
    </div>
    <div class="header-actions">
      <a href="/admin/field-schemas" class="btn btn-outline">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
        Manage Field Schemas
      </a>
      <a href="/admin/sections" class="btn btn-outline">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path></svg>
        Section Library
      </a>
      <button class="btn btn-primary" id="open-create-def-btn">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        New Section Definition
      </button>
    </div>
  </div>

  <!-- Info Banner -->
  <div style="background: linear-gradient(135deg, rgba(99,102,241,0.08), rgba(139,92,246,0.08)); border: 1px solid rgba(99,102,241,0.25); border-radius: 10px; padding: 1.25rem 1.5rem; margin-bottom: 2rem; display:flex; gap: 1rem; align-items: flex-start;">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:0.15rem;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
    <div>
      <strong style="font-size:0.9rem; color:var(--text-main); display:block; margin-bottom:0.25rem;">3-Layer Model: Field Schema → Section Definition → Section Instance</strong>
      <p style="font-size:0.83rem; color:var(--text-muted); margin:0; line-height:1.6;">
        A <strong>Section Definition</strong> = a Field Schema reference + an Astro component path.
        Manage the field structure in <a href="/admin/field-schemas" style="color:var(--primary);">Field Schemas</a>.
        Multiple definitions can share one schema — useful for alternate designs of the same content.
      </p>
    </div>
  </div>

  <!-- Search Filter Bar -->
  <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem; margin-bottom:1.75rem; flex-wrap:wrap;">
    <div style="font-size:0.85rem; color:var(--text-dim);">
      <strong style="color:var(--text-main);">{allDefinitions.length}</strong> definition{allDefinitions.length !== 1 ? 's' : ''} registered
      {allSchemas.length === 0 && (
        <span style="margin-left:0.75rem; color:var(--color-warning, #f59e0b); font-weight:600;">
          ⚠ No Field Schemas found — <a href="/admin/field-schemas" style="color:var(--color-warning, #f59e0b);">create schemas first</a> or run the migration script.
        </span>
      )}
    </div>
    <div style="position:relative; width:100%; max-width:320px;">
      <input type="text" id="def-search" placeholder="Search definitions by name or key..." style="padding-left:2.5rem; font-size:0.85rem;" />
      <span style="position:absolute; left:0.85rem; top:50%; transform:translateY(-50%); color:var(--text-dim); pointer-events:none; display:flex; align-items:center;">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </span>
    </div>
  </div>

  <!-- Definition Cards Grid -->
  <div class="defs-grid" id="defs-grid" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.5rem; margin-bottom: 5rem;">
    {allDefinitions.length === 0 ? (
      <div style="grid-column: 1/-1; text-align:center; padding: 5rem 2rem; border: 1px dashed var(--border-color); border-radius: 10px; background: var(--bg-surface); color: var(--text-dim);">
        <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.4; display:inline-block; margin-bottom:1rem;"><rect x="3" y="3" width="18" height="18" rx="2"></rect><line x1="9" y1="9" x2="15" y2="9"></line><line x1="9" y1="13" x2="15" y2="13"></line></svg>
        <h4 style="margin-bottom:0.5rem;">No Section Definitions Yet</h4>
        <p style="font-size:0.875rem;">First <a href="/admin/field-schemas" style="color:var(--primary);">create a Field Schema</a>, then click "New Section Definition" to add a design.</p>
      </div>
    ) : (
      definitionsWithMeta.map(def => (
        <div class="def-card" data-key={def.key}>
          <div class="def-card-head">
            <div>
              <h4 class="def-card-name">{def.name}</h4>
              <code class="def-key-tag">{def.key}</code>
            </div>
            {def.schema_ref ? (
              <div style="text-align:right;">
                <span style="font-size:0.65rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; background:rgba(16,185,129,0.1); color:var(--accent); padding:0.15rem 0.5rem; border-radius:4px; display:block; margin-bottom:0.3rem;">schema linked</span>
                {def.schemaFieldCount !== null && (
                  <span style="font-size:0.65rem; color:var(--text-dim);">{def.schemaFieldCount} fields</span>
                )}
              </div>
            ) : (
              <span style="font-size:0.65rem; font-weight:700; background:rgba(239,68,68,0.1); color:var(--color-error); padding:0.15rem 0.5rem; border-radius:4px; text-transform:uppercase;">no schema</span>
            )}
          </div>

          {def.description && (
            <p class="def-description">{def.description}</p>
          )}

          <div class="def-meta">
            {def.schema_ref && (
              <div class="def-meta-row">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line></svg>
                <span style="color:var(--accent);">{def.schema_ref}</span>
                {def.schemaName && <em style="font-style:normal; color:var(--text-dim);">({def.schemaName})</em>}
              </div>
            )}
            {def.componentPath && (
              <div class="def-meta-row">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                <span>{def.componentPath}</span>
              </div>
            )}
          </div>

          <div class="def-card-actions">
            <button class="btn btn-outline btn-sm edit-def-btn" data-key={def.key}>
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4z"></path></svg>
              Edit
            </button>
            <a href={`/admin/sections?create=true&type=${def.key}`} class="btn btn-outline btn-sm" title="Create instance">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              Add Instance
            </a>
            {def.schema_ref && (
              <a href={`/admin/field-schemas?edit=${def.schema_ref}`} class="btn btn-outline btn-sm" title="Edit linked schema">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                Edit Schema
              </a>
            )}
            <button class="btn-action delete-def-btn" data-key={def.key} data-name={def.name} title="Delete definition">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
            </button>
          </div>
        </div>
      ))
    )}
  </div>

  <!-- CREATE/EDIT Definition Modal -->
  <div class="modal-overlay" id="def-modal-overlay">
    <div class="modal-panel" style="max-width:680px; width:95vw;">
      <div class="modal-head">
        <h4 id="def-modal-title">Create Section Definition</h4>
        <button class="close-modal-btn" id="close-def-modal">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="modal-body" style="max-height:75vh; overflow-y:auto;">

        <!-- Metadata -->
        <div class="modal-section">
          <h5 class="modal-section-title">Definition Metadata</h5>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
            <div class="form-group">
              <label>Display Name <span class="req">*</span></label>
              <input type="text" id="def-name" placeholder="e.g. Hero Banner Dark" />
            </div>
            <div class="form-group">
              <label>Definition Key <span class="req">*</span></label>
              <input type="text" id="def-key" placeholder="e.g. hero_banner_dark (snake_case)" />
              <span class="field-help">Lowercase letters, numbers, underscores only. Immutable after creation.</span>
              <span id="def-key-err" class="field-err"></span>
            </div>
            <div class="form-group">
              <label>Astro Component Path</label>
              <input type="text" id="def-component" placeholder="e.g. MyBlock (under src/blocks/)" />
              <span class="field-help">Component under src/blocks/ — extension .astro optional.</span>
            </div>
            <div class="form-group">
              <label>Preview Image</label>
              <div style="display:flex; gap:0.5rem; align-items:center;">
                <input type="text" id="def-preview" placeholder="/uploads/preview.png" style="flex:1;" />
                <button type="button" class="btn btn-outline" id="btn-pick-preview" style="height:38px; white-space:nowrap;">Browse</button>
              </div>
            </div>
            <div class="form-group" style="grid-column:1/-1;">
              <label>Description</label>
              <textarea id="def-description" rows="2" placeholder="Brief description of what this layout renders..."></textarea>
            </div>
          </div>
        </div>

        <!-- Field Schema Reference -->
        <div class="modal-section">
          <h5 class="modal-section-title">Field Schema Reference</h5>
          <p style="font-size:0.82rem; color:var(--text-dim); margin-bottom:0.85rem; line-height:1.5;">
            Select an existing Field Schema to link to this definition. The schema defines the content fields.
            Multiple definitions can share the same schema (each with a different Astro component = different design).
            <a href="/admin/field-schemas" target="_blank" style="color:var(--primary);">Manage Field Schemas →</a>
          </p>
          <div class="form-group">
            <label>Field Schema <span class="req">*</span></label>
            <select id="def-schema-ref">
              <option value="">— Select a Field Schema —</option>
            </select>
            <span id="def-schema-ref-err" class="field-err"></span>
          </div>
          <!-- Schema preview: show fields once selected -->
          <div id="schema-preview-box" style="display:none; margin-top:0.75rem; background:rgba(16,185,129,0.04); border:1px solid rgba(16,185,129,0.2); border-radius:6px; padding:0.85rem;">
            <div style="font-size:0.75rem; font-weight:700; color:var(--accent); text-transform:uppercase; margin-bottom:0.5rem;">Schema Fields Preview</div>
            <div id="schema-preview-chips" style="display:flex; flex-wrap:wrap; gap:0.3rem;"></div>
          </div>
        </div>

      </div>
      <div class="modal-foot">
        <button class="btn btn-outline" id="cancel-def-modal">Cancel</button>
        <button class="btn btn-primary" id="save-def-btn">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
          Save Definition
        </button>
      </div>
    </div>
  </div>

  <!-- Delete Confirm Modal -->
  <div class="modal-overlay" id="delete-modal-overlay">
    <div class="modal-panel" style="max-width:480px;">
      <div class="modal-head">
        <h4>Delete Section Definition</h4>
        <button class="close-modal-btn" id="close-delete-modal">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="modal-body">
        <p style="color:var(--text-muted); font-size:0.9rem; line-height:1.65;">
          Delete definition <strong id="delete-def-name" style="color:var(--color-error);"></strong>?
          If any Section Instances use this definition, deletion will be blocked.
        </p>
        <div id="delete-dep-instances" style="display:none; margin-top:0.75rem; background:rgba(239,68,68,0.06); border:1px solid rgba(239,68,68,0.2); border-radius:6px; padding:0.75rem; font-size:0.82rem; color:var(--color-error);"></div>
      </div>
      <div class="modal-foot">
        <button class="btn btn-outline" id="cancel-delete-btn">Cancel</button>
        <button class="btn" style="background:var(--color-error); color:#fff;" id="confirm-delete-btn">Delete Definition</button>
      </div>
    </div>
  </div>

  <!-- Media Picker Modal -->
  <div class="media-modal-overlay" id="media-modal">
    <div class="media-modal">
      <div class="media-modal-header">
        <h4>Select Preview Image</h4>
        <button type="button" id="close-media-modal-btn" style="background:transparent;border:none;color:var(--text-muted);cursor:pointer;font-size:1.2rem;">✕</button>
      </div>
      <div class="media-grid" id="media-grid">
        <div style="grid-column:1/-1;text-align:center;padding:2rem;color:var(--text-muted);">Loading media...</div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast-notification" id="toast-notify">
    <div class="toast-content">
      <span class="toast-message" id="toast-message">Saved!</span>
    </div>
  </div>

</AdminLayout>

<style is:global>
  .def-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: var(--transition);
    box-shadow: 0 2px 12px var(--color-shadow);
  }
  .def-card:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 20px rgba(99,102,241,0.12);
    transform: translateY(-1px);
  }
  .def-card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }
  .def-card-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-main);
    margin: 0 0 0.25rem 0;
  }
  .def-key-tag {
    font-size: 0.7rem;
    font-family: monospace;
    background: var(--bg-base);
    border: 1px solid var(--border-color);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    color: var(--text-muted);
    white-space: nowrap;
  }
  .def-description {
    font-size: 0.825rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.55;
  }
  .def-meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .def-meta-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.775rem;
    color: var(--text-dim);
    font-family: monospace;
  }
  .def-card-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border-color);
  }
  .def-card-actions .btn-action {
    margin-left: auto;
    width: 30px; height: 30px;
    border-radius: 6px; border: 1px solid var(--border-color);
    background: transparent; color: var(--text-muted);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: var(--transition);
  }
  .def-card-actions .btn-action:hover {
    background: rgba(239,68,68,0.08);
    color: var(--color-error);
    border-color: var(--color-error);
  }
  .modal-overlay {
    position: fixed; top:0; left:0; right:0; bottom:0;
    background: rgba(8,12,20,0.75); backdrop-filter: blur(8px);
    z-index: 2000; display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.2s ease;
  }
  .modal-overlay.active { opacity: 1; pointer-events: auto; }
  .modal-panel {
    background: var(--bg-surface-solid); border: 1px solid var(--bg-surface-border);
    border-radius: var(--radius-lg); box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    display: flex; flex-direction: column; max-height: 92vh; overflow: hidden;
  }
  .modal-head { padding: 1.15rem 1.5rem; border-bottom: 1px solid var(--bg-surface-border); display: flex; justify-content: space-between; align-items: center; }
  .modal-head h4 { font-size: 1.05rem; font-weight: 700; }
  .modal-body { padding: 1.5rem; }
  .modal-foot { padding: 1rem 1.5rem; border-top: 1px solid var(--bg-surface-border); display: flex; justify-content: flex-end; gap: 0.75rem; }
  .modal-section { margin-bottom: 1.75rem; }
  .modal-section:last-child { margin-bottom: 0; }
  .modal-section-title { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-color); }
  .close-modal-btn { width: 32px; height: 32px; border-radius: 6px; border: 1px solid var(--border-color); background: transparent; color: var(--text-muted); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: var(--transition); }
  .close-modal-btn:hover { color: var(--text-main); background: rgba(255,255,255,0.05); }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-group label { font-size: 0.83rem; font-weight: 600; color: var(--text-muted); }
  .req { color: var(--color-error); }
  .field-help { font-size: 0.73rem; color: var(--text-dim); }
  .field-err { font-size: 0.75rem; color: var(--color-error); min-height: 1.1em; }
  input[type="text"], input[type="number"], select, textarea {
    padding: 0.6rem 0.85rem; border-radius: var(--radius-sm);
    background-color: var(--input-bg); border: 1px solid var(--input-border);
    color: var(--text-main); font-size: 0.88rem; outline: none;
    transition: var(--transition); width: 100%; box-sizing: border-box;
  }
  input:focus, select:focus, textarea:focus {
    border-color: var(--primary); box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
  }
  .toast-notification {
    position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9999;
    background: var(--bg-surface-solid); border: 1px solid var(--border-color);
    border-radius: 8px; padding: 0.85rem 1.25rem;
    box-shadow: 0 8px 30px rgba(0,0,0,0.35);
    transform: translateY(100px); opacity: 0;
    transition: transform 0.25s ease, opacity 0.25s ease;
    pointer-events: none;
  }
  .toast-notification.visible { transform: translateY(0); opacity: 1; }
  .toast-content { display: flex; align-items: center; gap: 0.5rem; }
  .toast-message { font-size: 0.88rem; color: var(--text-main); font-weight: 500; }
  .media-modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:9000; display:none; align-items:center; justify-content:center; }
  .media-modal-overlay.open { display:flex; }
  .media-modal { background:var(--bg-surface-solid); border:1px solid var(--border-color); border-radius:var(--radius-lg); width:min(1200px,95vw); height:min(850px,90vh); display:flex; flex-direction:column; overflow:hidden; }
  .media-modal-header { padding:1rem 1.25rem; border-bottom:1px solid var(--border-color); display:flex; justify-content:space-between; align-items:center; }
  .media-modal-header h4 { font-weight:700; color:var(--text-main); }
  .media-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:1rem; padding:1rem; overflow-y:auto; flex:1; }
  .media-item { position:relative; height:180px; border-radius:var(--radius-sm); overflow:hidden; border:2px solid transparent; cursor:pointer; background:#111827; }
  .media-item:hover { border-color:var(--primary); }
  .media-item img { display:block; width:100%; height:100%; object-fit:cover; }
</style>

<script is:inline define:vars={{ allDefinitions, allSchemas }}>
  let allDefs = allDefinitions || [];
  const schemas = allSchemas || [];
  let editMode = false;
  let editingKey = null;
  let pendingDeleteKey = null;
  let keyInputManuallyEdited = false;

  // ── Helpers ─────────────────────────────────────────────────────────────────

  function getDisplayComponentName(p) {
    if (!p) return '';
    if (p.startsWith('src/blocks/')) { let r = p.slice('src/blocks/'.length); return r.endsWith('.astro') ? r.slice(0, -6) : r; }
    return p;
  }

  function normalizeComponentPath(val) {
    let p = val.trim();
    if (!p) return '';
    if (!p.endsWith('.astro')) p += '.astro';
    if (p.startsWith('src/blocks/')) return p;
    if (p.startsWith('/src/blocks/')) return p.slice(1);
    if (p.startsWith('blocks/')) return 'src/' + p;
    if (p.startsWith('/blocks/')) return 'src/' + p.slice(1);
    return 'src/blocks/' + (p.startsWith('/') ? p.slice(1) : p);
  }

  // ── Schema ref dropdown ──────────────────────────────────────────────────────

  function populateSchemaDropdown(selectedKey = '') {
    const sel = document.getElementById('def-schema-ref');
    sel.innerHTML = '<option value="">— Select a Field Schema —</option>';
    schemas.forEach(s => {
      const opt = document.createElement('option');
      opt.value = s.schema_key;
      opt.textContent = `${s.schema_name} (${s.schema_key}) — ${s.fields?.length || 0} fields`;
      if (s.schema_key === selectedKey) opt.selected = true;
      sel.appendChild(opt);
    });
    updateSchemaPreview(selectedKey);
  }

  function updateSchemaPreview(schemaKey) {
    const box = document.getElementById('schema-preview-box');
    const chips = document.getElementById('schema-preview-chips');
    if (!schemaKey) { box.style.display = 'none'; return; }
    const schema = schemas.find(s => s.schema_key === schemaKey);
    if (!schema || !schema.fields?.length) { box.style.display = 'none'; return; }
    box.style.display = 'block';
    chips.innerHTML = schema.fields.slice(0, 10).map(f =>
      `<span style="font-size:0.68rem;background:var(--bg-base);border:1px solid var(--border-color);padding:0.15rem 0.5rem;border-radius:4px;color:var(--text-muted);font-family:monospace;display:inline-flex;align-items:center;gap:0.3rem;">
        ${f.name} <em style="font-style:normal;font-size:0.6rem;color:var(--primary);background:rgba(99,102,241,0.1);padding:0.05rem 0.3rem;border-radius:3px;">${f.type}</em>
      </span>`
    ).join('') + (schema.fields.length > 10 ? `<span style="font-size:0.68rem;color:var(--primary);">+${schema.fields.length-10} more</span>` : '');
  }

  document.getElementById('def-schema-ref')?.addEventListener('change', e => {
    updateSchemaPreview(e.target.value);
  });

  // ── Search ───────────────────────────────────────────────────────────────────

  const searchInput = document.getElementById('def-search');
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase().trim();
      document.querySelectorAll('.def-card').forEach(card => {
        const name = (card.querySelector('.def-card-name')?.textContent || '').toLowerCase();
        const key  = (card.dataset.key || '').toLowerCase();
        card.style.display = (!q || name.includes(q) || key.includes(q)) ? '' : 'none';
      });
    });
  }

  // ── Modal open/close ─────────────────────────────────────────────────────────

  function openModal(isEdit, def = null) {
    editMode = isEdit;
    editingKey = isEdit ? def.key : null;
    keyInputManuallyEdited = false;

    document.getElementById('def-modal-title').textContent = isEdit ? `Edit Definition: ${def.name}` : 'Create Section Definition';
    document.getElementById('def-key').value = isEdit ? def.key : '';
    document.getElementById('def-key').disabled = isEdit;
    document.getElementById('def-name').value = isEdit ? def.name : '';
    document.getElementById('def-component').value = isEdit ? getDisplayComponentName(def.componentPath) : '';
    document.getElementById('def-preview').value = isEdit ? (def.previewImage || '') : '';
    document.getElementById('def-description').value = isEdit ? (def.description || '') : '';
    document.getElementById('def-key-err').textContent = '';
    document.getElementById('def-schema-ref-err').textContent = '';

    populateSchemaDropdown(isEdit ? (def.schema_ref || '') : '');
    document.getElementById('def-modal-overlay').classList.add('active');
  }

  function closeModal() {
    document.getElementById('def-modal-overlay').classList.remove('active');
    editMode = false; editingKey = null;
  }

  // ── Save ─────────────────────────────────────────────────────────────────────

  async function saveDef() {
    const key         = document.getElementById('def-key').value.trim();
    const name        = document.getElementById('def-name').value.trim();
    const schema_ref  = document.getElementById('def-schema-ref').value;
    const componentPath = normalizeComponentPath(document.getElementById('def-component').value.trim());
    const previewImage  = document.getElementById('def-preview').value.trim();
    const description   = document.getElementById('def-description').value.trim();

    document.getElementById('def-key-err').textContent = '';
    document.getElementById('def-schema-ref-err').textContent = '';

    if (!name) { showToast('Display Name is required', true); return; }
    if (!editMode && !key) { document.getElementById('def-key-err').textContent = 'Key is required.'; return; }
    if (!editMode && !/^[a-z0-9_]+$/.test(key)) {
      document.getElementById('def-key-err').textContent = 'Only lowercase letters, numbers, underscores.';
      return;
    }
    if (!schema_ref) {
      document.getElementById('def-schema-ref-err').textContent = 'Please select a Field Schema.';
      return;
    }

    const payload = {
      key: editMode ? editingKey : key,
      name, schema_ref, componentPath, previewImage, description
    };

    try {
      const res = await fetch('/api/section-definitions-crud', {
        method: editMode ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (data.success) {
        const baseMsg = editMode ? 'Definition updated!' : 'Definition created!';
        showToast(data.warning ? `${baseMsg} ⚠ ${data.warning}` : baseMsg, !!data.warning);
        if (data.warning) console.warn('[Section Definitions] componentPath warning:', data.warning);
        closeModal();
        setTimeout(() => window.location.reload(), 700);
      } else {
        showToast('Error: ' + data.error, true);
        if (data.error?.includes('key')) document.getElementById('def-key-err').textContent = data.error;
      }
    } catch (e) { showToast('Network error', true); }
  }

  // ── Delete ───────────────────────────────────────────────────────────────────

  document.getElementById('confirm-delete-btn').addEventListener('click', async () => {
    if (!pendingDeleteKey) return;
    try {
      const res = await fetch('/api/section-definitions-crud', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: pendingDeleteKey })
      });
      const data = await res.json();
      if (data.success) {
        showToast('Definition deleted');
        document.getElementById('delete-modal-overlay').classList.remove('active');
        setTimeout(() => window.location.reload(), 700);
      } else {
        showToast(data.error, true);
        if (data.dependentInstances?.length) {
          const depEl = document.getElementById('delete-dep-instances');
          depEl.style.display = 'block';
          depEl.innerHTML = `<strong>Blocking instances:</strong> ${data.dependentInstances.map(id => `<code>${id}</code>`).join(', ')}`;
        }
      }
    } catch (e) { showToast('Network error', true); }
  });

  // ── Event wiring ─────────────────────────────────────────────────────────────

  document.getElementById('open-create-def-btn').addEventListener('click', () => openModal(false));
  document.getElementById('close-def-modal').addEventListener('click', closeModal);
  document.getElementById('cancel-def-modal').addEventListener('click', closeModal);
  document.getElementById('save-def-btn').addEventListener('click', saveDef);

  document.getElementById('close-delete-modal').addEventListener('click', () => {
    document.getElementById('delete-modal-overlay').classList.remove('active');
    pendingDeleteKey = null;
  });
  document.getElementById('cancel-delete-btn').addEventListener('click', () => {
    document.getElementById('delete-modal-overlay').classList.remove('active');
    pendingDeleteKey = null;
  });

  document.getElementById('defs-grid').addEventListener('click', e => {
    const editBtn = e.target.closest('.edit-def-btn');
    const delBtn  = e.target.closest('.delete-def-btn');

    if (editBtn) {
      const def = allDefs.find(d => d.key === editBtn.dataset.key);
      if (def) openModal(true, def);
    }

    if (delBtn) {
      pendingDeleteKey = delBtn.dataset.key;
      document.getElementById('delete-def-name').textContent = delBtn.dataset.name;
      document.getElementById('delete-dep-instances').style.display = 'none';
      document.getElementById('delete-dep-instances').innerHTML = '';
      document.getElementById('delete-modal-overlay').classList.add('active');
    }
  });

  // Auto-generate key from name
  window.addEventListener('DOMContentLoaded', () => {
    const nameInput = document.getElementById('def-name');
    const keyInput  = document.getElementById('def-key');

    nameInput?.addEventListener('input', () => {
      if (!editMode && !keyInputManuallyEdited) {
        const gen = nameInput.value.trim().toLowerCase()
          .replace(/[^a-z0-9_]+/g, '_').replace(/__+/g, '_').replace(/(^_|_$)/g, '');
        if (keyInput) keyInput.value = gen;
      }
    });
    keyInput?.addEventListener('input', () => { keyInputManuallyEdited = true; });

    // Handle ?edit= query param
    const editKey = new URLSearchParams(window.location.search).get('edit');
    if (editKey) {
      const def = allDefs.find(d => d.key === editKey);
      if (def) openModal(true, def);
    }

    // Media picker
    document.getElementById('btn-pick-preview')?.addEventListener('click', openMediaPicker);
    document.getElementById('close-media-modal-btn')?.addEventListener('click', closeMediaPicker);
  });

  // ── Media picker ─────────────────────────────────────────────────────────────

  async function openMediaPicker() {
    document.getElementById('media-modal').classList.add('open');
    const gridEl = document.getElementById('media-grid');
    gridEl.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:2rem;color:var(--text-muted);">Loading...</div>';
    try {
      const res = await fetch('/api/media-crud', { credentials: 'include' });
      const data = await res.json();
      const images = (data.media || data.items || []).filter(item => ['image','svg'].includes(item.type));
      if (!images.length) {
        gridEl.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:2rem;color:var(--text-muted);">No images found.</div>';
        return;
      }
      gridEl.innerHTML = images.map(img =>
        `<div class="media-item" onclick="selectMedia('${img.url}')"><img src="${img.url}" alt="${img.title||''}" loading="lazy" /></div>`
      ).join('');
    } catch {
      gridEl.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:2rem;color:var(--color-error);">Failed to load.</div>';
    }
  }

  function closeMediaPicker() { document.getElementById('media-modal').classList.remove('open'); }

  window.selectMedia = function(url) {
    const input = document.getElementById('def-preview');
    if (input) input.value = url;
    closeMediaPicker();
  };

  function showToast(msg, isError = false) {
    const t = document.getElementById('toast-notify');
    const m = document.getElementById('toast-message');
    if (!t || !m) return;
    m.textContent = msg;
    t.style.borderColor = isError ? 'var(--color-error)' : 'var(--border-color)';
    t.classList.add('visible');
    setTimeout(() => t.classList.remove('visible'), 3000);
  }
</script>
