---
import AdminLayout from "../../layouts/admin/AdminLayout.astro";
import fs from "node:fs";
import path from "node:path";
import { parse } from "yaml";

export const prerender = false;

// 1. Fetch Pages Count & Average SEO Score
const pagesDir = path.resolve("src/content/pages");
let totalPages = 0;
let totalSeoScore = 0;

if (fs.existsSync(pagesDir)) {
  const files = fs.readdirSync(pagesDir).filter(f => f.endsWith(".md"));
  totalPages = files.length;
  
  let scoredPages = 0;
  files.forEach(file => {
    try {
      const content = fs.readFileSync(path.join(pagesDir, file), "utf-8");
      const parts = content.split(/^---$/m);
      if (parts.length >= 3) {
        const data = parse(parts[1]) || {};
        const seo = data.seo || {};
        
        let seoScore = 0;
        if (seo.metaTitle) {
          const len = seo.metaTitle.length;
          if (len >= 30 && len <= 60) seoScore += 30;
        }
        if (seo.metaDescription) {
          const len = seo.metaDescription.length;
          if (len >= 120 && len <= 160) seoScore += 30;
        }
        if (seo.focusKeyword && seo.focusKeyword.trim()) seoScore += 20;
        if (seo.schemaType && seo.schemaType !== "none") seoScore += 20;
        
        totalSeoScore += seoScore;
        scoredPages++;
      }
    } catch (e) {
      // Ignore parse issues for average score
    }
  });
  if (scoredPages > 0) {
    totalSeoScore = Math.round(totalSeoScore / scoredPages);
  }
}

// 2. Fetch Uploads Count
const mediaMetaPath = path.resolve("public/uploads/media-meta.json");
let totalMedia = 0;
if (fs.existsSync(mediaMetaPath)) {
  try {
    const media = JSON.parse(fs.readFileSync(mediaMetaPath, "utf-8"));
    totalMedia = Array.isArray(media) ? media.length : 0;
  } catch (e) {}
} else {
  // Check physical files in uploads directory
  const uploadsDir = path.resolve("public/uploads");
  if (fs.existsSync(uploadsDir)) {
    const files = fs.readdirSync(uploadsDir).filter(f => !f.endsWith(".json") && f !== ".gitkeep");
    totalMedia = files.length;
  }
}

// 3. Fetch Redirects Count
const settingsPath = path.resolve("src/data/global-settings.json");
let activeRedirects = 0;
if (fs.existsSync(settingsPath)) {
  try {
    const settings = JSON.parse(fs.readFileSync(settingsPath, "utf-8"));
    if (settings.redirects && Array.isArray(settings.redirects)) {
      activeRedirects = settings.redirects.filter((r: any) => r.active !== false).length;
    }
  } catch (e) {}
}

// 4. Fetch Contact Leads Count & Recent Items
const contactsDir = path.resolve("src/content/contacts");
let totalLeads = 0;
let recentLeads: any[] = [];

if (fs.existsSync(contactsDir)) {
  const files = fs.readdirSync(contactsDir).filter(f => f.endsWith(".md") && f !== ".gitkeep");
  totalLeads = files.length;
  
  const leads = files.map(file => {
    try {
      const content = fs.readFileSync(path.join(contactsDir, file), "utf-8");
      const parts = content.split(/^---$/m);
      if (parts.length >= 3) {
        const data = parse(parts[1]) || {};
        return {
          name: data.name || "Anonymous",
          email: data.email || "",
          subject: data.subject || "No Subject",
          submittedAt: data.submittedAt ? new Date(data.submittedAt).toLocaleString() : fs.statSync(path.join(contactsDir, file)).mtime.toLocaleString(),
          rawTime: data.submittedAt ? new Date(data.submittedAt).getTime() : fs.statSync(path.join(contactsDir, file)).mtime.getTime()
        };
      }
    } catch(e) {}
    return null;
  }).filter(Boolean) as any[];
  
  recentLeads = leads.sort((a, b) => b.rawTime - a.rawTime).slice(0, 3);
}

import "../../styles/admin/css/dashboard.css"
---

<AdminLayout title="CMS Dashboard">
  
  <div class="dashboard-header-intro">
    <p class="subtitle">Welcome to your schema-driven Flat-File Astro CMS dashboard. Real-time statistics across pages layout, media catalog, redirects mapping, and lead briefs inbox.</p>
  </div>

  <!-- Real-time Stats Grid Widgets -->
  <div class="stats-cards-grid">
    
    <div class="stat-card pages-stat">
      <div class="stat-icon-box">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
      </div>
      <div class="stat-details">
        <h3>{totalPages}</h3>
        <span>Total Website Pages</span>
      </div>
      <div class="card-accent accent-indigo"></div>
    </div>

    <div class="stat-card media-stat">
      <div class="stat-icon-box">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
      </div>
      <div class="stat-details">
        <h3>{totalMedia}</h3>
        <span>Uploaded Assets</span>
      </div>
      <div class="card-accent accent-green"></div>
    </div>

    <div class="stat-card redirects-stat">
      <div class="stat-icon-box">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"></polyline><path d="M3 11V9a4 4 0 0 1 4-4h14"></path><polyline points="7 23 3 19 7 15"></polyline><path d="M21 13v2a4 4 0 0 1-4 4H3"></path></svg>
      </div>
      <div class="stat-details">
        <h3>{activeRedirects}</h3>
        <span>Active Redirect Maps</span>
      </div>
      <div class="card-accent accent-purple"></div>
    </div>

    <div class="stat-card leads-stat">
      <div class="stat-icon-box">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
      </div>
      <div class="stat-details">
        <h3>{totalLeads}</h3>
        <span>Leads Submitted</span>
      </div>
      <div class="card-accent accent-amber"></div>
    </div>

  </div>

  <div class="dashboard-layout-row" style="margin-top:2rem; display:grid; grid-template-columns: 1.2fr 0.8fr; gap:1.5rem; align-items:start;">
    
    <!-- Left Area: Quick Actions & SEO Health -->
    <div class="dash-col-left" style="display:flex; flex-direction:column; gap:1.5rem;">
      
      <!-- Quick Action Cards Grid -->
      <div class="form-card">
        <div class="card-header">
          <h3>Quick Administration Controls</h3>
        </div>
        <div class="card-body">
          <div class="quick-links-grid">
            <a href="/admin/pages" class="quick-link-box">
              <div class="ql-icon" style="background-color:rgba(99, 102, 241, 0.12); color:var(--primary);">P</div>
              <div class="ql-details">
                <h4>Pages Builder</h4>
                <p>Edit website layouts & copy</p>
              </div>
            </a>
            <a href="/admin/media" class="quick-link-box">
              <div class="ql-icon" style="background-color:rgba(16, 185, 129, 0.12); color:var(--accent);">M</div>
              <div class="ql-details">
                <h4>Media Library</h4>
                <p>Upload corporate asset files</p>
              </div>
            </a>
            <a href="/admin/menus" class="quick-link-box">
              <div class="ql-icon" style="background-color:rgba(168, 85, 247, 0.12); color:#A855F7;">N</div>
              <div class="ql-details">
                <h4>Header & Footer Menus</h4>
                <p>Manage nested navigation links</p>
              </div>
            </a>
            <a href="/admin/redirects" class="quick-link-box">
              <div class="ql-icon" style="background-color:rgba(239, 68, 68, 0.12); color:#EF4444;">R</div>
              <div class="ql-details">
                <h4>Path Redirects</h4>
                <p>Manage loop-free path aliases</p>
              </div>
            </a>
          </div>
        </div>
      </div>

      <!-- SEO Summary Dashboard -->
      <div class="form-card">
        <div class="card-header">
          <h3>SEO Health Rating</h3>
        </div>
        <div class="card-body" style="display:flex; align-items:center; gap:2rem;">
          <div style="width: 100px; height: 100px; flex-shrink:0;">
            <svg viewBox="0 0 36 36" class="circular-chart">
              <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" style="fill:none; stroke:rgba(156,163,175,0.08); stroke-width:3;"></path>
              <path class="circle" stroke-dasharray={`${totalSeoScore}, 100`} d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" style={`fill:none; stroke-width:3; stroke-linecap:round; stroke: ${totalSeoScore >= 80 ? 'var(--accent)' : (totalSeoScore >= 50 ? 'var(--color-warning)' : 'var(--color-error)')};`}></path>
              <text x="18" y="20.35" class="percentage" style="fill:var(--text-main); font-weight:700; font-size:8px; text-anchor:middle;">{totalSeoScore}%</text>
            </svg>
          </div>
          <div class="seo-summary-details">
            <h4 style="font-size:1.15rem; font-weight:700; color:var(--text-main); margin-bottom:0.35rem;">
              {totalSeoScore >= 80 ? 'Excellent Search Engine Health' : (totalSeoScore >= 50 ? 'Meta Settings Need Tweaks' : 'Critical SEO Deficiencies')}
            </h4>
            <p style="color:var(--text-muted); font-size:0.88rem; line-height:1.45;">Your average pages SEO score is compiled in real-time by validating titles, descriptions lengths, canonical link tags, keywords match indexes, and structured FAQ / Org schemas.</p>
            <a href="/admin/seo" style="color:var(--primary); font-weight:600; font-size:0.85rem; display:inline-block; margin-top:0.5rem; text-decoration:underline;">View detailed Page Audits →</a>
          </div>
        </div>
      </div>

    </div>

    <!-- Right Area: Recent Leads Inbox Feed -->
    <div class="dash-col-right">
      <div class="form-card">
        <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
          <h3>Leads Feed</h3>
          <a href="/admin/contacts" style="color:var(--primary); font-size:0.8rem; font-weight:600;">View Inbox</a>
        </div>
        <div class="card-body padding-zero" style="display:flex; flex-direction:column;">
          {recentLeads.length === 0 ? (
            <div style="padding:4rem 1.5rem; text-align:center; color:var(--text-dim);">
              <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom:0.75rem; opacity:0.4;"><rect x="3" y="4" width="18" height="16" rx="2" ry="2"></rect><polyline points="22,6 12,13 2,6"></polyline></svg>
              <p style="font-weight:600; font-size:0.95rem; margin-bottom:0.15rem;">Inbox is empty</p>
              <p style="font-size:0.78rem;">Customer submission alerts will show up here.</p>
            </div>
          ) : (
            recentLeads.map(lead => (
              <div class="dash-lead-row" style="padding:1.15rem 1.5rem; border-bottom:1px solid var(--bg-surface-border); display:flex; flex-direction:column; gap:0.25rem;">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                  <strong style="color:var(--text-main); font-size:0.92rem;">{lead.name}</strong>
                  <span style="font-size:0.72rem; color:var(--text-dim); font-weight:500;">{lead.submittedAt}</span>
                </div>
                <span style="font-size:0.8rem; color:var(--primary); font-weight:600;">{lead.email}</span>
                <p style="font-size:0.8rem; color:var(--text-muted); line-height:1.4; margin-top:0.25rem; font-style:italic;">&ldquo;{lead.subject}&rdquo;</p>
              </div>
            ))
          )}
        </div>
      </div>
    </div>

  </div>

</AdminLayout>

<style is:global>
  .dashboard-header-intro {
    margin-bottom: 2rem;
  }
  .subtitle {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Stats grid boxes */
  .stats-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .stat-card {
    background: var(--bg-surface);
    border: 1px solid var(--bg-surface-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 15px var(--color-shadow);
    backdrop-filter: blur(10px);
  }
  .stat-icon-box {
    width: 46px;
    height: 46px;
    border-radius: 12px;
    background: rgba(156, 163, 175, 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    flex-shrink: 0;
    border: 1px solid var(--border-color);
  }
  .stat-details h3 {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text-main);
    line-height: 1.15;
  }
  .stat-details span {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .card-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 3px;
  }
  .accent-indigo { background-color: var(--primary); }
  .accent-green { background-color: var(--accent); }
  .accent-purple { background-color: #A855F7; }
  .accent-amber { background-color: #F59E0B; }

  /* Quick links lists */
  .quick-links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }
  .quick-link-box {
    background: rgba(156, 163, 175, 0.015);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: var(--transition);
  }
  .quick-link-box:hover {
    transform: translateY(-2px);
    border-color: var(--primary);
    background-color: rgba(99, 102, 241, 0.02);
  }
  .ql-icon {
    width: 38px;
    height: 38px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.05rem;
    flex-shrink: 0;
  }
  .ql-details h4 {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text-main);
  }
  .ql-details p {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  .dash-lead-row:last-child {
    border-bottom: none !important;
  }
  
  @media (max-width: 768px) {
    .dashboard-layout-row {
      grid-template-columns: 1fr !important;
    }
  }
</style>
