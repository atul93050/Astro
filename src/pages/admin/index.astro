    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
  }
  .seo-health-label {
    font-size: 0.72rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  /* Action Buttons Grid Cell */
  .actions-cell {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
  }
  .btn-action {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-color);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: var(--transition);
  }
  .edit-btn:hover {
    background-color: var(--primary-light);
    color: var(--primary);
    border-color: var(--primary);
  }
  .duplicate-btn:hover {
    background-color: rgba(16, 185, 129, 0.1);
    color: var(--accent);
    border-color: var(--accent);
  }
  .delete-btn:hover {
    background-color: rgba(239, 68, 68, 0.1);
    color: var(--color-error);
    border-color: var(--color-error);
  }

  /* Confirmation Modals Custom Glassmorphism */
  .confirm-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(8, 12, 20, 0.75);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .confirm-modal-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }
  .confirm-modal {
    background: var(--bg-surface-solid);
    border: 1px solid var(--bg-surface-border);
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 500px;
    padding: 1.75rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    transform: scale(0.9);
    transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .confirm-modal-overlay.active .confirm-modal {
    transform: scale(1);
  }
  .confirm-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .confirm-modal-header h4 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-main);
  }
  .close-modal-btn {
    background: transparent;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    transition: var(--transition);
  }
  .close-modal-btn:hover {
    color: var(--text-main);
  }
  .confirm-modal-body p {
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 1rem;
  }
  .warning-text {
    background: rgba(239, 68, 68, 0.08);
    border-left: 3px solid var(--color-error);
    padding: 0.75rem 1rem;
    border-radius: 4px;
    font-size: 0.85rem !important;
    color: #F87171 !important;
  }
  .confirm-modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  /* Toasts */
  .toast-notification {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background: var(--bg-surface-solid);
    border-left: 4px solid var(--primary);
    border-top: 1px solid var(--bg-surface-border);
    border-bottom: 1px solid var(--bg-surface-border);
    border-right: 1px solid var(--bg-surface-border);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-sm);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35);
    z-index: 1100;
    transform: translateY(150%);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(8px);
  }
  .toast-notification.active {
    transform: translateY(0);
  }
  .toast-content {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-main);
  }
</style>

<script is:inline>
  function initDashboard() {
    // 1. Live Search Filter
    const searchInput = document.getElementById("pages-search");
    const rows = document.querySelectorAll(".page-row");
    const emptyRow = document.getElementById("empty-row");

    if (searchInput) {
      searchInput.addEventListener("input", filterRows);
    }

    const filterDropdown = document.getElementById("status-filter");
    if (filterDropdown) {
      filterDropdown.addEventListener("change", filterRows);
    }

    function filterRows() {
      const q = searchInput ? searchInput.value.toLowerCase().trim() : "";
      const status = filterDropdown ? filterDropdown.value : "all";
      let visibleCount = 0;

      rows.forEach(row => {
        const title = row.getAttribute("data-title") || "";
        const slug = row.getAttribute("data-slug") || "";
        const rowStatus = row.getAttribute("data-status") || "";

        const matchesQuery = title.includes(q) || slug.includes(q);
        const matchesStatus = status === "all" || rowStatus === status;

        if (matchesQuery && matchesStatus) {
          row.style.display = "";
          visibleCount++;
        } else {
          row.style.display = "none";
        }
      });

      if (emptyRow) {
        emptyRow.style.display = (visibleCount === 0 && rows.length > 0) ? "" : "none";
      }
    }

    // 2. Delete Page Modal Trigger
    const deleteModal = document.getElementById("delete-modal-overlay");
    const cancelDeleteBtn = document.getElementById("cancel-delete-btn");
    const cancelDeleteX = document.getElementById("cancel-delete-x");
    const confirmDeleteBtn = document.getElementById("confirm-delete-btn");
    const deletePageTitleSpan = document.getElementById("delete-page-title");
    const deletePageSlugSpan = document.getElementById("delete-page-slug");
    const deleteBtnText = document.getElementById("delete-btn-text");

    let activeDeleteSlug = "";

    document.querySelectorAll(".delete-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        const slug = btn.getAttribute("data-slug");
        const title = btn.getAttribute("data-title");
        activeDeleteSlug = slug;
        if (deletePageTitleSpan) deletePageTitleSpan.innerText = `"${title}"`;
        if (deletePageSlugSpan) deletePageSlugSpan.innerText = slug;
        if (deleteModal) deleteModal.classList.add("active");
      });
    });

    const closeModal = () => {
      if (deleteModal) deleteModal.classList.remove("active");
      activeDeleteSlug = "";
    };

    if (cancelDeleteBtn) cancelDeleteBtn.addEventListener("click", closeModal);
    if (cancelDeleteX) cancelDeleteX.addEventListener("click", closeModal);
    if (deleteModal) {
      deleteModal.addEventListener("click", (e) => {
        if (e.target === deleteModal) closeModal();
      });
    }

    // 3. API Delete Trigger
    if (confirmDeleteBtn) {
      confirmDeleteBtn.addEventListener("click", async () => {
        if (!activeDeleteSlug) return;
        
        confirmDeleteBtn.disabled = true;
        if (deleteBtnText) deleteBtnText.innerText = "Deleting...";

        try {
          const res = await fetch("/api/pages-crud", {
            method: "DELETE",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ slug: activeDeleteSlug })
          });
          const result = await res.json();
          
          if (result.success) {
            showToast("Page deleted successfully!");
            setTimeout(() => {
              window.location.reload();
            }, 1000);
          } else {
            showToast("Error: " + (result.error || "Could not delete page"));
            confirmDeleteBtn.disabled = false;
            if (deleteBtnText) deleteBtnText.innerText = "Yes, Delete Page";
          }
        } catch (e) {
          showToast("Network Error: Could not delete page");
          confirmDeleteBtn.disabled = false;
          if (deleteBtnText) deleteBtnText.innerText = "Yes, Delete Page";
        }
      });
    }

    // 4. Page Duplication
    document.querySelectorAll(".duplicate-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        const slug = btn.getAttribute("data-slug");
        btn.disabled = true;
        
        showToast("Cloning page structure...");

        try {
          // Fetch existing data
          const getRes = await fetch(`/api/pages-crud?action=get&slug=${slug}`);
          const getData = await getRes.json();

          if (!getData.success) {
            showToast("Error retrieving page schema");
            btn.disabled = false;
            return;
          }

          const originalPage = getData.page;
          const newSlug = `${originalPage.slug}-copy`;
          
          // Construct cloned data
          const clonedPage = {
            title: `${originalPage.title} (Cloned)`,
            slug: newSlug,
            status: "draft",
            seo: {
              ...originalPage.seo,
              metaTitle: `${originalPage.seo?.metaTitle} (Copy)`,
              canonicalUrl: ""
            },
            blocks: originalPage.blocks || [],
            body: getData.body || ""
          };

          // Save Cloned
          const postRes = await fetch("/api/pages-crud", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(clonedPage)
          });
          const postResult = await postRes.json();

          if (postResult.success) {
            showToast("Page duplicated successfully!");
            setTimeout(() => {
              window.location.reload();
            }, 1000);
          } else {
            showToast("Error: " + (postResult.errors?.slug || "Duplication failed. Slug may already exist."));
            btn.disabled = false;
          }
        } catch (e) {
          showToast("Network Error: Could not duplicate page");
          btn.disabled = false;
        }
      });
    });

    // Toast Utility
    const toast = document.getElementById("toast-notify");
    const toastMsg = document.getElementById("toast-message");
    
    function showToast(message) {
      if (toast && toastMsg) {
        toastMsg.innerText = message;
        toast.classList.add("active");
        setTimeout(() => {
          toast.classList.remove("active");
        }, 3000);
      }
    }
  }

  // Bind init functions
  document.addEventListener("DOMContentLoaded", initDashboard);
  document.addEventListener("astro:page-load", initDashboard);
  if (document.readyState === "interactive" || document.readyState === "complete") {
    initDashboard();
  }
</script>
