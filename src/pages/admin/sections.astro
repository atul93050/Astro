<script is:inline>
  const ICONS = {
    delete: `<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>`
  };
  let activeDeleteId = "";
  let selectedBlockType = "";
  let modalIdManuallyEdited = false;

  function selectCatalogType(type) {
    selectedBlockType = type;
    document.querySelectorAll(".catalog-item").forEach(item => {
      if (item.getAttribute("data-type") === type) {
        item.classList.add("selected");
      } else {
        item.classList.remove("selected");
      }
    });
  }
  // Expose function globally for click trigger
  window.selectCatalogType = selectCatalogType;

  function openCreateForType(type, name) {
    // Switch to Create tab, pre-select the type
    document.querySelectorAll(".tab-nav-btn").forEach(b => b.classList.remove("active"));
    const createTab = document.querySelector(".tab-nav-btn[data-tab='create']");
    if (createTab) createTab.classList.add("active");
    document.querySelectorAll(".submodule-view").forEach(v => v.classList.remove("active"));
    const createView = document.getElementById("view-create");
    if (createView) createView.classList.add("active");
    selectCatalogType(type);
    createView?.scrollIntoView({ behavior: "smooth", block: "start" });
  }
  window.openCreateForType = openCreateForType;

  function initSectionsList() {
    // 1. Search and status/type filter bindings
    const searchInput = document.getElementById("sections-search");
    if (!searchInput || searchInput.dataset.listenerBound) return;
    searchInput.dataset.listenerBound = "true";

    searchInput.addEventListener("input", filterAndSortSections);

    // Auto-generate inline Section ID from Section Display Name
    const inlineIdInput = document.getElementById("new-section-id");
    const inlineNameInput = document.getElementById("new-section-name");
    let inlineIdManuallyEdited = false;

    inlineNameInput?.addEventListener("input", () => {
      if (!inlineIdManuallyEdited) {
        const generated = inlineNameInput.value
          .trim()
          .toLowerCase()
          .replace(/[^a-z0-9-]+/g, '-')
          .replace(/--+/g, '-')
          .replace(/(^-|-$)/g, '');
        if (inlineIdInput) {
          inlineIdInput.value = generated;
        }
      }
    });

    inlineIdInput?.addEventListener("input", () => {
      inlineIdManuallyEdited = true;
    });

    // Auto-generate modal Section ID from Section Display Name
    const modalIdInput = document.getElementById("create-section-id");
    const modalNameInput = document.getElementById("create-section-name");

    modalNameInput?.addEventListener("input", () => {
      if (!modalIdManuallyEdited) {
        const generated = modalNameInput.value
          .trim()
          .toLowerCase()
          .replace(/[^a-z0-9-]+/g, '-')
          .replace(/--+/g, '-')
          .replace(/(^-|-$)/g, '');
        if (modalIdInput) {
          modalIdInput.value = generated;
        }
      }
    });

    modalIdInput?.addEventListener("input", () => {
      modalIdManuallyEdited = true;
    });

    const typeFilter = document.getElementById("type-filter");
    if (typeFilter) typeFilter.addEventListener("change", filterAndSortSections);

    const statusFilter = document.getElementById("status-filter");
    if (statusFilter) statusFilter.addEventListener("change", filterAndSortSections);

    const sortFilter = document.getElementById("sort-filter");
    if (sortFilter) sortFilter.addEventListener("change", filterAndSortSections);

    function filterAndSortSections() {
      const q = searchInput.value.trim().toLowerCase();
      const type = typeFilter ? typeFilter.value : "all";
      const status = statusFilter ? statusFilter.value : "all";
      const sortVal = sortFilter ? sortFilter.value : "updated";

      const grid = document.getElementById("sections-grid");
      if (!grid) return;
      const cards = Array.from(grid.querySelectorAll(".section-card"));
      let count = 0;

      // 1. Filtering
      cards.forEach(card => {
        const id = card.getAttribute("data-id") || "";
        const name = card.getAttribute("data-name") || "";
        const cType = card.getAttribute("data-type") || "";
        const typename = card.getAttribute("data-typename") || "";
        const cStatus = card.getAttribute("data-status") || "published";

        const matchQ = !q || id.includes(q) || name.includes(q) || typename.includes(q);
        const matchType = type === "all" || cType === type;
        const matchStatus = status === "all" || cStatus === status;

        if (matchQ && matchType && matchStatus) {
          card.style.display = "flex";
          count++;
        } else {
          card.style.display = "none";
        }
      });

      // 2. Sorting
      cards.sort((a, b) => {
        if (sortVal === "updated") {
          const dateA = new Date(a.getAttribute("data-updated")).getTime();
          const dateB = new Date(b.getAttribute("data-updated")).getTime();
          return dateB - dateA;
        } else if (sortVal === "created") {
          return a.getAttribute("data-id").localeCompare(b.getAttribute("data-id"));
        } else if (sortVal === "used") {
          const countA = parseInt(a.getAttribute("data-usage-count") || "0");
          const countB = parseInt(b.getAttribute("data-usage-count") || "0");
          return countB - countA;
        } else if (sortVal === "alpha") {
          return a.getAttribute("data-name").localeCompare(b.getAttribute("data-name"));
        }
        return 0;
      });

      // Re-append sorted elements
      cards.forEach(card => grid.appendChild(card));
      
      const fallback = document.querySelector(".no-sections-fallback");
      if (fallback) {
        fallback.style.display = count === 0 ? "block" : "none";
      }
    }

    // 2. Submodule Tab switcher
    const tabButtons = document.querySelectorAll(".tab-nav-btn");
    tabButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        tabButtons.forEach(b => b.classList.remove("active"));
        btn.classList.add("active");

        const tab = btn.getAttribute("data-tab");
        document.querySelectorAll(".submodule-view").forEach(view => {
          view.classList.remove("active");
        });
        
        const targetView = document.getElementById(`view-${tab}`);
        if (targetView) targetView.classList.add("active");

        if (tab === "templates") {
          renderTemplatesList();
        }
      });
    });

    // 3. Create submit trigger
    const submitCreateBtn = document.getElementById("btn-create-submit");
    if (submitCreateBtn) {
      submitCreateBtn.addEventListener("click", async () => {
        const idInput = document.getElementById("new-section-id");
        const nameInput = document.getElementById("new-section-name");
        const idErr = document.getElementById("new-section-id-err");
        const nameErr = document.getElementById("new-section-name-err");

        idErr.innerText = "";
        nameErr.innerText = "";

        const secId = idInput.value.trim().toLowerCase();
        const secName = nameInput.value.trim();

        if (!secId || !/^[a-z0-9-]+$/.test(secId)) {
          idErr.innerText = "Please enter a valid lowercase, alphanumeric section ID.";
          return;
        }

        if (!secName) {
          nameErr.innerText = "Display Name is required.";
          return;
        }

        if (!selectedBlockType) {
          showToast("Please select a section type template from the blueprint catalog.");
          return;
        }

        submitCreateBtn.disabled = true;

        try {
          const payload = {
            id: secId,
            type: selectedBlockType,
            name: secName,
            status: "published"
          };
          
          const res = await fetch("/api/sections-crud", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });
          
          const data = await res.json();
          if (data.success) {
            showToast("Section created successfully!");
            setTimeout(() => {
              window.location.href = `/admin/sections/editor?id=${secId}`;
            }, 800);
          } else {
            showToast("Error: " + (data.error || "Save failed"));
            submitCreateBtn.disabled = false;
          }
        } catch(e) {
          showToast("Connection error occurred.");
          submitCreateBtn.disabled = false;
        }
      });
    }

    // 5. Delete mappings overlay triggers
    const closeDeleteBtn = document.getElementById("close-delete-modal");
    const cancelDeleteBtn = document.getElementById("cancel-delete-btn");
    const confirmDeleteBtn = document.getElementById("confirm-delete-btn");

    const hideDeleteModal = () => {
      document.getElementById("delete-section-overlay").classList.remove("active");
      activeDeleteId = "";
    };

    if (closeDeleteBtn) closeDeleteBtn.addEventListener("click", hideDeleteModal);
    if (cancelDeleteBtn) cancelDeleteBtn.addEventListener("click", hideDeleteModal);

    if (confirmDeleteBtn) {
      confirmDeleteBtn.addEventListener("click", async () => {
        if (!activeDeleteId) return;
        confirmDeleteBtn.disabled = true;
        confirmDeleteBtn.innerText = "Deleting...";

        try {
          const res = await fetch("/api/sections-crud", {
            method: "DELETE",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id: activeDeleteId })
          });
          const data = await res.json();

          if (data.success) {
            showToast("Section deleted successfully!");
            setTimeout(() => {
              window.location.reload();
            }, 800);
          } else {
            showToast("Error: " + (data.error || "Delete failed"));
            confirmDeleteBtn.disabled = false;
            confirmDeleteBtn.innerText = "Delete Section";
          }
        } catch(e) {
          showToast("Network connection error");
          confirmDeleteBtn.disabled = false;
          confirmDeleteBtn.innerText = "Delete Section";
        }
      });
    }

    // 6. Viewport Switcher Preview handlers
    const deviceButtons = document.querySelectorAll(".device-btn");
    const iframeWrapper = document.getElementById("preview-device-viewport");
    deviceButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        deviceButtons.forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
        
        const device = btn.getAttribute("data-device");
        iframeWrapper.className = `device-viewport ${device}`;
      });
    });

    const closePreviewBtn = document.getElementById("close-preview-overlay");
    if (closePreviewBtn) {
      closePreviewBtn.addEventListener("click", () => {
        document.getElementById("preview-overlay").classList.remove("active");
        document.getElementById("preview-iframe").src = "about:blank";
      });
    }

    // 7. Click delegate binds
    document.addEventListener("click", (e) => {
      const delBtn = e.target.closest(".delete-btn");
      if (delBtn) {
        const id = delBtn.getAttribute("data-id");
        const name = delBtn.getAttribute("data-name");
        const count = parseInt(delBtn.getAttribute("data-usage-count") || "0");
        
        activeDeleteId = id;
        document.getElementById("delete-section-display-name").innerText = `"${name}"`;
        document.getElementById("usage-pages-count").innerText = count;
        
        const warning = document.getElementById("delete-usage-warning");
        if (warning) warning.style.display = count > 0 ? "block" : "none";

        document.getElementById("delete-section-overlay").classList.add("active");
      }

      const dupBtn = e.target.closest(".duplicate-btn");
      if (dupBtn) {
        const id = dupBtn.getAttribute("data-id");
        executeDuplication(id);
      }

      const prevBtn = e.target.closest(".preview-section-btn");
      if (prevBtn) {
        const id = prevBtn.getAttribute("data-id");
        const name = prevBtn.getAttribute("data-name");
        openLivePreview(id, name);
      }
    });

    // 8. Import Drag and Drop upload zone binding
    const dragZone = document.getElementById("import-drag-zone");
    const fileInput = document.getElementById("import-file-input");

    if (dragZone && fileInput) {
      dragZone.addEventListener("click", () => fileInput.click());
      fileInput.addEventListener("change", (e) => {
        if (fileInput.files.length > 0) {
          importSection(fileInput.files[0]);
        }
      });
      
      dragZone.addEventListener("dragover", (e) => {
        e.preventDefault();
        dragZone.style.borderColor = "var(--primary)";
        dragZone.style.background = "var(--primary-light)";
      });
      
      dragZone.addEventListener("dragleave", () => {
        dragZone.style.borderColor = "var(--border-color)";
        dragZone.style.background = "var(--bg-base)";
      });
      
      dragZone.addEventListener("drop", (e) => {
        e.preventDefault();
        dragZone.style.borderColor = "var(--border-color)";
        dragZone.style.background = "var(--bg-base)";
        if (e.dataTransfer.files.length > 0) {
          importSection(e.dataTransfer.files[0]);
        }
      });
    }

    // 9. "Create Reusable Section" header button → open create modal
    const createModalOverlay = document.getElementById("create-section-modal-overlay");
    const openCreateSectionBtn = document.getElementById("open-create-section-btn");
    if (openCreateSectionBtn && createModalOverlay) {
      openCreateSectionBtn.addEventListener("click", () => {
        selectedBlockType = "";
        document.querySelectorAll(".catalog-item").forEach(item => item.classList.remove("selected"));
        const ciInput = document.getElementById("create-section-id");
        const cnInput = document.getElementById("create-section-name");
        if (ciInput) ciInput.value = "";
        if (cnInput) cnInput.value = "";
        modalIdManuallyEdited = false;
        createModalOverlay.classList.add("active");
      });
    }

    // 10. Create Modal — close/cancel handlers
    const closeCreateModalX = document.getElementById("close-create-modal");
    const cancelCreateModalBtn = document.getElementById("cancel-create-btn");
    const hideCreateModal = () => {
      if (createModalOverlay) createModalOverlay.classList.remove("active");
    };
    if (closeCreateModalX) closeCreateModalX.addEventListener("click", hideCreateModal);
    if (cancelCreateModalBtn) cancelCreateModalBtn.addEventListener("click", hideCreateModal);
    if (createModalOverlay) {
      createModalOverlay.addEventListener("click", (e) => {
        if (e.target === createModalOverlay) hideCreateModal();
      });
    }

    // 11. confirm-create-btn — create section from modal form
    const confirmCreateBtn = document.getElementById("confirm-create-btn");
    if (confirmCreateBtn) {
      confirmCreateBtn.addEventListener("click", async () => {
        const createIdInput = document.getElementById("create-section-id");
        const createNameInput = document.getElementById("create-section-name");
        const createIdErr = document.getElementById("create-section-id-err");
        const createNameErr = document.getElementById("create-section-name-err");

        if (createIdErr) createIdErr.innerText = "";
        if (createNameErr) createNameErr.innerText = "";

        const secId = createIdInput ? createIdInput.value.trim().toLowerCase() : "";
        const secName = createNameInput ? createNameInput.value.trim() : "";

        if (!secId || !/^[a-z0-9-]+$/.test(secId)) {
          if (createIdErr) createIdErr.innerText = "Please enter a valid section ID (lowercase letters, numbers, dashes only).";
          return;
        }
        if (!secName) {
          if (createNameErr) createNameErr.innerText = "Display Name is required.";
          return;
        }
        if (!selectedBlockType) {
          showToast("Please select a section type blueprint from the catalog.");
          return;
        }

        confirmCreateBtn.disabled = true;
        const confirmSpan = confirmCreateBtn.querySelector("span");
        if (confirmSpan) confirmSpan.innerText = "Creating...";

        try {
          const res = await fetch("/api/sections-crud", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id: secId, type: selectedBlockType, name: secName, status: "published" })
          });
          const data = await res.json();
          if (data.success) {
            showToast("Section created successfully!");
            setTimeout(() => {
              window.location.href = `/admin/sections/editor?id=${secId}`;
            }, 800);
          } else {
            showToast("Error: " + (data.error || "Create failed"));
            confirmCreateBtn.disabled = false;
            if (confirmSpan) confirmSpan.innerText = "Create & Edit Section";
          }
        } catch(e) {
          showToast("Connection error occurred.");
          confirmCreateBtn.disabled = false;
          if (confirmSpan) confirmSpan.innerText = "Create & Edit Section";
        }
      });
    }
  }

  async function executeDuplication(id) {
    const newId = prompt("Enter a unique Section ID for the duplicated block:", `${id}-copy`);
    if (!newId) return;

    try {
      const getRes = await fetch(`/api/sections-crud?action=get&id=${id}`);
      const getData = await getRes.json();
      if (!getData.success) {
        showToast("Error reading source section");
        return;
      }

      const payload = {
        ...getData.section,
        id: newId.trim().toLowerCase(),
        name: `${getData.section.name || id} (Copy)`
      };

      const res = await fetch("/api/sections-crud", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (data.success) {
        showToast("Section duplicated successfully!");
        setTimeout(() => {
          window.location.reload();
        }, 800);
      } else {
        showToast("Error duplicating: " + (data.error || "failed"));
      }
    } catch(e) {
      showToast("Network Error occurred.");
    }
  }

  function openLivePreview(id, name) {
    document.getElementById("preview-section-title").innerText = `Preview Section: "${name}"`;
    document.getElementById("preview-iframe").src = `/admin/sections/preview?id=${id}`;
    document.getElementById("preview-overlay").classList.add("active");
  }

  // --- TEMPLATES SYSTEM CLIENT ENGINE ---
  function renderTemplatesList() {
    const container = document.getElementById("templates-list-container");
    if (!container) return;

    const templates = JSON.parse(localStorage.getItem("cms_section_templates") || "[]");
    if (templates.length === 0) {
      container.innerHTML = `
        <div class="no-sections-fallback" style="grid-column: 1 / -1; padding:3rem 1rem;">
          <h4>No section templates saved yet</h4>
          <p>Hover over any section in the Library and click the "Save as Template" action to register it.</p>
        </div>
      `;
      return;
    }

    container.innerHTML = templates.map((t, idx) => {
      const blockType = t.blockData.type || "hero";
      const fallbackImg = `/images/previews/${blockType}.png`;
      const typeName = blockType.charAt(0).toUpperCase() + blockType.slice(1) + " Blueprint";

      return `
        <div class="section-card" style="display:flex; flex-direction:column; background:var(--bg-surface); border:1px solid var(--border-color); border-radius:8px; overflow:hidden;">
          <div style="height:120px; background:var(--input-bg); display:flex; align-items:center; justify-content:center; overflow:hidden; border-bottom:1px solid var(--border-color);">
            <img src="${t.blockData.previewImage || fallbackImg}" style="width:100%; height:100%; object-fit:cover;" onerror="this.src='/images/previews/hero.png';" />
          </div>
          <div style="padding:1rem; flex:1; display:flex; flex-direction:column; justify-content:space-between; text-align:left;">
            <div>
              <h4 style="margin:0 0 0.25rem 0; font-size:0.95rem; font-weight:700; color:var(--text-main);">${t.name}</h4>
              <span style="font-size:0.7rem; font-family:monospace; background:var(--bg-base); border:1px solid var(--border-color); padding:0.1rem 0.35rem; border-radius:4px; font-weight:600; color:var(--text-dim);">${typeName}</span>
            </div>
            <div style="display:flex; gap:0.5rem; justify-content:space-between; align-items:center; border-top:1px solid var(--border-color); padding-top:0.75rem; margin-top:1rem;">
              <button class="btn btn-primary btn-sm" onclick="createFromTemplate(${idx})" style="padding:0.25rem 0.5rem; font-size:0.72rem; flex:1.5;">Create Section</button>
              <button class="btn-action delete-btn" onclick="deleteTemplate(${idx})" title="Delete Template" style="border:1px solid var(--border-color); width:28px; height:28px; display:flex; align-items:center; justify-content:center; border-radius:4px;">
                ${ICONS.delete}
              </button>
            </div>
          </div>
        </div>
      `;
    }).join('');
  }

  async function saveAsTemplate(id) {
    const templateName = prompt("Enter a name for this section template:");
    if (!templateName) return;

    try {
      const res = await fetch(`/api/sections-crud?action=get&id=${id}`);
      const data = await res.json();
      if (data.success) {
        const templates = JSON.parse(localStorage.getItem("cms_section_templates") || "[]");
        templates.push({
          name: templateName,
          blockData: data.section
        });
        localStorage.setItem("cms_section_templates", JSON.stringify(templates));
        showToast(`Template "${templateName}" saved successfully!`);
      } else {
        showToast("Error loading section content from disk.");
      }
    } catch(e) {
      showToast("Network Connection error");
    }
  }

  async function createFromTemplate(templateIndex) {
    const templates = JSON.parse(localStorage.getItem("cms_section_templates") || "[]");
    const template = templates[templateIndex];
    if (!template) return;

    const newId = prompt("Enter unique Section ID for the new instance:", `${template.blockData.type}-from-template`);
    if (!newId) return;

    const newName = prompt("Enter section display name:", `${template.name} Instance`);
    if (!newName) return;

    try {
      const payload = {
        ...template.blockData,
        id: newId.trim().toLowerCase(),
        name: newName.trim(),
        status: "published"
      };

      const res = await fetch("/api/sections-crud", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });

      const data = await res.json();
      if (data.success) {
        showToast("Section created from template successfully!");
        setTimeout(() => {
          window.location.href = `/admin/sections/editor?id=${payload.id}`;
        }, 800);
      } else {
        showToast("Error creating: " + data.error);
      }
    } catch(e) {
      showToast("Network Connection error");
    }
  }

  function deleteTemplate(index) {
    window.customConfirm("Are you sure you want to delete this template?", () => {
      const templates = JSON.parse(localStorage.getItem("cms_section_templates") || "[]");
      templates.splice(index, 1);
      localStorage.setItem("cms_section_templates", JSON.stringify(templates));
      showToast("Template deleted successfully!");
      renderTemplatesList();
    });
  }

  // --- BACKUP IMPORT & EXPORT CLIENT ENGINE ---
  async function exportSection(id, name) {
    try {
      const res = await fetch(`/api/sections-crud?action=get&id=${id}`);
      const data = await res.json();
      if (data.success) {
        const payload = {
          ...data.section,
          id: id,
          name: name
        };
        const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(payload, null, 2));
        const downloadAnchor = document.createElement('a');
        downloadAnchor.setAttribute("href", dataStr);
        downloadAnchor.setAttribute("download", `${id}-export.json`);
        document.body.appendChild(downloadAnchor);
        downloadAnchor.click();
        downloadAnchor.remove();
        showToast("✓ Section exported to JSON successfully!");
      } else {
        showToast("Error loading section for export.");
      }
    } catch(e) {
      showToast("Network error exporting section.");
    }
  }

  async function importSection(file) {
    const reader = new FileReader();
    reader.onload = async (e) => {
      try {
        const sectionData = JSON.parse(e.target.result);
        if (!sectionData.type) {
          showToast("Invalid backup JSON: Missing component 'type' field.");
          return;
        }

        const newId = prompt("Enter a unique Section ID for the imported block:", sectionData.id || "imported-block");
        if (!newId) return;

        const newName = prompt("Enter Section display name:", sectionData.name || "Imported Section");
        if (!newName) return;

        const payload = {
          ...sectionData,
          id: newId.trim().toLowerCase(),
          name: newName.trim(),
          status: "published"
        };

        const res = await fetch("/api/sections-crud", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        
        if (data.success) {
          showToast("✓ Section imported successfully!");
          setTimeout(() => {
            window.location.reload();
          }, 800);
        } else {
          showToast("Import failed: " + data.error);
        }
      } catch(err) {
        showToast("Error parsing JSON file. Make sure file content is valid JSON.");
      }
    };
    reader.readAsText(file);
  }

  // Expose triggers globally for inline click binds
  window.saveAsTemplate = saveAsTemplate;
  window.createFromTemplate = createFromTemplate;
  window.deleteTemplate = deleteTemplate;
  window.exportSection = exportSection;

  function showToast(message) {
    const notify = document.getElementById("toast-notify");
    const msgSpan = document.getElementById("toast-message");
    if (notify && msgSpan) {
      msgSpan.innerText = message;
      notify.classList.add("active");
      setTimeout(() => {
        notify.classList.remove("active");
      }, 3000);
    }
  }

  // Handle URL query parameters on page load
  window.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const create = params.get('create');
    const type = params.get('type');
    if (create === 'true') {
      const createModalOverlay = document.getElementById("create-section-modal-overlay");
      if (createModalOverlay) {
        // Clear inputs first
        const ciInput = document.getElementById("create-section-id");
        const cnInput = document.getElementById("create-section-name");
        if (ciInput) ciInput.value = "";
        if (cnInput) cnInput.value = "";
        modalIdManuallyEdited = false;
        
        // Show modal
        createModalOverlay.classList.add("active");
        
        // Select type if provided
        if (type) {
          selectCatalogType(type);
          
          // Switch catalog tab filter if needed to display the selected catalog item
          const selectedItem = document.querySelector(`#create-section-modal-overlay .catalog-item[data-type="${type}"]`);
          if (selectedItem) {
            const cat = selectedItem.getAttribute('data-category');
            if (cat) {
              const tabBtn = document.querySelector(`#create-section-modal-overlay .catalog-tab-btn[data-category="${cat}"]`);
              if (tabBtn) tabBtn.click();
            }
          }
        }
      }
    }
  });

  document.addEventListener("DOMContentLoaded", initSectionsList);
  document.addEventListener("astro:page-load", initSectionsList);
  if (document.readyState === "interactive" || document.readyState === "complete") {
    initSectionsList();
  }
</script>
