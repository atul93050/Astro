---
import AdminLayout from "../../layouts/admin/AdminLayout.astro";
import fs from "node:fs";
import path from "node:path";
import { parse } from "yaml";

export const prerender = false;

// 1. Load section definitions (developer-managed blueprints)
const definitionsPath = path.resolve("src/data/section-definitions.json");
let allDefinitions: any[] = [];
try {
  if (fs.existsSync(definitionsPath)) {
    allDefinitions = JSON.parse(fs.readFileSync(definitionsPath, "utf-8"));
  }
} catch (e) {
  console.error("Failed to load section definitions:", e);
}

// 2. Helper to parse frontmatter
function parseMarkdown(content: string) {
  const parts = content.split(/^---$/m);
  if (parts.length < 3) {
    return { data: {}, body: content };
  }
  const yamlStr = parts[1];
  const body = parts.slice(2).join("---").trim();
  try {
    const data = parse(yamlStr);
    return { data, body };
  } catch (e) {
    console.error("YAML Parse error:", e);
    return { data: {}, body };
  }
}

// 3. Gather usages across pages
const pagesDir = path.resolve("src/content/pages");
const usages: Record<string, Array<{ title: string; slug: string }>> = {};

if (fs.existsSync(pagesDir)) {
  const files = fs.readdirSync(pagesDir).filter(f => f.endsWith(".md"));
  files.forEach(file => {
    try {
      const filePath = path.join(pagesDir, file);
      const content = fs.readFileSync(filePath, "utf-8");
      const { data } = parseMarkdown(content);
      const slug = data.slug || path.basename(file, ".md");
      const title = data.title || slug;

      if (data && Array.isArray(data.blocks)) {
        data.blocks.forEach((block: any) => {
          if (block.sectionId) {
            if (!usages[block.sectionId]) {
              usages[block.sectionId] = [];
            }
            if (!usages[block.sectionId].some(p => p.slug === slug)) {
              usages[block.sectionId].push({ title, slug });
            }
          }
        });
      }
    } catch (e) {
      console.error("Error reading usages for page file:", file, e);
    }
  });
}

// 4. Gather section instances
const sectionsDir = path.resolve("src/content/sections");
if (!fs.existsSync(sectionsDir)) {
  fs.mkdirSync(sectionsDir, { recursive: true });
}

const sectionFiles = fs.readdirSync(sectionsDir).filter(f => f.endsWith(".md"));
const allSections = sectionFiles.map(file => {
  const filePath = path.join(sectionsDir, file);
  const content = fs.readFileSync(filePath, "utf-8");
  const { data } = parseMarkdown(content);
  const sectionId = path.basename(file, ".md");
  const type = data.type || "";
  const definition = allDefinitions.find((d: any) => d.key === type);

  return {
    id: sectionId,
    name: data.name || sectionId.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
    type,
    typeName: definition ? definition.name : (type || "Unknown Type"),
    status: data.status || "published",
    lastUpdated: fs.statSync(filePath).mtime.toLocaleString(),
    usedIn: usages[sectionId] || [],
    previewImage: data.previewImage || (definition?.previewImage) || ""
  };
});

---

<AdminLayout title="Section Library — CMS">

  <div class="dashboard-header">
    <div class="header-text">
      <p class="subtitle">Section Library: Create and manage reusable content section instances from developer-defined blueprints.</p>
    </div>
    <div class="header-actions">
      <a href="/admin/section-definitions" class="btn btn-outline">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
        Section Definitions
      </a>
      <button class="btn btn-primary" id="open-create-section-btn">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        <span>Create Section Instance</span>
      </button>
    </div>
  </div>

  <!-- Submodule Tab Switcher Navigation -->
  <div class="sections-tabs-navigation" style="display:flex; gap:0.5rem; border-bottom:1px solid var(--border-color); margin-bottom:2rem; overflow-x:auto; padding-bottom:0.25rem;">
    <button type="button" class="tab-nav-btn active" data-tab="library">Section Library</button>
    <button type="button" class="tab-nav-btn" data-tab="create">Create Instance</button>
    <button type="button" class="tab-nav-btn" data-tab="types">Available Types</button>
    <button type="button" class="tab-nav-btn" data-tab="templates">Templates</button>
    <button type="button" class="tab-nav-btn" data-tab="import-export">Import & Export</button>
  </div>

  <!-- Submodule 1: Section Library -->
  <div class="submodule-view active" id="view-library">
    <div class="section-title-wrap" style="margin-bottom:1rem; border-left:3px solid var(--primary); padding-left:0.75rem;">
      <h3 style="font-size:1.15rem; font-weight:700; color:var(--text-main);">Section Instances ({allSections.length})</h3>
    </div>

    <!-- Search and Filter Controls -->
    <div class="controls-bar" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; gap:1rem; flex-wrap:wrap;">
      <div class="search-input-wrap" style="position:relative; flex:1; max-width:400px; min-width:250px;">
        <svg class="search-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="position:absolute; left:0.85rem; top:50%; transform:translateY(-50%); color:var(--text-dim); pointer-events:none;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" id="sections-search" placeholder="Search by name, type, id..." style="padding-left:2.5rem !important;" />
      </div>

      <div class="filter-controls" style="display:flex; gap:0.5rem; align-items:center;">
        <select id="status-filter" style="padding:0.6rem 1rem; background-color:var(--input-bg); border:1px solid var(--input-border); color:var(--text-main); border-radius:var(--radius-sm); outline:none; font-size:0.88rem; font-weight:500;">
          <option value="all">All Statuses</option>
          <option value="published">Published</option>
          <option value="draft">Draft</option>
          <option value="archived">Archived</option>
        </select>
        
        <select id="type-filter" style="padding:0.6rem 1rem; background-color:var(--input-bg); border:1px solid var(--input-border); color:var(--text-main); border-radius:var(--radius-sm); outline:none; font-size:0.88rem; font-weight:500;">
          <option value="all">All Types</option>
          {allDefinitions.map((d: any) => (
            <option value={d.key}>{d.name}</option>
          ))}
        </select>

        <select id="sort-filter" style="padding:0.6rem 1rem; background-color:var(--input-bg); border:1px solid var(--input-border); color:var(--text-main); border-radius:var(--radius-sm); outline:none; font-size:0.88rem; font-weight:500;">
          <option value="updated">Recently Updated</option>
          <option value="created">Recently Created</option>
          <option value="used">Most Used</option>
          <option value="alpha">Alphabetical</option>
        </select>
      </div>
    </div>

    <!-- Sections Card Grid -->
    <div class="sections-grid-layout" id="sections-grid" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(290px, 1fr)); gap:1.5rem; margin-bottom:4rem;">
      {allSections.length === 0 ? (
        <div class="no-sections-fallback" style="grid-column:1 / -1; text-align:center; padding:5rem 2rem; border:1px dashed var(--border-color); border-radius:var(--radius-lg); background:var(--bg-surface); color:var(--text-dim);">
          <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.5; margin-bottom:1rem; display:inline-block;"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="9" x2="15" y2="9"></line><line x1="9" y1="13" x2="15" y2="13"></line></svg>
          <h4>No reusable sections created yet</h4>
          <p>Go to the "Create Section" tab to define a dynamic block.</p>
        </div>
      ) : (
        allSections.map(section => (
          <div class="section-card" data-id={section.id.toLowerCase()} data-name={section.name.toLowerCase()} data-type={section.type} data-typename={section.typeName.toLowerCase()} data-status={section.status} data-updated={section.lastUpdated} data-usage-count={section.usedIn.length}>
            <div class="section-card-preview-placeholder" style="position:relative; width:100%; height:140px; background:var(--input-bg); display:flex; align-items:center; justify-content:center; overflow:hidden;">
              {section.previewImage ? (
                <img src={section.previewImage} alt={section.name} style="width:100%; height:100%; object-fit:cover;" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
              ) : null}
              <div class="placeholder-icon-wrap" style={section.previewImage ? "position:absolute; display:none; align-items:center; justify-content:center; width:100%; height:100%;" : "position:absolute; display:flex; align-items:center; justify-content:center; width:100%; height:100%;"}>
                <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
              </div>
              <span class="preview-type-tag">{section.typeName}</span>
              <div class="card-action-overlay">
                <button class="btn btn-primary btn-sm preview-section-btn" data-id={section.id} data-name={section.name}>Preview Live</button>
              </div>
            </div>
            <div class="section-card-content">
              <div class="section-card-meta-line">
                <span class="section-card-id">ID: {section.id}</span>
                <span class={`status-badge ${section.status === 'published' ? 'published' : section.status === 'draft' ? 'draft' : 'archived'}`} style="text-transform:uppercase; font-size:0.65rem; font-weight:700; padding:0.1rem 0.35rem; border-radius:4px;">{section.status}</span>
              </div>
              <h4 class="section-card-title">{section.name}</h4>
              <div class="section-card-usages">
                <strong>Used on:</strong>
                {section.usedIn.length === 0 ? (
                  <span class="usage-count none">Unused / Reusable</span>
                ) : (
                  <div class="usage-links-wrap">
                    {section.usedIn.map(p => (
                      <a href={p.slug === 'index' ? '/' : `/${p.slug}`} target="_blank" class="usage-link-badge">
                        {p.title}
                      </a>
                    ))}
                  </div>
                )}
              </div>
              <div class="section-card-footer">
                <span class="card-updated">Updated: {section.lastUpdated.split(',')[0]}</span>
                <div class="card-footer-actions">
                  <a href={`/admin/sections/editor?id=${section.id}`} class="btn-action edit-btn" title="Edit Content">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4z"></path></svg>
                  </a>
                  <button class="btn-action duplicate-btn" data-id={section.id} title="Duplicate Block">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                  </button>
                  <button class="btn-action template-btn" onclick={`saveAsTemplate('${section.id}')`} title="Save as Template">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#10B981;"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                  </button>
                  <button class="btn-action delete-btn" data-id={section.id} data-name={section.name} data-usage-count={section.usedIn.length} title="Delete Block">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                  </button>
                </div>
              </div>
            </div>
          </div>
        ))
      )}
    </div>
  </div>

  <!-- Submodule 2: Create Section Instance -->
  <div class="submodule-view" id="view-create">
    <div class="section-title-wrap" style="margin-bottom:1rem; border-left:3px solid var(--primary); padding-left:0.75rem;">
      <h3 style="font-size:1.15rem; font-weight:700; color:var(--text-main);">Create Section Instance</h3>
    </div>
    <p style="color:var(--text-muted); margin-bottom:1.5rem; font-size:0.9rem;">Select a Section Definition (blueprint) below. The CMS auto-generates the edit form from the schema. <a href="/admin/section-definitions" style="color:var(--primary);">Manage definitions →</a></p>
    
    <div style="display:flex; flex-direction:column; gap:1.25rem; background:var(--bg-surface); padding:1.5rem; border:1px solid var(--border-color); border-radius:8px; margin-bottom:2rem; max-width:600px;">
      <div class="form-group">
        <label for="new-section-name">Section Display Name <span class="required">*</span></label>
        <input type="text" id="new-section-name" placeholder="e.g. Careers Accordion" style="width:100%;" />
        <span class="field-error" id="new-section-name-err" style="color:var(--color-error); font-size:0.78rem;"></span>
      </div>
      <div class="form-group">
        <label for="new-section-id">Unique Section ID <span class="required">*</span></label>
        <input type="text" id="new-section-id" placeholder="e.g. faq-careers" style="width:100%;" />
        <span class="field-help" style="font-size:0.75rem; color:var(--text-dim); display:block; margin-top:0.25rem;">Lowercase letters, numbers, and dashes only.</span>
        <span class="field-error" id="new-section-id-err" style="color:var(--color-error); font-size:0.78rem;"></span>
      </div>
    </div>

    <h5 style="margin-bottom:1rem; text-transform:uppercase; font-size:0.8rem; color:var(--text-muted); letter-spacing:0.05em; text-align:left;">Select a Section Blueprint ({allDefinitions.length} available)</h5>

    <div class="block-catalog-grid" id="new-block-catalog" style="max-height:none; grid-template-columns:repeat(auto-fill, minmax(200px, 1fr)); gap:1rem; border:none; padding:0; background:none; display:grid;">
      {allDefinitions.length === 0 ? (
        <div style="grid-column:1/-1; text-align:center; padding:3rem; border:1px dashed var(--border-color); border-radius:8px; color:var(--text-dim);">
          <p>No Section Definitions found. <a href="/admin/section-definitions" style="color:var(--primary);">Create a definition first →</a></p>
        </div>
      ) : (
        allDefinitions.map((d: any) => (
          <div class="catalog-item new-catalog-item" data-type={d.key} onclick={`selectCatalogType('${d.key}')`} style="border:1px solid var(--border-color); border-radius:8px; overflow:hidden; background:var(--bg-surface-solid); transition:var(--transition); cursor:pointer; display:flex; flex-direction:column;">
            <div style="width:100%; height:100px; background:var(--input-bg); display:flex; align-items:center; justify-content:center; overflow:hidden; position:relative; flex-shrink:0;">
              {d.previewImage ? (
                <img src={d.previewImage} alt={d.name} style="width:100%; height:100%; object-fit:cover;" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
              ) : null}
              <div style={d.previewImage ? "display:none; position:absolute; align-items:center; justify-content:center; width:100%; height:100%;" : "display:flex; align-items:center; justify-content:center; width:100%; height:100%;"}>
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.25;"><rect x="3" y="3" width="18" height="18" rx="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
              </div>
            </div>
            <div style="padding:0.65rem; text-align:center;">
              <strong style="font-size:0.82rem; color:var(--text-main); display:block; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{d.name}</strong>
            </div>
          </div>
        ))
      )}
    </div>
    
    <div style="margin-top:2rem; display:flex; gap:1rem;">
      <button type="button" class="btn btn-primary" id="btn-create-submit" style="padding:0.6rem 1.5rem;">Create & Edit Section</button>
    </div>
  </div>

  <!-- Submodule 3: Available Section Types (from definitions) -->
  <div class="submodule-view" id="view-types">
    <div class="section-title-wrap" style="margin-bottom:1rem; border-left:3px solid var(--primary); padding-left:0.75rem;">
      <h3 style="font-size:1.15rem; font-weight:700; color:var(--text-main);">Available Section Types ({allDefinitions.length})</h3>
    </div>
    <p style="color:var(--text-muted); margin-bottom:1.5rem; font-size:0.9rem;">Visual catalog of all available blueprints. Click any card to start a new section from that blueprint.</p>

    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(220px, 1fr)); gap:1.25rem; margin-bottom:5rem;">
      {allDefinitions.length === 0 ? (
        <div style="grid-column:1/-1; text-align:center; padding:3rem; border:1px dashed var(--border-color); border-radius:8px; color:var(--text-dim);">
          <p>No Section Types defined yet. <a href="/admin/section-definitions" style="color:var(--primary);">Create a definition →</a></p>
        </div>
      ) : (
        allDefinitions.map((d: any) => (
          <div style="background:var(--bg-surface); border:1px solid var(--border-color); border-radius:8px; overflow:hidden; display:flex; flex-direction:column; box-shadow: 0 4px 12px var(--color-shadow); transition:var(--transition); cursor:pointer;" onclick={`openCreateForType('${d.key}', '${d.name.replace(/\\/g, '\\\\').replace(/'/g, "\\'")}')`}>
            <div style="width:100%; height:150px; background:var(--input-bg); display:flex; align-items:center; justify-content:center; overflow:hidden; position:relative;">
              {d.previewImage ? (
                <img src={d.previewImage} alt={d.name} style="width:100%; height:100%; object-fit:cover;" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
              ) : null}
              <div style={d.previewImage ? "display:none; position:absolute; align-items:center; justify-content:center; width:100%; height:100%;" : "display:flex; align-items:center; justify-content:center; width:100%; height:100%;"}>
                <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.25;"><rect x="3" y="3" width="18" height="18" rx="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
              </div>
            </div>
            <div style="padding:0.9rem 1rem; text-align:center; border-top:1px solid var(--border-color);">
              <h4 style="margin:0; font-size:0.9rem; font-weight:700; color:var(--text-main);">{d.name}</h4>
            </div>
          </div>
        ))
      )}
    </div>
  </div>

  <!-- Submodule 4: Categories (retired) -->
  <div class="submodule-view" id="view-categories">
    <div style="max-width:560px; margin:3rem auto; text-align:center; padding:3rem 2rem; border:1px dashed var(--border-color); border-radius:10px; color:var(--text-muted);">
      <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.35; margin-bottom:1rem; display:inline-block;"><path d="M3 7h18M6 7V5a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v2M9 11v6M15 11v6M4 7l1 13a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2L20 7"></path></svg>
      <h4 style="margin:0 0 0.5rem; font-size:1rem; font-weight:700; color:var(--text-main);">Categories Removed</h4>
      <p style="margin:0 0 1.25rem; font-size:0.88rem; line-height:1.6;">The category field has been removed from the Section model. Sections are now organized by their linked <strong>Field Schema</strong>. Use Field Schemas to group related content structures.</p>
      <a href="/admin/field-schemas" class="btn btn-outline" style="display:inline-flex; align-items:center; gap:0.5rem; font-size:0.88rem;">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
        Manage Field Schemas →
      </a>
    </div>
  </div>

  <!-- Submodule 5: Templates -->
  <div class="submodule-view" id="view-templates">
    <div class="section-title-wrap" style="margin-bottom:1rem; border-left:3px solid var(--primary); padding-left:0.75rem;">
      <h3 style="font-size:1.15rem; font-weight:700; color:var(--text-main);">Saved Section Templates</h3>
    </div>
    <p style="color:var(--text-muted); margin-bottom:2rem; font-size:0.9rem;">Load a saved block template to quickly instantiate new sections with pre-configured content.</p>
    
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(290px, 1fr)); gap:1.5rem;" id="templates-list-container">
      <div class="no-sections-fallback" style="grid-column: 1 / -1; padding:3rem 1rem;">
        <h4>No section templates saved yet</h4>
        <p>Hover over any section in the Library and click the "Save as Template" action to register it.</p>
      </div>
    </div>
  </div>

  <!-- Submodule 6: Import & Export -->
  <div class="submodule-view" id="view-import-export">
    <div class="section-title-wrap" style="margin-bottom:1rem; border-left:3px solid var(--primary); padding-left:0.75rem;">
      <h3 style="font-size:1.15rem; font-weight:700; color:var(--text-main);">Import & Export Reusable Sections</h3>
    </div>
    <p style="color:var(--text-muted); margin-bottom:2rem; font-size:0.9rem;">Export individual block layout configs to JSON, or upload a JSON backup file to instantly create sections.</p>
    
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:2rem; align-items:start;">
      <!-- Import Block -->
      <div style="background:var(--bg-surface); border:1px solid var(--border-color); border-radius:8px; padding:1.5rem; display:flex; flex-direction:column; gap:1.25rem; box-shadow: 0 4px 12px var(--color-shadow); text-align:left;">
        <h4 style="margin:0; font-size:1.05rem; font-weight:700; color:var(--text-main);">Upload JSON Section Backup</h4>
        
        <div id="import-drag-zone" style="border:2px dashed var(--border-color); border-radius:8px; padding:3rem 2rem; text-align:center; cursor:pointer; background:var(--bg-base); transition:var(--transition);">
          <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="var(--primary)" stroke-width="2" style="margin-bottom:0.75rem; opacity:0.75; display:inline-block;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
          <p style="margin:0; font-size:0.85rem; color:var(--text-muted); font-weight:500;">Click to browse or drop section JSON file here</p>
          <input type="file" id="import-file-input" accept=".json" style="display:none;" />
        </div>
      </div>

      <!-- Export Block -->
      <div style="background:var(--bg-surface); border:1px solid var(--border-color); border-radius:8px; padding:1.5rem; display:flex; flex-direction:column; gap:1rem; max-height:400px; overflow-y:auto; box-shadow: 0 4px 12px var(--color-shadow);">
        <h4 style="margin:0; font-size:1.05rem; font-weight:700; color:var(--text-main);">Export Section Configs</h4>
        <div style="display:flex; flex-direction:column; gap:0.5rem;">
          {allSections.map(sec => (
            <div style="display:flex; justify-content:space-between; align-items:center; background:var(--bg-base); padding:0.5rem 0.75rem; border:1px solid var(--border-color); border-radius:6px;">
              <div style="min-width:0; text-align:left;">
                <strong style="font-size:0.85rem; display:block; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; color:var(--text-main);">{sec.name}</strong>
                <span style="font-size:0.7rem; color:var(--text-dim); font-family:monospace;">ID: {sec.id}</span>
              </div>
              <button type="button" class="btn btn-outline btn-sm" onclick={`exportSection('${sec.id}', '${sec.name}')`} style="padding:0.25rem 0.5rem; font-size:0.72rem; cursor:pointer;">Export</button>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Create Reusable Section Modal -->
  <div class="confirm-modal-overlay" id="create-section-modal-overlay">
    <div class="confirm-modal create-section-modal">
      <div class="confirm-modal-header">
        <h4>Create Reusable Section</h4>
        <button class="close-modal-btn" id="close-create-modal">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      
      <div class="confirm-modal-body">
        <div class="create-form-wrap" style="display:flex; flex-direction:column; gap:1rem; margin-bottom:1.5rem;">
          <div class="form-group">
            <label for="create-section-name">Section Display Name <span class="required">*</span></label>
            <input type="text" id="create-section-name" placeholder="e.g. Careers Accordion" required />
            <span class="field-error" id="create-section-name-err"></span>
          </div>

          <div class="form-group">
            <label for="create-section-id">Unique Section ID <span class="required">*</span></label>
            <input type="text" id="create-section-id" placeholder="e.g. faq-careers" required />
            <span class="field-help">Lowercase letters, numbers, and dashes only.</span>
            <span class="field-error" id="create-section-id-err"></span>
          </div>
        </div>

        <h5 style="margin-bottom:0.75rem; text-transform:uppercase; font-size:0.75rem; color:var(--text-muted); letter-spacing:0.05em;">Select Section Blueprint ({allDefinitions.length} available)</h5>

        <div class="block-catalog-grid" id="block-catalog" style="grid-template-columns:repeat(3, 1fr);">
          {allDefinitions.map((d: any) => (
            <div class="catalog-item" data-type={d.key} onclick={`selectCatalogType('${d.key}')`} style="flex-direction:column; align-items:stretch; padding:0; overflow:hidden; gap:0;">
              <div style="height:70px; background:var(--input-bg); display:flex; align-items:center; justify-content:center; overflow:hidden; position:relative; flex-shrink:0;">
                {d.previewImage ? (
                  <img src={d.previewImage} alt={d.name} style="width:100%; height:100%; object-fit:cover;" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                ) : null}
                <div style={d.previewImage ? "display:none; position:absolute; align-items:center; justify-content:center; width:100%; height:100%;" : "display:flex; align-items:center; justify-content:center; width:100%; height:100%;"}>
                  <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.25;"><rect x="3" y="3" width="18" height="18" rx="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                </div>
              </div>
              <div class="catalog-item-info" style="padding:0.4rem 0.5rem; text-align:center;">
                <strong style="font-size:0.72rem; white-space:normal; line-height:1.3;">{d.name}</strong>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="confirm-modal-footer">
        <button class="btn btn-outline" id="cancel-create-btn">Cancel</button>
        <button class="btn btn-primary" id="confirm-create-btn">
          <span>Create & Edit Section</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Delete Reusable Section Modal -->
  <div class="confirm-modal-overlay" id="delete-section-overlay">
    <div class="confirm-modal">
      <div class="confirm-modal-header">
        <h4>Delete Reusable Section</h4>
        <button class="close-modal-btn" id="close-delete-modal">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div class="confirm-modal-body">
        <p>Are you sure you want to delete section <strong id="delete-section-display-name">"Hero Home"</strong>?</p>
        <div class="warning-text" id="delete-usage-warning">
          <strong>⚠️ Active Usage Warning</strong>
          <p style="margin-top:0.25rem;">This section is currently in use on <span id="usage-pages-count">0</span> page(s). Deleting it will permanently remove it from these page builder lists!</p>
        </div>
      </div>
      <div class="confirm-modal-footer">
        <button class="btn btn-outline" id="cancel-delete-btn">Cancel</button>
