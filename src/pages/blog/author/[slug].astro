---
import MainLayout from '../../../layouts/MainLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getBlogPosts } from '../../../utils/blog';
import fs from 'node:fs';
import path from 'node:path';

export const prerender = false;

const { slug } = Astro.params;

// ─── Load metadata & settings ────────────────────────────────────────────────
let meta = { categories: [], tags: [], authors: [], settings: {} };
try {
  const metaPath = path.resolve('src/data/blog-meta.json');
  if (fs.existsSync(metaPath)) {
    meta = JSON.parse(fs.readFileSync(metaPath, 'utf-8'));
  }
} catch (e) {
  console.error("Failed to read blog-meta.json:", e);
}

const categories = meta.categories || [];
const authors = meta.authors || [];
const settings = meta.settings || {
  showExcerpt: true,
  showAuthor: true,
  showDate: true,
  showTags: true,
  showReadingTime: true
};

const authorInfo = authors.find((a: any) => a.slug === slug);
if (!authorInfo) {
  return Astro.redirect('/404');
}

// ─── Query Parameters ─────────────────────────────────────────────────────────
const q = Astro.url.searchParams.get('q') || '';
const page = parseInt(Astro.url.searchParams.get('page') || '1', 10);
const postsPerPage = 9;

// ─── Load & Filter posts ──────────────────────────────────────────────────────
const allPosts = await getBlogPosts();

let posts = allPosts
  .filter(post => post.data.status === 'published' && post.data.author === authorInfo.id)
  .map(post => {
    const body = post.body || '';
    const words = body.trim().split(/\s+/).length;
    const readingTime = Math.max(1, Math.ceil(words / 200));

    const catInfo = categories.find((c: any) => c.slug === post.data.category) || {
      name: "Uncategorized",
      slug: "uncategorized",
      color: "#8B3FB8"
    };

    return {
      ...post,
      readingTime,
      categoryInfo: catInfo,
      authorInfo
    };
  });

// Sort by publishDate descending
posts.sort((a, b) => {
  const dateA = new Date(a.data.publishDate || a.data.updatedDate || 0).getTime();
  const dateB = new Date(b.data.publishDate || b.data.updatedDate || 0).getTime();
  return dateB - dateA;
});

// Search filter inside author's posts
if (q) {
  const query = q.toLowerCase();
  posts = posts.filter(p => 
    p.data.title.toLowerCase().includes(query) || 
    (p.data.excerpt || '').toLowerCase().includes(query)
  );
}

// ─── Pagination ──────────────────────────────────────────────────────────────
const totalPosts = posts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage) || 1;
const currentPage = Math.min(Math.max(1, page), totalPages);
const startIndex = (currentPage - 1) * postsPerPage;
const paginatedPosts = posts.slice(startIndex, startIndex + postsPerPage);

function makeUrl(pageNum: number) {
  const params = new URLSearchParams(Astro.url.search);
  params.set('page', String(pageNum));
  return `/blog/author/${slug}?${params.toString()}`;
}
---

<MainLayout 
  title={`${authorInfo.name} | Author | Tangence Blog`}
  description={authorInfo.bio || `Read articles written by ${authorInfo.name} on Tangence.`}
>
  <Header />

  <main class="archive-main">
    
    <!-- Header Banner / Author Card -->
    <header class="archive-hero author-hero">
      <div class="container hero-content author-profile-card">
        <a href="/blog" class="back-link"><i class="fa fa-long-arrow-left"></i> All Articles</a>
        
        <div class="author-details-wrapper">
          <div class="author-avatar-large">
            {authorInfo.avatar ? (
              <img src={authorInfo.avatar} alt={authorInfo.name} />
            ) : (
              <span class="initials-avatar">{authorInfo.name.charAt(0)}</span>
            )}
          </div>
          <div class="author-text-info">
            <span class="archive-label">Author Archive</span>
            <h1 class="archive-title">{authorInfo.name}</h1>
            <span class="author-role-badge">{authorInfo.role}</span>
            {authorInfo.bio && <p class="author-bio">{authorInfo.bio}</p>}
            
            {/* Social Links */}
            <div class="author-socials">
              {authorInfo.website && (
                <a href={authorInfo.website} target="_blank" rel="noopener noreferrer" title="Website"><i class="fa fa-globe"></i> Website</a>
              )}
              {authorInfo.twitter && (
                <a href={`https://twitter.com/${authorInfo.twitter}`} target="_blank" rel="noopener noreferrer" title="Twitter"><i class="fa fa-twitter"></i> Twitter</a>
              )}
              {authorInfo.linkedin && (
                <a href={authorInfo.linkedin} target="_blank" rel="noopener noreferrer" title="LinkedIn"><i class="fa fa-linkedin"></i> LinkedIn</a>
              )}
            </div>
          </div>
        </div>
        
        <span class="count-badge">{totalPosts} {totalPosts === 1 ? 'article' : 'articles'} written</span>
      </div>
    </header>

    <!-- Search / Filter bar -->
    <section class="toolbar-section container">
      <div class="toolbar-wrapper">
        <h2>Articles by {authorInfo.name}</h2>
        
        <form action={`/blog/author/${slug}`} method="GET" class="search-form">
          <div class="search-input-wrapper">
            <input 
              type="text" 
              name="q" 
              placeholder="Search author posts..." 
              value={q}
              autocomplete="off"
            />
            <button type="submit" aria-label="Search"><i class="fa fa-search"></i></button>
          </div>
        </form>
      </div>
    </section>

    <!-- Grid List -->
    <section class="posts-section container">
      {paginatedPosts.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon"><i class="fa fa-search"></i></div>
          <h3>No articles found</h3>
          <p>We couldn't find any articles matching your search query from this author.</p>
          <a href={`/blog/author/${slug}`} class="btn-reset">Reset Search</a>
        </div>
      ) : (
        <div class="posts-grid">
          {paginatedPosts.map(post => (
            <article class="post-card">
              <div class="card-image">
                <a href={`/blog/${post.slug}`}>
                  <img 
                    src={post.data.featuredImage || '/images/default-blog.jpg'} 
                    alt={post.data.title}
                    loading="lazy"
                    onerror="this.src='https://images.unsplash.com/photo-1499750310107-5fef28a66643?q=80&w=600&auto=format&fit=crop'"
                  />
                </a>
                {post.categoryInfo && (
                  <span class="card-category-badge" style={`background-color: ${post.categoryInfo.color || '#6B2E97'}`}>
                    {post.categoryInfo.name}
                  </span>
                )}
              </div>
              
              <div class="card-content">
                <div class="card-meta">
                  {settings.showDate && (
                    <span class="card-meta-item">
                      {new Date(post.data.publishDate || "").toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                    </span>
                  )}
                  {settings.showReadingTime && (
                    <span class="card-meta-divider">•</span>
                    <span class="card-meta-item">{post.readingTime} min read</span>
                  )}
                </div>
                
                <h3 class="card-title">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </h3>
                
                {settings.showExcerpt && (
                  <p class="card-excerpt">{post.data.excerpt || 'Read the full article.'}</p>
                )}
                
                <div class="card-footer">
                  <a href={`/blog/${post.slug}`} class="card-link" aria-label={`Read ${post.data.title}`}>
                    Read Article <i class="fa fa-long-arrow-right"></i>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}

      <!-- Pagination -->
      {totalPages > 1 && (
        <nav class="pagination" aria-label="Author pagination">
          <a 
            href={currentPage > 1 ? makeUrl(currentPage - 1) : '#'} 
            class:list={['pag-btn', 'prev', { disabled: currentPage === 1 }]}
          >
            <i class="fa fa-angle-left"></i> Previous
          </a>
          
          <div class="pag-pages">
            {Array.from({ length: totalPages }).map((_, idx) => {
              const pageNum = idx + 1;
              return (
                <a 
                  href={makeUrl(pageNum)} 
                  class:list={['pag-page-link', { active: pageNum === currentPage }]}
                >
                  {pageNum}
                </a>
              );
            })}
          </div>
          
          <a 
            href={currentPage < totalPages ? makeUrl(currentPage + 1) : '#'} 
            class:list={['pag-btn', 'next', { disabled: currentPage === totalPages }]}
          >
            Next <i class="fa fa-angle-right"></i>
          </a>
        </nav>
      )}
    </section>

  </main>

  <Footer />
</MainLayout>

<style>
  .archive-main {
    padding-top: 80px;
    background-color: var(--bg-soft, #FAF6FE);
    color: var(--ink, #1A1A2E);
    min-height: 100vh;
    font-family: "Graphik", "Montserrat", sans-serif;
  }
  .author-hero {
    background: var(--gradient-hero, linear-gradient(135deg, #FFE4E1 0%, #F5E1FA 45%, #E8D5F7 100%));
    border-bottom: 1px solid var(--line, #EAE2F2);
    padding: 4rem 0;
  }
  .author-profile-card {
    display: flex;
    flex-direction: column;
  }
  .back-link {
    color: var(--ink-soft, #4A4A5E);
    font-weight: 700;
    font-size: 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    transition: transform 0.2s;
  }
  .back-link:hover {
    transform: translateX(-4px);
    color: var(--purple-700, #6B2E97);
  }
  
  .author-details-wrapper {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }
  .author-avatar-large {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(135deg, var(--purple-500, #8B3FB8) 0%, var(--pink-500, #F33B7B) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 25px rgba(74, 19, 112, 0.1);
    border: 3px solid white;
    flex-shrink: 0;
  }
  .author-avatar-large img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .initials-avatar {
    color: white;
    font-weight: 700;
    font-size: 2.5rem;
    text-transform: uppercase;
  }
  .author-text-info {
    flex-grow: 1;
  }
  .archive-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--purple-700, #6B2E97);
    margin-bottom: 0.25rem;
  }
  .archive-title {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 0.35rem;
    color: var(--ink, #1A1A2E);
  }
  .author-role-badge {
    display: inline-block;
    background: white;
    border: 1px solid var(--line, #EAE2F2);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--purple-700, #6B2E97);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .author-bio {
    font-size: 1.05rem;
    color: var(--ink-soft, #4A4A5E);
    line-height: 1.6;
    max-width: 700px;
    margin-bottom: 1.25rem;
  }
  
  .author-socials {
    display: flex;
    gap: 1.25rem;
  }
  .author-socials a {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink-soft, #4A4A5E);
    display: flex;
    align-items: center;
    gap: 0.35rem;
    transition: color 0.2s;
  }
  .author-socials a:hover {
    color: var(--purple-700, #6B2E97);
  }

  .count-badge {
    background: white;
    border: 1px solid var(--line, #EAE2F2);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--muted, #707085);
    align-self: flex-start;
  }

  .toolbar-section {
    padding: 3rem 1.5rem 2rem 1.5rem;
  }
  .toolbar-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--line, #EAE2F2);
    padding-bottom: 1rem;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .toolbar-wrapper h2 {
    font-size: 1.35rem;
    font-weight: 700;
  }
  
  /* Search Form */
  .search-form {
    width: 100%;
    max-width: 320px;
  }
  .search-input-wrapper {
    position: relative;
    display: flex;
  }
  .search-input-wrapper input {
    width: 100%;
    padding: 0.6rem 1rem !important;
    padding-right: 2.5rem !important;
    border: 1px solid var(--line, #EAE2F2) !important;
    border-radius: 30px !important;
    background-color: white !important;
    font-size: 0.85rem !important;
    height: 36px !important;
  }
  .search-input-wrapper button {
    position: absolute;
    right: 5px;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    color: var(--muted, #707085);
    cursor: pointer;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Grid Lists */
  .posts-section {
    padding-bottom: 6rem;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }
  .post-card {
    background: white;
    border: 1px solid var(--line, #EAE2F2);
    border-radius: var(--radius-md, 16px);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(74, 19, 112, 0.04);
  }
  .card-image {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .card-category-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
  }
  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  .card-meta {
    font-size: 0.78rem;
    color: var(--muted, #707085);
    margin-bottom: 0.5rem;
  }
  .card-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }
  .card-title a {
    color: var(--ink, #1A1A2E);
  }
  .card-title a:hover {
    color: var(--purple-700, #6B2E97);
  }
  .card-excerpt {
    font-size: 0.85rem;
    color: var(--ink-soft, #4A4A5E);
    line-height: 1.5;
    margin-bottom: 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-footer {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    border-top: 1px solid var(--line, #EAE2F2);
    padding-top: 1rem;
    margin-top: auto;
  }
  .card-link {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--purple-700, #6B2E97);
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .card-link:hover {
    color: var(--pink-600, #E91E63);
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: white;
    border: 1px solid var(--line, #EAE2F2);
    border-radius: var(--radius-lg, 24px);
    max-width: 500px;
    margin: 2rem auto;
  }
  .empty-icon {
    font-size: 2rem;
    color: var(--muted, #707085);
    margin-bottom: 1rem;
  }
  .btn-reset {
    display: inline-block;
    background: var(--purple-700, #6B2E97);
    color: white;
    padding: 0.5rem 1.25rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-top: 1rem;
  }

  /* Pagination */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 3rem;
    border-top: 1px solid var(--line, #EAE2F2);
    padding-top: 1.5rem;
  }
  .pag-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--line, #EAE2F2);
    border-radius: 20px;
    background: white;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink-soft, #4A4A5E);
  }
  .pag-btn.disabled {
    opacity: 0.5;
    pointer-events: none;
  }
  .pag-pages {
    display: flex;
    gap: 0.25rem;
  }
  .pag-page-link {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink-soft, #4A4A5E);
  }
  .pag-page-link.active {
    background: var(--purple-700, #6B2E97);
    color: white;
  }

  @media (max-width: 768px) {
    .author-details-wrapper {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1.5rem;
    }
  }

  @media (max-width: 640px) {
    .toolbar-wrapper {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
    }
    .search-form {
      max-width: 100%;
    }
  }
</style>
