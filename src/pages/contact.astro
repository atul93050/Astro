---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export const prerender = false;
---

<MainLayout 
  title="Contact Us | Tangence Performance Marketing" 
  description="Get in touch with Tangence performance marketing agency. Reach out to book a free 30-min audit for your Google, Meta, or Amazon ad budgets."
>
  <Header />

  <!-- Hero Section -->
  <section class="contact-hero">
    <div class="container text-center">
      <span class="badge">GET IN TOUCH</span>
      <h1>Let's build something enduring.</h1>
      <p class="hero-subtitle">Most agencies talk about growth hacks. We talk about performance systems that stand the test of time.</p>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="contact-body-sec">
    <div class="container">
      <div class="contact-grid">
        
        <!-- Left Side: Trust points & Office Info -->
        <div class="contact-info-panel">
          <div class="info-card">
            <h3>Why get in touch?</h3>
            <ul class="trust-list">
              <li>
                <div class="icon-bullet">✓</div>
                <div>
                  <strong>Senior strategists, not accounts managers</strong>
                  <p>Speak directly to professionals who execute, not relationship buffers.</p>
                </div>
              </li>
              <li>
                <div class="icon-bullet">✓</div>
                <div>
                  <strong>Ad budget optimization</strong>
                  <p>We'll screen-share your accounts and locate 3 high-impact leaks immediately.</p>
                </div>
              </li>
              <li>
                <div class="icon-bullet">✓</div>
                <div>
                  <strong>Fully dynamic reporting</strong>
                  <p>Access live dashboards with actual ROAS and customer acquisition cost figures.</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="info-card" style="margin-top: 1.5rem;">
            <h3>Corporate Contacts</h3>
            <p style="font-size: 0.9rem; color: #9CA3AF; margin-bottom: 0.75rem;">Email: <a href="mailto:hello@tangence.in" style="color:#6366F1; font-weight:600;">hello@tangence.in</a></p>
            <p style="font-size: 0.9rem; color: #9CA3AF;">Office Hours: Monday - Friday (9:00 AM - 6:00 PM IST)</p>
          </div>
        </div>

        <!-- Right Side: Interactive Form -->
        <div class="contact-form-panel">
          <div class="form-container">
            <h3>Send a Message</h3>
            <p style="font-size:0.85rem; color:#9CA3AF; margin-bottom: 1.5rem;">Fill out the brief contact details below and our team will get in touch with you.</p>
            
            <!-- Success/Error alert banners -->
            <div class="alert-banner success" id="contact-success-banner" style="display:none;">
              <div class="alert-icon">✓</div>
              <div class="alert-msg">
                <strong>Inquiry Submitted!</strong>
                <p>We have successfully received your inquiry and sent a confirmation. Our strategists will reply shortly.</p>
              </div>
            </div>

            <div class="alert-banner error" id="contact-error-banner" style="display:none;">
              <div class="alert-icon">✗</div>
              <div class="alert-msg">
                <strong>Submission Failed</strong>
                <p id="error-banner-text">Please review and correct the highlighted fields below.</p>
              </div>
            </div>

            <form id="public-contact-form" onsubmit="return false;">
              <div class="form-row">
                <div class="form-group">
                  <label for="contact-name">Full Name <span class="req">*</span></label>
                  <input type="text" id="contact-name" name="name" placeholder="John Doe" required />
                  <span class="error-msg" id="err-contact-name"></span>
                </div>
              </div>

              <div class="form-row" style="margin-top: 1rem;">
                <div class="form-group">
                  <label for="contact-email">Email Address <span class="req">*</span></label>
                  <input type="email" id="contact-email" name="email" placeholder="john@example.com" required />
                  <span class="error-msg" id="err-contact-email"></span>
                </div>
              </div>

              <div class="form-row" style="margin-top: 1rem;">
                <div class="form-group">
                  <label for="contact-subject">Inquiry Subject <span class="req">*</span></label>
                  <input type="text" id="contact-subject" name="subject" placeholder="e.g. Paid Ad Audit" required />
                  <span class="error-msg" id="err-contact-subject"></span>
                </div>
              </div>

              <div class="form-row" style="margin-top: 1rem;">
                <div class="form-group">
                  <label for="contact-message">Brief Details / Message <span class="req">*</span></label>
                  <textarea id="contact-message" name="message" rows="5" placeholder="Share your current challenges or website links..." required></textarea>
                  <span class="error-msg" id="err-contact-message"></span>
                </div>
              </div>

              <button type="submit" class="btn-submit" id="submit-contact-btn">
                <span id="btn-text">Submit Message Brief</span>
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<style>
  /* Premium Dark Section and Gradients styling */
  .contact-hero {
    background-color: #080C14;
    padding: 7rem 1.5rem 4rem 1.5rem;
    position: relative;
    overflow: hidden;
  }
  .contact-hero::after {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, rgba(99, 102, 241, 0) 70%);
    pointer-events: none;
  }
  .badge {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    background: rgba(99, 102, 241, 0.12);
    color: #6366F1;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    border-radius: 12px;
    margin-bottom: 1.25rem;
    border: 1px solid rgba(99, 102, 241, 0.2);
  }
  .contact-hero h1 {
    font-family: 'Outfit', sans-serif;
    color: #FFFFFF;
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    max-width: 800px;
    margin: 0 auto 1rem auto;
  }
  .hero-subtitle {
    font-family: 'Inter', sans-serif;
    color: #9CA3AF;
    font-size: 1.15rem;
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
  }
  .text-center {
    text-align: center;
  }

  /* Body structure */
  .contact-body-sec {
    background-color: #080C14;
    padding: 2rem 1.5rem 7rem 1.5rem;
    position: relative;
  }
  .contact-body-sec::after {
    content: '';
    position: absolute;
    bottom: -10%;
    left: -10%;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.05) 0%, rgba(16, 185, 129, 0) 70%);
    pointer-events: none;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 2.5rem;
    align-items: start;
    max-width: 1100px;
    margin: 0 auto;
  }
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  .info-card {
    background: rgba(13, 19, 33, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    backdrop-filter: blur(10px);
  }
  .info-card h3 {
    font-family: 'Outfit', sans-serif;
    color: #FFFFFF;
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
    border-left: 3px solid #6366F1;
    padding-left: 0.65rem;
  }
  .trust-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .trust-list li {
    display: flex;
    gap: 0.85rem;
  }
  .icon-bullet {
    width: 24px;
    height: 24px;
    background: rgba(16, 185, 129, 0.12);
    color: #10B981;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .trust-list strong {
    color: #FFFFFF;
    font-size: 0.95rem;
    display: block;
    margin-bottom: 0.15rem;
  }
  .trust-list p {
    color: #9CA3AF;
    font-size: 0.85rem;
    line-height: 1.4;
  }

  /* Form layouts */
  .form-container {
    background: rgba(13, 19, 33, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 2.25rem;
    box-shadow: 0 4px 25px rgba(0,0,0,0.4);
    backdrop-filter: blur(10px);
  }
  .form-container h3 {
    font-family: 'Outfit', sans-serif;
    color: #FFFFFF;
    font-size: 1.35rem;
    margin-bottom: 0.35rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .form-group label {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: #9CA3AF;
  }
  .req {
    color: #EF4444;
    margin-left: 2px;
  }
  .form-group input, .form-group textarea {
    padding: 0.75rem 1rem;
    background-color: rgba(8, 12, 20, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    color: #F3F4F6;
    font-size: 0.9rem;
    outline: none;
    transition: all 0.2s ease;
    width: 100%;
    box-sizing: border-box;
  }
  .form-group input:focus, .form-group textarea:focus {
    border-color: #6366F1;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
  }
  .error-msg {
    font-size: 0.75rem;
    color: #EF4444;
    font-weight: 500;
  }

  .btn-submit {
    width: 100%;
    padding: 0.85rem;
    background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
    border: none;
    border-radius: 8px;
    color: white;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(99,102,241,0.25);
    transition: all 0.22s ease;
    margin-top: 1.5rem;
  }
  .btn-submit:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(99,102,241,0.4);
  }
  .btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Alerts Banners */
  .alert-banner {
    display: flex;
    gap: 0.85rem;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
  }
  .alert-banner.success {
    background: rgba(16, 185, 129, 0.08);
    border: 1px solid rgba(16, 185, 129, 0.15);
    color: #34D399;
  }
  .alert-banner.success .alert-icon {
    width: 20px;
    height: 20px;
    background: rgba(16, 185, 129, 0.12);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    flex-shrink: 0;
  }
  .alert-banner.error {
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.15);
    color: #F87171;
  }
  .alert-banner.error .alert-icon {
    width: 20px;
    height: 20px;
    background: rgba(239, 68, 68, 0.12);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    flex-shrink: 0;
  }
  .alert-msg p {
    font-size: 0.78rem;
    margin-top: 0.15rem;
    opacity: 0.9;
  }
</style>

<script is:inline>
  function initContactPage() {
    const form = document.getElementById("public-contact-form");
    if (!form) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      
      const submitBtn = document.getElementById("submit-contact-btn");
      const btnText = document.getElementById("btn-text");
      const successBanner = document.getElementById("contact-success-banner");
      const errorBanner = document.getElementById("contact-error-banner");
      const errorBannerText = document.getElementById("error-banner-text");

      // Reset indicators
      successBanner.style.display = "none";
      errorBanner.style.display = "none";
      document.querySelectorAll(".error-msg").forEach(el => el.innerText = "");

      submitBtn.disabled = true;
      btnText.innerText = "Submitting Inquiry...";

      const formData = new FormData(form);

      try {
        const res = await fetch("/api/contact-submit", {
          method: "POST",
          body: formData
        });
        const result = await res.json();

        if (result.success) {
          successBanner.style.display = "flex";
          form.reset();
        } else {
          errorBanner.style.display = "flex";
          if (result.errors) {
            for (const [field, errMsg] of Object.entries(result.errors)) {
              const errorSpan = document.getElementById(`err-contact-${field}`);
              if (errorSpan) errorSpan.innerText = errMsg;
            }
          } else if (result.error) {
            errorBannerText.innerText = result.error;
          }
        }
      } catch (err) {
        errorBanner.style.display = "flex";
        errorBannerText.innerText = "Network connection failure. Please try again.";
      } finally {
        submitBtn.disabled = false;
        btnText.innerText = "Submit Message Brief";
      }
    });
  }

  // Bind init functions
  document.addEventListener("DOMContentLoaded", initContactPage);
  document.addEventListener("astro:page-load", initContactPage);
  if (document.readyState === "interactive" || document.readyState === "complete") {
    initContactPage();
  }
</script>
