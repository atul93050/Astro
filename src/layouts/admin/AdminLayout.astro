  <script is:inline>
    function initLayout() {
      // 1. Highlight Active Route Link in Sidebar
      const pathName = window.location.pathname;
      document.querySelectorAll(".sidebar-nav .nav-item").forEach(item => {
        item.classList.remove("active");
        const ind = item.querySelector(".active-indicator");
        if (ind) ind.style.display = "none";
      });

      let activeId = "nav-dashboard";
      if (pathName === "/admin" || pathName === "/admin/") {
        activeId = "nav-dashboard";
      } else if (pathName.includes("/admin/pages")) {
        activeId = "nav-pages";
      } else if (pathName.includes("/admin/section-definitions")) {
        activeId = "nav-section-defs";
      } else if (pathName.includes("/admin/sections")) {
        activeId = "nav-sections";
      } else if (pathName === "/admin/media" || pathName === "/admin/media/") {
        // If not in blog group view, show global media active
        activeId = "nav-media";
      } else if (pathName.includes("/admin/menus")) {
        activeId = "nav-menus";
      } else if (pathName.includes("/admin/seo")) {
        activeId = "nav-seo";
      } else if (pathName.includes("/admin/redirects")) {
        activeId = "nav-redirects";
      } else if (pathName.includes("/admin/settings")) {
        activeId = "nav-settings";
      } else if (pathName.includes("/admin/accounts")) {
        activeId = "nav-accounts";
      } else if (pathName.includes("/admin/contacts")) {
        activeId = "nav-contacts";
      } else if (pathName.includes("/admin/editor")) {
        activeId = "nav-pages";
      } else if (pathName === "/admin/blog" || pathName === "/admin/blog/") {
        activeId = "nav-blog-posts";
      } else if (pathName.includes("/admin/blog/create")) {
        activeId = "nav-blog-create";
      } else if (pathName.includes("/admin/blog/categories")) {
        activeId = "nav-blog-categories";
      } else if (pathName.includes("/admin/blog/tags")) {
        activeId = "nav-blog-tags";
      } else if (pathName.includes("/admin/blog/authors")) {
        activeId = "nav-blog-authors";
      } else if (pathName.includes("/admin/blog/comments")) {
        activeId = "nav-blog-comments";
      } else if (pathName.includes("/admin/blog/settings")) {
        activeId = "nav-blog-settings";
      } else if (pathName.includes("/admin/blog/edit")) {
        activeId = "nav-blog-posts";
      }
      
      const activeLink = document.getElementById(activeId);
      if (activeLink) {
        activeLink.classList.add("active");
        if (activeLink.classList.contains("nav-sub-item")) {
          const parentGroup = activeLink.closest(".nav-group");
          if (parentGroup) {
            parentGroup.classList.add("open");
          }
        } else {
          const ind = activeLink.querySelector(".active-indicator");
          if (ind) ind.style.display = "block";
        }
      }

      // 2. Mobile Sidebar Toggle Handler
      const menuBtn = document.getElementById("menu-toggle");
      const sidebar = document.getElementById("admin-sidebar");
      
      if (menuBtn && sidebar) {
        // Toggle Sidebar
        menuBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          sidebar.classList.toggle("mobile-open");
        });

        // Close sidebar on body click
        document.body.addEventListener("click", () => {
          sidebar.classList.remove("mobile-open");
        });

        // Stop propagation inside sidebar
        sidebar.addEventListener("click", (e) => {
          e.stopPropagation();
        });
      }

      // 3. Theme Toggle Switch Click Handler
      const themeBtn = document.getElementById("theme-toggle");
      if (themeBtn) {
        themeBtn.addEventListener("click", () => {
          const isLight = document.documentElement.classList.toggle("light-mode");
          localStorage.setItem("cms-theme", isLight ? "light" : "dark");
        });
      }

      // 4. Admin Session Logout Trigger
      const handleLogout = async () => {
        window.customConfirm("Are you absolutely sure you want to sign out?", async () => {
          try {
            const res = await fetch("/api/logout", { method: "POST" });
            const result = await res.json();
            if (result.success) {
              window.location.href = "/admin/login";
            }
          } catch (err) {
            window.alert("Network Error: Failed to logout");
          }
        });
      };

      const logoutBtn = document.getElementById("logout-btn");
      if (logoutBtn) {
        logoutBtn.addEventListener("click", handleLogout);
      }

      const topLogoutBtn = document.getElementById("top-logout-btn");
      if (topLogoutBtn) {
        topLogoutBtn.addEventListener("click", handleLogout);
      }

      // 5. Nav Group Toggle Handler for Blog
      const blogGroupBtn = document.getElementById("btn-group-blog");
      const blogGroup = document.getElementById("nav-group-blog");
      if (blogGroupBtn && blogGroup) {
        if (!blogGroupBtn.dataset.hasListener) {
          blogGroupBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            blogGroup.classList.toggle("open");
          });
          blogGroupBtn.dataset.hasListener = "true";
        }
      }
    }

    // Intercept native browser alert with custom modal
    window.alert = function(message) {
      const overlay = document.getElementById("global-alert-overlay");
      const msgEl = document.getElementById("global-alert-message");
      const panel = overlay ? overlay.querySelector(".confirm-modal") : null;
      if (overlay && msgEl) {
        msgEl.innerText = message;
        overlay.style.opacity = "1";
        overlay.style.pointerEvents = "auto";
        if (panel) panel.style.transform = "scale(1)";
      } else {
        console.warn("Global alert: " + message);
      }
    };

    // Asynchronous custom confirm helper using Promise & custom Modal
    let activeConfirmCallback = null;
    window.customConfirm = function(message, callback) {
      const overlay = document.getElementById("global-confirm-overlay");
      const msgEl = document.getElementById("global-confirm-message");
      const panel = overlay ? overlay.querySelector(".confirm-modal") : null;
      if (overlay && msgEl) {
        msgEl.innerText = message;
        activeConfirmCallback = callback;
        overlay.style.opacity = "1";
        overlay.style.pointerEvents = "auto";
        if (panel) panel.style.transform = "scale(1)";
      } else {
        // Fallback to native confirm if elements missing (should never happen)
        if (confirm(message) && callback) callback();
      }
    };

    // Close Modals events
    document.addEventListener("DOMContentLoaded", () => {
      // Alert Modal close
      const alertOk = document.getElementById("global-alert-ok-btn");
      const alertOverlay = document.getElementById("global-alert-overlay");
      if (alertOk && alertOverlay) {
        alertOk.addEventListener("click", () => {
          alertOverlay.style.opacity = "0";
          alertOverlay.style.pointerEvents = "none";
          const panel = alertOverlay.querySelector(".confirm-modal");
          if (panel) panel.style.transform = "scale(0.9)";
        });
      }

      // Confirm Modal close / confirm
      const confirmCancel = document.getElementById("global-confirm-cancel-btn");
      const confirmOk = document.getElementById("global-confirm-ok-btn");
      const confirmOverlay = document.getElementById("global-confirm-overlay");
      
      const hideConfirm = () => {
        if (confirmOverlay) {
          confirmOverlay.style.opacity = "0";
          confirmOverlay.style.pointerEvents = "none";
          const panel = confirmOverlay.querySelector(".confirm-modal");
          if (panel) panel.style.transform = "scale(0.9)";
        }
        activeConfirmCallback = null;
      };

      if (confirmCancel) confirmCancel.addEventListener("click", hideConfirm);
      if (confirmOk) {
        confirmOk.addEventListener("click", () => {
          if (activeConfirmCallback) activeConfirmCallback();
          hideConfirm();
        });
      }
    });

    // Initialize layout scripts onDOM ready & page-load transitions
    document.addEventListener("DOMContentLoaded", initLayout);
    document.addEventListener("astro:page-load", initLayout);
    if (document.readyState === "interactive" || document.readyState === "complete") {
      initLayout();
    }
  </script>

  <!-- Global Custom Alert Modal -->
  <div class="confirm-modal-overlay" id="global-alert-overlay" style="position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(8,12,20,0.8); backdrop-filter:blur(6px); z-index:99999; display:flex; align-items:center; justify-content:center; opacity:0; pointer-events:none; transition:opacity 0.2s ease;">
    <div class="confirm-modal" style="background:var(--bg-surface-solid, #111827); border:1px solid var(--border-color, rgba(255,255,255,0.08)); border-radius:12px; padding:2rem; width:90%; max-width:440px; box-shadow:0 20px 50px rgba(0,0,0,0.5); text-align:center; transform:scale(0.9); transition:transform 0.2s ease;">
      <div style="width:48px; height:48px; background:rgba(99,102,241,0.1); color:var(--primary, #6366F1); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1.25rem auto;">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
      </div>
      <h4 style="margin:0 0 0.75rem 0; font-family:'Outfit', sans-serif; font-size:1.15rem; font-weight:700; color:#fff;">Message</h4>
      <p id="global-alert-message" style="margin:0 0 1.5rem 0; font-size:0.875rem; color:#9ca3af; line-height:1.6; word-break:break-word; text-align:center;"></p>
      <button type="button" class="btn btn-primary" id="global-alert-ok-btn" style="width:100%; justify-content:center; padding:0.65rem 1.5rem; font-size:0.9rem; font-weight:600; border-radius:8px; background:linear-gradient(135deg, #6366F1 0%, #4F46E5 100%); color:#fff; border:none; cursor:pointer;">OK</button>
    </div>
  </div>

  <!-- Global Custom Confirm Modal -->
  <div class="confirm-modal-overlay" id="global-confirm-overlay" style="position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(8,12,20,0.8); backdrop-filter:blur(6px); z-index:99998; display:flex; align-items:center; justify-content:center; opacity:0; pointer-events:none; transition:opacity 0.2s ease;">
    <div class="confirm-modal" style="background:var(--bg-surface-solid, #111827); border:1px solid var(--border-color, rgba(255,255,255,0.08)); border-radius:12px; padding:2rem; width:90%; max-width:440px; box-shadow:0 20px 50px rgba(0,0,0,0.5); text-align:center; transform:scale(0.9); transition:transform 0.2s ease;">
      <div style="width:48px; height:48px; background:rgba(239,68,68,0.1); color:#ef4444; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1.25rem auto;">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
      </div>
      <h4 style="margin:0 0 0.75rem 0; font-family:'Outfit', sans-serif; font-size:1.15rem; font-weight:700; color:#fff;">Confirm Action</h4>
      <p id="global-confirm-message" style="margin:0 0 1.5rem 0; font-size:0.875rem; color:#9ca3af; line-height:1.6; word-break:break-word; text-align:center;"></p>
      <div style="display:flex; gap:0.75rem; justify-content:center; width:100%;">
        <button type="button" class="btn btn-outline" id="global-confirm-cancel-btn" style="flex:1; padding:0.65rem 1.5rem; font-size:0.9rem; font-weight:600; border-radius:8px; cursor:pointer;">Cancel</button>
        <button type="button" class="btn btn-primary" id="global-confirm-ok-btn" style="flex:1; padding:0.65rem 1.5rem; font-size:0.9rem; font-weight:600; border-radius:8px; background:linear-gradient(135deg, #6366F1 0%, #4F46E5 100%); color:#fff; border:none; cursor:pointer;">Confirm</button>
      </div>
    </div>
  </div>
</body>
</html>
