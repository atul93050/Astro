---
interface Props {
  title: string;
}

const { title } = Astro.props;

// Server-side Authentication gate check
const session = Astro.cookies.get("cms_session")?.value;
if (session !== "authenticated-admin-session-2026") {
  return Astro.redirect("/admin/login");
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Tangence CMS Dashboard</title>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <script is:inline>
    // Initialize Theme immediately on head parse to prevent flashing
    const theme = localStorage.getItem("cms-theme") || "dark";
    if (theme === "light") {
      document.documentElement.classList.add("light-mode");
    }
  </script>

  <style is:global>
    :root {
      --font-heading: 'Outfit', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      --font-body: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      
      /* Indigo Base Theme Palette */
      --primary: #6366F1;
      --primary-hover: #4F46E5;
      --primary-light: rgba(99, 102, 241, 0.12);
      --accent: #10B981;
      --accent-hover: #059669;
      --accent-light: rgba(16, 185, 129, 0.12);
      
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
      
      /* DARK MODE VARIABLES (Default) */
      --bg-base: #080C14;
      --bg-surface: rgba(13, 19, 33, 0.75);
      --bg-surface-solid: #0D1321;
      --bg-surface-border: rgba(255, 255, 255, 0.06);
      --text-main: #F3F4F6;
      --text-muted: #9CA3AF;
      --text-dim: #6B7280;
      --border-color: rgba(255, 255, 255, 0.06);
      --input-bg: rgba(8, 12, 20, 0.85);
      --input-border: rgba(255, 255, 255, 0.08);
      --input-border-focus: #6366F1;
      --color-shadow: rgba(0, 0, 0, 0.4);
      
      --color-success: #10B981;
      --color-error: #EF4444;
      --color-warning: #F59E0B;
      --color-info: #3B82F6;
      --glow-opacity: 0.08;
    }

    /* LIGHT MODE INJECTION RULES */
    html.light-mode {
      --bg-base: #F3F4F6;
      --bg-surface: rgba(255, 255, 255, 0.85);
      --bg-surface-solid: #FFFFFF;
      --bg-surface-border: rgba(0, 0, 0, 0.06);
      --text-main: #1F2937;
      --text-muted: #4B5563;
      --text-dim: #9CA3AF;
      --border-color: rgba(0, 0, 0, 0.06);
      --input-bg: #FFFFFF;
      --input-border: rgba(0, 0, 0, 0.12);
      --input-border-focus: #6366F1;
      --color-shadow: rgba(31, 41, 55, 0.08);
      --glow-opacity: 0.02;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--bg-base);
      color: var(--text-main);
      font-family: var(--font-body);
      min-height: 100vh;
      display: flex;
      overflow-x: hidden;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }
    ::-webkit-scrollbar-track {
      background: var(--bg-base);
    }
    ::-webkit-scrollbar-thumb {
      background: rgba(156, 163, 175, 0.2);
      border-radius: 4px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: rgba(156, 163, 175, 0.35);
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      font-weight: 600;
      letter-spacing: -0.02em;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button, input, textarea, select {
      font-family: inherit;
    }

    input[type="text"],
    input[type="number"],
    input[type="email"],
    input[type="password"],
    input[type="url"],
    input[type="search"],
    select,
    textarea {
      padding: 0.65rem 0.85rem !important;
      border-radius: var(--radius-sm) !important;
      background-color: var(--input-bg) !important;
      border: 1px solid var(--input-border) !important;
      color: var(--text-main) !important;
      font-size: 0.9rem !important;
      outline: none !important;
      transition: var(--transition) !important;
      box-sizing: border-box !important;
      height: 38px !important;
    }
    textarea {
      height: auto !important;
    }
    input[type="text"]:focus,
    input[type="number"]:focus,
    input[type="email"]:focus,
    input[type="password"]:focus,
    input[type="url"]:focus,
    input[type="search"]:focus,
    select:focus,
    textarea:focus {
      border-color: var(--primary) !important;
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15) !important;
    }
    select {
      appearance: none !important;
      -webkit-appearance: none !important;
      -moz-appearance: none !important;
      background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%239ca3af' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e") !important;
      background-repeat: no-repeat !important;
      background-position: right 0.85rem center !important;
      background-size: 0.85em !important;
      padding-right: 2.25rem !important;
      cursor: pointer;
    }
    input[type="checkbox"] {
      appearance: none !important;
      -webkit-appearance: none !important;
      -moz-appearance: none !important;
      width: 18px !important;
      height: 18px !important;
      border: 1.5px solid var(--input-border) !important;
      border-radius: 4px !important;
      background-color: var(--input-bg) !important;
      cursor: pointer;
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
      transition: var(--transition) !important;
      position: relative;
      vertical-align: middle;
    }
    input[type="checkbox"]:checked {
      background-color: var(--primary) !important;
      border-color: var(--primary) !important;
    }
    input[type="checkbox"]:checked::after {
      content: "" !important;
      width: 4px !important;
      height: 8px !important;
      border: solid white !important;
      border-width: 0 2px 2px 0 !important;
      transform: rotate(45deg) !important;
      margin-bottom: 2px !important;
    }
    input[type="checkbox"]:focus {
      outline: none !important;
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2) !important;
    }

    /* Form labels, validation errors, and helper texts */
    label {
      font-size: 0.825rem !important;
      font-weight: 600 !important;
      color: var(--text-muted) !important;
      margin-bottom: 0.35rem !important;
      display: inline-block !important;
    }
    .field-help {
      font-size: 0.72rem !important;
      color: var(--text-dim) !important;
      margin-top: 0.25rem !important;
      display: block !important;
    }
    .field-error, .field-err {
      font-size: 0.74rem !important;
      color: var(--color-error) !important;
      margin-top: 0.25rem !important;
      display: block !important;
      min-height: 1.1em !important;
    }

     /* Unified Media Catalog Selector Modal Grid styling */
    .media-picker-grid {
      display: grid !important;
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)) !important;
      gap: 0.75rem !important;
      padding: 0.5rem !important;
      background: var(--bg-base) !important;
      border: 1px solid var(--border-color) !important;
      border-radius: var(--radius-sm) !important;
      overflow-x: hidden !important;
    }
    .media-picker-item {
      aspect-ratio: 1 !important;
      height: 100px !important;
      border-radius: 6px !important;
      overflow: hidden !important;
      border: 2px solid transparent !important;
      cursor: pointer !important;
      position: relative !important;
      background: rgba(156, 163, 175, 0.03) !important;
      transition: var(--transition) !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      width: 100% !important;
      box-sizing: border-box !important;
    }
    .media-picker-item:hover {
      transform: scale(1.03) !important;
      border-color: var(--primary) !important;
    }
    .media-picker-item.selected {
      border-color: var(--accent) !important;
    }
    .media-picker-item img {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
    }
    .media-empty {
      grid-column: span 12 !important;
      text-align: center !important;
      padding: 2.5rem !important;
      color: var(--text-dim) !important;
      font-size: 0.85rem !important;
    }

    /* Global Modal Overlay styling */
    .confirm-modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: rgba(8, 12, 20, 0.75);
      backdrop-filter: blur(8px);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease;
    }
    .confirm-modal-overlay.active {
      opacity: 1;
      pointer-events: auto;
    }
    .confirm-modal {
      background: var(--bg-surface-solid);
      border: 1px solid var(--bg-surface-border);
      border-radius: var(--radius-lg);
      width: 100%;
      max-width: 500px;
      padding: 1.75rem;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
      transform: scale(0.9);
      transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .confirm-modal-overlay.active .confirm-modal {
      transform: scale(1);
    }
    .confirm-modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.25rem;
    }
    .confirm-modal-header h4 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-main);
    }
    .confirm-modal-body {
      font-size: 0.92rem;
      color: var(--text-muted);
      line-height: 1.5;
      margin-bottom: 1.5rem;
    }
    .confirm-modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 0.75rem;
      border-top: 1px solid var(--bg-surface-border);
      padding-top: 1.15rem;
    }
    .close-modal-btn {
      background: transparent;
      border: none;
      color: var(--text-muted);
      cursor: pointer;
      padding: 0.25rem;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: var(--transition);
    }
    .close-modal-btn:hover {
      color: var(--text-main);
      background: rgba(156, 163, 175, 0.08);
    }
    .warning-text {
      background: rgba(245, 158, 11, 0.08);
      border: 1px solid rgba(245, 158, 11, 0.2);
      border-radius: 6px;
      padding: 0.85rem;
      margin-top: 1rem;
      font-size: 0.85rem;
    }
    .warning-text strong {
      color: #F59E0B;
    }
    /* Preview device simulation wrappers */
    .preview-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(8, 12, 20, 0.8);
      backdrop-filter: blur(10px);
      z-index: 3000;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.22s ease;
    }
    .preview-overlay.active {
      opacity: 1;
      pointer-events: auto;
    }
    .preview-modal-wrap {
      width: 90vw;
      height: 90vh;
      background: var(--bg-surface-solid);
      border: 1px solid var(--bg-surface-border);
      border-radius: var(--radius-lg);
      box-shadow: 0 15px 40px rgba(0,0,0,0.5);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .preview-modal-top {
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--bg-surface-border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(156,163,175,0.015);
    }
    .preview-modal-title h4 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-main);
    }
    .preview-device-selectors {
      display: flex;
      gap: 0.25rem;
      background: var(--bg-base);
      padding: 0.25rem;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border-color);
    }
    .device-btn {
      padding: 0.35rem 0.85rem;
      border: none;
      background: transparent;
      color: var(--text-muted);
      font-size: 0.8rem;
      font-weight: 600;
      border-radius: 4px;
      cursor: pointer;
      transition: var(--transition);
    }
    .device-btn.active {
      background: var(--bg-surface);
      color: var(--primary);
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }
    .preview-modal-body-frame {
      flex: 1;
      background: #05080E;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      overflow: hidden;
    }
    .device-viewport {
      height: 100%;
      transition: width 0.3s ease;
      border-radius: 12px;
      border: 8px solid #1C2333;
      background: white;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    .device-viewport.desktop {
      width: 100%;
      max-width: 1200px;
    }
    .device-viewport.tablet {
      width: 768px;
    }
    .device-viewport.mobile {
      width: 375px;
    }
    .device-viewport iframe {
      width: 100%;
      height: 100%;
      border: none;
      background: white;
    }
    /* Unified Button Styles */
    .btn {
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
      gap: 0.5rem !important;
      padding: 0 1.25rem !important;
      height: 38px !important;
      border-radius: var(--radius-sm) !important;
      font-size: 0.875rem !important;
      font-weight: 600 !important;
      cursor: pointer !important;
      transition: var(--transition) !important;
      border: 1px solid transparent !important;
      text-align: center !important;
      white-space: nowrap !important;
      user-select: none !important;
      vertical-align: middle !important;
      box-sizing: border-box !important;
      outline: none !important;
    }

    .btn:hover {
      transform: translateY(-1px) !important;
    }

    .btn:active {
      transform: translateY(0) !important;
    }

    .btn:focus-visible {
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.4) !important;
    }

    .btn:disabled {
      opacity: 0.6 !important;
      cursor: not-allowed !important;
      pointer-events: none !important;
      box-shadow: none !important;
      transform: none !important;
    }

    .btn svg {
      width: 16px !important;
      height: 16px !important;
      flex-shrink: 0 !important;
      display: inline-block !important;
      vertical-align: middle !important;
      pointer-events: none !important;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--primary) 0%, #4f46e5 100%) !important;
      color: white !important;
      box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2) !important;
    }

    .btn-primary:hover {
      box-shadow: 0 6px 16px rgba(99, 102, 241, 0.35) !important;
    }

    .btn-outline {
      background: transparent !important;
      border: 1px solid var(--border-color) !important;
      color: var(--text-main) !important;
    }

    .btn-outline:hover {
      background: rgba(156, 163, 175, 0.08) !important;
      border-color: var(--text-muted) !important;
    }

    .btn-danger {
      background-color: var(--color-error) !important;
      color: white !important;
    }

    .btn-danger:hover {
      background-color: #DC2626 !important;
    }

    .btn-sm {
      height: 30px !important;
      padding: 0 0.85rem !important;
      font-size: 0.8rem !important;
    }

    /* Standardized Action Icon Buttons */
    .btn-action,
    .btn-action-sm {
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
      border-radius: var(--radius-sm) !important;
      background: transparent !important;
      border: 1px solid var(--border-color) !important;
      color: var(--text-muted) !important;
      cursor: pointer !important;
      transition: var(--transition) !important;
      box-sizing: border-box !important;
      flex-shrink: 0 !important;
    }
    .btn-action {
      width: 32px !important;
      height: 32px !important;
    }
    .btn-action-sm {
      width: 28px !important;
      height: 28px !important;
      border-radius: 4px !important;
    }
    .btn-action:hover,
    .btn-action-sm:hover {
      color: var(--text-main) !important;
      background: rgba(156, 163, 175, 0.08) !important;
      border-color: var(--text-muted) !important;
    }
    .btn-action:focus-visible,
    .btn-action-sm:focus-visible {
      outline: none !important;
      box-shadow: 0 0 0 2px var(--primary) !important;
    }
    .btn-action:disabled,
    .btn-action-sm:disabled {
      opacity: 0.35 !important;
      cursor: not-allowed !important;
      pointer-events: none !important;
    }
    .btn-action svg,
    .btn-action-sm svg {
      width: 15px !important;
      height: 15px !important;
      pointer-events: none !important;
    }
    .btn-action-sm svg {
      width: 13px !important;
      height: 13px !important;
    }
    
    /* Specific overrides for actions */
    .btn-action.delete-btn:hover,
    .btn-action-sm.btn-delete-node:hover,
    .btn-delete-block:hover {
      color: var(--color-error) !important;
      background: rgba(239, 68, 68, 0.08) !important;
      border-color: var(--color-error) !important;
    }
    .btn-action.edit-btn:hover {
      color: var(--primary) !important;
      background: var(--primary-light) !important;
      border-color: var(--primary) !important;
    }

    /* Dynamic listing table styles */
    .admin-table-wrapper {
      width: 100%;
      overflow-x: auto;
      background: var(--bg-surface);
      border: 1px solid var(--bg-surface-border);
      border-radius: var(--radius-lg);
      box-shadow: 0 4px 20px var(--color-shadow);
      backdrop-filter: blur(12px);
    }

    .admin-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    .admin-table th {
      background: rgba(156, 163, 175, 0.03);
      padding: 1.15rem 1.5rem;
      font-family: var(--font-heading);
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-dim);
      border-bottom: 1px solid var(--bg-surface-border);
    }

    .admin-table td {
      padding: 1.15rem 1.5rem;
      font-size: 0.92rem;
      border-bottom: 1px solid var(--bg-surface-border);
      color: var(--text-main);
    }

    .admin-table tr:last-child td {
      border-bottom: none;
    }

    .admin-table tr:hover td {
      background: rgba(156, 163, 175, 0.015);
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.25rem 0.65rem;
      border-radius: 12px;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .status-badge.published {
      background-color: rgba(16, 185, 129, 0.12);
      color: #10B981;
      border: 1px solid rgba(16, 185, 129, 0.15);
    }

    .status-badge.draft {
      background-color: rgba(245, 158, 11, 0.12);
      color: #F59E0B;
      border: 1px solid rgba(245, 158, 11, 0.15);
    }

    /* Global Toast Notification styling */
    .toast-notification {
      position: fixed !important;
      bottom: 2rem !important;
      right: 2rem !important;
      background: var(--bg-surface-solid) !important;
      border-left: 4px solid var(--primary) !important;
      border-top: 1px solid var(--bg-surface-border) !important;
      border-bottom: 1px solid var(--bg-surface-border) !important;
      border-right: 1px solid var(--bg-surface-border) !important;
      padding: 1rem 1.5rem !important;
      border-radius: var(--radius-sm) !important;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.35) !important;
      z-index: 1100 !important;
      transform: translateY(150%) !important;
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1) !important;
      backdrop-filter: blur(8px) !important;
      opacity: 0 !important;
    }
    .toast-notification.active,
    .toast-notification.visible {
      transform: translateY(0) !important;
      opacity: 1 !important;
    }
    .toast-content {
      font-size: 0.9rem !important;
      font-weight: 500 !important;
      color: var(--text-main) !important;
    }

    /* Collapsible Navigation Groups for Blog */
    .nav-group {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }
    .nav-group-header {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding: 0.75rem 0.85rem;
      border-radius: var(--radius-sm);
      color: var(--text-muted);
      font-size: 0.9rem;
      font-weight: 500;
      transition: var(--transition);
      background: transparent;
      border: none;
      width: 100%;
      text-align: left;
      cursor: pointer;
      position: relative;
    }
    .nav-group-header:hover {
      color: var(--text-main);
      background-color: rgba(156, 163, 175, 0.05);
    }
    .nav-group-header .chevron-icon {
      margin-left: auto;
      transition: transform 0.2s ease;
      color: var(--text-dim);
    }
    .nav-group.open .nav-group-header .chevron-icon {
      transform: rotate(180deg);
    }
    .nav-group-items {
      display: none;
      flex-direction: column;
      gap: 0.25rem;
      padding-left: 1.25rem;
      border-left: 1px solid var(--border-color);
      margin-left: 1.65rem;
      margin-top: 0.25rem;
      margin-bottom: 0.5rem;
    }
    .nav-group.open .nav-group-items {
      display: flex;
    }
    .nav-sub-item {
