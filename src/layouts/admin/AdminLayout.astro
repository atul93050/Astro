---
interface Props {
  title: string;
}

const { title } = Astro.props;

// Server-side Authentication gate check
const session = Astro.cookies.get("cms_session")?.value;
if (session !== "authenticated-admin-session-2026") {
  return Astro.redirect("/admin/login");
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Tangence CMS Dashboard</title>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <script is:inline>
    // Initialize Theme immediately on head parse to prevent flashing
    const theme = localStorage.getItem("cms-theme") || "dark";
    if (theme === "light") {
      document.documentElement.classList.add("light-mode");
    }
  </script>

  <style is:global>
    :root {
      --font-heading: 'Outfit', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      --font-body: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      
      /* Indigo Base Theme Palette */
      --primary: #6366F1;
      --primary-hover: #4F46E5;
      --primary-light: rgba(99, 102, 241, 0.12);
      --accent: #10B981;
      --accent-hover: #059669;
      --accent-light: rgba(16, 185, 129, 0.12);
      
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
      
      /* DARK MODE VARIABLES (Default) */
      --bg-base: #080C14;
      --bg-surface: rgba(13, 19, 33, 0.75);
      --bg-surface-solid: #0D1321;
      --bg-surface-border: rgba(255, 255, 255, 0.06);
      --text-main: #F3F4F6;
      --text-muted: #9CA3AF;
      --text-dim: #6B7280;
      --border-color: rgba(255, 255, 255, 0.06);
      --input-bg: rgba(8, 12, 20, 0.85);
      --input-border: rgba(255, 255, 255, 0.08);
      --input-border-focus: #6366F1;
      --color-shadow: rgba(0, 0, 0, 0.4);
      
      --color-success: #10B981;
      --color-error: #EF4444;
      --color-warning: #F59E0B;
      --color-info: #3B82F6;
      --glow-opacity: 0.08;
    }

    /* LIGHT MODE INJECTION RULES */
    html.light-mode {
      --bg-base: #F3F4F6;
      --bg-surface: rgba(255, 255, 255, 0.85);
      --bg-surface-solid: #FFFFFF;
      --bg-surface-border: rgba(0, 0, 0, 0.06);
      --text-main: #1F2937;
      --text-muted: #4B5563;
      --text-dim: #9CA3AF;
      --border-color: rgba(0, 0, 0, 0.06);
      --input-bg: #FFFFFF;
      --input-border: rgba(0, 0, 0, 0.12);
      --input-border-focus: #6366F1;
      --color-shadow: rgba(31, 41, 55, 0.08);
      --glow-opacity: 0.02;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--bg-base);
      color: var(--text-main);
      font-family: var(--font-body);
      min-height: 100vh;
      display: flex;
      overflow-x: hidden;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }
    ::-webkit-scrollbar-track {
      background: var(--bg-base);
    }
    ::-webkit-scrollbar-thumb {
      background: rgba(156, 163, 175, 0.2);
      border-radius: 4px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: rgba(156, 163, 175, 0.35);
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      font-weight: 600;
      letter-spacing: -0.02em;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button, input, textarea, select {
      font-family: inherit;
    }

    /* Common layout styling */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.65rem 1.25rem;
      border-radius: var(--radius-sm);
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
      border: none;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--primary) 0%, #4f46e5 100%);
      color: white;
      box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
    }

    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 16px rgba(99, 102, 241, 0.35);
    }

    .btn-outline {
      background: transparent;
      border: 1px solid var(--border-color);
      color: var(--text-main);
    }

    .btn-outline:hover {
      background: rgba(156, 163, 175, 0.08);
      border-color: var(--text-muted);
    }

    .btn-danger {
      background-color: var(--color-error);
      color: white;
    }

    .btn-danger:hover {
      background-color: #DC2626;
    }

    .btn-sm {
      padding: 0.4rem 0.85rem;
      font-size: 0.8rem;
    }

    /* Dynamic listing table styles */
    .admin-table-wrapper {
      width: 100%;
      overflow-x: auto;
      background: var(--bg-surface);
      border: 1px solid var(--bg-surface-border);
      border-radius: var(--radius-lg);
      box-shadow: 0 4px 20px var(--color-shadow);
      backdrop-filter: blur(12px);
    }

    .admin-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    .admin-table th {
      background: rgba(156, 163, 175, 0.03);
      padding: 1.15rem 1.5rem;
      font-family: var(--font-heading);
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-dim);
      border-bottom: 1px solid var(--bg-surface-border);
    }

    .admin-table td {
      padding: 1.15rem 1.5rem;
      font-size: 0.92rem;
      border-bottom: 1px solid var(--bg-surface-border);
      color: var(--text-main);
    }

    .admin-table tr:last-child td {
      border-bottom: none;
    }

    .admin-table tr:hover td {
      background: rgba(156, 163, 175, 0.015);
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.25rem 0.65rem;
      border-radius: 12px;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .status-badge.published {
      background-color: rgba(16, 185, 129, 0.12);
      color: #10B981;
      border: 1px solid rgba(16, 185, 129, 0.15);
    }

    .status-badge.draft {
      background-color: rgba(245, 158, 11, 0.12);
      color: #F59E0B;
      border: 1px solid rgba(245, 158, 11, 0.15);
    }
  </style>

  <style>
    .admin-container {
      display: flex;
      width: 100%;
      min-height: 100vh;
      position: relative;
    }

    /* Interactive Sidebar Navigation */
    .sidebar {
      width: 270px;
      height: 100vh;
      background-color: var(--bg-surface-solid);
      border-right: 1px solid var(--bg-surface-border);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0;
      left: 0;
      z-index: 100;
      transition: transform 0.3s ease, background-color 0.3s ease;
    }

    .sidebar-brand {
      padding: 1.75rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      border-bottom: 1px solid var(--bg-surface-border);
    }

    .brand-logo {
      width: 36px;
      height: 36px;
      background: linear-gradient(135deg, var(--primary) 0%, #a855f7 100%);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: 1.35rem;
      color: white;
      box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
    }

    .brand-text h2 {
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--text-main);
    }

    .brand-text span {
      font-size: 0.72rem;
      color: var(--text-dim);
      display: block;
      margin-top: -1px;
    }

    .sidebar-nav {
      flex: 1;
      padding: 1.5rem 0.85rem;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    .nav-section-title {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-dim);
      margin-top: 1.25rem;
      margin-bottom: 0.4rem;
      padding-left: 0.75rem;
    }

    .nav-section-title:first-of-type {
      margin-top: 0;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding: 0.75rem 0.85rem;
      border-radius: var(--radius-sm);
      color: var(--text-muted);
      font-size: 0.9rem;
      font-weight: 500;
      transition: var(--transition);
      position: relative;
    }

    .nav-item:hover {
      color: var(--text-main);
      background-color: rgba(156, 163, 175, 0.05);
    }

    .nav-item.active {
      color: white;
      background-color: var(--primary-light);
      font-weight: 600;
    }

    html.light-mode .nav-item.active {
      color: var(--primary);
    }

    .active-indicator {
      position: absolute;
      left: 0;
      top: 20%;
      bottom: 20%;
      width: 3px;
      background-color: var(--primary);
      border-radius: 0 4px 4px 0;
    }

    .sidebar-footer {
      padding: 1.25rem 1.5rem;
      border-top: 1px solid var(--bg-surface-border);
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .user-avatar {
      width: 38px;
      height: 38px;
      background-color: rgba(156, 163, 175, 0.06);
      border: 1px solid var(--border-color);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-heading);
      font-weight: 600;
      color: var(--text-main);
      font-size: 0.85rem;
    }

    .user-info h4 {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-main);
    }

    .user-info span {
      font-size: 0.7rem;
      color: var(--text-dim);
    }

    /* Main Area Router & Top bar navigation */
    .main-content {
      flex: 1;
      padding: 1.75rem 2.5rem 3rem 2.5rem;
      margin-left: 270px;
      min-width: 0;
      position: relative;
      transition: margin-left 0.3s ease;
    }

    .top-navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--bg-surface-border);
      margin-bottom: 2rem;
    }

    .top-title h2 {
      font-size: 1.4rem;
      color: var(--text-main);
      font-weight: 700;
    }

    .top-controls {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    /* Theme Switcher Button */
    .theme-toggle-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--bg-surface);
      border: 1px solid var(--bg-surface-border);
      color: var(--text-main);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: var(--transition);
    }

    .theme-toggle-btn:hover {
      background: rgba(156, 163, 175, 0.08);
      border-color: var(--text-muted);
      transform: scale(1.05);
    }

    .theme-toggle-btn .sun-icon {
      display: none;
    }

    .theme-toggle-btn .moon-icon {
      display: block;
    }

    html.light-mode .theme-toggle-btn .sun-icon {
      display: block;
    }

    html.light-mode .theme-toggle-btn .moon-icon {
      display: none;
    }

    /* Mobile hamburger menu toggle */
    .mobile-menu-toggle {
      display: none;
      width: 40px;
      height: 40px;
      background: var(--bg-surface-solid);
      border: 1px solid var(--bg-surface-border);
      border-radius: 8px;
      color: var(--text-main);
      align-items: center;
      justify-content: center;
      cursor: pointer;
      position: fixed;
      top: 1rem;
      left: 1rem;
      z-index: 101;
      transition: var(--transition);
    }

    /* Ambient background glows */
    .ambient-glow-1 {
      position: fixed;
      top: -10%;
      right: -10%;
      width: 600px;
      height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(99, 102, 241, var(--glow-opacity)) 0%, rgba(99, 102, 241, 0) 70%);
      z-index: -1;
      pointer-events: none;
      transition: background 0.3s ease;
    }

    .ambient-glow-2 {
      position: fixed;
      bottom: -10%;
      left: 10%;
      width: 600px;
      height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(16, 185, 129, var(--glow-opacity)) 0%, rgba(16, 185, 129, 0) 70%);
      z-index: -1;
      pointer-events: none;
      transition: background 0.3s ease;
    }

    /* Responsive grid styles */
    @media (max-width: 1024px) {
      .main-content {
        padding: 2rem 1.5rem;
      }
    }

    @media (max-width: 768px) {
      .sidebar {
        transform: translateX(-100%);
      }
      
      .sidebar.mobile-open {
        transform: translateX(0);
      }

      .main-content {
        margin-left: 0;
        padding-top: 5rem;
      }

      .mobile-menu-toggle {
        display: flex;
      }
    }
  </style>
</head>
<body>
  <div class="ambient-glow-1"></div>
  <div class="ambient-glow-2"></div>

  <!-- Mobile Hamburger Menu Button -->
  <button class="mobile-menu-toggle" id="menu-toggle" aria-label="Toggle Sidebar">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
  </button>

  <div class="admin-container">
    
    <!-- Sidebar Navigation -->
    <aside class="sidebar" id="admin-sidebar">
      <div class="sidebar-brand">
        <div class="brand-logo">T</div>
        <div class="brand-text">
          <h2>Tangence</h2>
          <span>CMS Panel v2.0</span>
        </div>
      </div>

      <nav class="sidebar-nav">
        <span class="nav-section-title">Manage Content</span>
        
        <a href="/admin" class="nav-item" id="nav-pages">
          <svg class="nav-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          <span>All Pages</span>
          <div class="active-indicator" style="display:none;"></div>
        </a>

        <a href="/admin/media" class="nav-item" id="nav-media">
          <svg class="nav-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
          <span>Media Library</span>
          <div class="active-indicator" style="display:none;"></div>
        </a>

        <a href="/admin/contacts" class="nav-item" id="nav-contacts">
          <svg class="nav-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          <span>Contacts Inbox</span>
          <div class="active-indicator" style="display:none;"></div>
        </a>

        <span class="nav-section-title">Settings</span>

        <a href="/admin/settings" class="nav-item" id="nav-settings">
          <svg class="nav-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
          <span>Global Settings</span>
          <div class="active-indicator" style="display:none;"></div>
        </a>

        <a href="/" class="nav-item external-link">
          <svg class="nav-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
          <span>View Website</span>
        </a>

        <button type="button" class="nav-item" id="logout-btn" style="background:transparent; border:none; width:calc(100% - 1.7rem); text-align:left; cursor:pointer; font-family:inherit;">
          <svg class="nav-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          <span>Sign Out</span>
        </button>
      </nav>

      <div class="sidebar-footer">
        <div class="user-avatar">AV</div>
        <div class="user-info">
          <h4>Atul Verma</h4>
          <span>Administrator</span>
        </div>
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="main-content">
      
      <!-- Top Navigation bar -->
      <nav class="top-navbar">
        <div class="top-title">
          <h2>{title}</h2>
        </div>
        <div class="top-controls">
          <!-- Premium Light/Dark Theme Switcher button -->
          <button class="theme-toggle-btn" id="theme-toggle" aria-label="Toggle Theme">
            <svg class="sun-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg class="moon-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
          
          <div class="user-avatar" style="width:36px;height:36px;">AV</div>
        </div>
      </nav>

      <!-- Slot injection -->
      <slot />

    </main>

  </div>

  <!-- Responsive Interactivity & Active Highlight JS -->
  <script is:inline>
    function initLayout() {
      // 1. Highlight Active Route Link in Sidebar
      const pathName = window.location.pathname;
      document.querySelectorAll(".sidebar-nav .nav-item").forEach(item => {
        item.classList.remove("active");
        item.querySelector(".active-indicator").style.display = "none";
      });

      let activeId = "nav-pages";
      if (pathName.includes("/admin/media")) {
        activeId = "nav-media";
      } else if (pathName.includes("/admin/contacts")) {
        activeId = "nav-contacts";
      } else if (pathName.includes("/admin/settings")) {
        activeId = "nav-settings";
      } else if (pathName !== "/admin" && pathName.startsWith("/admin/")) {
        activeId = "nav-pages"; // Page Editor belongs to Pages section
      }
      
      const activeLink = document.getElementById(activeId);
      if (activeLink) {
        activeLink.classList.add("active");
        activeLink.querySelector(".active-indicator").style.display = "block";
      }

      // 2. Mobile Sidebar Toggle Handler
      const menuBtn = document.getElementById("menu-toggle");
      const sidebar = document.getElementById("admin-sidebar");
      
      if (menuBtn && sidebar) {
        // Toggle Sidebar
        menuBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          sidebar.classList.toggle("mobile-open");
        });

        // Close sidebar on body click
        document.body.addEventListener("click", () => {
          sidebar.classList.remove("mobile-open");
        });

        // Stop propagation inside sidebar
        sidebar.addEventListener("click", (e) => {
          e.stopPropagation();
        });
      }

      // 3. Theme Toggle Switch Click Handler
      const themeBtn = document.getElementById("theme-toggle");
      if (themeBtn) {
        themeBtn.addEventListener("click", () => {
          const isLight = document.documentElement.classList.toggle("light-mode");
          localStorage.setItem("cms-theme", isLight ? "light" : "dark");
        });
      }

      // 4. Admin Session Logout Trigger
      const logoutBtn = document.getElementById("logout-btn");
      if (logoutBtn) {
        logoutBtn.addEventListener("click", async () => {
          if (confirm("Are you absolutely sure you want to sign out?")) {
            try {
              const res = await fetch("/api/logout", { method: "POST" });
              const result = await res.json();
              if (result.success) {
                window.location.href = "/admin/login";
              }
            } catch (err) {
              alert("Network Error: Failed to logout");
            }
          }
        });
      }
    }

    // Initialize layout scripts onDOM ready & page-load transitions
    document.addEventListener("DOMContentLoaded", initLayout);
    document.addEventListener("astro:page-load", initLayout);
    if (document.readyState === "interactive" || document.readyState === "complete") {
      initLayout();
    }
  </script>
</body>
</html>
