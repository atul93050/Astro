---
interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  robots?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  twitterCard?: string;
  schemaMarkup?: string;
  pageStyleUrl?: string;
  // Page Specific Scripts
  headerScripts?: string;
  footerScripts?: string;
  customCss?: string;
  customJs?: string;
  sectionScripts?: string[];
}

const {
  title,
  description = "",
  canonicalUrl = "",
  robots = "index, follow",
  ogTitle = "",
  ogDescription = "",
  ogImage = "",
  ogType = "website",
  twitterCard = "summary_large_image",
  schemaMarkup = "",
  pageStyleUrl = "",
  headerScripts: pageHeaderScripts = "",
  footerScripts: pageFooterScripts = "",
  customCss = "",
  customJs = "",
  sectionScripts = [],
} = Astro.props;

import { ClientRouter } from "astro:transitions";
import fs from "node:fs";
import path from "node:path";

// Load global settings
let globalSettings = {
  headerScripts: "",
  bodyStartScripts: "",
  bodyEndScripts: "",
  footerScripts: "",
};
try {
  const settingsPath = path.resolve("src/data/global-settings.json");
  if (fs.existsSync(settingsPath)) {
    globalSettings = {
      ...globalSettings,
      ...JSON.parse(fs.readFileSync(settingsPath, "utf-8")),
    };
  }
} catch (e) {
  // Graceful fallback
}

// Build sitewide Organization JSON-LD from global settings
const SITE = "https://www.tangence.in";
const gs: any = globalSettings;
const absUrl = (u: string) =>
  u && u.startsWith("http") ? u : `${SITE}${u || ""}`;
const orgSameAs = Object.values(gs.socialLinks || {}).filter(
  (v: any) => typeof v === "string" && v.trim(),
);
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Tangence",
  url: SITE,
  ...(gs.logo?.headerLogoUrl ? { logo: absUrl(gs.logo.headerLogoUrl) } : {}),
  ...(gs.contactInfo?.description
    ? { description: gs.contactInfo.description }
    : {}),
  ...(gs.contactInfo?.phone ? { telephone: gs.contactInfo.phone } : {}),
  ...(gs.contactInfo?.email ? { email: gs.contactInfo.email } : {}),
  ...(orgSameAs.length ? { sameAs: orgSameAs } : {}),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />

    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    <!-- Open Graph Tags -->
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={ogDescription || description} />
    {
      ogImage && (
        <meta
          property="og:image"
          content={
            ogImage.startsWith("http")
              ? ogImage
              : `https://www.tangence.in${ogImage}`
          }
        />
      )
    }
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Tangence" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={ogTitle || title} />
    <meta name="twitter:description" content={ogDescription || description} />
    {
      ogImage && (
        <meta
          name="twitter:image"
          content={
            ogImage.startsWith("http")
              ? ogImage
              : `https://www.tangence.in${ogImage}`
          }
        />
      )
    }

    <!-- Bootstrap CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC"
      crossorigin="anonymous"
    />

    <!-- Font Awesome v6 -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />

    <!-- Slick Carousel CSS -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css"
    />

    <!-- EWAC Custom Fonts & CSS -->
    <link href="/assets/fonts/fonts.css" rel="stylesheet" />
    <link href="/assets/css/main.css" rel="stylesheet" />

    <!-- Centralized per-page stylesheet (src/styles/pages/<slug>.css) -->
    {pageStyleUrl && <link rel="stylesheet" href={pageStyleUrl} />}

    <!-- Sitewide Organization Schema -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(organizationSchema)}
    />

    <!-- Custom Schema Markup Injection (page/post specific) -->
    {
      schemaMarkup && (
        <script type="application/ld+json" is:inline set:html={schemaMarkup} />
      )
    }

    <!-- Global Head Script Injection -->
    {
      globalSettings.headerScripts && (
        <Fragment set:html={globalSettings.headerScripts} />
      )
    }

    <!-- Page Specific Head Script Injection -->
    {pageHeaderScripts && <Fragment set:html={pageHeaderScripts} />}

    <!-- Page Specific Custom CSS Injection -->
    {customCss && <style is:inline set:html={customCss} />}

    <ClientRouter />
  </head>

  <body>
    <!-- Global Body Start Script Injection -->
    {
      globalSettings.bodyStartScripts && (
        <Fragment set:html={globalSettings.bodyStartScripts} />
      )
    }

    <slot />

    <script is:inline defer src="/js/new-lp-page.js"></script>

    <!-- Global Body End Script Injection -->
    {
      globalSettings.bodyEndScripts && (
        <Fragment set:html={globalSettings.bodyEndScripts} />
      )
    }

    <!-- Global Footer Script Injection -->
    {
      globalSettings.footerScripts && (
        <Fragment set:html={globalSettings.footerScripts} />
      )
    }

    <!-- Page Specific Footer Script Injection -->
    {pageFooterScripts && <Fragment set:html={pageFooterScripts} />}

    <!-- Page Specific Custom JavaScript Injection -->
    {customJs && <script is:inline set:html={customJs} />}
    <!-- jQuery and Slick Slider JS -->
    <script is:inline src="https://code.jquery.com/jquery-3.7.1.min.js"
    ></script>
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"
    ></script>
    <!-- GSAP & ScrollTrigger -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"
    ></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"
    ></script>

    <!-- Mobile Menu and Mega Menu JS -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        // Mega dropdown को सही स्थिति (left offset) पर रखने के लिए
        function setNavOffset() {
          var nav = document.querySelector(".nav");
          if (!nav) return;
          var rect = nav.getBoundingClientRect();
          document.documentElement.style.setProperty(
            "--nav-offset",
            rect.left + "px",
          );
        }
        window.addEventListener("resize", setNavOffset);
        setNavOffset();

        // मोबाइल मेनू ओपन/क्लोज लॉजिक
        const mobileMenu = document.getElementById("mobileMenu");
        const overlay = document.getElementById("overlay");
        const openMenuBtn = document.getElementById("openMenu");
        const closeMenuBtn = document.getElementById("closeMenu");

        if (openMenuBtn) {
          openMenuBtn.onclick = () => {
            mobileMenu?.classList.add("active");
            overlay?.classList.add("active");
          };
        }

        function closeMenu() {
          mobileMenu?.classList.remove("active");
          overlay?.classList.remove("active");
        }

        if (closeMenuBtn) closeMenuBtn.onclick = closeMenu;
        if (overlay) overlay.onclick = closeMenu;

        // मोबाइल सब-मेनू टॉगल (Accordion)
        document.querySelectorAll(".has-submenu > a").forEach((link) => {
          link.addEventListener("click", function (e) {
            e.preventDefault();
            const parent = this.parentElement;
            const siblings = parent.parentElement.children;

            Array.from(siblings).forEach((item) => {
              if (item !== parent) {
                item.classList.remove("active");
                item.querySelectorAll(".has-submenu").forEach((inner) => {
                  inner.classList.remove("active");
                });
              }
            });
            parent.classList.toggle("active");
          });
        });

        // स्क्रॉल करने पर मेगा-ड्रॉपडाउन को छिपाना
        window.addEventListener("scroll", function () {
          var megas = document.querySelectorAll(".dropdown.dropdown-mega");
          if (window.scrollY > 50) {
            megas.forEach(function (el) {
              el.style.display = "none";
            });
          } else {
            megas.forEach(function (el) {
              el.style.display = "";
            });
          }
        });
      });
      
    </script>
    <!-- Section Specific Scripts -->
    {sectionScripts.map((src) => (
      <script is:inline src={src} defer></script>
    ))}
  </body>
</html>
