---
interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  robots?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  twitterCard?: string;
  schemaMarkup?: string;
  // Page Specific Scripts
  headerScripts?: string;
  footerScripts?: string;
  customCss?: string;
  customJs?: string;
}

const {
  title,
  description = '',
  canonicalUrl = '',
  robots = 'index, follow',
  ogTitle = '',
  ogDescription = '',
  ogImage = '',
  twitterCard = 'summary_large_image',
  schemaMarkup = '',
  headerScripts: pageHeaderScripts = '',
  footerScripts: pageFooterScripts = '',
  customCss = '',
  customJs = ''
} = Astro.props;

import { ClientRouter } from "astro:transitions";
import fs from "node:fs";
import path from "node:path";

// Load global settings
let globalSettings = {
  headerScripts: "",
  bodyStartScripts: "",
  bodyEndScripts: "",
  footerScripts: "",
};
try {
  const settingsPath = path.resolve("src/data/global-settings.json");
  if (fs.existsSync(settingsPath)) {
    globalSettings = { ...globalSettings, ...JSON.parse(fs.readFileSync(settingsPath, "utf-8")) };
  }
} catch (e) {
  // Graceful fallback
}
---
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon.ico" sizes="any" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />

  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

  <!-- Open Graph Tags -->
  <meta property="og:title" content={ogTitle || title} />
  <meta property="og:description" content={ogDescription || description} />
  {ogImage && <meta property="og:image" content={ogImage.startsWith('http') ? ogImage : `https://www.tangence.in${ogImage}`} />}
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Tangence" />

  <!-- Twitter Cards -->
  <meta name="twitter:card" content={twitterCard} />
  <meta name="twitter:title" content={ogTitle || title} />
  <meta name="twitter:description" content={ogDescription || description} />
  {ogImage && <meta name="twitter:image" content={ogImage.startsWith('http') ? ogImage : `https://www.tangence.in${ogImage}`} />}

  <link rel="stylesheet" href="https://www.tangence.in/font/stylesheet.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/new-lp-page.css" />

  <!-- Custom Schema Markup Injection -->
  {schemaMarkup && (
    <script type="application/ld+json" is:inline set:html={schemaMarkup}></script>
  )}

  <!-- Global Head Script Injection -->
  {globalSettings.headerScripts && (
    <Fragment set:html={globalSettings.headerScripts} />
  )}

  <!-- Page Specific Head Script Injection -->
  {pageHeaderScripts && (
    <Fragment set:html={pageHeaderScripts} />
  )}

  <!-- Page Specific Custom CSS Injection -->
  {customCss && (
    <style is:inline set:html={customCss}></style>
  )}

  <ClientRouter />
</head>

<body>

  <!-- Global Body Start Script Injection -->
  {globalSettings.bodyStartScripts && (
    <Fragment set:html={globalSettings.bodyStartScripts} />
  )}

  <slot />

  <script is:inline src="/js/new-lp-page.js"></script>

  <!-- Global Body End Script Injection -->
  {globalSettings.bodyEndScripts && (
    <Fragment set:html={globalSettings.bodyEndScripts} />
  )}

  <!-- Global Footer Script Injection -->
  {globalSettings.footerScripts && (
    <Fragment set:html={globalSettings.footerScripts} />
  )}

  <!-- Page Specific Footer Script Injection -->
  {pageFooterScripts && (
    <Fragment set:html={pageFooterScripts} />
  )}

  <!-- Page Specific Custom JavaScript Injection -->
  {customJs && (
    <script is:inline set:html={customJs}></script>
  )}

</body>

</html>