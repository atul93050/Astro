---
import fs from "node:fs";
import path from "node:path";
import footerJson from "../data/footer.json";

// Dynamic Settings loader
let footer = {
  description: footerJson.description || "",
  phone: footerJson.phone || "",
  offices: footerJson.offices || [],
  cities: footerJson.cities || [],
  logo: {
    footerLogoUrl: "/images/scroll-logo.svg"
  },
  socialLinks: {
    facebook: "",
    linkedin: "",
    twitter: "",
    instagram: ""
  }
};

try {
  const settingsPath = path.resolve("src/data/global-settings.json");
  if (fs.existsSync(settingsPath)) {
    const data = JSON.parse(fs.readFileSync(settingsPath, "utf-8"));
    if (data.logo) footer.logo = data.logo;
    if (data.socialLinks) footer.socialLinks = data.socialLinks;
    
    // Merge contactInfo
    if (data.contactInfo) {
      if (data.contactInfo.description) footer.description = data.contactInfo.description;
      if (data.contactInfo.phone) footer.phone = data.contactInfo.phone;
      if (data.contactInfo.offices && data.contactInfo.offices.length > 0) footer.offices = data.contactInfo.offices;
      if (data.contactInfo.cities && data.contactInfo.cities.length > 0) footer.cities = data.contactInfo.cities;
    }
  }
} catch (e) {
  // Safe fallback
}
---

<footer class="site">

  <div class="footer-gradient footer-gradient-1"></div>
  <div class="footer-gradient footer-gradient-2"></div>
  <div class="footer-gradient footer-gradient-3"></div>

  <div class="container">

    <div class="foot-grid">

      <div class="tangence-detail">

        <div class="logo footer-logo">
          <a href="/">
            <img
              src={footer.logo.footerLogoUrl || "/images/scroll-logo.svg"}
              alt="Tangence"
            />
          </a>
        </div>

        <p class="footer-description">
          {footer.description}
        </p>

        <div class="footer-contact" style="display:flex; flex-direction:column; gap:0.5rem;">
          <a href={`tel:${footer.phone}`}>
            <i
              class="fa fa-phone"
              aria-hidden="true"
            ></i>

            <span>
              {footer.phone}
            </span>
          </a>

          <div class="footer-socials" style="display: flex; gap: 0.75rem; margin-top: 0.5rem; align-items:center;">
            {footer.socialLinks.facebook && (
              <a href={footer.socialLinks.facebook} target="_blank" class="social-icon" title="Facebook" style="color:#9CA3AF; text-decoration:none; transition:all 0.2s ease;">
                <i class="fa fa-facebook" aria-hidden="true" style="font-size:1.15rem;"></i>
              </a>
            )}
            {footer.socialLinks.linkedin && (
              <a href={footer.socialLinks.linkedin} target="_blank" class="social-icon" title="LinkedIn" style="color:#9CA3AF; text-decoration:none; transition:all 0.2s ease;">
                <i class="fa fa-linkedin" aria-hidden="true" style="font-size:1.15rem;"></i>
              </a>
            )}
            {footer.socialLinks.twitter && (
              <a href={footer.socialLinks.twitter} target="_blank" class="social-icon" title="Twitter/X" style="color:#9CA3AF; text-decoration:none; transition:all 0.2s ease;">
                <i class="fa fa-twitter" aria-hidden="true" style="font-size:1.15rem;"></i>
              </a>
            )}
            {footer.socialLinks.instagram && (
              <a href={footer.socialLinks.instagram} target="_blank" class="social-icon" title="Instagram" style="color:#9CA3AF; text-decoration:none; transition:all 0.2s ease;">
                <i class="fa fa-instagram" aria-hidden="true" style="font-size:1.15rem;"></i>
              </a>
            )}
          </div>
        </div>

      </div>

      <div class="footer-address">

        {footer.offices.map((office) => (

          <div class="address-items">

            <img
              src={office.icon}
              alt={office.title}
            />

            <div class="head-office">

              <h3>
                {office.title}
              </h3>

              <p>
                {office.address}
              </p>

            </div>

          </div>

        ))}

      </div>

    </div>

    <div class="city-details">

      <div class="city-details-frts">

        {footer.cities.map((city, index) => (

          <>
            <span>{city}</span>

            {index < footer.cities.length - 1 && (
              <span> | </span>
            )}

          </>

        ))}

      </div>

    </div>

  </div>

  <div class="foot-bottom">
    © {new Date().getFullYear()}
    {" "}
    Tangence India. All rights reserved.
  </div>

</footer>