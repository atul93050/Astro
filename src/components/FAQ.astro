---
interface Props {
  faq?: {
    eyebrow: string;
    title: string;
    items: Array<{
      question: string;
      answer: string;
      open?: boolean;
    }>;
  };
}

const { faq } = Astro.props;

import defaultFaqs from "../data/faq.json";

const eyebrow = faq?.eyebrow || "Common questions";
const title = faq?.title || "The things buyers actually ask us.";
const items = faq?.items && faq.items.length > 0 ? faq.items : defaultFaqs;
---

<section
  id="faq"
  class="anno"
  style="background:var(--bg-soft);"
>
  <div class="container">

    <div class="section-head">
      <span class="section-eyebrow">
        {eyebrow}
      </span>

      <h2>
        {title}
      </h2>
    </div>

    <div class="faq">

      {items.map((faq) => (

        <details
          class="faq-item"
          open={faq.open}
        >

          <summary class="faq-q">
            {faq.question}
          </summary>

          <div class="faq-a">
            {faq.answer}
          </div>

        </details>

      ))}

    </div>

  </div>
</section>