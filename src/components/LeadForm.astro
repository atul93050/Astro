---
const utm_source =
  Astro.url.searchParams.get("utm_source") || "";

const utm_medium =
  Astro.url.searchParams.get("utm_medium") || "";

const qt2 = utm_source;
---

<form
  method="post"
  class="contact-form"
  id="lead-form"
  action="/performance-marketing/newlppagesubmit.php"
  accept-charset="utf-8"
  novalidate
>

  <input
    type="hidden"
    name="queryst"
    value={qt2}
  />

  <input
    type="hidden"
    name="urltagging"
    value="Direct"
  />

  <input
    type="hidden"
    name="formsno"
    value="top"
  />

  <input
    type="hidden"
    name="utm_source"
    value={utm_source}
  />

  <input
    type="hidden"
    name="utm_medium"
    value={utm_medium}
  />

  <div class="field">
    <input
      id="name"
      type="text"
      name="name"
      placeholder="Name"
      required
    />
  </div>

  <div class="field">
    <input
      id="email"
      type="email"
      name="email"
      placeholder="Work Email"
      required
    />
  </div>

  <div class="field">
    <input
      id="phone"
      type="tel"
      name="mobile"
      placeholder="Phone Number"
      maxlength="10"
      required
    />
  </div>

  <div class="field">
    <select
      id="budget"
      name="budget"
      required
    >
      <option value="" disabled selected>
        Select Monthly Ad Budget
      </option>

      <option value="1L-2L">
        INR 1 Lakh to 2 Lakh
      </option>

      <option value="2L-5L">
        INR 2 Lakh to 5 Lakh
      </option>

      <option value="5L+">
        INR 5 Lakh and above
      </option>
    </select>
  </div>

  <div class="field textarea-field">
    <textarea
      id="message"
      name="message"
      rows="5"
      placeholder="Message"
    ></textarea>
  </div>

  <button
    type="submit"
    class="btn-primary"
  >
    Get my free audit →
  </button>

</form>