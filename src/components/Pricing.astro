---
interface Props {
  pricing?: {
    eyebrow: string;
    title: string;
    description: string;
    footer: string;
    items: Array<{
      title: string;
      price: string;
      suffix: string;
      subtext: string;
      featured: boolean;
      features: string[];
    }>;
  };
}

const { pricing } = Astro.props;

import defaultPricingPlans from "../data/pricing.json";

const eyebrow = pricing?.eyebrow || "How we work together";
const title = pricing?.title || "Three engagement models. No long lock-ins. No surprises.";
const description = pricing?.description || "We're one of the few performance agencies in India that publishes pricing.";
const footer = pricing?.footer || "3-month minimum. Exit anytime after that with 30 days' notice. No clawbacks. No contract gotchas.";
const items = pricing?.items && pricing.items.length > 0 ? pricing.items : defaultPricingPlans;
---

<section id="pricing" class="anno">
  <div class="container">

    <div class="section-head">
      <span class="section-eyebrow">
        {eyebrow}
      </span>

      <h2>
        {title}
      </h2>

      <p>
        {description}
      </p>
    </div>

    <div class="pricing-grid">

      {items.map((plan) => (

        <div
          class:list={[
            "pricing-card",
            { featured: plan.featured }
          ]}
        >

          <h3>{plan.title}</h3>

          <div class="price">
            {plan.price}

            <span
              style="font-size:14px;color:var(--muted);font-weight:500;"
            >
              {plan.suffix}
            </span>
          </div>

          <div class="price-sub">
            {plan.subtext}
          </div>

          <ul>
            {plan.features.map((feature) => (
              <li>{feature}</li>
            ))}
          </ul>

        </div>

      ))}

    </div>

    <div class="pricing-foot">
      {footer}
    </div>

  </div>
</section>