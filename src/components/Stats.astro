---
interface Props {
  stats?: {
    eyebrow: string;
    title: string;
    description: string;
    items: Array<{ num: string; label: string }>;
  };
}

const { stats } = Astro.props;

import { stats as defaultStats } from "../data/stats";

const eyebrow = stats?.eyebrow || "Why Tangence";
const title = stats?.title || "Built for the long game.";
const description = stats?.description || "Most Google Ads and PPC advertising agencies are 3–5 years old. We've been at this for two decades.";
const items = stats?.items && stats.items.length > 0 ? stats.items : defaultStats;
---

<section class="stats anno">
  <div class="container">
    <div class="section-head">
      <span class="section-eyebrow" style="color:#F33B7B;">{eyebrow}</span>
      <h2>{title}</h2>
      <p>
        {description}
      </p>
    </div>
    <div class="stat-grid">
      {
        items.map((stat) => {
          return (
            <div class="stat-tile">
              <div class="num">{stat.num}</div>
              <div class="label">{stat.label}</div>
            </div>
          );
        })
      }
      
    </div>
  </div>
</section>
