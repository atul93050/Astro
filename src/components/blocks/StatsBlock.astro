---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  items: Array<{
    num: string;
    label: string;
  }>;
}

const { eyebrow, title, description, items = [] } = Astro.props;
---
<section class="block-stats">
  <div class="container">
    <div class="section-head">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2>{title}</h2>
      {description && <p class="desc">{description}</p>}
    </div>
    
    <div class="stat-grid">
      {items.map((stat) => (
        <div class="stat-tile">
          <div class="num">{stat.num}</div>
          <div class="label">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .block-stats {
    padding: 6rem 0;
    background-color: #050811;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4rem auto;
  }

  .eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #F33B7B;
    display: block;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .desc {
    font-size: 1.05rem;
    color: #9CA3AF;
    margin-top: 0.75rem;
    line-height: 1.6;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
  }

  .stat-tile {
    background: rgba(17, 24, 39, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    padding: 2.5rem 1.5rem;
    text-align: center;
    backdrop-filter: blur(12px);
    transition: all 0.3s ease;
  }

  .stat-tile:hover {
    border-color: rgba(243, 59, 123, 0.25);
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(243, 59, 123, 0.05);
  }

  .num {
    font-family: 'Outfit', sans-serif;
    font-size: 3rem;
    font-weight: 800;
    color: white;
    margin-bottom: 0.5rem;
    line-height: 1;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, white 40%, rgba(255, 255, 255, 0.5) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .label {
    font-size: 0.95rem;
    line-height: 1.5;
    color: #9CA3AF;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .stat-tile {
      padding: 2rem 1rem;
    }
    .num {
      font-size: 2.5rem;
    }
  }
</style>
