---
interface Props {
  badge?: string;
  title: string;
  description: string;
  image?: string;
  bullets?: string[];
}

const { badge, title, description, image, bullets = [] } = Astro.props;
---
<section class="block-hero">
  <div class="block-glow block-glow-1"></div>
  <div class="block-glow block-glow-2"></div>
  
  <div class="container hero-grid">
    <div class="hero-text-area">
      {badge && <span class="eyebrow">{badge}</span>}
      <h1 set:html={title}></h1>
      <p class="hero-desc">{description}</p>
      
      {bullets.length > 0 && (
        <div class="hero-bullets">
          {bullets.map((bullet) => (
            <span>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="var(--accent, #10B981)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px;display:inline-block;vertical-align:middle;"><polyline points="20 6 9 17 4 12"></polyline></svg>
              {bullet}
            </span>
          ))}
        </div>
      )}
    </div>
    
    {image && (
      <div class="hero-visual-area">
        <div class="image-wrapper">
          <img src={image} alt="Hero illustration" />
          <div class="accent-border"></div>
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .block-hero {
    position: relative;
    padding: 7rem 0 5rem 0;
    background-color: #050811;
    overflow: hidden;
    color: white;
  }

  .block-glow {
    position: absolute;
    border-radius: 50%;
    z-index: 1;
    pointer-events: none;
  }

  .block-glow-1 {
    top: -10%;
    left: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, rgba(99, 102, 241, 0) 70%);
  }

  .block-glow-2 {
    bottom: -10%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.06) 0%, rgba(16, 185, 129, 0) 70%);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 2;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-grid:has(.hero-visual-area) {
    grid-template-columns: 1.1fr 0.9fr;
  }

  .hero-grid:not(:has(.hero-visual-area)) {
    grid-template-columns: 1fr;
    max-width: 800px;
    text-align: center;
    margin: 0 auto;
  }

  .eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #6366F1;
    display: block;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-family: 'Outfit', sans-serif;
    font-size: 3.5rem;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: white;
    margin-bottom: 1.5rem;
  }

  :global(.block-hero h1 .accent) {
    background: linear-gradient(135deg, #6366F1 0%, #10B981 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-desc {
    font-size: 1.15rem;
    line-height: 1.6;
    color: #9CA3AF;
    margin-bottom: 2rem;
  }

  .hero-bullets {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .hero-bullets span {
    font-size: 0.95rem;
    font-weight: 500;
    color: #D1D5DB;
  }

  .hero-visual-area .image-wrapper {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .hero-visual-area img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .accent-border {
    position: absolute;
    top: 15px;
    left: 15px;
    right: 15px;
    bottom: 15px;
    border: 1px solid rgba(99, 102, 241, 0.2);
    pointer-events: none;
    border-radius: 12px;
  }

  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr !important;
      gap: 3rem;
      text-align: center;
    }
    .hero-bullets {
      justify-content: center;
    }
    .hero-visual-area {
      max-width: 500px;
      margin: 0 auto;
    }
    h1 {
      font-size: 2.8rem;
    }
  }
</style>
