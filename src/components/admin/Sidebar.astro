---
const currentPath = Astro.url.pathname;
---
<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-logo">T</div>
    <div class="brand-text">
      <h2>Tangence</h2>
      <span>CMS Panel v1.0</span>
    </div>
  </div>

  <nav class="sidebar-nav">
    <span class="nav-section-title">Manage Content</span>
    
    <a href="/admin/home" class={`nav-item ${currentPath.includes('/admin/home') ? 'active' : ''}`}>
      <svg class="nav-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
      <span>Home Page</span>
      {currentPath.includes('/admin/home') && <div class="active-indicator" />}
    </a>

    <a href="/admin/about" class={`nav-item ${currentPath.includes('/admin/about') ? 'active' : ''}`}>
      <svg class="nav-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14 2 14 8 20 8"></polyline>
        <line x1="16" y1="13" x2="8" y2="13"></line>
        <line x1="16" y1="17" x2="8" y2="17"></line>
        <polyline points="10 9 9 9 8 9"></polyline>
      </svg>
      <span>About Us Page</span>
      {currentPath.includes('/admin/about') && <div class="active-indicator" />}
    </a>

    <span class="nav-section-title">Actions</span>

    <a href="/about-us" target="_blank" class="nav-item external-link">
      <svg class="nav-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
        <polyline points="15 3 21 3 21 9"></polyline>
        <line x1="10" y1="14" x2="21" y2="3"></line>
      </svg>
      <span>View Live Page</span>
    </a>
  </nav>

  <div class="sidebar-footer">
    <div class="user-avatar">AV</div>
    <div class="user-info">
      <h4>Atul Verma</h4>
      <span>Administrator</span>
    </div>
  </div>
</aside>

<style>
  .sidebar {
    width: 280px;
    height: 100vh;
    background-color: rgba(10, 15, 26, 0.9);
    border-right: 1px solid var(--bg-surface-border);
    backdrop-filter: blur(16px);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 100;
  }

  .sidebar-brand {
    padding: 2rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    border-bottom: 1px solid var(--bg-surface-border);
  }

  .brand-logo {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--primary) 0%, #a855f7 100%);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.5rem;
    color: white;
    box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4);
  }

  .brand-text h2 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-main);
  }

  .brand-text span {
    font-size: 0.75rem;
    color: var(--text-dim);
    display: block;
    margin-top: -2px;
  }

  .sidebar-nav {
    flex: 1;
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav-section-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-dim);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    padding-left: 0.75rem;
  }

  .nav-section-title:first-of-type {
    margin-top: 0;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 500;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
  }

  .nav-item:hover {
    color: var(--text-main);
    background-color: rgba(255, 255, 255, 0.03);
  }

  .nav-item.active {
    color: white;
    background-color: var(--primary-light);
    font-weight: 600;
  }

  .nav-icon {
    transition: var(--transition);
  }

  .nav-item:hover .nav-icon {
    transform: translateX(2px);
  }

  .nav-item.active .nav-icon {
    color: var(--primary);
  }

  .active-indicator {
    position: absolute;
    left: 0;
    top: 20%;
    bottom: 20%;
    width: 4px;
    background-color: var(--primary);
    border-radius: 0 4px 4px 0;
    box-shadow: 0 0 10px var(--primary);
  }

  .external-link {
    border: 1px dashed rgba(255, 255, 255, 0.08);
  }

  .external-link:hover {
    background-color: rgba(16, 185, 129, 0.05);
    border-color: rgba(16, 185, 129, 0.2);
    color: var(--accent);
  }

  .external-link:hover .nav-icon {
    color: var(--accent);
    transform: translate(2px, -2px);
  }

  .sidebar-footer {
    padding: 1.5rem;
    border-top: 1px solid var(--bg-surface-border);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .user-avatar {
    width: 42px;
    height: 42px;
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--text-main);
  }

  .user-info h4 {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-main);
  }

  .user-info span {
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  @media (max-width: 768px) {
    .sidebar {
      width: 100%;
      height: auto;
      position: absolute;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem 1.5rem;
      border-right: none;
      border-bottom: 1px solid var(--bg-surface-border);
    }

    .sidebar-brand {
      padding: 0;
      border-bottom: none;
    }

    .sidebar-nav {
      display: none; /* Hide standard nav on mobile or build mobile menu */
    }

    .sidebar-footer {
      padding: 0;
      border-top: none;
    }
  }
</style>
