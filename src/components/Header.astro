---
import fs from "node:fs";
import path from "node:path";
import PrimaryNav from "./navigation/PrimaryNav.astro";
import MobileNav from "./navigation/MobileNav.astro";
import { getMenuAtLocation } from "../utils/menus";

const currentPath = Astro.url.pathname;

// Load logo from global settings
let logo = { headerLogoUrl: "/images/tangence-black.png" };
try {
  const settingsPath = path.resolve("src/data/global-settings.json");
  if (fs.existsSync(settingsPath)) {
    const data = JSON.parse(fs.readFileSync(settingsPath, "utf-8"));
    if (data.logo) logo = data.logo;
  }
} catch (e) {}

// CMS-driven menus
const primaryMenu = getMenuAtLocation("primary-header");
const mobileMenu  = getMenuAtLocation("mobile-menu") || primaryMenu;
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <!-- Logo -->
    <div class="header-logo">
      <a href="/" aria-label="Go to homepage">
        <img
          src={logo.headerLogoUrl || "/images/tangence-black.png"}
          alt="Tangence"
          loading="eager"
          width="160"
          height="40"
        />
      </a>
    </div>

    <!-- Desktop Primary Nav (hidden on mobile via CSS) -->
    <div class="header-nav desktop-only">
      <PrimaryNav menu={primaryMenu} currentPath={currentPath} />
    </div>

    <!-- CTA + Mobile Toggle -->
    <div class="header-cta-row">
      <a href="#book-audit" class="btn-call desktop-only">Book a free audit</a>
      <MobileNav menu={mobileMenu} />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 500;
    background: rgba(8, 12, 20, 0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: background 0.3s ease;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
  }

  .header-logo img {
    height: 36px;
    width: auto;
    display: block;
  }

  .header-nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .header-cta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .btn-call {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.15rem;
    background: linear-gradient(135deg, #6366F1 0%, #4f46e5 100%);
    color: white;
    font-size: 0.85rem;
    font-weight: 700;
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.25);
    transition: all 0.22s ease;
  }

  .btn-call:hover {
    box-shadow: 0 6px 16px rgba(99, 102, 241, 0.4);
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .desktop-only { display: none !important; }
    .header-inner { gap: 1rem; }
  }
</style>
