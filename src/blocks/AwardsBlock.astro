---
interface Props {
  eyebrow?: string;
  title: string;
  items: Array<{
    title: string;
    organization: string;
    year?: string;
    logo: string;
  }>;
}

const { eyebrow, title, items = [] } = Astro.props;
const validItems = (items || []).filter(item => item && (item.title || item.logo || item.organization));
---
<section class="block-awards">
  <div class="container">
    {(eyebrow || title) && (
      <div class="section-head">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        {title && <h2>{title}</h2>}
      </div>
    )}

    {validItems.length > 0 && (
      <div class="awards-grid">
        {validItems.map((award) => (
          <div class="award-tile">
            {award.logo && (
              <div class="award-logo-box">
                <img src={award.logo} alt={award.title || "Award Logo"} class="award-logo" loading="lazy" decoding="async" />
              </div>
            )}
            <div class="award-info">
              {award.year && <span class="award-year">{award.year}</span>}
              {award.title && <h3>{award.title}</h3>}
              {award.organization && <p class="organization">{award.organization}</p>}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .block-awards {
    padding: 6rem 0;
    background-color: #050811;
    color: white;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4rem auto;
  }

  .eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #10B981;
    display: block;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .awards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .award-tile {
    background: rgba(17, 24, 39, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    padding: 2.25rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    backdrop-filter: blur(12px);
    transition: all 0.3s ease;
  }

  .award-tile:hover {
    border-color: rgba(99, 102, 241, 0.25);
    transform: translateY(-4px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
  }

  .award-logo-box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    flex-shrink: 0;
  }

  .award-logo {
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .award-info {
    flex-grow: 1;
  }

  .award-year {
    font-family: 'Outfit', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: #6366F1;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 0.25rem;
  }

  .award-info h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: white;
    line-height: 1.3;
  }

  .organization {
    font-size: 0.85rem;
    color: #9CA3AF;
  }
</style>
