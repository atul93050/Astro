---
interface Props {
  eyebrow?: string;
  title: string;
  members: Array<{
    name: string;
    role: string;
    bio: string;
    image: string;
  }>;
}

const { eyebrow, title, members = [] } = Astro.props;
const validMembers = (members || []).filter(m => m && (m.name || m.image));
---
<section class="block-team">
  <div class="container">
    {(eyebrow || title) && (
      <div class="section-header">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        {title && <h2>{title}</h2>}
      </div>
    )}

    {validMembers.length > 0 && (
      <div class="team-grid">
        {validMembers.map((member) => (
          <div class="team-card">
            <div class="team-image-box">
              <img src={member.image || "/uploads/team-placeholder.png"} alt={member.name || "Team Member"} />
              {member.bio && (
                <div class="hover-overlay">
                  <p class="member-bio">{member.bio}</p>
                </div>
              )}
            </div>
            <div class="team-details">
              {member.name && <h3>{member.name}</h3>}
              {member.role && <span class="member-role">{member.role}</span>}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .block-team {
    padding: 6rem 0;
    background-color: #03060E;
    border-top: 1px solid rgba(255,255,255,0.04);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 4rem auto;
  }

  .eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #6366F1;
    display: block;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 2.5rem;
    color: white;
    font-weight: 800;
    margin-top: 0.25rem;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2.5rem;
  }

  .team-card {
    background: rgba(17, 24, 39, 0.4);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .team-card:hover {
    border-color: rgba(99, 102, 241, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.3);
  }

  .team-image-box {
    position: relative;
    width: 100%;
    height: 320px;
    overflow: hidden;
    background: #000;
  }

  .team-image-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .team-card:hover .team-image-box img {
    transform: scale(1.05);
  }

  .hover-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(10, 15, 26, 0.95);
    padding: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .team-card:hover .hover-overlay {
    opacity: 1;
  }

  .member-bio {
    color: #D1D5DB;
    font-size: 0.95rem;
    line-height: 1.6;
    text-align: center;
  }

  .team-details {
    padding: 1.5rem;
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.04);
  }

  .team-details h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.2rem;
    color: white;
    font-weight: 600;
  }

  .member-role {
    color: #6366F1;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-top: 0.25rem;
  }
</style>
