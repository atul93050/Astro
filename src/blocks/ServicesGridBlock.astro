---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  services: Array<{
    title: string;
    description: string;
    icon?: string;
    link?: string;
  }>;
}

const { eyebrow, title, description, services = [] } = Astro.props;
---
<section class="block-services">
  <div class="container">
    <div class="section-head">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2>{title}</h2>
      {description && <p class="desc">{description}</p>}
    </div>

    <div class="services-grid">
      {services.map((srv) => (
        <div class="service-card">
          <div class="card-glow"></div>
          <div class="card-content">
            <div class="icon-box">
              <span class="icon">{srv.icon || "✓"}</span>
            </div>
            <h3>{srv.title}</h3>
            <p>{srv.description}</p>
            {srv.link && (
              <a href={srv.link} class="learn-more">
                <span>Explore Capabilities</span>
                <span class="arrow">→</span>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .block-services {
    padding: 6.5rem 0;
    background-color: #050811;
    color: white;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4.5rem auto;
  }

  .eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #10B981;
    display: block;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 2.6rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .desc {
    font-size: 1.1rem;
    color: #9CA3AF;
    margin-top: 0.75rem;
    line-height: 1.6;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
  }

  .service-card {
    position: relative;
    background: rgba(17, 24, 39, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    overflow: hidden;
    backdrop-filter: blur(12px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .service-card:hover {
    transform: translateY(-6px);
    border-color: rgba(99, 102, 241, 0.25);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
  }

  .card-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 10% 10%, rgba(99, 102, 241, 0.04) 0%, rgba(99, 102, 241, 0) 60%);
    pointer-events: none;
    z-index: 1;
  }

  .card-content {
    position: relative;
    z-index: 2;
    padding: 3rem 2.5rem;
  }

  .icon-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 16px;
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.2);
    margin-bottom: 1.75rem;
    color: #6366F1;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .service-card:hover .icon-box {
    background: #6366F1;
    color: white;
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.4);
    border-color: #6366F1;
  }

  h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: white;
  }

  p {
    font-size: 0.98rem;
    line-height: 1.6;
    color: #9CA3AF;
    margin-bottom: 1.75rem;
  }

  .learn-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #6366F1;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .learn-more:hover {
    color: #818cf8;
  }

  .learn-more .arrow {
    transition: transform 0.2s ease;
  }

  .learn-more:hover .arrow {
    transform: translateX(4px);
  }
</style>
