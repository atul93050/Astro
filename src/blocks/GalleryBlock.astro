---
interface Props {
  eyebrow?: string;
  title: string;
  items: Array<{
    image: string;
    caption?: string;
    alt?: string;
  }>;
}

const { eyebrow, title, items = [] } = Astro.props;
const validItems = (items || []).filter(item => item && item.image);
---
<section class="block-gallery">
  <div class="container">
    {(eyebrow || title) && (
      <div class="section-head">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        {title && <h2>{title}</h2>}
      </div>
    )}

    {validItems.length > 0 && (
      <div class="gallery-grid">
        {validItems.map((item) => (
          <div class="gallery-card">
            <img src={item.image} alt={item.alt || item.caption || "Gallery Photo"} class="gallery-img" loading="lazy" decoding="async" />
            {item.caption && (
              <div class="caption-overlay">
                <p class="caption-text">{item.caption}</p>
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .block-gallery {
    padding: 6.5rem 0;
    background-color: #03060E;
    color: white;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4.5rem auto;
  }

  .eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #F33B7B;
    display: block;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  .gallery-card {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 4/3;
    background: #111827;
    border: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .gallery-card:hover {
    transform: scale(1.03) translateY(-4px);
    border-color: rgba(99, 102, 241, 0.25);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.4);
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .gallery-card:hover .gallery-img {
    transform: scale(1.08);
  }

  .caption-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to top, rgba(10, 15, 26, 0.95) 0%, rgba(10, 15, 26, 0.4) 60%, rgba(10, 15, 26, 0) 100%);
    display: flex;
    align-items: flex-end;
    padding: 2rem;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 2;
  }

  .gallery-card:hover .caption-overlay {
    opacity: 1;
  }

  .caption-text {
    font-family: 'Outfit', sans-serif;
    color: white;
    font-size: 1.05rem;
    font-weight: 600;
    transform: translateY(10px);
    transition: transform 0.3s ease;
  }

  .gallery-card:hover .caption-text {
    transform: translateY(0);
  }
</style>
