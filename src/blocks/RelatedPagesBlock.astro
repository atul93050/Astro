---
interface Props {
  eyebrow?: string;
  title: string;
  pages: Array<{
    label: string;
    link: string;
    description?: string;
  }>;
}

const { eyebrow, title, pages = [] } = Astro.props;
const validPages = (pages || []).filter(item => item && (item.label || item.link));
---
<section class="block-related-pages">
  <div class="container">
    {(eyebrow || title) && (
      <div class="section-head">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        {title && <h2>{title}</h2>}
      </div>
    )}

    {validPages.length > 0 && (
      <div class="related-grid">
        {validPages.map((item) => (
          <a href={item.link || "#"} class="related-card">
            <div class="card-glow"></div>
            <div class="card-content">
              <span class="arrow-indicator">↗</span>
              {item.label && <h3>{item.label}</h3>}
              {item.description && <p>{item.description}</p>}
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .block-related-pages {
    padding: 6rem 0;
    background-color: #03060E;
    color: white;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4rem auto;
  }

  .eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #F33B7B;
    display: block;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 2.35rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .related-card {
    position: relative;
    background: rgba(17, 24, 39, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    overflow: hidden;
    backdrop-filter: blur(12px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    color: white;
    display: block;
  }

  .related-card:hover {
    transform: translateY(-4px);
    border-color: rgba(99, 102, 241, 0.25);
    box-shadow: 0 12px 25px rgba(0, 0, 0, 0.3);
  }

  .card-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 10% 10%, rgba(99, 102, 241, 0.03) 0%, rgba(99, 102, 241, 0) 60%);
    pointer-events: none;
    z-index: 1;
  }

  .card-content {
    position: relative;
    z-index: 2;
    padding: 2.5rem 2rem;
  }

  .arrow-indicator {
    position: absolute;
    top: 2rem;
    right: 2rem;
    font-size: 1.25rem;
    color: #6366F1;
    transition: transform 0.2s ease;
  }

  .related-card:hover .arrow-indicator {
    transform: translate(3px, -3px);
    color: #818cf8;
  }

  h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    padding-right: 1.5rem;
  }

  p {
    font-size: 0.9rem;
    line-height: 1.5;
    color: #9CA3AF;
  }
</style>
