---
interface Props {
  eyebrow?: string;
  title: string;
  items: Array<{
    question: string;
    answer: string;
  }>;
}

const { eyebrow, title, items = [] } = Astro.props;
---
<section class="block-faq">
  <div class="container">
    <div class="section-head">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2>{title}</h2>
    </div>

    <div class="faq-accordion">
      {items.map((item, index) => (
        <details class="faq-item" open={index === 0}>
          <summary class="faq-q">
            {item.question}
          </summary>
          <div class="faq-a">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .block-faq {
    padding: 6rem 0;
    background-color: #050811;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #10B981;
    display: block;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .faq-accordion {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .faq-item {
    background: rgba(17, 24, 39, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    overflow: hidden;
    backdrop-filter: blur(12px);
    transition: all 0.3s ease;
  }

  .faq-item[open] {
    border-color: rgba(99, 102, 241, 0.2);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
  }

  .faq-q {
    padding: 1.5rem 2rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: white;
    cursor: pointer;
    list-style: none;
    position: relative;
    user-select: none;
  }

  .faq-q::-webkit-details-marker {
    display: none;
  }

  .faq-q::after {
    content: "+";
    position: absolute;
    right: 2rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.5rem;
    color: #9CA3AF;
    font-weight: 400;
    transition: transform 0.3s ease;
  }

  .faq-item[open] .faq-q::after {
    content: "−";
    color: #6366F1;
  }

  .faq-a {
    padding: 0 2rem 1.5rem 2rem;
    font-size: 1rem;
    line-height: 1.6;
    color: #9CA3AF;
    border-top: 1px solid transparent;
  }

  .faq-item[open] .faq-a {
    border-top: 1px solid rgba(255, 255, 255, 0.03);
  }
</style>
