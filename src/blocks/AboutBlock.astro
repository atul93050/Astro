---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  image?: string;
  highlights?: string[];
}

const { eyebrow, title, description, image, highlights = [] } = Astro.props;
---
<section class="block-about">
  <div class="container">
    <div class="about-grid">
      {image && (
        <div class="about-left">
          <div class="image-stack">
            <div class="image-frame">
              <img src={image} alt={title} class="about-img" />
              <div class="border-overlay"></div>
            </div>
            <div class="back-card glow-card"></div>
          </div>
        </div>
      )}
      <div class="about-right">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        <h2>{title}</h2>
        <p class="description">{description}</p>
        
        {highlights.length > 0 && (
          <ul class="highlights-list">
            {highlights.map(item => (
              <li>
                <div class="check-icon">✓</div>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .block-about {
    padding: 6.5rem 0;
    background-color: #050811;
    overflow: hidden;
    color: white;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 4.5rem;
    align-items: center;
  }

  @media (max-width: 991px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }
  }

  .image-stack {
    position: relative;
    max-width: 480px;
    margin: 0 auto;
  }

  .image-frame {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    z-index: 2;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .about-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 4/3;
  }

  .border-overlay {
    position: absolute;
    top: 16px;
    left: 16px;
    right: 16px;
    bottom: 16px;
    border: 1px solid rgba(99, 102, 241, 0.25);
    pointer-events: none;
    border-radius: 16px;
    z-index: 3;
  }

  .back-card {
    position: absolute;
    top: -20px;
    left: -20px;
    width: 100%;
    height: 100%;
    border-radius: 24px;
    z-index: 1;
  }

  .glow-card {
    background: radial-gradient(circle at 10% 20%, rgba(99, 102, 241, 0.1) 0%, rgba(16, 185, 129, 0.05) 90%);
    border: 1px solid rgba(255, 255, 255, 0.03);
  }

  .eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #6366F1;
    display: block;
    margin-bottom: 0.75rem;
  }

  h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 2.75rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    line-height: 1.25;
  }

  .description {
    font-size: 1.1rem;
    line-height: 1.65;
    color: #9CA3AF;
    margin-bottom: 2rem;
  }

  .highlights-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .highlights-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.02rem;
    color: #E5E7EB;
  }

  .check-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgba(16, 185, 129, 0.15);
    color: #10B981;
    font-weight: 700;
    font-size: 0.75rem;
  }
</style>
