---
interface Props {
  section_title?: string;
  description?: string;
  services_list?: Array<{
    name: string;
    image: string;
    description: string;
    link: string;
  }>;
}

const { section_title, description, services_list } = Astro.props;

const defaultTitle = "Our Services";
const defaultDescription = "EWAC Alloys Limited has been in preventive maintenance and repair of industrial machinery, we offer an unrivalled range of cost-effective solutions to wear-related problems since 1962. We consistently serve maintenance and repair needs across all industries through our turnkey solutions.";

const defaultServices = [
  {
    name: "Turnkey Solutions",
    image: "/assets/images/turnkey-solutions1.png",
    description: "End-to-end project execution covering site assessment, engineering design, alloy selection, application, and post-service support — all under one roof.",
    link: "#"
  },
  {
    name: "Railways",
    image: "/assets/images/turnkey-solutions2.png",
    description: "Specialized welding and hard-facing solutions for rail tracks, wheel flanges, crossings, and switches — extending asset life and reducing downtime.",
    link: "#"
  },
  {
    name: "ERF Services",
    image: "/assets/images/turnkey-solutions3.png",
    description: "Expert repair and refurbishment solutions for heavy industrial components, tailored for power, cement, steel, and mining sectors.",
    link: "#"
  }
];

const displayTitle = section_title || defaultTitle;
const displayDesc = description || defaultDescription;
const displayServices = (services_list && services_list.length > 0) ? services_list : defaultServices;
// Double list items to match the original DOM structure for slider initialization if required
const displayItems = displayServices.length <= 3 ? [...displayServices, ...displayServices] : displayServices;
---

<section class="services-section">
  <div class="container">
    <div class="services-header">
      <div class="services-header-left">
        <h2 class="services-heading">{displayTitle}</h2>
        {displayDesc && <p class="services-sub" set:html={displayDesc}></p>}
      </div>
      <div class="services-header-right">
        <button class="svc-arrow svc-prev" id="svcPrev"><i class="fas fa-chevron-left"></i></button>
        <button class="svc-arrow svc-next" id="svcNext"><i class="fas fa-chevron-right"></i></button>
      </div>
    </div>

    <div class="services-slider" id="mainServicesSlider">
      {displayItems.map((svc) => (
        <div class="svc-card">
          <div class="svc-img-wrap">
            <img src={svc.image} alt={svc.name} />
          </div>
          <h3 class="svc-name">{svc.name}</h3>
          <p class="svc-desc">{svc.description}</p>
          <a href={svc.link} class="svc-link">Read More</a>
        </div>
      ))}
    </div>
  </div>
</section>
