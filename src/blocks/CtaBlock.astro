---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  buttonText: string;
  buttonLink: string;
}

const { eyebrow, title, description, buttonText, buttonLink } = Astro.props;
---
<section class="block-cta">
  <div class="container">
    <div class="cta-card">
      <div class="glow-overlay"></div>
      <div class="cta-content">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        <h2>{title}</h2>
        <p>{description}</p>
        <a href={buttonLink} class="btn btn-filled">{buttonText}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .block-cta {
    padding: 6rem 0;
    background-color: #03060E;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .cta-card {
    position: relative;
    background: linear-gradient(135deg, rgba(17, 24, 39, 0.8) 0%, rgba(99, 102, 241, 0.08) 100%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 24px;
    padding: 4.5rem 3rem;
    text-align: center;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(12px);
  }

  .glow-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, rgba(99, 102, 241, 0) 70%);
    z-index: 1;
    pointer-events: none;
  }

  .cta-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0 auto;
  }

  .eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #10B981;
    display: block;
    margin-bottom: 0.75rem;
  }

  h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 2.75rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }

  p {
    font-size: 1.1rem;
    color: #9CA3AF;
    line-height: 1.6;
    margin-bottom: 2.25rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 1rem 2.5rem;
    border-radius: 12px;
    font-size: 1.05rem;
    font-weight: 600;
    transition: all 0.25s ease;
    text-decoration: none;
    cursor: pointer;
  }

  .btn-filled {
    background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
    color: white;
    box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4);
  }

  .btn-filled:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.6);
  }

  @media (max-width: 768px) {
    .cta-card {
      padding: 3rem 1.5rem;
    }
    h2 {
      font-size: 2.1rem;
    }
  }
</style>
