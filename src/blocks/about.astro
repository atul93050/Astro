---
interface Props {
  paragraph_text?: string;
  animation_gif?: string;
  stats?: Array<{
    icon?: string;
    target?: string | number;
    format?: string;
    label?: string;
  }>;
}

const { paragraph_text, animation_gif, stats } = Astro.props;

const defaultParagraph = "<strong>EWAC was started as a joint venture between Larsen & Toubro Limited</strong>, India & Eutectic Castolin Group, Switzerland, in 1962. In the year 2011, EWAC Alloys Limited became a wholly owned subsidiary of Larsen & Toubro Limited (L&T). Subsequently, in 2018, EWAC was acquired by Colfax, USA. EWAC Alloys Limited has been a leader in Maintenance and Repair in the Indian Welding Industry. The company manufactures and sells cutting-edge welding products, kits, and accessories. EWAC exports products to over 50 countries across South America, Europe, Africa, ME, SEA, China, Japan, South Korea, Sri Lanka, and Bangladesh.";

const defaultStats = [
  {
    icon: "/assets/images/icon1.svg",
    target: "7000",
    format: "comma",
    label: "Customers"
  },
  {
    icon: "/assets/images/icon2.svg",
    target: "64",
    format: "",
    label: "Years"
  },
  {
    icon: "/assets/images/icon3.svg",
    target: "500",
    format: "",
    label: "Products"
  },
  {
    icon: "/assets/images/icon4.svg",
    target: "9",
    format: "",
    label: "Industries"
  }
];

const displayParagraph = paragraph_text || defaultParagraph;
const displayGif = animation_gif || "/assets/images/Welding_Animation.gif";
const displayStats = (stats && stats.length > 0) ? stats : defaultStats;
---

<section class="about-section" id="about-stats">
  <div class="about-gear-bg">
    <img src="/assets/images/about-gear1.svg" alt="img" class="gear1" />
    <img src="/assets/images/about-gear2.svg" alt="img" class="gear2" />
    <img src="/assets/images/about-gear2.svg" alt="img" class="gear3" />
  </div>
  <div class="about-men-bg">
    <img src={displayGif} alt="img" />
  </div>
  <div class="container">
    <p class="about-para" set:html={displayParagraph}></p>
    <div class="stats-row">
      {displayStats.map((item) => (
        <div class="stat-item">
          <img src={item.icon} alt="" />
          <div class="stat-number">
            <span class="count" data-target={item.target} data-format={item.format}>0</span>+
          </div>
          <div class="stat-label">{item.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
