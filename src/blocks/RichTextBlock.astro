---
interface Props {
  content: string;
}

const { content } = Astro.props;

// A simple and robust server-side regex-based markdown-to-HTML parser
function parseMarkdown(md: string) {
  if (!md) return "";
  let html = md;
  
  // Escape HTML tags to prevent XSS except basic markup if intended
  // We can convert markdown characters safely.
  
  // Headers (H3, H2, H1)
  html = html.replace(/^### (.*$)/gim, '<h3>$1</h3>');
  html = html.replace(/^## (.*$)/gim, '<h2>$1</h2>');
  html = html.replace(/^# (.*$)/gim, '<h1>$1</h1>');
  
  // Bold (**text**)
  html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
  
  // Italics (*text*)
  html = html.replace(/\*(.*?)\*/g, '<em>$1</em>');
  
  // Bullet lists (lines starting with - or *)
  html = html.replace(/^\s*-\s+(.*$)/gim, '<li>$1</li>');
  html = html.replace(/^\s*\*\s+(.*$)/gim, '<li>$1</li>');
  
  // Group list items into <ul>
  // We look for consecutive <li> tags and wrap them in <ul>
  html = html.replace(/(<li>.*?<\/li>)+/gs, '<ul>$&</ul>');
  
  // Paragraphs (lines that are not headers, lists, or empty)
  // Split by double newlines, wrap non-HTML elements in <p>
  const lines = html.split(/\n\n+/);
  const parsedLines = lines.map(line => {
    const trimmed = line.trim();
    if (!trimmed) return "";
    if (trimmed.startsWith('<h') || trimmed.startsWith('<ul') || trimmed.startsWith('<li')) {
      return trimmed;
    }
    // Replace single newlines inside paragraph with spaces
    const cleanParagraph = trimmed.replace(/\n/g, ' ');
    return `<p>${cleanParagraph}</p>`;
  });
  
  return parsedLines.join('\n');
}

const parsedContent = parseMarkdown(content);
---
<section class="block-rich-text">
  <div class="container">
    <article class="prose" set:html={parsedContent}></article>
  </div>
</section>

<style>
  .block-rich-text {
    padding: 5rem 0;
    background-color: #050811;
    color: #D1D5DB;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .prose {
    line-height: 1.85;
    font-size: 1.1rem;
  }

  :global(.prose h1, .prose h2, .prose h3) {
    color: white;
    font-family: 'Outfit', sans-serif;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  :global(.prose h1) { font-size: 2.25rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.5rem; }
  :global(.prose h2) { font-size: 1.75rem; }
  :global(.prose h3) { font-size: 1.35rem; }

  :global(.prose p) {
    margin-bottom: 1.5rem;
  }

  :global(.prose ul, .prose ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.75rem;
  }

  :global(.prose li) {
    margin-bottom: 0.5rem;
    list-style: disc;
  }

  :global(.prose strong) {
    color: white;
  }
</style>
