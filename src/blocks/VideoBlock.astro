---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  videoUrl: string;
  coverImage?: string;
}

const { eyebrow, title, description, videoUrl, coverImage } = Astro.props;

// Convert standard YouTube watch link to embed format if needed
let resolvedUrl = videoUrl;
if (videoUrl.includes("youtube.com/watch?v=")) {
  const videoId = videoUrl.split("v=")[1]?.split("&")[0];
  if (videoId) {
    resolvedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
  }
} else if (videoUrl.includes("youtu.be/")) {
  const videoId = videoUrl.split("youtu.be/")[1]?.split("?")[0];
  if (videoId) {
    resolvedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
  }
} else {
  // Ensure autoplay on click is enabled
  if (!resolvedUrl.includes("autoplay=")) {
    resolvedUrl += (resolvedUrl.includes("?") ? "&" : "?") + "autoplay=1";
  }
}
---
<section class="block-video">
  <div class="container">
    <div class="section-head">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2>{title}</h2>
      {description && <p class="desc">{description}</p>}
    </div>

    <div class="video-wrapper-outer">
      <div class="video-container" id="video-click-container">
        {coverImage && (
          <div class="cover-overlay" id="video-cover-overlay">
            <img src={coverImage} alt={title} class="cover-poster" />
            <div class="play-btn-pulse">
              <div class="play-icon">▶</div>
            </div>
          </div>
        )}
        <iframe
          id="video-iframe"
          data-src={resolvedUrl}
          title={title}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const videoContainers = document.querySelectorAll("#video-click-container");
    videoContainers.forEach(container => {
      const cover = container.querySelector("#video-cover-overlay");
      const iframe = container.querySelector("#video-iframe");
      
      if (cover && iframe) {
        cover.addEventListener("click", () => {
          const src = iframe.getAttribute("data-src");
          if (src) {
            iframe.setAttribute("src", src);
          }
          cover.style.opacity = "0";
          setTimeout(() => {
            cover.style.display = "none";
          }, 300);
        });
      } else if (iframe && !cover) {
        // No cover, load immediately
        const src = iframe.getAttribute("data-src");
        if (src) {
          iframe.setAttribute("src", src);
        }
      }
    });
  });
</script>

<style>
  .block-video {
    padding: 6.5rem 0;
    background-color: #050811;
    color: white;
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4rem auto;
  }

  .eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #6366F1;
    display: block;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .desc {
    font-size: 1.05rem;
    color: #9CA3AF;
    margin-top: 0.75rem;
    line-height: 1.6;
  }

  .video-wrapper-outer {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    background: #000;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
  }

  .video-container {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    height: 0;
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .cover-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    cursor: pointer;
    background: #000;
    transition: opacity 0.3s ease;
  }

  .cover-poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
  }

  .play-btn-pulse {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    background: #6366F1;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.6);
    animation: pulse 2s infinite;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .cover-overlay:hover .play-btn-pulse {
    background: #4F46E5;
    transform: translate(-50%, -50%) scale(1.08);
  }

  .play-icon {
    font-size: 1.75rem;
    color: white;
    margin-left: 6px; /* center align adjustment for right triangle pointer */
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.6);
    }
    70% {
      box-shadow: 0 0 0 20px rgba(99, 102, 241, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(99, 102, 241, 0);
    }
  }
</style>
