---
interface Props {
  section_title?: string;
  sub_title?: string;
  color?: string;
}

const {
  section_title = "Roll Section Title Placeholder",
  sub_title = "DYNAMIC BLOCK",
  color = "#6366f1",
} = Astro.props;

import "../styles/sections/nagesh_section.css";
---

<section class="nagesh-section">
  <div class="container">

    <div class="section-header">
      <span
        class="badge"
        style={`background:${color}20;color:${color};border-color:${color}40;`}
      >
        CUSTOM SECTION
      </span>

      <h2>{section_title}</h2>

      <p>{sub_title}</p>
    </div>

    <div class="section-card">
      <div
        class="color-preview"
        style={`background:${color};`}
      ></div>

      <div class="content">
        <h3>Dynamic Content</h3>

        <p>
          This section is rendered from CMS generated schema fields.
          Any value updated from the Section Instance editor will
          automatically appear here.
        </p>
      </div>
    </div>

  </div>
</section>

