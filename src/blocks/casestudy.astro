---
import { getCollection } from "astro:content";

interface Props {
  section_title?: string;
  animation_gif?: string;
  related_blogs?: string[];
  bottom_cta_text?: string;
  bottom_cta_url?: string;
}

const {
  section_title = "Case Studies",
  animation_gif = "/assets/images/Welding_Animation.gif",
  related_blogs = [],
  bottom_cta_text = "View all Case Studies",
  bottom_cta_url = "#"
} = Astro.props;

// Fetch all blog posts
const allBlogs = await getCollection("blog");

// Filter and order only the selected blog posts
const selectedBlogs = allBlogs.filter(post => related_blogs.includes(post.id));

// Fallback items if no blogs are selected/available
const fallbackItems = [
  {
    image: "/assets/images/case1.png",
    title: "Why Choose HVOF Coating? Key Advantages for Industrial Efficiency and Durability",
    url: "#"
  },
  {
    image: "/assets/images/case2.png",
    title: "Maximizing Work Efficiency with Thermal Spray Powder: A Guide to Its Benefits",
    url: "#"
  },
  {
    image: "/assets/images/case3.png",
    title: "Why Welding Electrodes Are Essential for Industrial Success: Benefits and Applications",
    url: "#"
  },
  {
    image: "/assets/images/case2.png",
    title: "Maximizing Work Efficiency with Thermal Spray Powder: A Guide to Its Benefits",
    url: "#"
  }
];

const itemsToRender = selectedBlogs.length > 0
  ? selectedBlogs.map(blog => ({
      image: blog.data.featuredImage || "/assets/images/case1.png",
      title: blog.data.title,
      url: `/blog/${blog.id}`
    }))
  : fallbackItems;
---

<!-- CASE STUDIES -->
<section class="uni-slider-section case-study">
  <div class="uni-men-bg"><img src={animation_gif} alt="img"></div>
  <div class="heading-back-wrap"></div>
  <div class="container">
    <div class="uni-slider-heading">
      <h2>{section_title}</h2>
    </div>
    <div class="uni-slider-wrap">
      <div class="services-slider">
        {itemsToRender.map((item) => (
          <div class="svc-card">
            <div class="svc-img-wrap"><img src={item.image} alt={item.title}></div>
            <h3 class="svc-name">{item.title}</h3>
            <a href={item.url} class="svc-link">Read More</a>
          </div>
        ))}
      </div>
      <div class="uni-slider-footer">
        <a href={bottom_cta_url} class="blogs-view-all">{bottom_cta_text}</a>
      </div>
    </div>
  </div>
</section>
