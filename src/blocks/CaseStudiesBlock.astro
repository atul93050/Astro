---
interface Props {
  eyebrow?: string;
  title: string;
  items: Array<{
    title: string;
    client: string;
    category?: string;
    image: string;
    excerpt: string;
    link?: string;
  }>;
}

const { eyebrow, title, items = [] } = Astro.props;
---
<section class="block-case-studies">
  <div class="container">
    <div class="section-head">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2>{title}</h2>
    </div>

    <div class="cases-grid">
      {items.map((item) => (
        <div class="case-card">
          <div class="case-image-box">
            <img src={item.image} alt={item.title} class="case-img" />
            {item.category && <span class="category-badge">{item.category}</span>}
          </div>
          <div class="case-content">
            <span class="client-name">{item.client}</span>
            <h3>{item.title}</h3>
            <p class="excerpt">{item.excerpt}</p>
            {item.link && (
              <a href={item.link} class="btn-link">
                <span>View Full Study</span>
                <svg class="arrow-svg" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .block-case-studies {
    padding: 6.5rem 0;
    background-color: #050811;
    color: white;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4.5rem auto;
  }

  .eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #6366F1;
    display: block;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 2.6rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 2.5rem;
  }

  .case-card {
    background: rgba(17, 24, 39, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    overflow: hidden;
    backdrop-filter: blur(12px);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .case-card:hover {
    transform: translateY(-6px);
    border-color: rgba(99, 102, 241, 0.25);
    box-shadow: 0 15px 30px rgba(0,0,0,0.4);
  }

  .case-image-box {
    position: relative;
    width: 100%;
    height: 240px;
    overflow: hidden;
  }

  .case-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .case-card:hover .case-img {
    transform: scale(1.05);
  }

  .category-badge {
    position: absolute;
    bottom: 20px;
    left: 20px;
    background: rgba(10, 15, 26, 0.85);
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(8px);
    color: #6366F1;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.35rem 0.85rem;
    border-radius: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .case-content {
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .client-name {
    font-size: 0.85rem;
    font-weight: 700;
    color: #10B981;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
    display: block;
  }

  h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
    line-height: 1.35;
  }

  .excerpt {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #9CA3AF;
    margin-bottom: 1.75rem;
    flex-grow: 1;
  }

  .btn-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #6366F1;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
    margin-top: auto;
  }

  .btn-link:hover {
    color: #818cf8;
  }

  .arrow-svg {
    width: 16px;
    height: 16px;
    transition: transform 0.2s ease;
  }

  .btn-link:hover .arrow-svg {
    transform: translateX(4px);
  }
</style>
