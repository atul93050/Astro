---
interface Props {
  eyebrow?: string;
  title: string;
  limit?: number;
}

const { eyebrow, title, limit = 3 } = Astro.props;

// Premium mockup articles list
const mockArticles = [
  {
    title: "Locating Marketing Waste inside Meta Campaign Budgets",
    category: "Meta Ads",
    date: "May 28, 2026",
    excerpt: "Learn how we identified 32% redundant overlap in startup ad accounts targeting Noida enterprise buyers.",
    image: "/uploads/mission.png",
    author: "Atul Verma"
  },
  {
    title: "Google Search Attribution Models for Enterprise SaaS Retainers",
    category: "Attribution",
    date: "May 15, 2026",
    excerpt: "Vanity metrics fail when scaling above ₹50L monthly spend. Explore why we enforce live acquisition cost loops.",
    image: "/uploads/vision.png",
    author: "Strategy Team"
  },
  {
    title: "Organic Conversion search structures that outlast algorithmic hacks",
    category: "SEO Growth",
    date: "April 29, 2026",
    excerpt: "Most agencies build temporary hacks. Here is how we build long-term conversion authority engines.",
    image: "/uploads/about-hero.png",
    author: "Atul Verma"
  },
  {
    title: "Programmatic Ad Networks Audit checklist for Mid-Market CFOs",
    category: "Audit Systems",
    date: "April 12, 2026",
    excerpt: "A complete step-by-step checklist to auditing agency report gaps and hidden markup fees.",
    image: "/uploads/mission.png",
    author: "Acquisition Desk"
  }
];

const articlesToShow = mockArticles.slice(0, limit);
---
<section class="block-blog-listing">
  <div class="container">
    {(eyebrow || title) && (
      <div class="section-head">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        {title && <h2>{title}</h2>}
      </div>
    )}

    <div class="blog-grid">
      {articlesToShow.map((article) => (
        <div class="blog-card">
          <div class="card-image-box">
            <img src={article.image} alt={article.title} class="blog-img" loading="lazy" decoding="async" />
            <span class="category">{article.category}</span>
          </div>
          <div class="card-content">
            <div class="meta-row">
              <span class="date">{article.date}</span>
              <span class="bullet">•</span>
              <span class="author">{article.author}</span>
            </div>
            <h3>{article.title}</h3>
            <p class="excerpt">{article.excerpt}</p>
            <a href="#" class="read-more-btn">
              <span>Read Full Article</span>
              <span class="arrow">→</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .block-blog-listing {
    padding: 6.5rem 0;
    background-color: #050811;
    color: white;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4.5rem auto;
  }

  .eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #6366F1;
    display: block;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 2.5rem;
  }

  .blog-card {
    background: rgba(17, 24, 39, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    overflow: hidden;
    backdrop-filter: blur(12px);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .blog-card:hover {
    transform: translateY(-6px);
    border-color: rgba(99, 102, 241, 0.25);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.4);
  }

  .card-image-box {
    position: relative;
    width: 100%;
    height: 220px;
    overflow: hidden;
    background: #000;
  }

  .blog-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .blog-card:hover .blog-img {
    transform: scale(1.04);
  }

  .category {
    position: absolute;
    top: 20px;
    right: 20px;
    background: rgba(99, 102, 241, 0.95);
    color: white;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.3rem 0.75rem;
    border-radius: 8px;
    z-index: 2;
  }

  .card-content {
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: #6B7280;
    margin-bottom: 0.75rem;
  }

  .bullet {
    color: #4B5563;
  }

  .author {
    color: #9CA3AF;
  }

  h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
    line-height: 1.35;
  }

  .excerpt {
    font-size: 0.95rem;
    line-height: 1.65;
    color: #9CA3AF;
    margin-bottom: 1.75rem;
    flex-grow: 1;
  }

  .read-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #6366F1;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
    margin-top: auto;
  }

  .read-more-btn:hover {
    color: #818cf8;
  }

  .read-more-btn .arrow {
    transition: transform 0.2s ease;
  }

  .read-more-btn:hover .arrow {
    transform: translateX(4px);
  }
</style>
