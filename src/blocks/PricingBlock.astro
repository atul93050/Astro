---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  footer?: string;
  items: Array<{
    title: string;
    price: string;
    suffix?: string;
    subtext?: string;
    featured?: boolean;
    features: string[];
  }>;
}

const { eyebrow, title, description, footer, items = [] } = Astro.props;
---
<section class="block-pricing">
  <div class="container">
    <div class="section-head">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2>{title}</h2>
      {description && <p class="desc">{description}</p>}
    </div>

    <div class="pricing-grid">
      {items.map((plan) => (
        <div class={`pricing-card ${plan.featured ? "featured" : ""}`}>
          {plan.featured && <div class="featured-badge">MOST POPULAR</div>}
          <div class="card-glow"></div>
          <div class="card-content">
            <h3 class="plan-title">{plan.title}</h3>
            <p class="plan-subtext">{plan.subtext}</p>
            <div class="price-container">
              <span class="price-value">{plan.price}</span>
              <span class="price-suffix">{plan.suffix || "/mo"}</span>
            </div>
            
            <ul class="features-list">
              {plan.features.map((feat) => (
                <li>
                  <svg class="check-svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span>{feat}</span>
                </li>
              ))}
            </ul>

            <a href="/contact" class={`btn ${plan.featured ? "btn-primary" : "btn-secondary"}`}>
              Get Started
            </a>
          </div>
        </div>
      ))}
    </div>

    {footer && <p class="pricing-footnote">{footer}</p>}
  </div>
</section>

<style>
  .block-pricing {
    padding: 6.5rem 0;
    background-color: #03060E;
    color: white;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-head {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4.5rem auto;
  }

  .eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #F33B7B;
    display: block;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 2.6rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .desc {
    font-size: 1.1rem;
    color: #9CA3AF;
    margin-top: 0.75rem;
    line-height: 1.6;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
    align-items: stretch;
    max-width: 1000px;
    margin: 0 auto;
  }

  .pricing-card {
    position: relative;
    background: rgba(17, 24, 39, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    overflow: hidden;
    backdrop-filter: blur(12px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
  }

  .pricing-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
  }

  .pricing-card.featured {
    border-color: rgba(99, 102, 241, 0.4);
    box-shadow: 0 10px 30px rgba(99, 102, 241, 0.05);
  }

  .featured-badge {
    position: absolute;
    top: 20px;
    right: 20px;
    background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0.35rem 0.85rem;
    border-radius: 12px;
    z-index: 3;
  }

  .card-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 50% 0%, rgba(99, 102, 241, 0.08) 0%, rgba(99, 102, 241, 0) 70%);
    pointer-events: none;
    z-index: 1;
  }

  .pricing-card.featured .card-glow {
    background: radial-gradient(circle at 50% 0%, rgba(99, 102, 241, 0.15) 0%, rgba(99, 102, 241, 0) 70%);
  }

  .card-content {
    position: relative;
    z-index: 2;
    padding: 3.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    flex-grow: 1;
  }

  .plan-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.5rem;
  }

  .plan-subtext {
    font-size: 0.92rem;
    color: #9CA3AF;
    margin-bottom: 2rem;
  }

  .price-container {
    display: flex;
    align-items: baseline;
    margin-bottom: 2.5rem;
  }

  .price-value {
    font-family: 'Outfit', sans-serif;
    font-size: 2.75rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .price-suffix {
    font-size: 1rem;
    color: #9CA3AF;
    margin-left: 0.25rem;
  }

  .features-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-grow: 1;
  }

  .features-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: #D1D5DB;
  }

  .check-svg {
    width: 18px;
    height: 18px;
    color: #10B981;
    flex-shrink: 0;
  }

  .btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 0.85rem 1.5rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.98rem;
    transition: all 0.25s ease;
    text-decoration: none;
  }

  .btn-primary {
    background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
    color: white;
    box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.5);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: white;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-2px);
  }

  .pricing-footnote {
    text-align: center;
    font-size: 0.9rem;
    color: #6B7280;
    margin-top: 3.5rem;
  }
</style>
